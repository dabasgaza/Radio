<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!--
        ═══════════════════════════════════════════════════════════════
        MD3 Shape / Corner Radius System
        ═══════════════════════════════════════════════════════════════
    -->

    <!--  ── Base Shape Tokens ──  -->
    <CornerRadius x:Key="Shape.None">0</CornerRadius>
    <CornerRadius x:Key="Shape.ExtraSmall">4</CornerRadius>
    <CornerRadius x:Key="Shape.Small">8</CornerRadius>
    <CornerRadius x:Key="Shape.Medium">12</CornerRadius>
    <CornerRadius x:Key="Shape.Large">16</CornerRadius>
    <CornerRadius x:Key="Shape.ExtraLarge">28</CornerRadius>
    <CornerRadius x:Key="Shape.Full">999</CornerRadius>

    <!--  ── Component-Specific Shapes ──  -->
    <CornerRadius x:Key="Shape.Button">20</CornerRadius>
    <CornerRadius x:Key="Shape.Card">12</CornerRadius>
    <CornerRadius x:Key="Shape.Dialog">28</CornerRadius>
    <CornerRadius x:Key="Shape.FAB">16</CornerRadius>
    <CornerRadius x:Key="Shape.Chip">8</CornerRadius>
    <CornerRadius x:Key="Shape.TextField">4</CornerRadius>
    <CornerRadius x:Key="Shape.Snackbar">8</CornerRadius>
    <CornerRadius x:Key="Shape.SearchBar">28</CornerRadius>
    <CornerRadius x:Key="Shape.NavRail">16</CornerRadius>
    <CornerRadius x:Key="Shape.Menu">4</CornerRadius>
    <CornerRadius x:Key="Shape.Tooltip">4</CornerRadius>

</ResourceDictionary>