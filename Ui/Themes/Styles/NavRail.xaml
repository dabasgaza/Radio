<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        ═══════════════════════════════════════════════════════════════
        Navigation Rail Styles — Material Design 3
        Naming: NavRail.{Variant}
        ═══════════════════════════════════════════════════════════════
    -->

    <!--  ── NavRail.Container — The rail background ──  -->
    <Style x:Key="NavRail.Container" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}" />
        <Setter Property="Width" Value="80" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!--  ── NavRail.Item — Single rail item (RadioButton) ──  -->
    <Style x:Key="NavRail.Item" TargetType="RadioButton">
        <Setter Property="Width" Value="80" />
        <Setter Property="Height" Value="72" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <!-- Active Indicator Pill -->
                        <Rectangle x:Name="Indicator"
                                   RadiusX="16"
                                   RadiusY="16"
                                   Fill="{DynamicResource SecondaryContainerBrush}"
                                   Opacity="0"
                                   Margin="4,0"
                                   Effect="{DynamicResource Shadow.Elevation1}" />
                        
                        <!-- Content Stack -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <!-- Icon -->
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="Center"
                                              Width="24"
                                              Height="24" />
                            <!-- Label -->
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       TextWrapping="NoWrap" />
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Checked State -->
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Indicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource OnSecondaryContainerBrush}" />
                        </Trigger>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Indicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.08"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <!-- Pressed State -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Indicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.12"
                                                         Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <!-- Disabled State -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="{DynamicResource State.DisabledOpacity}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── NavRail.FAB — FAB pinned to rail bottom ──  -->
    <Style x:Key="NavRail.FAB" TargetType="Button" BasedOn="{StaticResource FAB.Small}">
        <Setter Property="Margin" Value="16,0,16,16" />
    </Style>

</ResourceDictionary>