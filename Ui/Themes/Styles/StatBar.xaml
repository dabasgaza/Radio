<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        ═══════════════════════════════════════════════════════════════
        StatusBar Styles — Material Design 3
        Naming: StatBar.{Variant}
        ═══════════════════════════════════════════════════════════════
    -->

    <!--  ── StatBar.Default — Standard status bar ──  -->
    <Style x:Key="StatBar.Default" TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
        <Setter Property="Height" Value="32" />
        <Setter Property="FontSize" Value="{DynamicResource Type.Body.Small}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource OutlineVariantBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <!--  ── StatBar.Primary — Primary colored status bar ──  -->
    <Style x:Key="StatBar.Primary" TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
        <Setter Property="Height" Value="32" />
        <Setter Property="FontSize" Value="{DynamicResource Type.Body.Small}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}" />
    </Style>

    <!--  ── StatBar.Transparent — Minimal transparent ──  -->
    <Style x:Key="StatBar.Transparent" TargetType="StatusBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
        <Setter Property="Height" Value="24" />
        <Setter Property="FontSize" Value="{DynamicResource Type.Body.Small}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}" />
    </Style>

</ResourceDictionary>