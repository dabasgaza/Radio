<UserControl x:Class="YourNamespace.UserControls.ModernEpisodeActionsMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="220">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/ModernEpisodeStyles.xaml"/>
                <ResourceDictionary Source="../Styles/EpisodeAnimations.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Modern Popup Actions Menu -->
    <materialDesign:PopupBox Width="32" Height="32"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              PlacementMode="BottomAndAlignRightEdges"
                              ToolTip="المزيد من الإجراءات">
        <materialDesign:PopupBox.ToggleContent>
            <Grid>
                <Ellipse Width="32" Height="32"
                         Fill="{StaticResource CardBackgroundBrush}"
                         Opacity="0"/>
                <materialDesign:PackIcon Kind="DotsVertical"
                                         Width="20" Height="20"
                                         Foreground="{StaticResource TextSecondaryBrush}">
                    <materialDesign:PackIcon.RenderTransform>
                        <RotateTransform CenterX="10" CenterY="10"/>
                    </materialDesign:PackIcon.RenderTransform>
                </materialDesign:PackIcon>
            </Grid>
        </materialDesign:PopupBox.ToggleContent>

        <!-- Modern Menu Panel -->
        <Border Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="14"
                Padding="6"
                Width="200"
                Effect="{StaticResource MaterialDesignShadowEffect}">
            <StackPanel>

                <!-- Menu Header -->
                <Border Background="{StaticResource PrimaryMainBrush}"
                        CornerRadius="10"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        Opacity="0.9">
                    <TextBlock Text="خيارات الحلقة"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Menu Items -->
                <!-- View Records -->
                <Button Style="{StaticResource ModernMenuItemButton}"
                        Click="BtnViewRecords_Click"
                        Visibility="{Binding CanViewRecords, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="28" Height="28"
                                Background="{StaticResource PrimaryMainBrush}"
                                CornerRadius="8" Opacity="0.1">
                            <materialDesign:PackIcon Kind="History"
                                                     Width="14" Height="14"
                                                     Foreground="{StaticResource PrimaryMainBrush}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="عرض السجلات"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="عرض سجل التعديلات"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="2"
                                                  Kind="ChevronLeft"
                                                  Width="16" Height="16"
                                                  Foreground="{StaticResource TextSecondaryBrush}"
                                                  VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{StaticResource DividerBrush}"
                           Margin="12,4" Opacity="0.3"/>

                <!-- Revert Action -->
                <Button Style="{StaticResource ModernMenuItemButton}"
                        Click="BtnRevert_Click"
                        Visibility="{Binding CanRevert, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="28" Height="28"
                                Background="#FFE0F2FE"
                                CornerRadius="8">
                            <materialDesign:PackIcon Kind="Undo"
                                                     Width="14" Height="14"
                                                     Foreground="#FF0288D1"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="تراجع عن الإجراء"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="إلغاء آخر تعديل"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <!-- Cancel Episode -->
                <Button Style="{StaticResource ModernMenuItemButton}"
                        Click="BtnCancelEpisode_Click"
                        Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="28" Height="28"
                                Background="#FFFFEBEE"
                                CornerRadius="8">
                            <materialDesign:PackIcon Kind="CloseCircleOutline"
                                                     Width="14" Height="14"
                                                     Foreground="#FFD32F2F"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="إلغاء الحلقة"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="#FFD32F2F"/>
                            <TextBlock Text="إلغاء الحلقة الحالية"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{StaticResource DividerBrush}"
                           Margin="12,4" Opacity="0.3"/>

                <!-- Edit & Delete Section -->
                <Button Style="{StaticResource ModernMenuItemButton}"
                        Click="BtnEdit_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="28" Height="28"
                                Background="#FFFFF8E1"
                                CornerRadius="8">
                            <materialDesign:PackIcon Kind="PencilOutline"
                                                     Width="14" Height="14"
                                                     Foreground="#FFF57C00"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="تعديل"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="تعديل بيانات الحلقة"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <Button Style="{StaticResource ModernMenuItemButton}"
                        Click="BtnDelete_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="28" Height="28"
                                Background="#FFFFEBEE"
                                CornerRadius="8">
                            <materialDesign:PackIcon Kind="DeleteOutline"
                                                     Width="14" Height="14"
                                                     Foreground="#FFD32F2F"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="حذف"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="#FFD32F2F"/>
                            <TextBlock Text="حذف الحلقة نهائياً"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>
    </materialDesign:PopupBox>
</UserControl>