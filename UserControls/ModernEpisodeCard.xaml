<UserControl x:Class="YourNamespace.UserControls.ModernEpisodeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:YourNamespace.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/ModernEpisodeStyles.xaml"/>
                <ResourceDictionary Source="../Styles/EpisodeAnimations.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource ModernEpisodeCard}"
            Margin="0,0,0,12"
            Padding="16">
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Episode Number Badge -->
                <Border Grid.Column="0"
                        Width="36" Height="36"
                        Background="{StaticResource PrimaryMainBrush}"
                        CornerRadius="10"
                        Margin="0,0,10,0">
                    <TextBlock Text="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"/>
                </Border>

                <!-- Title and Status -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="اسم الحلقة"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Grid>
                            <Ellipse Width="8" Height="8"
                                     Fill="{StaticResource PrimaryMainBrush}"/>
                            <Ellipse Width="8" Height="8"
                                     Fill="{StaticResource PrimaryMainBrush}"
                                     Opacity="0.4">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                        <TextBlock Text="نشط"
                                   Margin="6,0,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource PrimaryMainBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Button -->
                <Button Grid.Column="2"
                        Style="{StaticResource AnimatedIconButton}"
                        Click="BtnMoreActions_Click"
                        ToolTip="المزيد">
                    <materialDesign:PackIcon Kind="DotsHorizontal"
                                             Width="20" Height="20"
                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </Grid>

            <!-- Content Section -->
            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Progress Ring -->
                <materialDesign:ProgressRing Grid.Column="0"
                                              Width="50" Height="50"
                                              IsActive="True"
                                              Value="65"
                                              Foreground="{StaticResource PrimaryMainBrush}"
                                              Margin="0,0,12,0"/>

                <!-- Details -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Info Items -->
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0"
                                                  Kind="CalendarOutline"
                                                  Width="14" Height="14"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1"
                                   Margin="8,0,0,0"
                                   Text="01 يناير 2024"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0"
                                                  Kind="ClockOutline"
                                                  Width="14" Height="14"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1"
                                   Margin="8,0,0,0"
                                   Text="02:30 م - 10:00 م (7.5 ساعات)"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Footer Stats Section -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stat Items -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="AccountGroupOutline"
                                             Width="14" Height="14"
                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="45"
                               Margin="4,0,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CurrencyUsd"
                                             Width="14" Height="14"
                                             Foreground="{StaticResource SuccessBrush}"/>
                    <TextBlock Text="12,500"
                               Margin="4,0,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                             Width="14" Height="14"
                                             Foreground="{StaticResource SuccessBrush}"/>
                    <TextBlock Text="68%"
                               Margin="4,0,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>