<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Gradient Brushes for Dynamic Episode Cards (from AppColors) -->
    <LinearGradientBrush x:Key="EpisodeCardGradient1" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Primary600Color}" Offset="0"/>
        <GradientStop Color="{StaticResource Primary400Color}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="EpisodeCardGradient2" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Secondary600Color}" Offset="0"/>
        <GradientStop Color="{StaticResource Secondary400Color}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="EpisodeCardGradient3" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource SuccessDarkColor}" Offset="0"/>
        <GradientStop Color="{StaticResource SuccessColor}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="EpisodeCardGradient4" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource InfoColor}" Offset="0"/>
        <GradientStop Color="{StaticResource InfoDarkColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Modern Glass Effect Card Style -->
    <Style x:Key="ModernEpisodeCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Animated Menu Item Style -->
    <Style x:Key="ModernMenuItemButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Margin" Value="2,1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="10,0">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PressedOverlayBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Popup Menu Style -->
    <Style x:Key="ModernPopupMenu" TargetType="materialDesign:PopupBox">
        <Setter Property="PlacementMode" Value="BottomAndAlignRightEdges"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <!-- Status Indicator Styles -->
    <Style x:Key="StatusPulse" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="{StaticResource EpisodeActiveBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.5" Color="{StaticResource SuccessColor}"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>