<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Episode Specific Colors (references to AppColors for consistency) -->
    <Color x:Key="EpisodeActiveColor" />
    <Color x:Key="EpisodePendingColor" />
    <Color x:Key="EpisodeCancelledColor" />
    <Color x:Key="EpisodeCompletedColor" />

    <!-- Status Badge Styles -->
    <Style x:Key="EpisodeStatusBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.15"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>