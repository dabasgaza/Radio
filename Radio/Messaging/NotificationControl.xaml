<UserControl
    x:Class="Radio.Messaging.NotificationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Height="Auto"
    MinHeight="70"
    MaxWidth="420"
    FlowDirection="RightToLeft">

    <UserControl.Resources>
        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="16"
            Direction="270"
            Opacity="0.14"
            ShadowDepth="2" />
    </UserControl.Resources>

    <Border
        x:Name="RootBorder"
        Padding="16,14"
        BorderThickness="1"
        CornerRadius="14"
        Effect="{StaticResource CardShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══ المحتوى الرئيسي ═══  -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  أيقونة النوع (دائرة بيضاء على خلفية ملونة)  -->
                <Border
                    x:Name="IconCircle"
                    Width="36"
                    Height="36"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="18">
                    <materialDesign:PackIcon
                        x:Name="Icon"
                        Width="18"
                        Height="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Kind="Information" />
                </Border>

                <!--  العنوان + الرسالة  -->
                <StackPanel
                    Grid.Column="1"
                    Margin="14,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="TxtTitle"
                        FontSize="13.5"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="TxtMessage"
                        MaxWidth="310"
                        Margin="0,3,0,0"
                        FontSize="12.5"
                        LineHeight="18"
                        Opacity="0.85"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  زر الإغلاق  -->
                <Button
                    Grid.Column="2"
                    Width="26"
                    Height="26"
                    Margin="6,0,0,0"
                    Padding="0"
                    VerticalAlignment="Top"
                    Click="BtnClose_Click"
                    Cursor="Hand"
                    Opacity="0.5"
                    Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon
                        Name="CloseIcon"
                        Width="14"
                        Height="14"
                        Kind="Close" />
                </Button>
            </Grid>

            <!--  ═══ شريط التقدم ═══  -->
            <Border
                x:Name="ProgressBar"
                Grid.Row="1"
                Height="3"
                HorizontalAlignment="Stretch"
                CornerRadius="1.5"
                Opacity="0.5" />
        </Grid>
    </Border>
</UserControl>
