<UserControl
    x:Class="Radio.Messaging.NotificationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Width="380"
    Height="Auto"
    MinHeight="70"
    FlowDirection="RightToLeft">

    <Grid>
        <Border
            x:Name="RootBorder"
            Margin="0,0,0,3"
            Padding="16,12"
            BorderBrush="#E0E0E0"
            BorderThickness="1,1,1,0"
            CornerRadius="12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  الأيقونة  -->
                <materialDesign:PackIcon
                    x:Name="Icon"
                    Width="28"
                    Height="28"
                    Margin="0,0,14,0"
                    VerticalAlignment="Center" />

                <!--  المحتوى  -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="TxtTitle"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#212121" />
                    <TextBlock
                        x:Name="TxtMessage"
                        MaxWidth="300"
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="#616161"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  زر الإغلاق  -->
                <Button
                    Grid.Column="2"
                    Width="24"
                    Height="24"
                    Padding="0"
                    VerticalAlignment="Top"
                    Click="BtnClose_Click"
                    Cursor="Hand"
                    Opacity="0.5"
                    Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon
                        Width="14"
                        Height="14"
                        Kind="Close" />
                </Button>
            </Grid>
        </Border>

        <!--  شريط التقدم السفلي  -->
        <Border
            x:Name="ProgressBar"
            Height="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            CornerRadius="0,0,12,12" />
    </Grid>
</UserControl>