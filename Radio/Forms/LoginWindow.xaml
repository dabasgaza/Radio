<mah:MetroWindow
    x:Class="Radio.Forms.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="تسجيل الدخول - بث برو"
    Width="900"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowCloseButton="False"
    ShowTitleBar="False"
    Style="{StaticResource Window.Login}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <materialDesign:DialogHost DialogTheme="Inherit" Identifier="LoginDialog">
        <Grid Margin="30">
            <!--  التأثير الخارجي للنافذة  -->
            <Grid.Effect>
                <DropShadowEffect
                    BlurRadius="40"
                    Opacity="0.2"
                    ShadowDepth="0"
                    Color="Black" />
            </Grid.Effect>

            <materialDesign:Card Background="White" UniformCornerRadius="32">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  ════════════════ الجانب الأيسر (الهوية) ════════════════  -->
                    <Border
                        Grid.Column="0"
                        ClipToBounds="True"
                        CornerRadius="32,0,0,32">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#0D0D4F" />
                                <GradientStop Offset="0.5" Color="#1A237E" />
                                <GradientStop Offset="1" Color="#303F9F" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <!--  عناصر زخرفية خلفية  -->
                            <Ellipse
                                Width="300"
                                Height="300"
                                Margin="-150,-150,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Fill="White"
                                Opacity="0.03">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="100" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse
                                Width="200"
                                Height="200"
                                Margin="0,0,-100,-50"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Fill="{StaticResource SecondaryMainBrush}"
                                Opacity="0.07">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="80" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <StackPanel Margin="40" VerticalAlignment="Center">
                                <!--  اللوجو  -->
                                <Border
                                    Width="90"
                                    Height="90"
                                    materialDesign:ElevationAssist.Elevation="Dp6"
                                    Background="White"
                                    CornerRadius="24">
                                    <materialDesign:PackIcon
                                        Width="50"
                                        Height="50"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource PrimaryDarkBrush}"
                                        Kind="Broadcast" />
                                </Border>

                                <TextBlock
                                    Margin="0,28,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="28"
                                    FontWeight="Black"
                                    Style="{StaticResource Type.TitleLarge.OnColor}"
                                    Text="إذاعة صوت القدس" />

                                <TextBlock
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    Opacity="0.7"
                                    Style="{StaticResource Type.BodyMedium.OnColor}"
                                    Text="نظام إدارة الإنتاج الإذاعي" />

                                <Border
                                    Width="50"
                                    Height="3"
                                    Margin="0,32"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource SecondaryMainBrush}"
                                    CornerRadius="1.5" />

                                <TextBlock
                                    Opacity="0.9"
                                    Style="{StaticResource Type.BodyMedium.OnColor}"
                                    Text="مرحباً بك مجدداً في مركز التحكم لإدارة محتوى البث والنشر الرقمي"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Margin="0,100,0,0"
                                    HorizontalAlignment="Center"
                                    Foreground="White"
                                    Opacity="0.4"
                                    Style="{StaticResource Type.Overline}"
                                    Text="V3.5 ENTERPRISE EDITION" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  ════════════════ الجانب الأيمن (النموذج) ════════════════  -->
                    <Grid Grid.Column="1" Background="White">
                        <!--  زر الإغلاق العلوي  -->
                        <Button
                            Margin="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="CloseButton_Click"
                            Foreground="{StaticResource ErrorBrush}"
                            Style="{StaticResource MaterialDesignIconButton}">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Kind="Close" />
                        </Button>

                        <StackPanel Margin="64,0" VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="32"
                                Foreground="{StaticResource PrimaryDarkBrush}"
                                Style="{StaticResource Type.TitleLarge}"
                                Text="تسجيل الدخول" />

                            <TextBlock
                                Margin="0,12,0,48"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Style="{StaticResource Type.BodyMedium}"
                                Text="الرجاء إدخال بيانات الاعتماد للوصول الآمن" />

                            <!--  حقل اسم المستخدم  -->
                            <TextBox
                                x:Name="TxtUsername"
                                Height="60"
                                Margin="0,0,0,24"
                                materialDesign:HintAssist.Hint="اسم المستخدم"
                                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                materialDesign:TextFieldAssist.LeadingIcon="AccountCircle"
                                materialDesign:TextFieldAssist.LeadingIconSize="22"
                                FontSize="16"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Text="admin" />

                            <!--  حقل كلمة المرور  -->
                            <PasswordBox
                                x:Name="TxtPassword"
                                Height="60"
                                Margin="0,0,0,20"
                                materialDesign:HintAssist.Hint="كلمة المرور"
                                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                materialDesign:TextFieldAssist.LeadingIcon="Lock"
                                materialDesign:TextFieldAssist.LeadingIconSize="22"
                                FontSize="16"
                                Password="Admin@123"
                                Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />

                            <!--  زر الدخول  -->
                            <Button
                                x:Name="BtnLogin"
                                Height="60"
                                Margin="0,12,0,0"
                                materialDesign:ButtonAssist.CornerRadius="16"
                                materialDesign:ElevationAssist.Elevation="Dp4"
                                Background="{StaticResource PrimaryDarkBrush}"
                                BorderBrush="{StaticResource PrimaryDarkBrush}"
                                Click="BtnLogin_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <Grid>
                                    <StackPanel x:Name="BtnContent" Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center"
                                            Kind="Login" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Text="تأكيد الدخول" />
                                    </StackPanel>

                                    <ProgressBar
                                        x:Name="LoginProgress"
                                        Width="28"
                                        Height="28"
                                        Foreground="White"
                                        IsIndeterminate="True"
                                        Style="{StaticResource MaterialDesignCircularProgressBar}"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Button>

                            <TextBlock
                                Margin="0,48,0,0"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource TextHintBrush}"
                                Style="{StaticResource Type.Caption}"
                                Text="الدعم الفني: support@radio.com" />
                        </StackPanel>

                        <!--  منطقة الإشعارات  -->
                        <StackPanel
                            x:Name="NotificationHost"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom" />

                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </materialDesign:DialogHost>
</mah:MetroWindow>