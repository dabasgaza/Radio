<mah:MetroWindow
    x:Class="Radio.Forms.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Forms"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LoginWindow"
    Width="800"
    Height="450"
    Background="{DynamicResource MahApps.Brushes.Window.Background}"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid>
            <StackPanel Margin="40" VerticalAlignment="Center">
                <!--  Logo/Icon  -->
                <materialDesign:PackIcon
                    Width="60"
                    Height="60"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                    Kind="Broadcast" />

                <TextBlock
                    Margin="0,10,0,30"
                    HorizontalAlignment="Center"
                    Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                    Text="نظام إدارة سير العمل البرامجي" />

                <!--  Input Fields  -->
                <TextBox
                    x:Name="TxtUsername"
                    Margin="0,0,0,15"
                    materialDesign:HintAssist.Hint="اسم المستخدم"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Account"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <PasswordBox
                    x:Name="TxtPassword"
                    Margin="0,0,0,10"
                    materialDesign:HintAssist.Hint="كلمة المرور"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Lock"
                    Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />

                <!--  Error Message Area  -->
                <TextBlock
                    x:Name="LblError"
                    Margin="0,5"
                    HorizontalAlignment="Center"
                    Foreground="Red"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />

                <!--  Login Button  -->
                <Button
                    x:Name="BtnLogin"
                    Height="50"
                    Margin="0,20,0,0"
                    Click="BtnLogin_Click"
                    Content="تسجيل الدخول"
                    Style="{StaticResource MaterialDesignRaisedButton}" />

                <!--  Progress Bar (Hidden by default)  -->
                <ProgressBar
                    x:Name="LoginProgress"
                    Margin="0,15,0,0"
                    Style="{StaticResource MaterialDesignLinearProgressBar}"
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>

    </Grid>
</mah:MetroWindow>
