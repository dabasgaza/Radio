<mah:MetroWindow
    x:Class="Radio.Forms.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Forms"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LoginWindow"
    Width="800"
    Height="550"
    Background="{DynamicResource MahApps.Brushes.Window.Background}"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <materialDesign:Card
            Margin="20"
            materialDesign:ElevationAssist.Elevation="Dp4"
            Background="#1E1E1E"
            UniformCornerRadius="15">
            <StackPanel Margin="10" VerticalAlignment="Center">
                <materialDesign:PackIcon
                    Width="80"
                    Height="80"
                    HorizontalAlignment="Center"
                    Foreground="#3F51B5"
                    Kind="Broadcast" />
                <TextBlock
                    Margin="0,15,0,5"
                    HorizontalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="بث برو | Broadcast Pro" />
                <TextBlock
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="Gray"
                    Text="يرجى تسجيل الدخول للمتابعة" />

                <TextBox
                    x:Name="TxtUsername"
                    Margin="0,0,0,20"
                    materialDesign:HintAssist.Foreground="Gray"
                    materialDesign:HintAssist.Hint="اسم المستخدم"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Account"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <PasswordBox
                    x:Name="TxtPassword"
                    Margin="0,0,0,10"
                    materialDesign:HintAssist.Foreground="Gray"
                    materialDesign:HintAssist.Hint="كلمة المرور"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Lock"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />

                <TextBlock
                    x:Name="LblError"
                    Margin="0,5"
                    HorizontalAlignment="Center"
                    Foreground="#FF5252"
                    Visibility="Collapsed" />

                <Button
                    x:Name="BtnLogin"
                    Height="45"
                    Margin="0,25,0,0"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="#3F51B5"
                    BorderBrush="#3F51B5"
                    Click="BtnLogin_Click"
                    Content="دخول آمن"
                    Foreground="White" />
                <ProgressBar
                    x:Name="LoginProgress"
                    Margin="0,15,0,0"
                    Style="{StaticResource MaterialDesignCircularProgressBar}"
                    Visibility="Collapsed" />
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</mah:MetroWindow>
