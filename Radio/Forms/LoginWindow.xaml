<mah:MetroWindow
    x:Class="Radio.Forms.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="تسجيل الدخول - بث برو"
    Width="900"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowCloseButton="False"
    ShowTitleBar="False"
    Style="{StaticResource Window.Login}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Grid Margin="30">
        <Grid.Effect>
            <DropShadowEffect
                BlurRadius="30"
                Opacity="0.15"
                ShadowDepth="0"
                Color="Black" />
        </Grid.Effect>

        <materialDesign:Card Background="White" UniformCornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="24,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#1A237E" />
                            <GradientStop Offset="1" Color="#3F51B5" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <materialDesign:PackIcon
                            Width="200"
                            Height="200"
                            Margin="0,0,-50,-50"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Foreground="White"
                            Kind="RadioTower"
                            Opacity="0.05" />

                        <StackPanel Margin="40" VerticalAlignment="Center">
                            <materialDesign:PackIcon
                                Width="70"
                                Height="70"
                                HorizontalAlignment="Center"
                                Foreground="White"
                                Kind="Broadcast" />

                            <TextBlock
                                Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                FontSize="32"
                                FontWeight="Black"
                                Foreground="White"
                                Text="إذاعة صوت القدس" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="White"
                                Opacity="0.7"
                                Text="نظام إدارة الإنتاج الإذاعي" />

                            <Border
                                Width="40"
                                Height="2"
                                Margin="0,30"
                                HorizontalAlignment="Center"
                                Background="#4FACFE"
                                CornerRadius="1" />

                            <TextBlock
                                FontSize="13"
                                Foreground="White"
                                Opacity="0.9"
                                Text="مرحباً بك مجدداً في مركز التحكم"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,80,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                FontWeight="Light"
                                Foreground="White"
                                Opacity="0.4"
                                Text="v3.0 Premium Edition" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Background="White">
                    <Button
                        Margin="15"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"
                        Foreground="{StaticResource ErrorBrush}"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            Kind="Close" />
                    </Button>

                    <StackPanel Margin="60,0" VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="30"
                            Foreground="#1E293B"
                            Text="تسجيل الدخول" />
                        <TextBlock
                            Margin="0,10,0,45"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="#64748B"
                            Text="الرجاء إدخال بيانات الاعتماد للوصول إلى النظام" />

                        <TextBox
                            x:Name="TxtUsername"
                            Height="55"
                            Margin="0,0,0,25"
                            materialDesign:HintAssist.Hint="اسم المستخدم"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="AccountCircleOutline"
                            materialDesign:TextFieldAssist.LeadingIconSize="20"
                            FontSize="15"
                            Foreground="#1E293B"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="admin" />

                        <PasswordBox
                            x:Name="TxtPassword"
                            Height="55"
                            Margin="0,0,0,15"
                            materialDesign:HintAssist.Hint="كلمة المرور"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                            materialDesign:TextFieldAssist.LeadingIconSize="20"
                            FontSize="15"
                            Foreground="#1E293B"
                            Password="Admin@123"
                            Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />


                        <Button
                            x:Name="BtnLogin"
                            Height="55"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            materialDesign:ElevationAssist.Elevation="Dp2"
                            Background="#1A237E"
                            BorderBrush="#1A237E"
                            Click="BtnLogin_Click"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White">
                            <Grid>
                                <StackPanel x:Name="BtnContent" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Kind="LoginVariant" />
                                    <TextBlock VerticalAlignment="Center" Text="دخول آمن" />
                                </StackPanel>

                                <ProgressBar
                                    x:Name="LoginProgress"
                                    Width="24"
                                    Height="24"
                                    Foreground="White"
                                    IsIndeterminate="True"
                                    Style="{StaticResource MaterialDesignCircularProgressBar}"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Button>

                        <TextBlock
                            Margin="0,40,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="#94A3B8"
                            Text="إذا واجهت مشكلة في الدخول، يرجى التواصل مع الدعم الفني" />
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Snackbar
            x:Name="LoginSnackbar"
            Margin="0,0,0,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Background="#334155"
            MessageQueue="{materialDesign:MessageQueue}" />
    </Grid>
</mah:MetroWindow>