<mah:MetroWindow
    x:Class="Radio.Forms.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Forms"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LoginWindow"
    Width="800"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <!--  Modern close button style  -->
        <Style x:Key="ModernCloseButton" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="#FF4444"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="0"
                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
    </Window.Resources>

    <!--  Main layout  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <!--  Sleek title bar  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Window background (transparency support)  -->
        <Border
            Grid.RowSpan="2"
            Background="{DynamicResource MahApps.Brushes.Window.Background}"
            CornerRadius="16" />

        <!--  Gradient background  -->
        <Border Grid.RowSpan="2" CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#1A1A2E" />
                    <GradientStop Offset="0.5" Color="#16213E" />
                    <GradientStop Offset="1" Color="#0F3460" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!--  Subtle accents  -->
        <Ellipse
            Grid.RowSpan="2"
            Width="600"
            Height="600"
            Fill="#3F51B5"
            Opacity="0.08" />
        <Ellipse
            Grid.RowSpan="2"
            Width="400"
            Height="400"
            Margin="100,0,0,100"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Fill="#5C6BC0"
            Opacity="0.05" />

        <!--  Custom Title Bar (only close button)  -->
        <Border
            Grid.Row="0"
            CornerRadius="16,16,0,0"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Offset="0" Color="#2A2A3E" />
                    <GradientStop Offset="1" Color="#1E1E2E" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <!--  App icon and title  -->
                <StackPanel
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Foreground="#3F51B5"
                        Kind="Broadcast" />
                    <TextBlock
                        Margin="8,0,0,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#E0E0E0"
                        Text="Broadcast Pro" />
                </StackPanel>

                <!--  Modern close button (right side)  -->
                <Button
                    x:Name="CloseButton"
                    Margin="0,0,16,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="CloseButton_Click"
                    Style="{StaticResource ModernCloseButton}"
                    ToolTip="إغلاق">
                    <materialDesign:PackIcon
                        Width="14"
                        Height="14"
                        Kind="Close" />
                </Button>
            </Grid>
        </Border>

        <!--  Main content (same professional login card)  -->
        <Grid Grid.Row="1" Margin="0,0,0,0">
            <materialDesign:Card
                Margin="30,20,30,30"
                materialDesign:ElevationAssist.Elevation="Dp8"
                Background="#22FFFFFF"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                UniformCornerRadius="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Left decorative panel  -->
                    <Border
                        Grid.Column="0"
                        Width="200"
                        Background="#1A3F51B5"
                        CornerRadius="20,0,0,20">
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <materialDesign:PackIcon
                                Width="70"
                                Height="70"
                                HorizontalAlignment="Center"
                                Foreground="White"
                                Kind="Broadcast"
                                Opacity="0.9" />
                            <TextBlock
                                Margin="0,20,0,5"
                                HorizontalAlignment="Center"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="إذاعة صوت القدس" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="#CCFFFFFF"
                                Opacity="0.8"
                                Text="Broadcast Pro" />
                            <Separator Margin="0,25,0,15" Background="#55FFFFFF" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="#CCFFFFFF"
                                Text="نظام إدارة البث الاحترافي"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Right login form  -->
                    <StackPanel
                        Grid.Column="1"
                        Margin="30,20,30,20"
                        VerticalAlignment="Center">
                        <materialDesign:PackIcon
                            Width="50"
                            Height="50"
                            HorizontalAlignment="Center"
                            Foreground="Beige"
                            Kind="AccountKey" />

                        <TextBlock
                            Margin="0,15,0,5"
                            HorizontalAlignment="Center"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="تسجيل الدخول" />

                        <TextBlock
                            Margin="0,0,0,35"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="#CCCCCC"
                            Text="أدخل بيانات اعتمادك للمتابعة" />

                        <TextBox
                            x:Name="TxtUsername"
                            Margin="0,0,0,20"
                            materialDesign:HintAssist.Foreground="#AAAAAA"
                            materialDesign:HintAssist.Hint="اسم المستخدم"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="Account"
                            CaretBrush="#3F51B5"
                            Foreground="White"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="admin" />

                        <PasswordBox
                            x:Name="TxtPassword"
                            Margin="0,0,0,15"
                            materialDesign:HintAssist.Foreground="#AAAAAA"
                            materialDesign:HintAssist.Hint="كلمة المرور"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="Lock"
                            CaretBrush="#3F51B5"
                            Foreground="White"
                            Password="Admin@123"
                            Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />

                        <TextBlock
                            x:Name="LblError"
                            Margin="0,5"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="#FF5252"
                            Visibility="Collapsed" />

                        <Button
                            x:Name="BtnLogin"
                            Height="48"
                            Margin="0,25,0,0"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Background="#3F51B5"
                            BorderBrush="#3F51B5"
                            Click="BtnLogin_Click"
                            Content="دخول آمن"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetProperty="Background.Color"
                                                To="#5C6BC0"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Button.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetProperty="Background.Color"
                                                To="#3F51B5"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>

                        <ProgressBar
                            x:Name="LoginProgress"
                            Width="40"
                            Height="40"
                            Margin="0,15,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource MaterialDesignCircularProgressBar}"
                            Visibility="Collapsed" />

                        <TextBlock
                            Margin="0,25,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="#AAAAAA">
                            <Hyperlink
                                Foreground="#9FA8DA"
                                NavigateUri="#"
                                ToolTip="لا يؤثر على وظيفة تسجيل الدخول">
                                نسيت كلمة المرور؟
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</mah:MetroWindow>