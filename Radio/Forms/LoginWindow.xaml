<mah:MetroWindow
    x:Class="Radio.Forms.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="تسجيل الدخول - Broadcast Pro"
    Width="860"
    Height="650"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowCloseButton="False"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <!--  التخطيط الرئيسي  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <!--  App Bar Height  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  خلفية مسطحة (Strict Flat Surface)  -->
        <Border
            Grid.RowSpan="2"
            Background="{DynamicResource MaterialDesignPaper}"
            CornerRadius="8" />

        <!--  Top App Bar (طبقاً للمواصفات)  -->
        <Border
            Grid.Row="0"
            Background="#303F9F"
            CornerRadius="8,8,0,0"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        Foreground="White"
                        Kind="Broadcast" />
                    <TextBlock
                        Margin="12,0,0,0"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="White"
                        Text="Broadcast Pro" />
                </StackPanel>
                <Button
                    Margin="0,0,8,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="CloseButton_Click"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="إغلاق">
                    <materialDesign:PackIcon Kind="Close" />
                </Button>
            </Grid>
        </Border>

        <!--  المحتوى الرئيسي (البطاقة)  -->
        <Grid Grid.Row="1" Margin="24">
            <Border
                Background="{DynamicResource MaterialDesignCardBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="1"
                CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Opacity="0.1"
                        ShadowDepth="4"
                        Color="#000000" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  اللوحة اليمنى (Sidebar Specs: Indigo 700)  -->
                    <Border
                        Grid.Column="0"
                        Background="#303F9F"
                        CornerRadius="8,0,0,8">
                        <StackPanel Margin="32,0" VerticalAlignment="Center">

                            <materialDesign:PackIcon
                                Width="64"
                                Height="64"
                                HorizontalAlignment="Center"
                                Foreground="#DEEEFF"
                                Kind="Broadcast" />

                            <TextBlock
                                Margin="0,24,0,8"
                                HorizontalAlignment="Center"
                                FontSize="22"
                                FontWeight="Medium"
                                Foreground="#DEEEFF"
                                Text="إذاعة صوت القدس" />

                            <Border
                                Padding="12,4"
                                HorizontalAlignment="Center"
                                Background="{StaticResource SuccessBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Medium"
                                    Foreground="White"
                                    Text="v2.0 PRO" />
                            </Border>

                            <Border
                                Width="40"
                                Height="1"
                                Margin="0,32,0,32"
                                HorizontalAlignment="Center"
                                Background="#FFFFFF30" />

                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="#DEEEFF"
                                Text="نظام إدارة البث الاحترافي"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,48,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="#FFFFFF60"
                                Text="© 2025 جميع الحقوق محفوظة" />
                        </StackPanel>
                    </Border>

                    <!--  لوحة النموذج (اليسرى)  -->
                    <StackPanel
                        Grid.Column="1"
                        Margin="48,40,48,40"
                        VerticalAlignment="Center">

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="28"
                            FontWeight="Regular"
                            Foreground="{DynamicResource MaterialDesignBody}"
                            Text="تسجيل الدخول" />
                        <TextBlock
                            Margin="0,8,0,40"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Text="أدخل بيانات اعتمادك للمتابعة" />

                        <!--  حقل اسم المستخدم (MaterialDesignOutlinedTextBox)  -->
                        <TextBox
                            x:Name="TxtUsername"
                            Margin="0,0,0,24"
                            materialDesign:HintAssist.Hint="اسم المستخدم"
                            materialDesign:TextFieldAssist.PrefixText="  "
                            FontSize="14"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="admin" />

                        <!--  حقل كلمة المرور  -->
                        <PasswordBox
                            x:Name="TxtPassword"
                            Margin="0,0,0,8"
                            materialDesign:HintAssist.Hint="كلمة المرور"
                            materialDesign:TextFieldAssist.PrefixText="  "
                            FontSize="14"
                            Password="Admin@123"
                            Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />

                        <!--  زر الدخول (Primary Spec: #1565C0)  -->
                        <Button
                            x:Name="BtnLogin"
                            Height="48"
                            Margin="0,24,0,0"
                            Click="BtnLogin_Click"
                            Content="تسجيل الدخول"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="MaterialDesignRaisedButtonBackground" Color="#1565C0" />
                                <SolidColorBrush x:Key="MaterialDesignRaisedButtonForeground" Color="White" />
                            </Button.Resources>
                        </Button>

                        <!--  مؤشر التحميل  -->
                        <ProgressBar
                            x:Name="LoginProgress"
                            Width="36"
                            Height="36"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Center"
                            IsIndeterminate="True"
                            Style="{StaticResource MaterialDesignCircularProgressBar}"
                            Visibility="Collapsed" />

                        <TextBlock
                            Margin="0,24,0,0"
                            HorizontalAlignment="Center"
                            FontSize="14">
                            <Hyperlink Foreground="#1565C0" NavigateUri="#">نسيت كلمة المرور؟</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>