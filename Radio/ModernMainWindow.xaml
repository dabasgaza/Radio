<mah:MetroWindow
    x:Class="Radio.ModernMainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Radio.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="RadioFlow Modern"
    Width="1280"
    Height="800"
    Background="{DynamicResource AppBackgroundBrush}"
    FlowDirection="RightToLeft"
    ShowCloseButton="False"
    ShowMaxRestoreButton="False"
    ShowMinButton="False"
    ShowTitleBar="False"
    Style="{StaticResource Window.Main}"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid>
        <materialDesign:DialogHost Identifier="ModernRootDialog" OverlayBackground="{StaticResource OverlayScrimBrush}">
            <Grid SizeChanged="Window_SizeChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        x:Name="ColSidebar"
                        Width="Auto"
                        MinWidth="64"
                        MaxWidth="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Height="48"
                    Panel.ZIndex="10"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderThickness="0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Direction="270"
                            Opacity="0.06"
                            ShadowDepth="2"
                            Color="#0F172A" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Margin="12,0"
                            Orientation="Horizontal">
                            <Button
                                x:Name="BtnMenuToggle"
                                Width="36"
                                Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnMenuToggle_Click"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <materialDesign:PackIcon
                                    x:Name="MenuIcon"
                                    Width="24"
                                    Height="24"
                                    Kind="Menu" />
                            </Button>

                            <StackPanel
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Border
                                    Width="32"
                                    Height="32"
                                    VerticalAlignment="Center"
                                    CornerRadius="16">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Offset="0" Color="{DynamicResource Primary500Color}" />
                                            <GradientStop Offset="1" Color="{DynamicResource Primary700Color}" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="White"
                                        Kind="RadioTower" />
                                </Border>
                                <TextBlock
                                    x:Name="AppTitle"
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryDarkBrush}"
                                    Style="{StaticResource Type.TitleSmall}"
                                    Text="بث برو" />
                                <Border
                                    Margin="4,0"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SecondaryLightBrush}"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource SecondaryMainBrush}"
                                        Text="MODERN" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button
                            x:Name="BtnGoBack"
                            Grid.Column="1"
                            Width="36"
                            Height="36"
                            Margin="4,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnGoBack_Click"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            ToolTip="رجوع"
                            Visibility="Collapsed">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="ArrowRight" />
                        </Button>

                        <TextBlock
                            x:Name="BreadcrumbBar"
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Style="{StaticResource Type.Caption}"
                            Visibility="Collapsed" />

                        <StackPanel
                            Grid.Column="3"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                x:Name="BtnNotifications"
                                Width="40"
                                Height="40"
                                Margin="4,0"
                                ToolTip="الإشعارات">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="20"
                                                        SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <materialDesign:Badged Badge="3" BadgeBackground="{DynamicResource ErrorBrush}">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Kind="BellOutline" />
                                </materialDesign:Badged>
                            </Button>

                            <Border
                                Width="1"
                                Height="20"
                                Margin="8,0"
                                Background="{DynamicResource DividerBrush}"
                                CornerRadius="0.5"
                                Opacity="0.6" />

                            <Border
                                Margin="4,0"
                                Padding="2"
                                VerticalAlignment="Center"
                                Background="{DynamicResource SurfaceVariantBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                ToolTip="حجم خط النظام — يُطبَّق على كل الشاشات">
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        x:Name="BtnZoomOut"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        Click="BtnZoomOut_Click"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        ToolTip="تصغير الخط (Ctrl+-)">
                                        <TextBlock
                                            FontSize="{DynamicResource FontSize.Label}"
                                            FontWeight="SemiBold"
                                            Text="-A" />
                                    </Button>

                                    <Button
                                        x:Name="BtnZoomReset"
                                        Height="32"
                                        MinWidth="44"
                                        Padding="8,0"
                                        Click="BtnZoomReset_Click"
                                        Foreground="{DynamicResource PrimaryMainBrush}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        ToolTip="إعادة الحجم الافتراضي">
                                        <TextBlock
                                            x:Name="ZoomPercentageText"
                                            FontSize="{DynamicResource FontSize.Caption}"
                                            FontWeight="Bold"
                                            Text="100%" />
                                    </Button>

                                    <Button
                                        x:Name="BtnZoomIn"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        Click="BtnZoomIn_Click"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        ToolTip="تكبير الخط (Ctrl++)">
                                        <TextBlock
                                            FontSize="{DynamicResource FontSize.Label}"
                                            FontWeight="SemiBold"
                                            Text="+A" />
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Button
                                x:Name="BtnUserProfile"
                                Width="160"
                                Height="40"
                                Margin="4,0"
                                Click="BtnUserProfile_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Padding" Value="8,4" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        x:Name="border"
                                                        Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="20">
                                                        <ContentPresenter VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="32"
                                        Height="32"
                                        BorderBrush="White"
                                        BorderThickness="1.5"
                                        CornerRadius="16"
                                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="{DynamicResource Primary500Color}" />
                                                <GradientStop Offset="1" Color="{DynamicResource Primary700Color}" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock
                                            x:Name="UserInitials"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Text="MA" />
                                    </Border>
                                    <TextBlock
                                        x:Name="UserFirstName"
                                        Margin="8,0,4,0"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Style="{StaticResource Type.BodyMedium}"
                                        Text="مستخدم" />
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextDisabledBrush}"
                                        Kind="ChevronDown" />
                                </StackPanel>
                            </Button>

                            <Border
                                Width="1"
                                Height="20"
                                Margin="8,0"
                                Background="{DynamicResource DividerBrush}"
                                CornerRadius="0.5"
                                Opacity="0.6" />

                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <StackPanel.Resources>
                                    <Style x:Key="WindowControlBtnStyle" TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="Width" Value="40" />
                                        <Setter Property="Height" Value="32" />
                                        <Setter Property="Margin" Value="2,0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <Style x:Key="WindowCloseBtnStyle" TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="Width" Value="40" />
                                        <Setter Property="Height" Value="32" />
                                        <Setter Property="Margin" Value="2,0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#FEE2E2" />
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </StackPanel.Resources>
                                <Button Click="BtnMinimize_Click" Style="{StaticResource WindowControlBtnStyle}">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Kind="WindowMinimize" />
                                </Button>
                                <Button Click="BtnMaximize_Click" Style="{StaticResource WindowControlBtnStyle}">
                                    <materialDesign:PackIcon
                                        x:Name="MaximizeIcon"
                                        Width="18"
                                        Height="18"
                                        Kind="WindowMaximize" />
                                </Button>
                                <Button Click="BtnClose_Click" Style="{StaticResource WindowCloseBtnStyle}">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Kind="Close" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <ctrl:ModernSidebarControl
                    x:Name="SidebarNav"
                    Grid.Row="1"
                    Grid.Column="0" />

                <Grid Grid.Row="1" Grid.Column="1">
                    <!--  Wrapped in a modern container card  -->
                    <Border
                        Margin="24"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="16"
                                Direction="270"
                                Opacity="0.03"
                                ShadowDepth="4"
                                Color="#0F172A" />
                        </Border.Effect>
                        <ContentControl x:Name="MainContentArea" Margin="0" />
                    </Border>

                    <Border
                        x:Name="OnAirWidget"
                        Width="280"
                        Margin="0,24,24,0"
                        Padding="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        BorderThickness="0"
                        CornerRadius="16"
                        Visibility="Collapsed">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#F43F5E" />
                                <GradientStop Offset="1" Color="#BE123C" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="20"
                                Direction="270"
                                Opacity="0.3"
                                ShadowDepth="6"
                                Color="#F43F5E" />
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    x:Name="LivePulse"
                                    Width="12"
                                    Height="12"
                                    Fill="White" />
                                <TextBlock
                                    Margin="8,0"
                                    FontSize="{DynamicResource FontSize.Button}"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="مباشر الآن" />
                            </StackPanel>

                            <TextBlock
                                x:Name="OnAirElapsedTime"
                                Margin="0,8"
                                FontSize="{DynamicResource FontSize.Display}"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="00:00:00" />
                            <TextBlock
                                x:Name="OnAirProgramName"
                                FontSize="{DynamicResource FontSize.Label}"
                                FontWeight="Medium"
                                Foreground="#FFE4E6"
                                Text="اسم البرنامج الحالي" />

                            <Button
                                Height="38"
                                Margin="0,20,0,0"
                                Click="BtnStopOnAir_Click"
                                Content="إيقاف البث"
                                Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#33FFFFFF" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        x:Name="bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#4DFFFFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#66FFFFFF" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <ctrl:BottomNavigationView
                    x:Name="BottomNav"
                    Grid.Row="2"
                    Visibility="Collapsed" />

                <Popup
                    x:Name="UserProfilePopup"
                    AllowsTransparency="True"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=BtnUserProfile}"
                    StaysOpen="False">
                    <Border
                        Margin="8"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="32"
                                Direction="270"
                                Opacity="0.14"
                                ShadowDepth="8"
                                Color="#0F172A" />
                        </Border.Effect>
                        <StackPanel Width="260">

                            <!--  ── Profile Header with Gradient ──  -->
                            <Border
                                Margin="6,6,6,0"
                                Padding="16,14"
                                CornerRadius="10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="{DynamicResource Primary100Color}" />
                                        <GradientStop Offset="1" Color="{DynamicResource Primary50Color}" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Avatar Circle  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="42"
                                        Height="42"
                                        Margin="0,0,12,0"
                                        CornerRadius="21">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="{DynamicResource Primary500Color}" />
                                                <GradientStop Offset="1" Color="{DynamicResource Primary700Color}" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock
                                            x:Name="PopupUserInitials"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Text="MA" />
                                    </Border>

                                    <!--  Name & Role  -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            x:Name="PopupUserName"
                                            FontSize="{DynamicResource FontSize.BodyLarge}"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource PrimaryDarkBrush}"
                                            Text="مستخدم" />
                                        <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                            <Border
                                                Padding="6,2"
                                                Background="{DynamicResource PrimaryXLightBrush}"
                                                CornerRadius="4">
                                                <TextBlock
                                                    x:Name="PopupUserRole"
                                                    FontSize="{DynamicResource FontSize.Caption}"
                                                    FontWeight="Medium"
                                                    Foreground="{DynamicResource PrimaryMainBrush}"
                                                    Text="الدور" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!--  ── Separator ──  -->
                            <Border
                                Height="1"
                                Margin="16,8"
                                Background="{DynamicResource DividerBrush}"
                                Opacity="0.6" />

                            <!--  ── Logout Button — Premium Style ──  -->
                            <Border Margin="8,0,8,8">
                                <Button
                                    x:Name="BtnLogoutStyled"
                                    Height="42"
                                    HorizontalContentAlignment="Center"
                                    BorderThickness="0"
                                    Click="BtnLogout_Click"
                                    Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                x:Name="LogoutBd"
                                                Height="{TemplateBinding Height}"
                                                CornerRadius="10"
                                                Cursor="Hand"
                                                SnapsToDevicePixels="True">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Offset="0" Color="#EF4444" />
                                                        <GradientStop Offset="1" Color="#DC2626" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        VerticalAlignment="Center"
                                                        Foreground="White"
                                                        Kind="LogoutVariant" />
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{DynamicResource FontSize.Button}"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="تسجيل الخروج" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="LogoutBd" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Offset="0" Color="#DC2626" />
                                                                <GradientStop Offset="1" Color="#B91C1C" />
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="LogoutBd" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect
                                                                BlurRadius="12"
                                                                Opacity="0.25"
                                                                ShadowDepth="3"
                                                                Color="#EF4444" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="LogoutBd" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Offset="0" Color="#B91C1C" />
                                                                <GradientStop Offset="1" Color="#991B1B" />
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Border>

                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </materialDesign:DialogHost>

        <StackPanel
            x:Name="NotificationHost"
            Margin="0,0,0,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Panel.ZIndex="9999" />
    </Grid>
</mah:MetroWindow>