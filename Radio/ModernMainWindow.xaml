<mah:MetroWindow
    x:Class="Radio.ModernMainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Radio.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="RadioFlow Modern"
    Width="1280"
    Height="800"
    Background="{DynamicResource AppBackgroundBrush}"
    FlowDirection="RightToLeft"
    ShowCloseButton="False"
    ShowMaxRestoreButton="False"
    ShowMinButton="False"
    ShowTitleBar="False"
    Style="{StaticResource Window.Main}"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <ResourceDictionary>
            <ctrl:ResponsiveNavigationControl x:Key="NavControl" NavigationRequested="NavigationRequested" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <materialDesign:DialogHost Identifier="ModernRootDialog" OverlayBackground="{StaticResource OverlayScrimBrush}">
            <Grid SizeChanged="Window_SizeChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        x:Name="ColSidebar"
                        Width="Auto"
                        MinWidth="64"
                        MaxWidth="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Height="48"
                    Panel.ZIndex="10"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Margin="12,0"
                            Orientation="Horizontal">
                            <Button
                                x:Name="BtnMenuToggle"
                                Width="36"
                                Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnMenuToggle_Click"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <materialDesign:PackIcon
                                    x:Name="MenuIcon"
                                    Width="24"
                                    Height="24"
                                    Kind="Menu" />
                            </Button>

                            <StackPanel
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="24"
                                    Height="24"
                                    Foreground="{DynamicResource PrimaryMainBrush}"
                                    Kind="RadioTower" />
                                <TextBlock
                                    x:Name="AppTitle"
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryDarkBrush}"
                                    Style="{StaticResource Type.BodySmall}"
                                    Text="بث برو | Modern" />
                            </StackPanel>
                        </StackPanel>

                        <Button
                            x:Name="BtnGoBack"
                            Grid.Column="1"
                            Width="36"
                            Height="36"
                            Margin="4,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnGoBack_Click"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            ToolTip="رجوع"
                            Visibility="Collapsed">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="ArrowRight" />
                        </Button>

                        <TextBlock
                            x:Name="BreadcrumbBar"
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Style="{StaticResource Type.Overline}" />

                        <StackPanel
                            Grid.Column="3"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                Width="40"
                                Height="40"
                                Margin="4,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <materialDesign:Badged Badge="3" BadgeBackground="{DynamicResource ErrorBrush}">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Kind="BellOutline" />
                                </materialDesign:Badged>
                            </Button>

                            <Separator
                                Width="1"
                                Height="20"
                                Margin="8,10"
                                Opacity="0.5"
                                Style="{StaticResource MaterialDesignDarkSeparator}" />

                            <Button
                                x:Name="BtnUserProfile"
                                Height="40"
                                Margin="4,0"
                                Padding="4,2"
                                Click="BtnUserProfile_Click"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="30"
                                        Height="30"
                                        Background="{DynamicResource PrimaryMainBrush}"
                                        CornerRadius="15">
                                        <TextBlock
                                            x:Name="UserInitials"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Style="{StaticResource Type.Overline}"
                                            Text="MA" />
                                    </Border>
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextDisabledBrush}"
                                        Kind="ChevronDown" />
                                </StackPanel>
                            </Button>

                            <Separator
                                Width="1"
                                Height="20"
                                Margin="8,10"
                                Opacity="0.5"
                                Style="{StaticResource MaterialDesignDarkSeparator}" />

                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Width="46"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="BtnMinimize_Click"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Kind="WindowMinimize" />
                                </Button>
                                <Button
                                    Width="46"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="BtnMaximize_Click"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                    <materialDesign:PackIcon
                                        x:Name="MaximizeIcon"
                                        Width="18"
                                        Height="18"
                                        Kind="WindowMaximize" />
                                </Button>
                                <Button
                                    Width="46"
                                    Height="32"
                                    Padding="0"
                                    materialDesign:RippleAssist.Feedback="#20FF0000"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="BtnClose_Click"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Kind="Close" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <ctrl:ResponsiveNavigationControl
                    x:Name="ResponsiveNav"
                    Grid.Row="1"
                    Grid.Column="0"
                    Mode="{Binding NavigationMode}"
                    NavigationRequested="NavigationRequested" />

                <Grid Grid.Row="1" Grid.Column="1">
                    <ContentControl x:Name="MainContentArea" Margin="24" />

                    <Border
                        x:Name="OnAirWidget"
                        Width="280"
                        Margin="0,20,20,0"
                        Padding="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Effect="{StaticResource MaterialDesignShadowDepth1}"
                        Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    x:Name="LivePulse"
                                    Width="10"
                                    Height="10"
                                    Fill="{DynamicResource OnAirBrush}" />
                                <TextBlock
                                    Margin="8,0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource OnAirBrush}"
                                    Text="مباشر الآن" />
                            </StackPanel>

                            <TextBlock
                                x:Name="OnAirElapsedTime"
                                Margin="0,8"
                                FontSize="36"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="00:00:00" />
                            <TextBlock
                                x:Name="OnAirProgramName"
                                FontSize="14"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="اسم البرنامج الحالي" />

                            <Button
                                Margin="0,20,0,0"
                                Background="{DynamicResource OnAirBrush}"
                                BorderThickness="0"
                                Click="BtnStopOnAir_Click"
                                Content="إيقاف البث"
                                Foreground="White"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <ctrl:BottomNavigationView
                    x:Name="BottomNav"
                    Grid.Row="2"
                    Visibility="Collapsed" />

                <Popup
                    x:Name="UserProfilePopup"
                    AllowsTransparency="True"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=BtnUserProfile}"
                    StaysOpen="False">
                    <Border
                        Margin="4"
                        Background="White"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Effect="{StaticResource MaterialDesignShadowDepth2}">
                        <StackPanel Width="200" Margin="0,8">
                            <Button
                                Click="BtnLogout_Click"
                                Content="تسجيل الخروج"
                                Foreground="{DynamicResource ErrorBrush}"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </materialDesign:DialogHost>

        <StackPanel
            x:Name="NotificationHost"
            Margin="0,0,0,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Panel.ZIndex="9999" />
    </Grid>
</mah:MetroWindow>