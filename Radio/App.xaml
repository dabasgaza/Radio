<!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║                            App.xaml                                     ║
    ║         نقطة الدخول لنظام الستايل الموحّد — Radio Project              ║
    ║                                                                          ║
    ║  ترتيب التحميل (مهم جداً — لا تغيّر الترتيب):                          ║
    ║   1. Material Design 2 Defaults                                          ║
    ║   2. BundledTheme (Indigo + LightBlue + Light)                          ║
    ║   3. AppFonts.xaml        ← نظام الخطوط والأحجام المركزي               ║
    ║   4. AppColors.xaml       ← Design Tokens + Brushes                     ║
    ║   5. Windows.xaml         ← ستايلات النوافذ والـ UserControl           ║
    ║   6. TextBlock.xaml       ← Typography Scale                            ║
    ║   7. Buttons.xaml         ← جميع أنواع الأزرار                         ║
    ║   8. TextBox.xaml         ← حقول النصوص والبحث وكلمة المرور           ║
    ║   9. ComboBox.xaml        ← قوائم الاختيار                             ║
    ║   10. ListBox.xaml        ← قوائم العرض والـ Chips                     ║
    ║   11. DateTimePicker.xaml ← منتقيات التاريخ والوقت                    ║
    ║   12. DataGrid.xaml       ← جداول البيانات                             ║
    ║   13. Cards.xaml          ← بطاقات العرض والتغليف                      ║
    ║   14. ColorZone.xaml      ← ترويسات النوافذ والـ Header               ║
    ╚══════════════════════════════════════════════════════════════════════════╝
-->
<Application
    x:Class="Radio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:Radio.Converter"
    xmlns:converters="clr-namespace:Radio.Converter"
    xmlns:local="clr-namespace:Radio"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!--
                    ══════════════════════════════════════════════
                    1. Material Design 2 Defaults — يجب أن يكون أولاً
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    2. BundledTheme — الثيم الأساسي
                    Primary: Indigo | Secondary: LightBlue | Base: Light
                    ══════════════════════════════════════════════
                -->
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Indigo"
                    SecondaryColor="LightBlue" />

                <!--
                    ══════════════════════════════════════════════
                    3. Fonts & Typography System
                    نظام الخطوط والأحجام المركزي
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/AppFonts.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    4. Design Tokens — الأساس الذي تعتمد عليه كل الملفات
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/AppColors.xaml" />
                <ResourceDictionary Source="Resources/AppStyles.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    5. Windows & UserControl Styles
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/Windows.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    6. Typography
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/TextBlock.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    7. Buttons
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/Buttons.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    8. Text Inputs
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/TextBox.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    9. ComboBox
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/ComboBox.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    10. ListBox + Chips
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/ListBox.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    11. Date & Time Pickers
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/DateTimePicker.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    12. DataGrid — يعتمد على AppColors لذا يأتي بعده
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/DataGrid.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    13. Cards
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/Cards.xaml" />

                <!--
                    ══════════════════════════════════════════════
                    14. ColorZone & Header Zones
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/ColorZone.xaml" />


                <!--
                    ══════════════════════════════════════════════
                    15. TabControl
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/TabControl.xaml" />


                <!--
                    ══════════════════════════════════════════════
                    15. NavRail
                    ══════════════════════════════════════════════
                -->
                <ResourceDictionary Source="Resources/NavRail.xaml" />
                <ResourceDictionary Source="Resources/PopupBox.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <!--
                ══════════════════════════════════════════════════
                Global Converters
                ══════════════════════════════════════════════════
            -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <converter:PermissionVisibilityConverter x:Key="PermissionVisibilityConverter" />

            <converter:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

            <converter:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />

            <converter:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />

            <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

            <converters:MediaTypeDisplayConverter x:Key="MediaTypeDisplayConverter" />

            <!--
                ══════════════════════════════════════════════════
                ON AIR Pulse Storyboard (global — يُستخدم في MainWindow)
                ══════════════════════════════════════════════════
            -->
            <Storyboard x:Key="OnAirPulseStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation
                    AutoReverse="True"
                    Storyboard.TargetProperty="Opacity"
                    From="0.2"
                    To="0.9"
                    Duration="0:0:1" />
            </Storyboard>

        </ResourceDictionary>
    </Application.Resources>
</Application>