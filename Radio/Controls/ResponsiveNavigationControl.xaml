<UserControl
    x:Class="Radio.Controls.ResponsiveNavigationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="260"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!--  MD3 Navigation Rail Item — Expanded (icon + label inline)  -->
        <Style x:Key="NavRail.Item" TargetType="RadioButton">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="NavRail" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="Bd"
                            Height="{TemplateBinding Height}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="24"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter
                                    x:Name="IconHost"
                                    Grid.Column="0"
                                    Width="24"
                                    Height="24"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    x:Name="LabelHost"
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Label}"
                                    FontWeight="Medium"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding Tag}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryContainerBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource OnPrimaryContainerBrush}" />
                                <Setter TargetName="LabelHost" Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  MD3 Navigation Rail Item — Collapsed (icon only)  -->
        <Style x:Key="NavRail.Item.Collapsed" TargetType="RadioButton">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="NavRail" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="Bd"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="24">
                            <ContentPresenter
                                x:Name="IconHost"
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryContainerBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  MD3 Navigation Rail Sub-Item (indented, smaller)  -->
        <Style
            x:Key="NavRail.SubItem"
            BasedOn="{StaticResource NavRail.Item}"
            TargetType="RadioButton">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="32,0" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
        </Style>

        <!--  MD3 Section Header Label  -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Micro}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
            <Setter Property="Margin" Value="16,12,0,4" />
        </Style>

        <!--  MD3 Divider within the rail  -->
        <Style x:Key="NavRail.Divider" TargetType="Separator">
            <Setter Property="Margin" Value="16,4" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
        </Style>

    </UserControl.Resources>

    <!--  Navigation Rail Container  -->
    <Border
        x:Name="RootBorder"
        materialDesign:ElevationAssist.Elevation="Dp1"
        Background="{DynamicResource SurfaceBrush}"
        BorderBrush="{DynamicResource DividerBrush}"
        BorderThickness="0,0,0,0"
        SnapsToDevicePixels="True">

        <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="NavPanel" Margin="4,8" />
            </ScrollViewer>

            <!--  Accent Border (right edge for RTL)  -->
            <Border
                x:Name="AccentBorder"
                Width="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{DynamicResource PrimaryMainBrush}"
                BorderThickness="0" />
        </Grid>
    </Border>
</UserControl>
