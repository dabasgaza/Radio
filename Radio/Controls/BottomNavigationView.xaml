<UserControl
    x:Class="Radio.Controls.BottomNavigationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="80"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="BottomNavItem" TargetType="RadioButton">
            <Setter Property="Width" Value="72" />
            <Setter Property="Height" Value="60" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border
                                x:Name="ActivePill"
                                Width="48"
                                Height="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource PrimaryContainerBrush}"
                                CornerRadius="16"
                                Opacity="0" />
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <ContentPresenter
                                    x:Name="IconHost"
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    x:Name="LabelHost"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Micro}"
                                    FontWeight="Medium"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding Tag}" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ActivePill" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource OnPrimaryContainerBrush}" />
                                <Setter TargetName="LabelHost" Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActivePill" Property="Opacity" Value="0.6" />
                                <Setter TargetName="ActivePill" Property="Background" Value="#0A6366F1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border
        Height="80"
        Background="{DynamicResource SurfaceBrush}"
        BorderBrush="{DynamicResource DividerBrush}"
        BorderThickness="0,1,0,0"
        CornerRadius="28,28,0,0"
        Effect="{DynamicResource MaterialDesignShadowElevation3}">
        <ItemsControl
            x:Name="NavItemsControl"
            Margin="8"
            HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Border>
</UserControl>
