<mah:MetroWindow
    x:Class="Radio.Views.Publishing.WebsitePublishDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="نشر على الموقع الإلكتروني"
    Width="500"
    Height="450"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterOwner">

    <materialDesign:Card
        Margin="30"
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource Shadow.Dialog}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="28"
                        Height="28"
                        VerticalAlignment="Center"
                        Kind="Web" />

                    <TextBlock
                        Grid.Column="1"
                        Margin="16,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.TitleLarge.OnColor}"
                        Text="نشر الحلقة على الموقع الإلكتروني" />

                    <Button
                        Grid.Column="2"
                        Click="BtnCancel_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  Form Content  -->
            <StackPanel Grid.Row="1" Margin="24">
                <!--  نوع الوسيط  -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="Bold"
                        Foreground="#616161"
                        Style="{StaticResource Type.Caption}"
                        Text="نوع الوسيط *" />
                    <ComboBox
                        x:Name="CmbMediaType"
                        materialDesign:HintAssist.Hint="اختر نوع الوسيط"
                        SelectedValuePath="Tag"
                        Style="{StaticResource Input.ComboBox}">
                        <ComboBoxItem Content="فيديو" Tag="Video" />
                        <ComboBoxItem Content="صوتي" Tag="Audio" />
                        <ComboBoxItem Content="فيديو وصوت" Tag="Both" />
                    </ComboBox>
                </StackPanel>

                <!--  العنوان  -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="Bold"
                        Foreground="#616161"
                        Style="{StaticResource Type.Caption}"
                        Text="عنوان النشر *" />
                    <TextBox
                        x:Name="TxtTitle"
                        Height="40"
                        materialDesign:HintAssist.Hint="أدخل عنوان النشر على الموقع"
                        Style="{StaticResource Input.Text}" />
                </StackPanel>

                <!--  الملاحظات  -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="Bold"
                        Foreground="#616161"
                        Style="{StaticResource Type.Caption}"
                        Text="ملاحظات (اختياري)" />
                    <TextBox
                        x:Name="TxtNotes"
                        Height="100"
                        materialDesign:HintAssist.Hint="أدخل أي ملاحظات إضافية"
                        AcceptsReturn="True"
                        Style="{StaticResource Input.Text.Multiline}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  تاريخ النشر (تلقائي)  -->
                <TextBlock
                    Margin="0,12,0,0"
                    FontStyle="Italic"
                    Foreground="#999"
                    Style="{StaticResource Type.Overline}"
                    Text="سيتم النشر فوراً في:" />
                <TextBlock
                    x:Name="TxtPublishTime"
                    Margin="0,4,0,0"
                    Foreground="#616161"
                    Style="{StaticResource Type.Caption}"
                    Text="" />
            </StackPanel>

            <!--  حاوية الإشعارات  -->
            <StackPanel
                x:Name="NotificationHost"
                Grid.Row="1"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Panel.ZIndex="999" />


            <!--  Footer  -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Padding="16,8"
                        Click="BtnCancel_Click"
                        Content="إلغاء"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />
                    <Button
                        x:Name="BtnPublish"
                        Padding="16,8"
                        Click="BtnPublish_Click"
                        Content="نشر على الموقع"
                        Style="{StaticResource Btn.Primary}" />
                </StackPanel>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>
