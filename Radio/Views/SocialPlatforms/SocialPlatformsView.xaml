<UserControl
    x:Class="Radio.Views.SocialPlatforms.SocialPlatformsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Width="1000"
    Height="700"
    Style="{StaticResource View.Base}">

    <UserControl.Resources>
        <!--  Platform brand colors  -->
        <SolidColorBrush x:Key="PlatBg.Facebook" Color="#E8F0FE" />
        <SolidColorBrush x:Key="PlatFg.Facebook" Color="#1877F2" />
        <SolidColorBrush x:Key="PlatBg.Twitter" Color="#E8F5FE" />
        <SolidColorBrush x:Key="PlatFg.Twitter" Color="#1DA1F2" />
        <SolidColorBrush x:Key="PlatBg.X" Color="#E8F5FE" />
        <SolidColorBrush x:Key="PlatFg.X" Color="#1DA1F2" />
        <SolidColorBrush x:Key="PlatBg.YouTube" Color="#FFEBEE" />
        <SolidColorBrush x:Key="PlatFg.YouTube" Color="#FF0000" />
        <SolidColorBrush x:Key="PlatBg.Instagram" Color="#FDF2F8" />
        <SolidColorBrush x:Key="PlatFg.Instagram" Color="#E1306C" />
        <SolidColorBrush x:Key="PlatBg.TikTok" Color="#F3F4F6" />
        <SolidColorBrush x:Key="PlatFg.TikTok" Color="#010101" />

        <Style x:Key="PlatformBarStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF2F6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Name}" Value="Facebook">
                    <Setter Property="Background" Value="{StaticResource PlatBg.Facebook}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Twitter">
                    <Setter Property="Background" Value="{StaticResource PlatBg.Twitter}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="X">
                    <Setter Property="Background" Value="{StaticResource PlatBg.X}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="YouTube">
                    <Setter Property="Background" Value="{StaticResource PlatBg.YouTube}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Instagram">
                    <Setter Property="Background" Value="{StaticResource PlatBg.Instagram}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="TikTok">
                    <Setter Property="Background" Value="{StaticResource PlatBg.TikTok}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlatformCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF2F6" />
            <Setter Property="BorderBrush" Value="#6366F1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Name}" Value="Facebook">
                    <Setter Property="Background" Value="{StaticResource PlatBg.Facebook}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PlatFg.Facebook}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Twitter">
                    <Setter Property="Background" Value="{StaticResource PlatBg.Twitter}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PlatFg.Twitter}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="X">
                    <Setter Property="Background" Value="{StaticResource PlatBg.X}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PlatFg.X}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="YouTube">
                    <Setter Property="Background" Value="{StaticResource PlatBg.YouTube}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PlatFg.YouTube}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Instagram">
                    <Setter Property="Background" Value="{StaticResource PlatBg.Instagram}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PlatFg.Instagram}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="TikTok">
                    <Setter Property="Background" Value="{StaticResource PlatBg.TikTok}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PlatFg.TikTok}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlatformIconFgStyle" TargetType="materialDesign:PackIcon">
            <Setter Property="Foreground" Value="#6366F1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Name}" Value="فيس بوك">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.Facebook}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Twitter">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.Twitter}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="X">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.X}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="YouTube">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.YouTube}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Instagram">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.Instagram}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="TikTok">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.TikTok}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="PlatformBadgeFgStyle"
            BasedOn="{StaticResource Type.Caption}"
            TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6366F1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Name}" Value="Facebook">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.Facebook}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Twitter">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.Twitter}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="X">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.X}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="YouTube">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.YouTube}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="Instagram">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.Instagram}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="TikTok">
                    <Setter Property="Foreground" Value="{StaticResource PlatFg.TikTok}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="PlatformDataGridRow"
            BasedOn="{StaticResource DataGrid.Row}"
            TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border
                            x:Name="RowBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    Width="5"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Stretch"
                                    Style="{StaticResource PlatformBarStyle}" />
                                <SelectiveScrollingGrid Grid.Column="1">
                                    <SelectiveScrollingGrid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </SelectiveScrollingGrid.ColumnDefinitions>
                                    <SelectiveScrollingGrid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </SelectiveScrollingGrid.RowDefinitions>
                                    <DataGridCellsPresenter
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </SelectiveScrollingGrid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource RowAlternateBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SurfaceContainerHighestBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource PrimaryContainerBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="FacebookWorkplace" />
                        <TextBlock
                            Margin="12,0,0,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إدارة منصات التواصل الاجتماعي" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="تنظيم قنوات النشر الرقمي وربطها بدورة البث الإذاعي" />
                </StackPanel>

                <Button
                    x:Name="BtnAddNew"
                    Grid.Column="1"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Click="BtnAddNew_Click"
                    Style="{StaticResource Btn.AddNew}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlusThick" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="إضافة منصة" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. شريط البحث والإحصائيات ═══════  -->
        <Grid Grid.Row="1" Margin="24,20,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Stretch"
                materialDesign:HintAssist.Hint="البحث باسم المنصة..."
                materialDesign:TextFieldAssist.HasClearButton="True"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <materialDesign:Card
                Grid.Column="1"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="ShareVariant" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.BodySmall}"
                            Text="إجمالي المنصات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Style="{StaticResource Type.Numeric.Medium}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!--  ═══════ 3. جدول البيانات ═══════  -->
        <materialDesign:Card
            Grid.Row="2"
            Margin="24,10,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="14">
            <DataGrid
                x:Name="DataGrid"
                AutoGenerateColumns="False"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                IsReadOnly="True"
                RowStyle="{StaticResource PlatformDataGridRow}"
                SelectionMode="Single"
                Style="{StaticResource DataGrid.Main}">

                <DataGrid.Columns>
                    <!--  عمود اسم المنصة مع أيقونة + شريط لوني  -->
                    <DataGridTemplateColumn Width="*" Header="اسم المنصة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Border
                                        Width="4"
                                        Height="28"
                                        Margin="0,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="2"
                                        Style="{StaticResource PlatformBarStyle}" />
                                    <StackPanel Margin="16,0,0,0" Orientation="Horizontal">
                                        <Border
                                            Width="34"
                                            Height="34"
                                            BorderThickness="1.5"
                                            CornerRadius="8"
                                            Style="{StaticResource PlatformCardStyle}">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Kind="{Binding Icon, TargetNullValue=ShareVariant, FallbackValue=ShareVariant}"
                                                Style="{StaticResource PlatformIconFgStyle}" />
                                        </Border>
                                        <TextBlock
                                            Margin="12,0"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود رمز الأيقونة  -->
                    <DataGridTemplateColumn
                        Width="200"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="رمز الأيقونة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    MinWidth="80"
                                    Padding="12,5"
                                    HorizontalAlignment="Center"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Style="{StaticResource PlatformCardStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontWeight="Medium"
                                        Style="{StaticResource PlatformBadgeFgStyle}"
                                        Text="{Binding Icon, TargetNullValue=—}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الإجراءات  -->
                    <DataGridTemplateColumn
                        Width="150"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource Btn.Icon.Edit}"
                                        Tag="{Binding}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{StaticResource PrimaryMainBrush}"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Margin="8,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource Btn.Icon.Delete}"
                                        Tag="{Binding}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="DeleteOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!--  شريط التحميل  -->
        <ProgressBar
            x:Name="ProgressBar"
            Grid.Row="2"
            Margin="24,10,24,0"
            VerticalAlignment="Top"
            IsIndeterminate="True"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
