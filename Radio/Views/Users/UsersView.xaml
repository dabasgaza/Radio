<UserControl
    x:Class="Radio.Views.Users.UsersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="35"
                            Height="35"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="ShieldAccountVariantOutline" />
                        <TextBlock
                            Margin="15,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="منظومة إدارة المستخدمين" />
                    </StackPanel>
                    <TextBlock
                        Margin="50,5,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="التحكم في الحسابات، مراجعة النشاط، وتخصيص صلاحيات الوصول" />
                </StackPanel>

                <Button
                    x:Name="BtnAddUser"
                    Grid.Column="1"
                    Click="BtnAddUser_Click"
                    Style="{StaticResource Btn.AddNew}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon VerticalAlignment="Center" Kind="AccountPlus" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Text="إضافة مستخدم جديد" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1" Margin="25,20,25,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="2.5*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Style="{StaticResource Input.Search}" />

            <UniformGrid Grid.Column="1" Columns="3">
                <materialDesign:Card
                    Margin="5"
                    Padding="15,10"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="38"
                            Height="38"
                            Background="#104527A0"
                            CornerRadius="8">
                            <materialDesign:PackIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="#4527A0"
                                Kind="AccountGroup" />
                        </Border>
                        <StackPanel Margin="12,0">
                            <TextBlock Style="{StaticResource Type.Caption}" Text="الإجمالي" />
                            <TextBlock
                                x:Name="TxtTotalUsers"
                                Style="{StaticResource Type.Numeric.Medium}"
                                Text="0" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Margin="5"
                    Padding="15,10"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="38"
                            Height="38"
                            Background="#1000C853"
                            CornerRadius="8">
                            <materialDesign:PackIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="#00C853"
                                Kind="AccountCheck" />
                        </Border>
                        <StackPanel Margin="12,0">
                            <TextBlock Style="{StaticResource Type.Caption}" Text="نشط الآن" />
                            <TextBlock
                                x:Name="TxtActiveUsers"
                                Foreground="#00C853"
                                Style="{StaticResource Type.Numeric.Medium}"
                                Text="0" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Margin="5"
                    Padding="15,10"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="38"
                            Height="38"
                            Background="#10D50000"
                            CornerRadius="8">
                            <materialDesign:PackIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="#D50000"
                                Kind="AccountCancel" />
                        </Border>
                        <StackPanel Margin="12,0">
                            <TextBlock Style="{StaticResource Type.Caption}" Text="معطل" />
                            <TextBlock
                                x:Name="TxtInactiveUsers"
                                Foreground="#D50000"
                                Style="{StaticResource Type.Numeric.Medium}"
                                Text="0" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>
        </Grid>

        <materialDesign:Card
            Grid.Row="2"
            Margin="25,10,25,25"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="15">
            <DataGrid
                x:Name="DgUsers"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="200" Header="المستخدم">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5,0" Orientation="Horizontal">
                                    <Border
                                        Width="38"
                                        Height="38"
                                        Padding="2"
                                        BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                        BorderThickness="1"
                                        CornerRadius="19">
                                        <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="18">
                                            <materialDesign:PackIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Kind="Account"
                                                Opacity="0.5" />
                                        </Border>
                                    </Border>
                                    <StackPanel Margin="15,0" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Type.BodyLarge}" Text="{Binding FullName}" />
                                        <TextBlock Style="{StaticResource Type.Caption}" Text="{Binding Username}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="180"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="الصلاحية">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip
                                    x:Name="RoleChip"
                                    Width="120"
                                    Height="32"
                                    HorizontalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding RoleName}"
                                    Icon="{materialDesign:PackIcon Kind=BadgeAccountOutline}">
                                    <materialDesign:Chip.Style>
                                        <Style BasedOn="{StaticResource {x:Type materialDesign:Chip}}" TargetType="materialDesign:Chip">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignDivider}" />
                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RoleName}" Value="Admin">
                                                    <Setter Property="Background" Value="#1B5E20" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="IconBackground" Value="#2E7D32" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding RoleName}" Value="التنسيق">
                                                    <Setter Property="Background" Value="#4527A0" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="IconBackground" Value="#5E35B1" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding RoleName}" Value="الإنتاج">
                                                    <Setter Property="Background" Value="#006064" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="IconBackground" Value="#00838F" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding RoleName}" Value="النشر الرقمي">
                                                    <Setter Property="Background" Value="#37474F" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:Chip.Style>
                                </materialDesign:Chip>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn
                        Width="120"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="الحالة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ToggleButton
                                    Click="Status_Click"
                                    Foreground="{DynamicResource SuccessBrush}"
                                    IsChecked="{Binding IsActive}"
                                    Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                    ToolTip="تبديل حالة الحساب" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="200"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إدارة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل البيانات">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="AccountEditOutline" />
                                    </Button>
                                    <Button
                                        Margin="8,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف الحساب">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="DeleteSweepOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>