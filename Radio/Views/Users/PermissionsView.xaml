<UserControl
    x:Class="Radio.Views.Users.PermissionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Style="{StaticResource View.Base}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Kind="ShieldKeyOutline" />
                    <TextBlock
                        Margin="15,0"
                        Style="{StaticResource Type.TitleLarge.OnColor}"
                        Text="صلاحيات النظام" />
                </StackPanel>
                <TextBlock
                    Margin="50,5,0,0"
                    Style="{StaticResource Type.BodyMedium.OnColor}"
                    Text="الصلاحيات تُعرَّف في كود النظام وتُزامَن تلقائياً عند كل تشغيل — للقراءة فقط" />
            </StackPanel>
        </materialDesign:ColorZone>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="24">
            <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp1" UniformCornerRadius="16">
                <DataGrid
                    x:Name="DgPermissions"
                    Margin="0"
                    CellStyle="{StaticResource DataGrid.Cell}"
                    ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                    IsReadOnly="True"
                    RowStyle="{StaticResource DataGrid.Row}"
                    Style="{StaticResource DataGrid.Main}">
                    <DataGrid.Columns>
                        <!--  المعرف  -->
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding PermissionId}"
                            CellStyle="{StaticResource DataGrid.Cell.Center}"
                            Header="المعرف" />

                        <!--  الوحدة البرمجية  -->
                        <DataGridTemplateColumn
                            Width="160"
                            CellStyle="{StaticResource DataGrid.Cell.Center}"
                            Header="الوحدة البرمجية">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="120"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource SecondaryLightBrush}"
                                        CornerRadius="15">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource SecondaryMainBrush}"
                                            Text="{Binding Module}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  الاسم البرمجي  -->
                        <DataGridTextColumn
                            Width="220"
                            Binding="{Binding SystemName}"
                            CellStyle="{StaticResource DataGrid.Cell.Center}"
                            FontWeight="SemiBold"
                            Header="الاسم البرمجي" />

                        <!--  الاسم المعروض  -->
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding DisplayName}"
                            CellStyle="{StaticResource DataGrid.Cell.Left}"
                            Header="الاسم المعروض" />
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
