<mah:MetroWindow
    x:Class="Radio.Views.Users.UserFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات المستخدم"
    Width="650"
    Height="750"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card Margin="30" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Style="{StaticResource Zone.Header.Green}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="60"
                        Height="60"
                        Background="#30FFFFFF"
                        CornerRadius="30">
                        <materialDesign:PackIcon
                            Width="35"
                            Height="35"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Kind="AccountTie" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="20,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إدارة بيانات المستخدم" />
                        <TextBlock
                            x:Name="TxtSubtitle"
                            Opacity="0.8"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="يرجى ملء كافة الحقول لضمان أمن الحساب" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="35,25"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            VerticalAlignment="Center"
                            Foreground="#4527A0"
                            Kind="ShieldAccount" />
                        <TextBlock
                            Margin="10,0"
                            FontWeight="Bold"
                            Opacity="0.6"
                            Style="{StaticResource Type.Overline}"
                            Text="بيانات الحساب والصلاحيات" />
                    </StackPanel>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox
                            x:Name="TxtFullName"
                            Grid.Row="0"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="الاسم الكامل *"
                            materialDesign:TextFieldAssist.LeadingIcon="AccountCard"
                            Style="{StaticResource Input.Text}" />

                        <TextBox
                            x:Name="TxtUsername"
                            Grid.Row="0"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="اسم المستخدم *"
                            materialDesign:TextFieldAssist.LeadingIcon="At"
                            Style="{StaticResource Input.Text}" />

                        <PasswordBox
                            x:Name="TxtPassword"
                            Grid.Row="2"
                            Grid.Column="0"
                            Height="52"
                            materialDesign:HintAssist.Hint="كلمة المرور"
                            materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                            Style="{StaticResource Input.Password}" />

                        <ComboBox
                            x:Name="CboRoles"
                            Grid.Row="2"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="الدور / الصلاحية *"
                            materialDesign:TextFieldAssist.LeadingIcon="ShieldKeyOutline"
                            DisplayMemberPath="RoleDescription"
                            SelectedValuePath="RoleId"
                            Style="{StaticResource Input.ComboBox}" />
                    </Grid>

                    <Border
                        x:Name="PwdHintCard"
                        Margin="0,-10,0,30"
                        Padding="15,10"
                        Background="#104527A0"
                        CornerRadius="10"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="16"
                                Foreground="#4527A0"
                                Kind="Information" />
                            <TextBlock
                                x:Name="TxtPwdHint"
                                Margin="10,0"
                                VerticalAlignment="Center"
                                Foreground="#4527A0"
                                Style="{StaticResource Type.Caption}"
                                Text="اترك كلمة المرور فارغة إذا كنت لا تريد تغييرها" />
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,0,0,30" Background="{DynamicResource MaterialDesignDivider}" />

                    <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            VerticalAlignment="Center"
                            Foreground="#0097A7"
                            Kind="ContactPhone" />
                        <TextBlock
                            Margin="10,0"
                            FontWeight="Bold"
                            Opacity="0.6"
                            Style="{StaticResource Type.Overline}"
                            Text="معلومات التواصل والاتصال" />
                    </StackPanel>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="TxtPhone"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="رقم الهاتف"
                            materialDesign:TextFieldAssist.LeadingIcon="PhoneOutline"
                            Style="{StaticResource Input.Text}" />

                        <TextBox
                            x:Name="TxtEmail"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="البريد الإلكتروني"
                            materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                            Style="{StaticResource Input.Text}" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="BtnCancel"
                        Grid.Column="0"
                        Click="BtnCancel_Click"
                        Content="إلغاء التغييرات"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الحساب"
                        Style="{StaticResource Btn.Primary}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="AccountCheckOutline" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>