<mah:MetroWindow
    x:Class="Radio.Views.Users.PermissionMatrixView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Users"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PermissionMatrixView"
    Width="800"
    Height="450"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,20"
            Style="{StaticResource MaterialDesignHeadline5TextBlock}"
            Text="مصفوفة الصلاحيات" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <!--  قائمة الأدوار  -->
                <ColumnDefinition Width="*" />
                <!--  قائمة الصلاحيات  -->
            </Grid.ColumnDefinitions>

            <!--  1. قائمة الأدوار  -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,10,0">
                <ListBox
                    x:Name="LstRoles"
                    DisplayMemberPath="RoleName"
                    SelectionChanged="LstRoles_SelectionChanged"
                    Style="{StaticResource MaterialDesignListBox}" />
            </materialDesign:Card>

            <!--  2. مصفوفة الصلاحيات للدور المختار  -->
            <materialDesign:Card Grid.Column="1" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer>
                        <ListBox
                            x:Name="ItemsPermissions"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!--  استخدام Grid لضمان توزيع المساحة بين النص والـ Checkbox  -->
                                    <Grid Margin="0,5">
                                        <CheckBox
                                            HorizontalAlignment="Stretch"
                                            materialDesign:CheckBoxAssist.CheckBoxSize="24"
                                            CommandParameter="{Binding PermissionId}"
                                            IsChecked="{Binding IsAssigned}"
                                            Style="{StaticResource MaterialDesignCheckBox}">

                                            <!--  وضع النص داخل الـ CheckBox مع تحديد اللون  -->
                                            <TextBlock
                                                Margin="10,0"
                                                FontSize="16"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Text="{Binding DisplayName}" />
                                        </CheckBox>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Button
                        Grid.Row="1"
                        Margin="0,20,0,0"
                        Click="BtnSavePermissions_Click"
                        Content="حفظ تعديلات الصلاحيات" />
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</mah:MetroWindow>
