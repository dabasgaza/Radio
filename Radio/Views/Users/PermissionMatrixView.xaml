<mah:MetroWindow
    x:Class="Radio.Views.Users.PermissionMatrixView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة صلاحيات الوصول المتقدمة"
    Width="1000"
    Height="650"
    AllowsTransparency="True"
    Background="Transparent"
    FlowDirection="RightToLeft"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    UseNoneWindowStyle="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <materialDesign:Card
        Margin="30"
        materialDesign:ElevationAssist.Elevation="Dp3"
        Background="{DynamicResource MaterialDesignPaper}"
        UniformCornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Padding="30,25"
                Foreground="White"
                Mode="Custom"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <materialDesign:ColorZone.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#1B5E20" />
                        <GradientStop Offset="1" Color="#0D2511" />
                    </LinearGradientBrush>
                </materialDesign:ColorZone.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="40"
                        Height="40"
                        VerticalAlignment="Center"
                        Kind="ShieldLockOutline" />

                    <StackPanel Grid.Column="1" Margin="20,0">
                        <TextBlock
                            FontSize="24"
                            FontWeight="ExtraBold"
                            Foreground="White"
                            Text="مصفوفة الصلاحيات السيادية" />
                        <TextBlock
                            FontSize="12"
                            Foreground="White"
                            Opacity="0.7"
                            Text="التحكم الكامل في أدوار المستخدمين وصلاحيات الوصول للوحدات البرمجية" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button
                            x:Name="BtnSavePermissions"
                            Height="45"
                            Padding="20,0"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            Background="#FFB300"
                            BorderThickness="0"
                            Click="BtnSavePermissions_Click"
                            Foreground="#1B5E20">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon VerticalAlignment="Center" Kind="ShieldCheck" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="اعتماد وحفظ التغييرات" />
                            </StackPanel>
                        </Button>

                        <Button
                            Margin="20,0,0,0"
                            Click="BtnClose_Click"
                            Foreground="White"
                            Opacity="0.5"
                            Style="{StaticResource MaterialDesignIconButton}">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Kind="Close" />
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:ColorZone>

            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="25" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <materialDesign:Card
                    Grid.Column="0"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="15"
                            Background="#F1F8E9"
                            CornerRadius="15,15,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Foreground="#2E7D32" Kind="AccountKey" />
                                <TextBlock
                                    Margin="12,0"
                                    FontWeight="Bold"
                                    Foreground="#2E7D32"
                                    Text="الأدوار والوظائف" />
                            </StackPanel>
                        </Border>

                        <ListBox
                            x:Name="LstRoles"
                            Grid.Row="1"
                            Margin="5"
                            ItemContainerStyle="{StaticResource MaterialDesignNavigationPrimaryListBoxItem}"
                            SelectionChanged="LstRoles_SelectionChanged"
                            Style="{StaticResource MaterialDesignNavigationListBox}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="10,6" Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            VerticalAlignment="Center"
                                            Kind="BadgeAccountHorizontalOutline"
                                            Opacity="0.5" />
                                        <TextBlock
                                            Margin="15,0"
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            Text="{Binding RoleName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card
                    Grid.Column="2"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="15"
                            Background="#F1F8E9"
                            CornerRadius="15,15,0,0">
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="#2E7D32"
                                Text="توزيع صلاحيات الدور المختار" />
                        </Border>

                        <ScrollViewer
                            Grid.Row="1"
                            Padding="20"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ItemsPermissions">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid VerticalAlignment="Top" Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="8"
                                            Padding="18"
                                            Background="Transparent"
                                            BorderBrush="#C8E6C9"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="15"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource MaterialDesignBody}"
                                                        Text="{Binding DisplayName}" />
                                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Width="12"
                                                            Height="12"
                                                            Kind="FolderOpenOutline"
                                                            Opacity="0.4" />
                                                        <TextBlock
                                                            Margin="5,0"
                                                            FontSize="10"
                                                            Opacity="0.5"
                                                            Text="{Binding Module}" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <ToggleButton
                                                    Grid.Column="1"
                                                    Foreground="#2E7D32"
                                                    IsChecked="{Binding IsAssigned, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                    ToolTip="منح الصلاحية لهذا الدور" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>