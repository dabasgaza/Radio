<UserControl
    x:Class="Radio.Views.Users.AuditLogsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryDarkBrush}"
                        Style="{StaticResource Type.Headline}"
                        Text="سجل العمليات والتدقيق (Audit Logs)" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodyMedium}"
                        Text="تتبع ومراقبة جميع الإجراءات التي تمت على قاعدة البيانات من إضافة وتعديل وحذف." />
                </StackPanel>

                <materialDesign:PackIcon
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource PrimaryMainBrush}"
                    Kind="History" />
            </Grid>
        </Border>

        <!--  Filters Card  -->
        <materialDesign:Card
            Grid.Row="1"
            Margin="0,0,0,16"
            Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Users Filter  -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="المستخدم" />
                    <ComboBox
                        x:Name="ComboUsers"
                        materialDesign:TextFieldAssist.LeadingIcon="Account"
                        DisplayMemberPath="FullName"
                        SelectedValuePath="UserId"
                        Style="{StaticResource Input.ComboBox}" />
                </StackPanel>

                <!--  Actions Filter  -->
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="نوع الإجراء" />
                    <ComboBox
                        x:Name="ComboActions"
                        materialDesign:TextFieldAssist.LeadingIcon="Settings"
                        Style="{StaticResource Input.ComboBox}">
                        <ComboBoxItem Content="الكل" Tag="" />
                        <ComboBoxItem Content="إضافة (ADDED)" Tag="ADDED" />
                        <ComboBoxItem Content="تعديل (MODIFIED)" Tag="MODIFIED" />
                        <ComboBoxItem Content="حذف منطقي (SOFT_DELETED)" Tag="SOFT_DELETED" />
                        <ComboBoxItem Content="حذف نهائي (DELETED)" Tag="DELETED" />
                    </ComboBox>
                </StackPanel>

                <!--  Date Range From  -->
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="من تاريخ" />
                    <DatePicker x:Name="DpFrom" Style="{StaticResource Input.DatePicker}" />
                </StackPanel>

                <!--  Date Range To  -->
                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="إلى تاريخ" />
                    <DatePicker x:Name="DpTo" Style="{StaticResource Input.DatePicker}" />
                </StackPanel>

                <!--  Filter Actions  -->
                <StackPanel
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        x:Name="BtnFilter"
                        Margin="0,0,8,0"
                        Click="BtnFilter_Click"
                        Style="{StaticResource Btn.Primary}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Margin="0,0,4,0"
                                Kind="Magnify" />
                            <TextBlock Text="بحث" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="BtnResetFilters"
                        Click="BtnResetFilters_Click"
                        Style="{StaticResource Btn.Icon}">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            Kind="FilterOff" />
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!--  Main Layout Grid (DataGrid & Details Panel)  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition x:Name="ColDetails" Width="1.2*" />
            </Grid.ColumnDefinitions>

            <!--  Logs DataGrid  -->
            <materialDesign:Card
                Grid.Column="0"
                Margin="0,0,16,0"
                Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid
                        x:Name="GridLogs"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True"
                        SelectionChanged="GridLogs_SelectionChanged"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="140"
                                Binding="{Binding ChangedAt, StringFormat='dd-MM-yyyy HH:mm:ss'}"
                                Header="تاريخ العملية" />

                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding UserFullName}"
                                Header="المستخدم" />

                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding TableName}"
                                Header="الجدول" />

                            <DataGridTextColumn
                                Width="80"
                                Binding="{Binding RecordId}"
                                Header="معرف السجل" />

                            <DataGridTemplateColumn Width="130" Header="الإجراء">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            Background="Transparent"
                                            CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Action}" Value="ADDED">
                                                            <Setter Property="Background" Value="{StaticResource SuccessLightBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="MODIFIED">
                                                            <Setter Property="Background" Value="{StaticResource InfoLightBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="SOFT_DELETED">
                                                            <Setter Property="Background" Value="{StaticResource WarningLightBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="DELETED">
                                                            <Setter Property="Background" Value="{StaticResource ErrorLightBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Action}" Value="ADDED">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                <Setter Property="Text" Value="إضافة" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Action}" Value="MODIFIED">
                                                                <Setter Property="Foreground" Value="{StaticResource InfoBrush}" />
                                                                <Setter Property="Text" Value="تعديل" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Action}" Value="SOFT_DELETED">
                                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                <Setter Property="Text" Value="حذف منطقي" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Action}" Value="DELETED">
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                <Setter Property="Text" Value="حذف نهائي" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Reason}"
                                Header="السبب" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextDisabledBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="ملاحظة: يعرض الجدول آخر 500 عملية فقط للحفاظ على الأداء." />
                </Grid>
            </materialDesign:Card>

            <!--  Details Panel  -->
            <materialDesign:Card Grid.Column="1" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Details Header  -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock
                            FontWeight="Bold"
                            Style="{StaticResource Type.TitleMedium}"
                            Text="تفاصيل العملية والمقارنة" />
                        <Separator Margin="0,8,0,0" />
                    </StackPanel>

                    <!--  Details Content  -->
                    <Grid
                        x:Name="GridDetailsContent"
                        Grid.Row="1"
                        Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Meta Info  -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock
                                x:Name="TxtDetailUser"
                                Margin="0,2"
                                Style="{StaticResource Type.BodyMedium}" />
                            <TextBlock
                                x:Name="TxtDetailTable"
                                Margin="0,2"
                                Style="{StaticResource Type.BodyMedium}" />
                            <TextBlock
                                x:Name="TxtDetailAction"
                                Margin="0,2"
                                Style="{StaticResource Type.BodyMedium}" />
                            <TextBlock
                                x:Name="TxtDetailDate"
                                Margin="0,2"
                                Style="{StaticResource Type.BodyMedium}" />
                        </StackPanel>

                        <!--  Changes Comparison List  -->
                        <ListView
                            x:Name="LvChanges"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            HorizontalContentAlignment="Stretch"
                            BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="0,8"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!--  Field Name  -->
                                            <TextBlock
                                                Grid.Row="0"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource PrimaryMainBrush}"
                                                Style="{StaticResource Type.BodySmall}"
                                                Text="{Binding FieldName}" />

                                            <!--  Comparison Row  -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!--  Old Value  -->
                                                <Border
                                                    Grid.Column="0"
                                                    Padding="6,4"
                                                    Background="{StaticResource ErrorLightBrush}"
                                                    CornerRadius="4">
                                                    <TextBlock
                                                        Foreground="{StaticResource ErrorBrush}"
                                                        Style="{StaticResource Type.BodySmall}"
                                                        Text="{Binding OldValue}"
                                                        TextWrapping="Wrap" />
                                                </Border>

                                                <!--  Arrow Indicator  -->
                                                <materialDesign:PackIcon
                                                    Grid.Column="1"
                                                    Width="16"
                                                    Height="16"
                                                    Margin="8,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextDisabledBrush}"
                                                    Kind="ArrowLeft" />

                                                <!--  New Value  -->
                                                <Border
                                                    Grid.Column="2"
                                                    Padding="6,4"
                                                    Background="{StaticResource SuccessLightBrush}"
                                                    CornerRadius="4">
                                                    <TextBlock
                                                        Foreground="{StaticResource SuccessBrush}"
                                                        Style="{StaticResource Type.BodySmall}"
                                                        Text="{Binding NewValue}"
                                                        TextWrapping="Wrap" />
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!--  Placeholder text when no selection  -->
                    <TextBlock
                        x:Name="TxtPlaceholder"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextDisabledBrush}"
                        Style="{StaticResource Type.BodyLarge}"
                        Text="اختر عملية من الجدول لعرض تفاصيل التغييرات." />
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
