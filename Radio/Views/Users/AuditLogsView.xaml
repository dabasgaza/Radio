<UserControl
    x:Class="Radio.Views.Users.AuditLogsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryDarkBrush}"
                        Style="{StaticResource Type.HeadlineSmall}"
                        Text="سجل العمليات والتدقيق (Audit Logs)" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodyMedium}"
                        Text="تتبع ومراقبة جميع الإجراءات التي تمت على قاعدة البيانات من إضافة وتعديل وحذف." />
                </StackPanel>

                <materialDesign:PackIcon
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource PrimaryMainBrush}"
                    Kind="History" />
            </Grid>
        </Border>

        <!-- Filters Card -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Users Filter -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="المستخدم" />
                    <ComboBox x:Name="ComboUsers" DisplayMemberPath="FullName" SelectedValuePath="UserId" />
                </StackPanel>

                <!-- Actions Filter -->
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="نوع الإجراء" />
                    <ComboBox x:Name="ComboActions">
                        <ComboBoxItem Content="الكل" Tag="" />
                        <ComboBoxItem Content="إضافة (ADDED)" Tag="ADDED" />
                        <ComboBoxItem Content="تعديل (MODIFIED)" Tag="MODIFIED" />
                        <ComboBoxItem Content="حذف منطقي (SOFT_DELETED)" Tag="SOFT_DELETED" />
                        <ComboBoxItem Content="حذف نهائي (DELETED)" Tag="DELETED" />
                    </ComboBox>
                </StackPanel>

                <!-- Date Range From -->
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="من تاريخ" />
                    <DatePicker x:Name="DpFrom" />
                </StackPanel>

                <!-- Date Range To -->
                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock
                        Margin="0,0,0,4"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="إلى تاريخ" />
                    <DatePicker x:Name="DpTo" />
                </StackPanel>

                <!-- Filter Actions -->
                <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Orientation="Horizontal">
                    <Button
                        x:Name="BtnFilter"
                        Margin="0,0,8,0"
                        Click="BtnFilter_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Margin="0,0,4,0"
                                Kind="Magnify" />
                            <TextBlock Text="بحث" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="BtnResetFilters"
                        Click="BtnResetFilters_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            Kind="FilterOff" />
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Main Layout Grid (DataGrid & Details Panel) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition x:Name="ColDetails" Width="1.2*" />
            </Grid.ColumnDefinitions>

            <!-- Logs DataGrid -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid
                        x:Name="GridLogs"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True"
                        SelectionChanged="GridLogs_SelectionChanged"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="140"
                                Binding="{Binding ChangedAt, StringFormat='dd-MM-yyyy HH:mm:ss'}"
                                Header="تاريخ العملية" />
                            
                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding UserFullName}"
                                Header="المستخدم" />

                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding TableName}"
                                Header="الجدول" />

                            <DataGridTextColumn
                                Width="80"
                                Binding="{Binding RecordId}"
                                Header="معرف السجل" />

                            <DataGridTemplateColumn Width="130" Header="الإجراء">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="6,2"
                                            CornerRadius="4"
                                            HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Action}" Value="ADDED">
                                                            <Setter Property="Background" Value="#E8F5E9" />
                                                            <Setter Property="Child">
                                                                <Setter.Value>
                                                                    <TextBlock Foreground="#2E7D32" Text="إضافة" FontWeight="SemiBold"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="MODIFIED">
                                                            <Setter Property="Background" Value="#E3F2FD" />
                                                            <Setter Property="Child">
                                                                <Setter.Value>
                                                                    <TextBlock Foreground="#1565C0" Text="تعديل" FontWeight="SemiBold"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="SOFT_DELETED">
                                                            <Setter Property="Background" Value="#FFF3E0" />
                                                            <Setter Property="Child">
                                                                <Setter.Value>
                                                                    <TextBlock Foreground="#EF6C00" Text="حذف منطقي" FontWeight="SemiBold"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="DELETED">
                                                            <Setter Property="Background" Value="#FFEBEE" />
                                                            <Setter Property="Child">
                                                                <Setter.Value>
                                                                    <TextBlock Foreground="#C62828" Text="حذف نهائي" FontWeight="SemiBold"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Reason}"
                                Header="السبب" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextDisabledBrush}"
                        Style="{StaticResource Type.BodySmall}"
                        Text="ملاحظة: يعرض الجدول آخر 500 عملية فقط للحفاظ على الأداء." />
                </Grid>
            </materialDesign:Card>

            <!-- Details Panel -->
            <materialDesign:Card Grid.Column="1" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Details Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock
                            FontWeight="Bold"
                            Style="{StaticResource Type.TitleMedium}"
                            Text="تفاصيل العملية والمقارنة" />
                        <Separator Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Details Content -->
                    <Grid Grid.Row="1" x:Name="GridDetailsContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Meta Info -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock x:Name="TxtDetailUser" Style="{StaticResource Type.BodyMedium}" Margin="0,2" />
                            <TextBlock x:Name="TxtDetailTable" Style="{StaticResource Type.BodyMedium}" Margin="0,2" />
                            <TextBlock x:Name="TxtDetailAction" Style="{StaticResource Type.BodyMedium}" Margin="0,2" />
                            <TextBlock x:Name="TxtDetailDate" Style="{StaticResource Type.BodyMedium}" Margin="0,2" />
                        </StackPanel>

                        <!-- Changes Comparison List -->
                        <ListView x:Name="LvChanges" Grid.Row="1" BorderThickness="0" Margin="0,8,0,0" HorizontalContentAlignment="Stretch">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Field Name -->
                                            <TextBlock Grid.Row="0" FontWeight="Bold" Foreground="{DynamicResource PrimaryMainBrush}" Text="{Binding FieldName}" Style="{StaticResource Type.BodySmall}" />
                                            
                                            <!-- Comparison Row -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Old Value -->
                                                <Border Grid.Column="0" Background="#FFEBEE" CornerRadius="4" Padding="6,4">
                                                    <TextBlock Foreground="#C62828" Text="{Binding OldValue}" TextWrapping="Wrap" Style="{StaticResource Type.BodySmall}" />
                                                </Border>

                                                <!-- Arrow Indicator -->
                                                <materialDesign:PackIcon Grid.Column="1" Kind="ArrowLeft" Width="16" Height="16" Margin="8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDisabledBrush}" />

                                                <!-- New Value -->
                                                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="4" Padding="6,4">
                                                    <TextBlock Foreground="#2E7D32" Text="{Binding NewValue}" TextWrapping="Wrap" Style="{StaticResource Type.BodySmall}" />
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- Placeholder text when no selection -->
                    <TextBlock
                        x:Name="TxtPlaceholder"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextDisabledBrush}"
                        Style="{StaticResource Type.BodyLarge}"
                        Text="اختر عملية من الجدول لعرض تفاصيل التغييرات." />
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
