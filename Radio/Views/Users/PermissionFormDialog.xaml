<mah:MetroWindow
    x:Class="Radio.Views.Users.PermissionFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة تعريف الصلاحية"
    Width="500"
    Height="Auto"
    SizeToContent="Height"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterOwner">

    <materialDesign:Card Margin="25" UniformCornerRadius="24" 
                         materialDesign:ElevationAssist.Elevation="Dp8"
                         Effect="{StaticResource Shadow.Dialog}"
                         BorderThickness="1" BorderBrush="{StaticResource DividerBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Border Background="{StaticResource PrimaryDarkBrush}" CornerRadius="24,24,0,0">
                <Grid Margin="24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="ShieldEdit" />
                        <TextBlock
                            x:Name="TxtDialogTitle"
                            Margin="16,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إضافة صلاحية نظام جديدة" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Click="BtnCancel_Click"
                            Padding="0"
                            Width="32"
                            Height="32"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White">
                        <materialDesign:PackIcon Kind="Close" Width="24" Height="24" />
                    </Button>
                </Grid>
            </Border>

            <!--  Body  -->
            <StackPanel Grid.Row="1" Margin="24">

                <!--  System Name  -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="Bold"
                        Style="{StaticResource Type.Caption}"
                        Text="الاسم البرمجي (System Name) *" />
                    <TextBox
                        x:Name="TxtSystemName"
                        materialDesign:HintAssist.Hint="مثال: EPISODE_DELETE"
                        Style="{StaticResource Input.Text}" />
                    <TextBlock
                        Margin="4,4,0,0"
                        Foreground="{StaticResource ErrorBrush}"
                        Style="{StaticResource Type.Overline}"
                        Text="تنبيه: يجب أن يطابق هذا الاسم الثوابت البرمجية بدقة" />
                </StackPanel>

                <!--  Display Name  -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="Bold"
                        Style="{StaticResource Type.Caption}"
                        Text="الاسم المعروض (Display Name) *" />
                    <TextBox
                        x:Name="TxtDisplayName"
                        materialDesign:HintAssist.Hint="مثال: حذف حلقة"
                        Style="{StaticResource Input.Text}" />
                </StackPanel>

                <!--  Module  -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="Bold"
                        Style="{StaticResource Type.Caption}"
                        Text="الوحدة البرمجية (Module) *" />
                    <ComboBox
                        x:Name="CmbModule"
                        materialDesign:HintAssist.Hint="اختر أو اكتب اسم الوحدة"
                        IsEditable="True"
                        Style="{StaticResource Input.ComboBox}">
                        <ComboBoxItem Content="إدارة الحلقات" />
                        <ComboBoxItem Content="النشر الرقمي" />
                        <ComboBoxItem Content="شؤون الموظفين" />
                        <ComboBoxItem Content="الضيوف" />
                        <ComboBoxItem Content="التقارير" />
                        <ComboBoxItem Content="إدارة النظام" />
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!--  Footer  -->
            <Border
                Grid.Row="2"
                Padding="24,16"
                Background="{StaticResource Neutral50Brush}"
                CornerRadius="0,0,24,24">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Button
                        x:Name="BtnSave"
                        Click="BtnSave_Click"
                        Style="{StaticResource Btn.Primary}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon VerticalAlignment="Center" Kind="ContentSave" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="حفظ الصلاحية" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="12,0"
                        Click="BtnCancel_Click"
                        Content="إلغاء"
                        Style="{StaticResource Btn.Secondary}" />
                </StackPanel>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>
