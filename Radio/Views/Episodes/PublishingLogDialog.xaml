<mah:MetroWindow
    x:Class="Radio.Views.Episodes.PublishingLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PublishingLogDialog"
    Width="800"
    Height="450"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock
                Margin="0,0,0,20"
                Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                Text="توثيق روابط النشر" />
            <TextBox
                x:Name="TxtYouTube"
                Margin="0,0,0,10"
                materialDesign:HintAssist.Hint="رابط يوتيوب"
                Style="{StaticResource MaterialDesignOutlinedTextBox}" />
            <TextBox
                x:Name="TxtFacebook"
                Margin="0,0,0,10"
                materialDesign:HintAssist.Hint="رابط فيسبوك"
                Style="{StaticResource MaterialDesignOutlinedTextBox}" />
            <TextBox
                x:Name="TxtTwitter"
                Margin="0,0,0,10"
                materialDesign:HintAssist.Hint="رابط تويتر (X)"
                Style="{StaticResource MaterialDesignOutlinedTextBox}" />
            <TextBox
                x:Name="TxtSoundCloud"
                Margin="0,0,0,10"
                materialDesign:HintAssist.Hint="رابط ساوند كلاود"
                Style="{StaticResource MaterialDesignOutlinedTextBox}" />
            <Button
                Name="BtnSave"
                Margin="0,20,0,0"
                Click="BtnSave_Click"
                Content="تأكيد النشر"
                Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
