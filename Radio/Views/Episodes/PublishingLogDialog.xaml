<mah:MetroWindow
    x:Class="Radio.Views.Episodes.PublishingLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="نشر مقاطع الضيوف"
    Width="900"
    Height="720"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterOwner">

    <materialDesign:Card
        Margin="30"
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource Shadow.Dialog}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ Header ═══════  -->
            <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Kind="CloudUploadOutline" />

                    <StackPanel Grid.Column="1" Margin="16,0">
                        <TextBlock Style="{StaticResource Type.TitleLarge.OnColor}" Text="نشر مقاطع الضيوف على السوشيال ميديا" />
                        <TextBlock Style="{StaticResource Type.BodyMedium.OnColor}" Text="سجّل بيانات النشر الرقمي لكل ضيف مع المنصات والروابط" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ Content ═══════  -->
            <Grid Grid.Row="1" Margin="24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  ═══════ العمود الأيسر: قائمة الضيوف مع حالة النشر ═══════  -->
                <Border
                    Grid.Column="0"
                    Margin="0,0,20,0"
                    Padding="0"
                    Background="{StaticResource SurfaceVariantBrush}"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  عنوان القائمة  -->
                        <Border
                            Padding="16,14"
                            Background="{StaticResource PrimaryXLightBrush}"
                            CornerRadius="12,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource PrimaryMainBrush}"
                                    Kind="AccountGroupOutline" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryMainBrush}"
                                    Style="{StaticResource Type.BodyMedium}"
                                    Text="قائمة الضيوف" />
                            </StackPanel>
                        </Border>

                        <!--  قائمة الضيوف  -->
                        <ListBox
                            x:Name="LstGuests"
                            Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0"
                            SelectionChanged="LstGuests_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,8" />
                                    <Setter Property="Margin" Value="4,2" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  أيقونة الحالة  -->
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            VerticalAlignment="Center"
                                            Kind="CircleMedium">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>

                                        <!--  اسم الضيف  -->
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="8,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource Type.Caption}"
                                            Text="{Binding FullName}"
                                            TextTrimming="CharacterEllipsis" />

                                        <!--  شارة الحالة  -->
                                        <Border
                                            Grid.Column="2"
                                            Padding="8,2"
                                            VerticalAlignment="Center"
                                            CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                            <Setter Property="Background" Value="{StaticResource SuccessLightBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                            <Setter Property="Background" Value="{StaticResource WarningLightBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontWeight="Medium">
                                                <TextBlock.Style>
                                                    <Style BasedOn="{StaticResource Type.Overline}" TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}" />
                                                        <Setter Property="Text" Value="انتظار" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                <Setter Property="Text" Value="جاهز" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                <Setter Property="Text" Value="ناقص" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!--  ═══════ العمود الأيمن: بيانات النشر للضيف المحدد ═══════  -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PnlGuestForm" IsEnabled="False">

                        <!--  صف: عنوان المقطع + نوع الوسائط  -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="TxtClipTitle"
                                Grid.Column="0"
                                materialDesign:HintAssist.Hint="عنوان المقطع *"
                                materialDesign:TextFieldAssist.LeadingIcon="RenameBox"
                                Style="{StaticResource Input.Text}"
                                TextChanged="FormField_Changed" />

                            <ComboBox
                                x:Name="CmbMediaType"
                                Grid.Column="2"
                                materialDesign:HintAssist.Hint="نوع الوسائط *"
                                materialDesign:TextFieldAssist.LeadingIcon="Multimedia"
                                SelectedIndex="2"
                                SelectionChanged="FormField_Changed"
                                Style="{StaticResource Input.ComboBox}">
                                <ComboBoxItem Content="مقطع صوتي" Tag="Audio" />
                                <ComboBoxItem Content="مقطع مرئي" Tag="Video" />
                                <ComboBoxItem Content="كلاهما" Tag="Both" />
                            </ComboBox>
                        </Grid>

                        <!--  صف: مدة المقطع  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.Caption}"
                            Text="مدة المقطع" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="TxtMinutes"
                                HorizontalContentAlignment="Center"
                                materialDesign:HintAssist.Hint="دقائق"
                                MaxLength="3"
                                PreviewTextInput="TxtDuration_PreviewTextInput"
                                Style="{StaticResource Input.Text}"
                                TextChanged="FormField_Changed" />

                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextHintBrush}"
                                Style="{StaticResource Type.Headline.OnColor}"
                                Text=":" />

                            <TextBox
                                x:Name="TxtSeconds"
                                Grid.Column="2"
                                HorizontalContentAlignment="Center"
                                materialDesign:HintAssist.Hint="ثوانٍ"
                                MaxLength="2"
                                PreviewTextInput="TxtDuration_PreviewTextInput"
                                Style="{StaticResource Input.Text}"
                                TextChanged="FormField_Changed" />

                            <TextBlock
                                Grid.Column="3"
                                Margin="12,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextDisabledBrush}"
                                Style="{StaticResource Type.Overline}"
                                Text="اتركهما فارغين إن لم تكن المدة معروفة"
                                TextWrapping="Wrap" />
                        </Grid>

                        <!--  فاصل  -->
                        <Separator Margin="0,0,0,16" Background="{StaticResource DividerBrush}" />

                        <!--  عنوان قسم المنصات  -->
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource PrimaryMainBrush}"
                                Kind="ShareVariant" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Style="{StaticResource Type.BodyMedium}"
                                Text="منصات النشر" />
                        </StackPanel>

                        <!--  بطاقات المنصات  -->
                        <ItemsControl x:Name="IcPlatforms">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="16,14"
                                        Background="{StaticResource SurfaceVariantBrush}"
                                        CornerRadius="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!--  صف 1: أيقونة المنصة + اسمها + CheckBox  -->
                                            <CheckBox
                                                Grid.Row="0"
                                                Margin="0,0,0,10"
                                                Checked="FormField_Changed"
                                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                Style="{StaticResource MaterialDesignCheckBox}"
                                                Unchecked="FormField_Changed">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        Kind="{Binding PlatformIcon, TargetNullValue=ShareVariant, FallbackValue=ShareVariant}" />
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding PlatformName}" />
                                                </StackPanel>
                                            </CheckBox>

                                            <!--  صف 2: حقل الرابط مع بادئة https:// ثابتة  -->
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!--  بادئة https:// ثابتة غير قابلة للتعديل  -->
                                                <Border
                                                    Grid.Column="0"
                                                    Padding="12,0"
                                                    VerticalAlignment="Stretch"
                                                    Background="{StaticResource SurfaceVariantBrush}"
                                                    BorderBrush="{StaticResource DividerBrush}"
                                                    BorderThickness="1,1,0,1"
                                                    CornerRadius="4,0,0,4">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        Style="{StaticResource Type.Caption}"
                                                        Text="https://" />
                                                </Border>

                                                <!--  حقل إدخال الرابط (بدون البروتوكول)  -->
                                                <TextBox
                                                    Grid.Column="1"
                                                    materialDesign:HintAssist.Hint="youtube.com/watch?v=..."
                                                    IsEnabled="{Binding IsSelected}"
                                                    PreviewKeyDown="Url_PreviewKeyDown"
                                                    PreviewTextInput="Url_PreviewTextInput"
                                                    Style="{StaticResource Input.Text}"
                                                    Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    TextChanged="FormField_Changed" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  ═══════ لوحة أخطاء التحقق ═══════  -->
                        <Border
                            x:Name="PnlValidationErrors"
                            Margin="0,16,0,0"
                            Padding="16,12"
                            Background="#FFFDE7"
                            BorderBrush="#FFB300"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock
                                    x:Name="LblValidationHeader"
                                    Margin="0,0,0,8"
                                    FontWeight="SemiBold"
                                    Foreground="#E65100"
                                    Style="{StaticResource Type.Caption}" />
                                <ItemsControl x:Name="LstValidationMessages">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,3" Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="#E65100"
                                                    Kind="AlertCircleOutline" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Foreground="#BF360C"
                                                    Style="{StaticResource Type.Overline}"
                                                    Text="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!--  حاوية الإشعارات  -->
            <StackPanel
                x:Name="NotificationHost"
                Grid.Row="1"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Panel.ZIndex="999" />


            <!--  ═══════ Footer ═══════  -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  ملخص الحالة  -->
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextHintBrush}"
                            Kind="InformationOutline" />
                        <TextBlock
                            x:Name="TxtStatusSummary"
                            Margin="8,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Style="{StaticResource Type.Overline}"
                            Text="" />
                    </StackPanel>

                    <!--  أزرار الإجراءات  -->
                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,12,0"
                            Click="BtnClose_Click"
                            Content="إلغاء"
                            IsCancel="True"
                            Style="{StaticResource Btn.Cancel}" />
                        <Button
                            x:Name="BtnSaveAll"
                            Click="BtnSaveAll_Click"
                            Style="{StaticResource Btn.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon VerticalAlignment="Center" Kind="ContentSaveAllOutline" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="حفظ الكل" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>
