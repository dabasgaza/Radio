<mah:MetroWindow
    x:Class="Radio.Views.Episodes.PublishingLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="توثيق الروابط الرقمية"
    Width="580"
    Height="620"
    BorderThickness="1"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card
        Margin="30"
        Effect="{StaticResource Shadow.Dialog}"
        Style="{StaticResource Card.Form}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Style="{StaticResource Zone.Header.Neutral}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="CloudSync" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock Style="{StaticResource Type.TitleLarge.OnColor}" Text="مركز النشر الرقمي" />

                        <TextBlock Style="{StaticResource Type.BodyMedium.OnColor}" Text="أرشفة روابط الحلقة على منصات التواصل الاجتماعي" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:Card
                            Grid.Column="0"
                            Padding="12"
                            materialDesign:ElevationAssist.Elevation="Dp1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        VerticalAlignment="Center"
                                        Foreground="#FF0000"
                                        Kind="Youtube" />
                                    <TextBlock
                                        Margin="8,0"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Text="يوتيوب" />
                                </StackPanel>
                                <TextBox
                                    x:Name="TxtYouTube"
                                    materialDesign:HintAssist.Hint="رابط الفيديو"
                                    Style="{StaticResource Input.Text}" />
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card
                            Grid.Column="2"
                            Padding="12"
                            materialDesign:ElevationAssist.Elevation="Dp1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        VerticalAlignment="Center"
                                        Foreground="#1877F2"
                                        Kind="Facebook" />
                                    <TextBlock
                                        Margin="8,0"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Text="فيسبوك" />
                                </StackPanel>
                                <TextBox
                                    x:Name="TxtFacebook"
                                    materialDesign:HintAssist.Hint="رابط المنشور"
                                    Style="{StaticResource Input.Text}" />
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:Card
                            Grid.Column="0"
                            Padding="12"
                            materialDesign:ElevationAssist.Elevation="Dp1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Kind="Twitter" />
                                    <TextBlock
                                        Margin="8,0"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Text="تويتر (X)" />
                                </StackPanel>
                                <TextBox
                                    x:Name="TxtTwitter"
                                    materialDesign:HintAssist.Hint="رابط التغريدة"
                                    Style="{StaticResource Input.Text}" />
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card
                            Grid.Column="2"
                            Padding="12"
                            materialDesign:ElevationAssist.Elevation="Dp1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        VerticalAlignment="Center"
                                        Foreground="#F57C00"
                                        Kind="Soundcloud" />
                                    <TextBlock
                                        Margin="8,0"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Text="ساوند كلاود" />
                                </StackPanel>
                                <TextBox
                                    x:Name="TxtSoundCloud"
                                    materialDesign:HintAssist.Hint="رابط الملف الصوتي"
                                    Style="{StaticResource Input.Text}" />
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>

                    <Border Margin="0,10" Style="{StaticResource Card.Info}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Foreground="#1565C0"
                                Kind="Information"
                                Opacity="0.7" />
                            <TextBlock
                                Margin="12,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Opacity="0.8"
                                Text="تأكد من صحة الروابط لضمان ظهورها بشكل صحيح في تقارير النشر." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="إلغاء"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ وتوثيق النشر"
                        Style="{StaticResource Btn.Primary}" />
                </Grid>
            </Border>
        </Grid>

    </materialDesign:Card>
</mah:MetroWindow>