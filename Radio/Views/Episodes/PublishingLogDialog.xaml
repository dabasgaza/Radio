<mah:MetroWindow
    x:Class="Radio.Views.Episodes.PublishingLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PublishingLogDialog"
    Width="560"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    GlowBrush="Cyan"
    ResizeMode="NoResize"
    ShowCloseButton="False"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <mah:MetroWindow.Resources>

        <!--  ══════════════ الألوان (Rose Pink) ══════════════  -->
        <SolidColorBrush x:Key="BgBase" Color="#0C0F16" />
        <SolidColorBrush x:Key="BgInput" Color="#21262F" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A3042" />
        <SolidColorBrush x:Key="TextMain" Color="#E0E4EB" />
        <SolidColorBrush x:Key="TextMuted" Color="#5E6687" />
        <SolidColorBrush x:Key="RoseMain" Color="#EC407A" />
        <SolidColorBrush x:Key="RoseLight" Color="#F06292" />
        <SolidColorBrush x:Key="RedAccent" Color="#E54D4D" />

        <!--  ══════════════ التدرجات والتأثيرات ══════════════  -->
        <LinearGradientBrush x:Key="GradRoseBtn" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#EC407A" />
            <GradientStop Offset="1" Color="#F06292" />
        </LinearGradientBrush>
        <DropShadowEffect
            x:Key="GlowRose"
            BlurRadius="14"
            Opacity="0.3"
            ShadowDepth="0"
            Color="#EC407A" />
        <DropShadowEffect
            x:Key="BtnShadow"
            BlurRadius="18"
            Opacity="0.3"
            ShadowDepth="4"
            Color="#EC407A" />
        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="8"
            Opacity="0.4"
            ShadowDepth="2"
            Color="#000000" />

        <!--  ══════════════ تخصيص ألوان حقول MaterialDesign ══════════════  -->
        <SolidColorBrush x:Key="MaterialDesignBrush.Foreground" Color="#E0E4EB" />
        <SolidColorBrush x:Key="MaterialDesignBrush.Background" Color="#21262F" />
        <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#EC407A" />

        <!--  ══════════════ زر إغلاق مخصص ══════════════  -->
        <Style x:Key="BtnCloseStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E54D4D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ زر تأكيد النشر ══════════════  -->
        <Style x:Key="BtnSaveStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0C0F16" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="24,0"
                            Background="{StaticResource GradRoseBtn}"
                            CornerRadius="10"
                            Effect="{StaticResource BtnShadow}"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Margin="0,0,10,0"
                                    Kind="CloudUploadOutline" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ زر إلغاء ══════════════  -->
        <Style x:Key="BtnCancelStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#5E6687" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#21262F"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="10"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    Kind="Close" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                                <Setter Property="Foreground" Value="#E54D4D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <!--  ═══════════════════════════════════════════  -->
    <!--  التخطيط الرئيسي  -->
    <!--  ═══════════════════════════════════════════  -->
    <Grid Background="#0C0F16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ═══════════ خلفية النافذة ═══════════  -->
        <Border Grid.RowSpan="3" CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#15181F" />
                    <GradientStop Offset="1" Color="#0C0F16" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!--  ═══════════ شريط علوي (Card مدمج) ═══════════  -->
        <Border
            Grid.Row="0"
            Margin="14,14,14,0"
            Background="#181C24"
            BorderBrush="#2A3042"
            BorderThickness="1"
            CornerRadius="12"
            Effect="{StaticResource CardShadow}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  أيقونة + العنوان  -->
                <StackPanel
                    Margin="18,18,0,18"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Width="42"
                        Height="42"
                        Background="{StaticResource GradRoseBtn}"
                        CornerRadius="11"
                        Effect="{StaticResource GlowRose}">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="CloudUploadOutline" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="توثيق روابط النشر" />
                        <TextBlock
                            Margin="0,3,0,0"
                            FontSize="11"
                            Foreground="#5E6687"
                            Text="أدخل روابط المنصات لنشر الحلقة عليها" />
                    </StackPanel>
                </StackPanel>

                <!--  زر الإغلاق  -->
                <Button
                    Grid.Column="2"
                    Margin="0,0,14,0"
                    Click="BtnClose_Click"
                    Style="{StaticResource BtnCloseStyle}"
                    ToolTip="إغلاق">
                    <materialDesign:PackIcon
                        Width="14"
                        Height="14"
                        Foreground="#5E6687"
                        Kind="Close" />
                </Button>
            </Grid>
        </Border>

        <!--  ═══════════ المحتوى ═══════════  -->
        <ScrollViewer
            Grid.Row="1"
            Margin="14,12,14,8"
            Padding="12,0,12,8"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  يوتيوب  -->
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#FF0000"
                        Text="يوتيوب" />
                    <TextBox
                        x:Name="TxtYouTube"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="أدخل رابط يوتيوب"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Youtube"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </StackPanel>

                <!--  فيسبوك  -->
                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#1877F2"
                        Text="فيسبوك" />
                    <TextBox
                        x:Name="TxtFacebook"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="أدخل رابط المنشور أو الصفحة"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Facebook"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </StackPanel>

                <!--  تويتر / X  -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#1DA1F2"
                        Text="تويتر (X)" />
                    <TextBox
                        x:Name="TxtTwitter"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="أدخل رابط التغريدة"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Twitter"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </StackPanel>

                <!--  ساوند كلاود  -->
                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#F57C00"
                        Text="ساوند كلاود" />
                    <TextBox
                        x:Name="TxtSoundCloud"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="أدخل رابط الحلقة"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Soundcloud"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!--  ═══════════ التذييل ═══════════  -->
        <Border
            Grid.Row="2"
            Margin="14,0,14,14"
            Padding="14,16"
            Background="#141821"
            BorderBrush="#2A3042"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="إلغاء"
                    IsCancel="True"
                    Style="{StaticResource BtnCancelStyle}" />

                <Button
                    x:Name="BtnSave"
                    Grid.Column="2"
                    Click="BtnSave_Click"
                    Content="تأكيد النشر"
                    Style="{StaticResource BtnSaveStyle}" />
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>