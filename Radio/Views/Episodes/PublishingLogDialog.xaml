<UserControl
    x:Class="Radio.Views.Episodes.PublishingLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Width="860"
    Height="700"
    Style="{StaticResource View.Base}">
    <materialDesign:Card
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource Shadow.Dialog}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
                <TextBlock
                    Margin="16,0"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="نشر مقاطع الضيوف على السوشيال ميديا" />
            </materialDesign:ColorZone>

            <!--  Content Grid: Guests List + Platform Selection  -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  قائمة الضيوف على اليسار  -->
                <Border
                    Grid.Column="0"
                    Margin="0,0,16,0"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,1,0">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="14"
                            FontWeight="Bold"
                            Text="الضيوف" />
                        <ListBox
                            x:Name="LstGuests"
                            Background="Transparent"
                            BorderThickness="0"
                            SelectionChanged="LstGuests_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,8" Text="{Binding FullName}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!--  منصات النشر على اليمين  -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <!--  عنوان المقطع  -->
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#616161"
                        Text="عنوان المقطع" />
                    <TextBox
                        x:Name="TxtClipTitle"
                        Height="40"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="أدخل عنوان المقطع"
                        Style="{StaticResource Input.Text}" />

                    <!--  مدة المقطع  -->
                    <TextBlock
                        Margin="0,12,0,8"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#616161"
                        Text="مدة المقطع (دقيقة:ثانية)" />
                    <TextBox
                        x:Name="TxtDuration"
                        Height="40"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="مثال: 05:30"
                        Style="{StaticResource Input.Text}" />

                    <!--  المنصات  -->
                    <TextBlock
                        Margin="0,12,0,12"
                        FontSize="14"
                        FontWeight="Bold"
                        Text="منصات النشر" />
                    <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="IcPlatforms">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="0,12"
                                        BorderBrush="#F0F0F0"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!--  CheckBox للمنصة  -->
                                            <CheckBox
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Content="{Binding PlatformName}"
                                                FontSize="12"
                                                IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                            <!--  TextBox للرابط  -->
                                            <TextBox
                                                Grid.Column="1"
                                                Height="36"
                                                Margin="12,0,0,0"
                                                materialDesign:HintAssist.Hint="رابط النشر"
                                                IsEnabled="{Binding IsSelected}"
                                                Style="{StaticResource Input.Text}"
                                                Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>

            <!--  Footer  -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Padding="16,8"
                        Click="BtnClose_Click"
                        Content="إغلاق"
                        Style="{StaticResource Btn.Cancel}" />
                    <Button
                        Padding="16,8"
                        Click="BtnSave_Click"
                        Content="حفظ النشر"
                        Style="{StaticResource Btn.Primary}" />
                </StackPanel>
            </Border>
        </Grid>
    </materialDesign:Card>
</UserControl>