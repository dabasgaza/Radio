<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:local1="clr-namespace:Radio.Converter;assembly=Radio"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="850"
    d:DesignWidth="1100"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <materialDesign:ColorZone
            Padding="24,16"
            materialDesign:ElevationAssist.Elevation="Dp2"
            Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="RadioFm" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="المركز الرئيسي للبث" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Opacity="0.8"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="المحرك الأساسي لإدارة المحتوى، الجدولة، والانتشار الرقمي" />
                </StackPanel>

                <Button
                    x:Name="BtnAddEpisode"
                    Grid.Column="1"
                    Height="45"
                    Padding="24,0"
                    VerticalAlignment="Center"
                    Click="BtnAddEpisode_Click"
                    Content="جدولة حلقة جديدة"
                    Style="{StaticResource Btn.AddNew}" />
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. شريط البحث والإحصائيات (KPIs) ═══════  -->
        <Grid Grid.Row="1" Margin="24,24,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Stretch"
                materialDesign:HintAssist.Hint="البحث السريع في سجلات البث..."
                materialDesign:TextFieldAssist.HasClearButton="True"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  كرت الإحصائية 1: إجمالي الحلقات  -->
            <materialDesign:Card
                Grid.Column="1"
                Margin="0,0,12,0"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="ChartBoxOutline" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.Caption}"
                            Text="إجمالي الحلقات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            Style="{StaticResource Type.Numeric.Large}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  كرت الإحصائية 2: منشورة  -->
            <materialDesign:Card
                Grid.Column="2"
                Margin="0,0,12,0"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Success}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="CloudCheckOutline" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.Caption}"
                            Text="منشورة" />
                        <TextBlock
                            x:Name="TxtPublished"
                            Foreground="{StaticResource SuccessBrush}"
                            Style="{StaticResource Type.Numeric.Large}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  كرت الإحصائية 3: مجدولة  -->
            <materialDesign:Card
                Grid.Column="3"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Warning}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource WarningBrush}"
                            Kind="ProgressClock" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.Caption}"
                            Text="مجدولة" />
                        <TextBlock
                            x:Name="TxtExecuted"
                            Foreground="{StaticResource WarningBrush}"
                            Style="{StaticResource Type.Numeric.Large}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!--  ═══════ 3. بطاقات الحلقات ═══════  -->
        <ListBox
            x:Name="DgEpisodes"
            Grid.Row="2"
            Margin="32,8,32,24"
            Background="Transparent"
            BorderThickness="0"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource MaterialDesignListBox}">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,14" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card
                        Padding="0"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        Background="{StaticResource SurfaceBrush}"
                        UniformCornerRadius="14">

                        <materialDesign:Card.Style>
                            <Style TargetType="materialDesign:Card">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:Card.Style>

                        <!--  استخدام DockPanel لضمان تثبيت شريط الأزرار في الأسفل  -->
                        <DockPanel>
                            <!--  ═══════ شريط الأزرار (مُثبَّت في الأسفل) ═══════  -->
                            <Border
                                Padding="20,14,20,16"
                                Background="Transparent"
                                DockPanel.Dock="Bottom">



                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  إجراءات سير العمل + التصحيحية  -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button
                                            Background="{StaticResource HeaderGradientBrush}"
                                            Click="BtnMarkExecuted_Click"
                                            IsEnabled="{Binding CanMarkExecuted}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="تنفيذ الحلقة">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="White"
                                                Kind="PlayCircleOutline" />
                                        </Button>
                                        <Button
                                            Margin="8,0,0,0"
                                            Background="{StaticResource SuccessBrush}"
                                            Click="BtnMarkPublished_Click"
                                            IsEnabled="{Binding CanMarkPublished}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="نشر رقمي">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="White"
                                                Kind="CloudUploadOutline" />
                                        </Button>
                                        <Button
                                            Margin="8,0,0,0"
                                            Background="#2196F3"
                                            Click="BtnToggleWebsitePublish_Click"
                                            IsEnabled="{Binding CanToggleWebsitePublish}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="نشر على الموقع">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="White"
                                                Kind="Web" />
                                        </Button>

                                        <!--  فاصل  -->
                                        <Border
                                            Width="1"
                                            Height="24"
                                            Margin="14,0"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource DividerBrush}" />

                                        <!--  زر عرض السجلات — يظهر فقط إذا كانت الحلقة منفّذة أو بعدها  -->
                                        <Button
                                            Background="#5C6BC0"
                                            Click="BtnViewRecords_Click"
                                            IsEnabled="{Binding CanViewRecords}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="عرض السجلات">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="White"
                                                Kind="ClipboardTextOutline" />
                                        </Button>

                                        <Border
                                            Width="1"
                                            Height="24"
                                            Margin="14,0"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource DividerBrush}" />

                                        <Button
                                            Background="{StaticResource WarningBrush}"
                                            Click="BtnRevert_Click"
                                            IsEnabled="{Binding CanRevert}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="تراجع عن الإجراء">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="White"
                                                Kind="UndoVariant" />
                                        </Button>
                                        <Button
                                            Margin="8,0,0,0"
                                            Background="{StaticResource ErrorBrush}"
                                            Click="BtnCancelEpisode_Click"
                                            IsEnabled="{Binding CanCancel}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="إلغاء الحلقة">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="White"
                                                Kind="Cancel" />
                                        </Button>
                                    </StackPanel>

                                    <!--  إجراءات الإدارة  -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Click="BtnEdit_Click"
                                            Cursor="Hand"
                                            Style="{StaticResource Btn.Icon.Edit}"
                                            ToolTip="تعديل الحلقة">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="PencilOutline" />
                                        </Button>
                                        <Button
                                            Width="36"
                                            Height="36"
                                            Click="BtnDelete_Click"
                                            Cursor="Hand"
                                            Style="{StaticResource Btn.Icon.Delete}"
                                            ToolTip="حذف الحلقة">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="{StaticResource ErrorBrush}"
                                                Kind="DeleteOutline" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!--  ═══════ شريط الحالة الملون (يسار) ═══════  -->
                            <Border
                                Width="5"
                                CornerRadius="5,0,0,5"
                                DockPanel.Dock="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                <Setter Property="Background" Value="{StaticResource SecondaryMainBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة رقمياً">
                                                <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                <Setter Property="Background" Value="#2196F3" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!--  ═══════ المحتوى الرئيسي للبطاقة ═══════  -->
                            <Grid Margin="20,16,20,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!--  الصف 1: البرنامج + التاريخ + Chip الحالة  -->
                                <Border Padding="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  شارة البرنامج  -->
                                        <Border
                                            Padding="25,6"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="16"
                                                    Height="16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource SecondaryMainBrush}"
                                                    Kind="RadioFm" />
                                                <TextBlock
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource PrimaryMainBrush}"
                                                    Style="{StaticResource Type.BodyLarge}"
                                                    Text="{Binding ProgramName}" />
                                            </StackPanel>
                                        </Border>

                                        <!--  التاريخ والوقت  -->
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="16,0,0,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding ScheduledExecutionTime, StringFormat='dddd', ConverterCulture='ar-SA'}" />
                                            <Border
                                                Width="1"
                                                Height="16"
                                                Margin="10,0"
                                                Background="{StaticResource DividerBrush}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd', ConverterCulture='en-US'}" />
                                            <Border
                                                Width="1"
                                                Height="16"
                                                Margin="10,0"
                                                Background="{StaticResource DividerBrush}" />
                                            <Border
                                                Padding="8,4"
                                                Background="{StaticResource SurfaceVariantBrush}"
                                                CornerRadius="6">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,4,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource SecondaryMainBrush}"
                                                        Kind="ClockOutline" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        Style="{StaticResource Type.Caption}"
                                                        Text="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!--  Chip الحالة  -->
                                        <materialDesign:Chip
                                            Grid.Column="2"
                                            Height="26"
                                            Padding="10,0"
                                            Content="{Binding StatusText}"
                                            FontWeight="Medium">
                                            <materialDesign:Chip.Style>
                                                <Style BasedOn="{StaticResource {x:Type materialDesign:Chip}}" TargetType="materialDesign:Chip">
                                                    <Setter Property="Height" Value="26" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                            <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=ClockOutline}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                            <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CheckAll}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة رقمياً">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CheckDecagramOutline}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                            <Setter Property="Background" Value="#2196F3" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=Web}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CloseCircleOutline}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:Chip.Style>
                                        </materialDesign:Chip>
                                    </Grid>
                                </Border>

                                <!--  الصف 2: العنوان + الضيوف + ملاحظات  -->
                                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                    <!--  عنوان الحلقة  -->
                                    <TextBlock
                                        Style="{StaticResource Type.TitleMedium}"
                                        Text="{Binding EpisodeName}"
                                        TextTrimming="CharacterEllipsis" />

                                    <!--  عداد الضيوف  -->
                                    <StackPanel
                                        Margin="0,8,0,0"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="1">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="2">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="3">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="4">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="5">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextHintBrush}"
                                            Kind="AccountGroupOutline" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextHintBrush}"
                                            Style="{StaticResource Type.Caption}"
                                            Text="{Binding GuestItems.Count}" />
                                    </StackPanel>

                                    <!--  قائمة الضيوف  -->
                                    <ItemsControl
                                        Margin="0,10,0,0"
                                        Grid.IsSharedSizeScope="True"
                                        ItemsSource="{Binding GuestItems}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,0,4"
                                                    Padding="12,10"
                                                    Background="{StaticResource SurfaceVariantBrush}"
                                                    CornerRadius="8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="GuestNameCol" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="GuestTimeCol" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                            <Border
                                                                Width="32"
                                                                Height="32"
                                                                Background="{StaticResource PrimaryXLightBrush}"
                                                                CornerRadius="8">
                                                                <materialDesign:PackIcon
                                                                    Width="16"
                                                                    Height="16"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{StaticResource SecondaryMainBrush}"
                                                                    Kind="AccountOutline" />
                                                            </Border>
                                                            <!--  إسم الضيف  -->
                                                            <TextBlock
                                                                Margin="10,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                                Style="{StaticResource Type.BodyMedium}"
                                                                Text="{Binding Name}" />
                                                        </StackPanel>

                                                        <Border
                                                            Grid.Column="1"
                                                            Margin="16,0"
                                                            Padding="10,4"
                                                            VerticalAlignment="Center"
                                                            CornerRadius="6">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Topic}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Topic}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock
                                                                Foreground="{StaticResource PrimaryMainBrush}"
                                                                Style="{StaticResource Type.Caption}"
                                                                Text="{Binding Topic}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </Border>

                                                        <Border
                                                            Grid.Column="2"
                                                            Padding="8,4"
                                                            VerticalAlignment="Center"
                                                            CornerRadius="6">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource InfoLightBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HostingTime}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon
                                                                    Width="12"
                                                                    Height="12"
                                                                    Margin="0,0,5,0"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{StaticResource TextHintBrush}"
                                                                    Kind="ClockOutline" />
                                                                <TextBlock
                                                                    Foreground="{StaticResource TextHintBrush}"
                                                                    Style="{StaticResource Type.Overline}"
                                                                    Text="{Binding HostingTime, Converter={StaticResource TimeSpanToStringConverter}}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  لا يوجد ضيوف  -->
                                    <Border
                                        Margin="0,8,0,0"
                                        Padding="12,10"
                                        Background="{StaticResource SurfaceVariantBrush}"
                                        CornerRadius="8"
                                        Visibility="Collapsed">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Style="{StaticResource Type.Caption}"
                                            Text="لا يوجد ضيوف مسجلين لهذه الحلقة" />
                                    </Border>

                                    <!--  ملاحظات خاصة  -->
                                    <Border
                                        Margin="0,10,0,0"
                                        Padding="12,8"
                                        CornerRadius="8"
                                        Visibility="Collapsed">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFF8E1" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SpecialNotes}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpecialNotes}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Foreground="#F9A825"
                                                Kind="NoteTextOutline" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.Overline}"
                                                Text="{Binding SpecialNotes}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>

                                    <!--  سبب الإلغاء  -->
                                    <Border
                                        Margin="0,8,0,0"
                                        Padding="12,8"
                                        CornerRadius="8"
                                        Visibility="{Binding CancellationReason, Converter={StaticResource StringToVisibilityConverter}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFEBEE" />
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ErrorBrush}"
                                                    Kind="Cancel" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource ErrorBrush}"
                                                    Style="{StaticResource Type.Overline}"
                                                    Text="{Binding CancellationReason}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button
                                                Grid.Column="1"
                                                Width="28"
                                                Height="28"
                                                Click="BtnEditCancellationReason_Click"
                                                Cursor="Hand"
                                                Style="{StaticResource Btn.Icon}"
                                                ToolTip="تعديل سبب الإلغاء">
                                                <materialDesign:PackIcon
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="{StaticResource ErrorBrush}"
                                                    Kind="PencilOutline" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>