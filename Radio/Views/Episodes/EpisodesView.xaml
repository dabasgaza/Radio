<!--
    ═══════════════════════════════════════════════════════════════════════════
    EpisodesView.xaml — المرحلة الثانية: أنماط العرض المتقدمة
    ═══════════════════════════════════════════════════════════════════════════
    التحسينات المُنفَّذة (المرحلة الأولى + الثانية):
    المرحلة 1:
    1. إخفاء الأزرار المعطلة (Visibility بدلاً من IsEnabled)
    2. فلاتر سريعة حسب الحالة (Chips)
    3. توسيع نطاق البحث
    4. زيادة عرض شريط الحالة إلى 8 بكسل
    5. إجراء رئيسي بارز + قائمة ثانوية (Overflow)
    6. عداد نتائج البحث والتصفية
    7. اختصارات لوحة المفاتيح
    8. شريط تقدم دورة الحياة (Stepper)
    9. ملخص الضيوف كعداد
    المرحلة 2:
    10. ثلاثة أنماط عرض: بطاقات / جدول / مختصر
    11. أزرار تبديل أنماط العرض في شريط الفلاتر
    12. ترتيب حسب: التاريخ / الحالة / البرنامج / الاسم
    13. تصفية حسب البرنامج (ComboBox)
    14. عرض الجدول (DataGrid) مع أعمدة MaterialDesign
    15. العرض المختصر كقائمة أفقية مبسّطة
    ═══════════════════════════════════════════════════════════════════════════
-->
<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:local1="clr-namespace:Radio.Converter;assembly=Radio"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="850"
    d:DesignWidth="1100"
    Focusable="True"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  ═══ ستايل CheckBox دائري بتصميم MD3 للبطاقات ═══  -->
        <Style x:Key="Card.CheckBox" TargetType="CheckBox">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <!--  الخلفية الدائرية (تظهر عند التحديد)  -->
                            <Ellipse
                                x:Name="FillCircle"
                                Width="24"
                                Height="24"
                                Fill="{StaticResource PrimaryMainBrush}"
                                Opacity="0" />
                            <!--  الإطار الدائري  -->
                            <Ellipse
                                x:Name="OuterRing"
                                Width="24"
                                Height="24"
                                Fill="Transparent"
                                Stroke="{StaticResource BorderDefaultBrush}"
                                StrokeThickness="1.5" />
                            <!--  علامة الصح  -->
                            <materialDesign:PackIcon
                                x:Name="CheckIcon"
                                Width="13"
                                Height="13"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="CheckBold"
                                Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="FillCircle" Property="Opacity" Value="1" />
                                <Setter TargetName="CheckIcon" Property="Opacity" Value="1" />
                                <Setter TargetName="OuterRing" Property="Stroke" Value="{StaticResource PrimaryMainBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterRing" Property="Stroke" Value="{StaticResource PrimaryMainBrush}" />
                                <Setter TargetName="OuterRing" Property="StrokeThickness" Value="2.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <materialDesign:ColorZone
            Padding="24,16"
            materialDesign:ElevationAssist.Elevation="Dp2"
            Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="RadioFm" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="المركز الرئيسي للبث" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Opacity="0.8"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="المحرك الأساسي لإدارة المحتوى، الجدولة، والانتشار الرقمي" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="BtnKeyboardHelp"
                        Width="36"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="BtnKeyboardHelp_Click"
                        Foreground="White"
                        Style="{StaticResource Btn.Icon}"
                        ToolTip="اختصارات لوحة المفاتيح (Ctrl+K)">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Kind="KeyboardOutline" />
                    </Button>
                    <Button
                        x:Name="BtnAddEpisode"
                        Height="45"
                        Padding="24,0"
                        VerticalAlignment="Center"
                        Click="BtnAddEpisode_Click"
                        Content="جدولة حلقة جديدة"
                        Style="{StaticResource Btn.AddNew}" />
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. مركز القيادة الموحّد (بحث + فلاتر + أنماط عرض) ═══════  -->
        <!--  ═══════ 2. شريط التصفية الاحترافي الموحد (Unified Professional Filter Bar) ═══════  -->
        <Border
            Grid.Row="1"
            Margin="24,16"
            Padding="0"
            materialDesign:ElevationAssist.Elevation="Dp1"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  الصف الأساسي: بحث + تحكم  -->
                    <RowDefinition Height="Auto" />
                    <!--  لوحة الفلاتر المتقدمة (قابلة للطي)  -->
                    <RowDefinition Height="Auto" />
                    <!--  شريط الحالات والشرائح النشطة  -->
                </Grid.RowDefinitions>

                <!--  1. الصف الأساسي  -->
                <Border Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  البحث السريع  -->
                        <TextBox
                            x:Name="TxtSearch"
                            Grid.Column="0"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            materialDesign:HintAssist.Hint="البحث عن حلقة، ضيف، أو ملاحظة..."
                            materialDesign:TextFieldAssist.HasClearButton="True"
                            Style="{StaticResource Input.Search}"
                            TextChanged="TxtSearch_TextChanged" />

                        <!--  عداد النتائج الذكي  -->
                        <Border
                            Grid.Column="1"
                            Margin="0,0,12,0"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            Background="{StaticResource PrimaryXLightBrush}"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource PrimaryMainBrush}"
                                    Kind="ListBoxOutline" />
                                <TextBlock
                                    x:Name="TxtResultsCount"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Button}"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource PrimaryMainBrush}"
                                    Text="0 حلقة" />
                            </StackPanel>
                        </Border>

                        <!--  تبديل أنماط العرض  -->
                        <Border
                            Grid.Column="2"
                            Margin="0,0,12,0"
                            Padding="2"
                            VerticalAlignment="Center"
                            Background="{StaticResource SurfaceVariantBrush}"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton
                                    x:Name="ViewCards"
                                    Click="ViewMode_Click"
                                    GroupName="ViewMode"
                                    IsChecked="True"
                                    Style="{StaticResource Btn.Tab}"
                                    ToolTip="عرض البطاقات">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Kind="ViewDashboardOutline" />
                                </RadioButton>
                                <RadioButton
                                    x:Name="ViewTable"
                                    Click="ViewMode_Click"
                                    GroupName="ViewMode"
                                    Style="{StaticResource Btn.Tab}"
                                    ToolTip="عرض الجدول">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Kind="Table" />
                                </RadioButton>
                                <RadioButton
                                    x:Name="ViewCompact"
                                    Click="ViewMode_Click"
                                    GroupName="ViewMode"
                                    Style="{StaticResource Btn.Tab}"
                                    ToolTip="عرض مختصر">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Kind="FormatListBulleted" />
                                </RadioButton>
                            </StackPanel>
                        </Border>

                        <!--  زر الفلاتر المتقدمة (مع Badge)  -->
                        <Grid Grid.Column="3">
                            <ToggleButton
                                x:Name="BtnToggleAdvancedFilters"
                                Height="40"
                                Padding="12,0"
                                Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Kind="FilterVariant" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="{DynamicResource FontSize.Input}"
                                        FontWeight="Medium"
                                        Text="تصفية متقدمة" />
                                </StackPanel>
                            </ToggleButton>

                            <!--  Badge: مؤشر الفلاتر النشطة  -->
                            <Border
                                x:Name="FilterBadge"
                                Width="18"
                                Height="18"
                                Margin="0,-4,-4,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{StaticResource ErrorBrush}"
                                CornerRadius="9"
                                Visibility="Collapsed">
                                <TextBlock
                                    x:Name="TxtFilterCount"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Micro}"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="1" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!--  2. لوحة الفلاتر المتقدمة (تظهر عند التفعيل)  -->
                <Border
                    x:Name="PnlAdvancedFilters"
                    Grid.Row="1"
                    Padding="24,16"
                    Background="{StaticResource SurfaceVariantBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,1"
                    Visibility="{Binding IsChecked, ElementName=BtnToggleAdvancedFilters, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <!--  الصف الأول: ترتيب + برنامج  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Style="{StaticResource Type.Caption}"
                                    Text="الترتيب حسب" />
                                <ComboBox
                                    x:Name="CmbSortBy"
                                    materialDesign:HintAssist.Hint="اختر معيار الترتيب"
                                    SelectionChanged="CmbSortBy_SelectionChanged"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Style="{StaticResource Type.Caption}"
                                    Text="تصفية حسب البرنامج" />
                                <ComboBox
                                    x:Name="CmbProgramFilter"
                                    materialDesign:HintAssist.Hint="كل البرامج"
                                    materialDesign:TextFieldAssist.HasClearButton="True"
                                    SelectionChanged="CmbProgramFilter_SelectionChanged"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            </StackPanel>

                            <Button
                                Grid.Column="2"
                                VerticalAlignment="Bottom"
                                Click="BtnResetFilters_Click"
                                Content="إعادة تعيين"
                                Foreground="{StaticResource ErrorBrush}"
                                Style="{StaticResource Btn.Ghost}" />
                        </Grid>

                        <!--  الصف الثاني: فلتر نطاق التاريخ  -->
                        <Border
                            Margin="0,12,0,0"
                            Padding="16,12"
                            Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource FontSize.Input}"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="فلتر التاريخ:" />

                                <Button
                                    x:Name="BtnToday"
                                    Grid.Column="1"
                                    Height="32"
                                    Margin="12,0,0,0"
                                    Padding="12,0"
                                    Click="QuickDateFilter_Click"
                                    Content="اليوم"
                                    FontSize="{DynamicResource FontSize.Button}"
                                    Style="{StaticResource Btn.Ghost}" />

                                <Button
                                    x:Name="BtnThisWeek"
                                    Grid.Column="2"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    Click="QuickDateFilter_Click"
                                    Content="هذا الأسبوع"
                                    FontSize="{DynamicResource FontSize.Button}"
                                    Style="{StaticResource Btn.Ghost}" />

                                <Button
                                    x:Name="BtnThisMonth"
                                    Grid.Column="3"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    Click="QuickDateFilter_Click"
                                    Content="هذا الشهر"
                                    FontSize="{DynamicResource FontSize.Button}"
                                    Style="{StaticResource Btn.Ghost}" />

                                <Border
                                    Grid.Column="4"
                                    Width="1"
                                    Height="24"
                                    Margin="12,0"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource DividerBrush}" />

                                <ToggleButton
                                    x:Name="BtnCustomRange"
                                    Grid.Column="5"
                                    Height="32"
                                    Padding="12,0"
                                    Checked="BtnCustomRange_Checked"
                                    Content="نطاق مخصّص"
                                    FontSize="{DynamicResource FontSize.Button}"
                                    Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}"
                                    Unchecked="BtnCustomRange_Unchecked" />

                                <StackPanel
                                    x:Name="PnlDateRange"
                                    Grid.Column="6"
                                    Margin="8,0,0,0"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <DatePicker
                                        x:Name="DpDateFrom"
                                        Width="140"
                                        materialDesign:HintAssist.Hint="من تاريخ"
                                        SelectedDateChanged="DpDateFrom_SelectedDateChanged"
                                        Style="{StaticResource Input.DatePicker}" />
                                    <TextBlock
                                        Margin="8,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="←" />
                                    <DatePicker
                                        x:Name="DpDateTo"
                                        Width="140"
                                        materialDesign:HintAssist.Hint="إلى تاريخ"
                                        SelectedDateChanged="DpDateTo_SelectedDateChanged"
                                        Style="{StaticResource Input.DatePicker}" />
                                </StackPanel>

                                <Button
                                    x:Name="BtnClearDateFilter"
                                    Grid.Column="7"
                                    Width="28"
                                    Height="28"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Click="BtnClearDateFilter_Click"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="مسح فلتر التاريخ"
                                    Visibility="Collapsed">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Foreground="{StaticResource ErrorBrush}"
                                        Kind="CloseCircleOutline" />
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!--  3. شريط الحالات والشرائح النشطة  -->
                <Grid Grid.Row="2" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  تبويبات الحالة  -->
                    <Border
                        Margin="16,0"
                        Background="Transparent"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,0,0,1">
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Hidden"
                            PanningMode="HorizontalOnly"
                            VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton
                                    x:Name="FilterAll"
                                    Height="45"
                                    MinWidth="80"
                                    Click="StatusFilter_Click"
                                    GroupName="StatusFilter"
                                    IsChecked="True"
                                    Style="{StaticResource Btn.Tab}">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Kind="AllInclusive" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Input}"
                                                Text="الكل" />
                                        </StackPanel>
                                        <Border
                                            Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource PrimaryMainBrush}"
                                            Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BoolToVisConverter}}" />
                                    </Grid>
                                </RadioButton>
                                <RadioButton
                                    x:Name="FilterPlanned"
                                    Height="45"
                                    MinWidth="100"
                                    Click="StatusFilter_Click"
                                    GroupName="StatusFilter"
                                    Style="{StaticResource Btn.Tab}">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <Border
                                                Width="10"
                                                Height="10"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource WarningBrush}"
                                                CornerRadius="5" />
                                            <TextBlock
                                                x:Name="ChipPlanned"
                                                VerticalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Input}"
                                                Text="مجدولة" />
                                        </StackPanel>
                                        <Border
                                            Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource WarningBrush}"
                                            Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BoolToVisConverter}}" />
                                    </Grid>
                                </RadioButton>
                                <RadioButton
                                    x:Name="FilterExecuted"
                                    Height="45"
                                    MinWidth="100"
                                    Click="StatusFilter_Click"
                                    GroupName="StatusFilter"
                                    Style="{StaticResource Btn.Tab}">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <Border
                                                Width="10"
                                                Height="10"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource SecondaryMainBrush}"
                                                CornerRadius="5" />
                                            <TextBlock
                                                x:Name="ChipExecuted"
                                                VerticalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Input}"
                                                Text="منفّذة" />
                                        </StackPanel>
                                        <Border
                                            Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource SecondaryMainBrush}"
                                            Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BoolToVisConverter}}" />
                                    </Grid>
                                </RadioButton>
                                <RadioButton
                                    x:Name="FilterPublished"
                                    Height="45"
                                    MinWidth="100"
                                    Click="StatusFilter_Click"
                                    GroupName="StatusFilter"
                                    Style="{StaticResource Btn.Tab}">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <Border
                                                Width="10"
                                                Height="10"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource SuccessBrush}"
                                                CornerRadius="5" />
                                            <TextBlock
                                                x:Name="ChipPublished"
                                                VerticalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Input}"
                                                Text="منشورة" />
                                        </StackPanel>
                                        <Border
                                            Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource SuccessBrush}"
                                            Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BoolToVisConverter}}" />
                                    </Grid>
                                </RadioButton>
                                <RadioButton
                                    x:Name="FilterWebPublished"
                                    Height="45"
                                    MinWidth="110"
                                    Click="StatusFilter_Click"
                                    GroupName="StatusFilter"
                                    Style="{StaticResource Btn.Tab}">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Foreground="#2196F3"
                                                Kind="Web" />
                                            <TextBlock
                                                x:Name="ChipWebPublished"
                                                VerticalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Input}"
                                                Text="الموقع" />
                                        </StackPanel>
                                        <Border
                                            Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="#2196F3"
                                            Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BoolToVisConverter}}" />
                                    </Grid>
                                </RadioButton>
                                <RadioButton
                                    x:Name="FilterCancelled"
                                    Height="45"
                                    MinWidth="100"
                                    Click="StatusFilter_Click"
                                    GroupName="StatusFilter"
                                    Style="{StaticResource Btn.Tab}">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource ErrorBrush}"
                                                Kind="CloseCircleOutline" />
                                            <TextBlock
                                                x:Name="ChipCancelled"
                                                VerticalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Input}"
                                                Text="ملغاة" />
                                        </StackPanel>
                                        <Border
                                            Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource ErrorBrush}"
                                            Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BoolToVisConverter}}" />
                                    </Grid>
                                </RadioButton>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!--  منطقة الشرائح النشطة (Filter Chips)  -->
                    <StackPanel
                        x:Name="PnlActiveChips"
                        Grid.Row="1"
                        Margin="16,8"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource FontSize.Button}"
                            Foreground="{StaticResource TextHintBrush}"
                            Text="الفلاتر النشطة:" />
                        <ItemsControl x:Name="ItemsActiveChips">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Chip
                                        Margin="0,0,8,0"
                                        Content="{Binding Label}"
                                        DeleteClick="Chip_DeleteClick"
                                        IsDeletable="True" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!--  ═══════ 4. منطقة المحتوى — ثلاثة أنماط عرض + شريط العمليات المجمعة ═══════  -->
        <Grid Grid.Row="2" Margin="24,0,24,24">

            <!--
                ═══════════════════════════════════════════════════════════
                4-أ: عرض البطاقات (Cards) — الافتراضي
                ═══════════════════════════════════════════════════════════
            -->
            <ListBox
                x:Name="CardsView"
                Background="Transparent"
                BorderThickness="0"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                Style="{StaticResource MaterialDesignListBox}">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="0,0,-12,0" IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,12,12" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!--
                            ═══════════════════════════════════════════════════════════
                            بطاقة حلقة - تصميم متجاوب ومضغوط وعالي التفاصيل وغاية في الإبداع
                            ═══════════════════════════════════════════════════════════
                        -->
                        <materialDesign:Card
                            Width="330"
                            Padding="0"
                            materialDesign:ElevationAssist.Elevation="Dp1"
                            Background="{StaticResource SurfaceBrush}"
                            UniformCornerRadius="12">
                            <materialDesign:Card.Style>
                                <Style TargetType="materialDesign:Card">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryMainBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:Card.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <!--  المحتوى الرئيسي  -->
                                    <ColumnDefinition Width="5" />
                                    <!--  شريط الحالة الجانبي الملون  -->
                                </Grid.ColumnDefinitions>

                                <!--  ═══ شريط الحالة الجانبي الملون ═══  -->
                                <Border Grid.Column="1" CornerRadius="0,12,12,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                    <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                    <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!--  ═══ المحتوى الرئيسي ═══  -->
                                <Grid Grid.Column="0" Margin="14,12,12,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <!--  الصف 0: شريحة الحالة + البرنامج + CheckBox  -->
                                        <RowDefinition Height="Auto" />
                                        <!--  الصف 1: اسم الحلقة  -->
                                        <RowDefinition Height="Auto" />
                                        <!--  الصف 2: التاريخ والوقت  -->
                                        <RowDefinition Height="Auto" />
                                        <!--  الصف 3: تفاصيل الضيوف وفريق العمل والمراسلين  -->
                                        <RowDefinition Height="Auto" />
                                        <!--  الصف 4: ملاحظات خاصة  -->
                                        <RowDefinition Height="Auto" />
                                        <!--  الصف 5: سبب الإلغاء  -->
                                        <RowDefinition Height="Auto" />
                                        <!--  الصف 6: شريط الإجراءات والعمليات  -->
                                    </Grid.RowDefinitions>

                                    <!--  ═══ الصف 0: شريحة البرنامج + شريحة الحالة + CheckBox ═══  -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  وسم البرنامج  -->
                                        <Border
                                            Padding="8,4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="6">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="13"
                                                    Height="13"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource SecondaryMainBrush}"
                                                    Kind="RadioFm" />
                                                <TextBlock
                                                    MaxWidth="110"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource PrimaryMainBrush}"
                                                    Style="{StaticResource Type.Caption}"
                                                    Text="{Binding ProgramName}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>

                                        <!--  شريحة الحالة المبتكرة بلمسة إبداعية  -->
                                        <Border
                                            Grid.Column="1"
                                            Margin="6,0"
                                            Padding="8,3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#15FFA726" />
                                                    <!--  مجدولة  -->
                                                    <Setter Property="BorderBrush" Value="#40FFA726" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                            <Setter Property="Background" Value="#1526A69A" />
                                                            <Setter Property="BorderBrush" Value="#4026A69A" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                            <Setter Property="Background" Value="#1566BB6A" />
                                                            <Setter Property="BorderBrush" Value="#4066BB6A" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                            <Setter Property="Background" Value="#1529B6F6" />
                                                            <Setter Property="BorderBrush" Value="#4029B6F6" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                            <Setter Property="Background" Value="#15EF5350" />
                                                            <Setter Property="BorderBrush" Value="#40EF5350" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse
                                                    Width="6"
                                                    Height="6"
                                                    Margin="0,0,5,0"
                                                    VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#FFA726" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                                    <Setter Property="Fill" Value="#26A69A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                                    <Setter Property="Fill" Value="#66BB6A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                                    <Setter Property="Fill" Value="#29B6F6" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                                    <Setter Property="Fill" Value="#EF5350" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#E65100" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                                    <Setter Property="Foreground" Value="#004D40" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                                    <Setter Property="Foreground" Value="#1B5E20" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                                    <Setter Property="Foreground" Value="#01579B" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                                    <Setter Property="Foreground" Value="#B71C1C" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding StatusText, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!--  CheckBox التحديد المتعدد  -->
                                        <CheckBox
                                            Grid.Column="2"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Checked="ItemCheckBox_CheckedChanged"
                                            IsChecked="{Binding IsSelected}"
                                            Style="{StaticResource Card.CheckBox}"
                                            ToolTip="تحديد للإجراءات المجمعة"
                                            Unchecked="ItemCheckBox_CheckedChanged" />
                                    </Grid>

                                    <!--  ═══ الصف 1: اسم الحلقة (بسيط ومحدود بحد أقصى سطرين) ═══  -->
                                    <TextBlock
                                        Grid.Row="1"
                                        MaxHeight="42"
                                        Margin="0,0,0,8"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Style="{StaticResource Type.TitleMedium}"
                                        Text="{Binding EpisodeName}"
                                        TextTrimming="WordEllipsis"
                                        TextWrapping="Wrap" />

                                    <!--  ═══ الصف 2: التاريخ والوقت مدمجين أفقياً ═══  -->
                                    <Grid Grid.Row="2" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <!--  التاريخ  -->
                                            <materialDesign:PackIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextHintBrush}"
                                                Kind="CalendarMonthOutline" />
                                            <TextBlock
                                                Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                FontWeight="Medium"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd', ConverterCulture='en-US'}" />

                                            <!--  فاصل  -->
                                            <TextBlock
                                                Margin="8,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource DividerBrush}"
                                                Text="|" />

                                            <!--  الوقت  -->
                                            <materialDesign:PackIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource SecondaryMainBrush}"
                                                Kind="ClockOutline" />
                                            <TextBlock
                                                Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                FontWeight="Medium"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}" />
                                        </StackPanel>
                                    </Grid>

                                    <!--  ═══ الصف 3: تفاصيل الضيوف وفريق العمل والمراسلين بلمسة إبداعية (Pills/Tags) ═══  -->
                                    <StackPanel Grid.Row="3" Margin="0,0,0,4">
                                        <!--  الضيوف  -->
                                        <ItemsControl Margin="0,2" ItemsSource="{Binding GuestItems}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Style.Triggers>
                                                        <Trigger Property="HasItems" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,2,4,2"
                                                        Padding="6,2"
                                                        Background="#10673AB7"
                                                        BorderBrush="#25673AB7"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        ToolTip="ضيف حلقة">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon
                                                                Width="12"
                                                                Height="12"
                                                                Margin="0,0,4,0"
                                                                VerticalAlignment="Center"
                                                                Foreground="#673AB7"
                                                                Kind="Account" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="#673AB7"
                                                                Style="{StaticResource Type.Caption}">
                                                                <Run Text="{Binding Name, Mode=OneWay}" />
                                                                <Run Text="{Binding Topic, StringFormat=' ({0})', Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!--  المراسلون  -->
                                        <ItemsControl Margin="0,2" ItemsSource="{Binding CorrespondentItems}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Style.Triggers>
                                                        <Trigger Property="HasItems" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,2,4,2"
                                                        Padding="6,2"
                                                        Background="#1000BCD4"
                                                        BorderBrush="#2500BCD4"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        ToolTip="مراسل">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon
                                                                Width="12"
                                                                Height="12"
                                                                Margin="0,0,4,0"
                                                                VerticalAlignment="Center"
                                                                Foreground="#0097A7"
                                                                Kind="Microphone" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="#00838F"
                                                                Style="{StaticResource Type.Caption}">
                                                                <Run Text="{Binding FullName, Mode=OneWay}" />
                                                                <Run Text="{Binding Topic, StringFormat=' ({0})', Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!--  فريق العمل  -->
                                        <ItemsControl Margin="0,2" ItemsSource="{Binding EmployeeItems}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Style.Triggers>
                                                        <Trigger Property="HasItems" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,2,4,2"
                                                        Padding="6,2"
                                                        Background="#10607D8B"
                                                        BorderBrush="#25607D8B"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        ToolTip="فريق العمل">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon
                                                                Width="12"
                                                                Height="12"
                                                                Margin="0,0,4,0"
                                                                VerticalAlignment="Center"
                                                                Foreground="#607D8B"
                                                                Kind="AccountOutline" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="#37474F"
                                                                Style="{StaticResource Type.Caption}">
                                                                <Run Text="{Binding FullName, Mode=OneWay}" />
                                                                <Run Text="{Binding StaffRoleName, StringFormat=' ({0})', Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!--  ═══ الصف 4: ملاحظات خاصة (تظهر مباشرة داخل صندوق أصفر ناعم شبه ورقة الملاحظات) ═══  -->
                                    <Border
                                        Grid.Row="4"
                                        Margin="0,4,0,0"
                                        Padding="10,8"
                                        Background="#FFFDE7"
                                        BorderBrush="#FFE082"
                                        BorderThickness="1,1,4,1"
                                        CornerRadius="6"
                                        Visibility="{Binding SpecialNotes, Converter={StaticResource NullToCollapsedConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon
                                                Grid.Column="0"
                                                Width="14"
                                                Height="14"
                                                Margin="0,1,6,0"
                                                VerticalAlignment="Top"
                                                Foreground="#F57F17"
                                                Kind="NoteOutline" />
                                            <TextBlock
                                                Grid.Column="1"
                                                MaxHeight="45"
                                                VerticalAlignment="Center"
                                                Foreground="#5D4037"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding SpecialNotes}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <!--  ═══ الصف 5: سبب الإلغاء (يظهر للحلقات الملغاة فقط) ═══  -->
                                    <Border
                                        Grid.Row="5"
                                        Margin="0,4,0,0"
                                        Padding="10,8"
                                        Background="{StaticResource ErrorLightBrush}"
                                        BorderBrush="{StaticResource ErrorBrush}"
                                        BorderThickness="1,1,4,1"
                                        CornerRadius="6"
                                        Visibility="{Binding CancellationReason, Converter={StaticResource NullToCollapsedConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon
                                                Grid.Column="0"
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource ErrorBrush}"
                                                Kind="CloseCircleOutline" />
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                TextTrimming="CharacterEllipsis">
                                                <Run
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource ErrorBrush}"
                                                    Text="سبب الإلغاء: " />
                                                <Run Text="{Binding CancellationReason}" />
                                            </TextBlock>
                                            <Button
                                                Grid.Column="2"
                                                Width="22"
                                                Height="22"
                                                Padding="2"
                                                Click="BtnEditCancellationReason_Click"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="تعديل سبب الإلغاء">
                                                <materialDesign:PackIcon
                                                    Width="12"
                                                    Height="12"
                                                    Foreground="{StaticResource ErrorBrush}"
                                                    Kind="PencilOutline" />
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!--  ═══ الصف 6: شريط الإجراءات والعمليات ═══  -->
                                    <Border
                                        Grid.Row="6"
                                        Margin="0,10,0,0"
                                        Padding="0,8,0,0"
                                        BorderBrush="{StaticResource DividerBrush}"
                                        BorderThickness="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!--  الإجراءات الأساسية  -->
                                            <StackPanel
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <Button
                                                    Height="30"
                                                    Padding="10,0"
                                                    Background="{StaticResource HeaderGradientBrush}"
                                                    Click="BtnMarkExecuted_Click"
                                                    Style="{StaticResource Btn.Primary}"
                                                    ToolTip="تنفيذ الحلقة"
                                                    Visibility="{Binding CanMarkExecuted, Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Width="14"
                                                            Height="14"
                                                            Margin="0,0,4,0"
                                                            VerticalAlignment="Center"
                                                            Kind="PlayCircleOutline" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            Text="تنفيذ" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    Height="30"
                                                    Margin="4,0,0,0"
                                                    Padding="10,0"
                                                    Click="BtnMarkPublished_Click"
                                                    Style="{StaticResource Btn.Secondary}"
                                                    ToolTip="نشر رقمي"
                                                    Visibility="{Binding CanMarkPublished, Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Width="14"
                                                            Height="14"
                                                            Margin="0,0,4,0"
                                                            VerticalAlignment="Center"
                                                            Kind="CloudUploadOutline" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            Text="نشر" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    Width="30"
                                                    Height="30"
                                                    Margin="4,0,0,0"
                                                    Padding="0"
                                                    Background="{StaticResource InfoGradientBrush}"
                                                    Click="BtnToggleWebsitePublish_Click"
                                                    Style="{StaticResource Btn.Primary}"
                                                    ToolTip="نشر على الموقع"
                                                    Visibility="{Binding CanToggleWebsitePublish, Converter={StaticResource BoolToVisConverter}}">
                                                    <materialDesign:PackIcon
                                                        Width="14"
                                                        Height="14"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Kind="Web" />
                                                </Button>
                                            </StackPanel>

                                            <!--  قائمة الإجراءات الإضافية الحديثة  -->
                                            <!--  قائمة الإجراءات الإضافية الحديثة  -->
                                            <materialDesign:PopupBox
                                                Grid.Column="1"
                                                Width="34"
                                                Height="34"
                                                Margin="0"
                                                VerticalAlignment="Center"
                                                PlacementMode="BottomAndAlignRightEdges"
                                                ToolTip="المزيد من الإجراءات">

                                                <materialDesign:PopupBox.ToggleContent>
                                                    <Border
                                                        Width="34"
                                                        Height="34"
                                                        Background="Transparent"
                                                        CornerRadius="17">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <materialDesign:PackIcon
                                                            Width="20"
                                                            Height="20"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Cursor="Hand"
                                                            Foreground="{StaticResource TextSecondaryBrush}"
                                                            Kind="DotsVertical" />
                                                    </Border>
                                                </materialDesign:PopupBox.ToggleContent>

                                                <!--  القائمة المنبثقة  -->
                                                <Border
                                                    Width="240"
                                                    Padding="8"
                                                    Background="{StaticResource SurfaceBrush}"
                                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="16"
                                                    FlowDirection="RightToLeft">
                                                    <StackPanel>

                                                        <!--
                                                            ───────────────────────────────
                                                            Header القائمة
                                                            ───────────────────────────────
                                                        -->
                                                        <Border
                                                            Height="44"
                                                            Margin="0,0,0,8"
                                                            Padding="4,0"
                                                            Background="{StaticResource HeaderGradientBrush}"
                                                            CornerRadius="10">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border
                                                                    Grid.Column="0"
                                                                    Width="32"
                                                                    Height="32"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center">
                                                                    <materialDesign:PackIcon
                                                                        Width="16"
                                                                        Height="16"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="White"
                                                                        Kind="TuneVertical" />
                                                                </Border>

                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Margin="0,0,4,0"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="12"
                                                                    FontWeight="Bold"
                                                                    Foreground="White"
                                                                    Text="إجراءات الحلقة" />
                                                            </Grid>
                                                        </Border>

                                                        <!--
                                                            ───────────────────────────────
                                                            عرض السجلات
                                                            ───────────────────────────────
                                                        -->
                                                        <Button
                                                            Height="44"
                                                            Margin="0,2"
                                                            Padding="4,0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Click="BtnViewRecords_Click"
                                                            Style="{StaticResource Btn.Ghost}"
                                                            Visibility="{Binding CanViewRecords, Converter={StaticResource BoolToVisConverter}}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border
                                                                    Grid.Column="0"
                                                                    Width="32"
                                                                    Height="32"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="{StaticResource PrimaryXLightBrush}"
                                                                    CornerRadius="8">
                                                                    <materialDesign:PackIcon
                                                                        Width="16"
                                                                        Height="16"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="{StaticResource PrimaryMainBrush}"
                                                                        Kind="History" />
                                                                </Border>

                                                                <StackPanel
                                                                    Grid.Column="1"
                                                                    Margin="0,0,4,0"
                                                                    VerticalAlignment="Center">
                                                                    <TextBlock
                                                                        FontSize="12"
                                                                        FontWeight="Medium"
                                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                                        Text="عرض السجلات" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="10"
                                                                        Foreground="{StaticResource TextHintBrush}"
                                                                        Text="سجل تعديلات الحلقة" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>

                                                        <!--
                                                            ───────────────────────────────
                                                            تراجع عن الإجراء
                                                            ───────────────────────────────
                                                        -->
                                                        <Button
                                                            Height="44"
                                                            Margin="0,2"
                                                            Padding="4,0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Click="BtnRevert_Click"
                                                            Style="{StaticResource Btn.Ghost}"
                                                            Visibility="{Binding CanRevert, Converter={StaticResource BoolToVisConverter}}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border
                                                                    Grid.Column="0"
                                                                    Width="32"
                                                                    Height="32"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="#FFFEF3E0"
                                                                    CornerRadius="8">
                                                                    <materialDesign:PackIcon
                                                                        Width="16"
                                                                        Height="16"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="#FFF57C00"
                                                                        Kind="Undo" />
                                                                </Border>

                                                                <StackPanel
                                                                    Grid.Column="1"
                                                                    Margin="0,0,4,0"
                                                                    VerticalAlignment="Center">
                                                                    <TextBlock
                                                                        FontSize="12"
                                                                        FontWeight="Medium"
                                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                                        Text="تراجع عن الإجراء" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="10"
                                                                        Foreground="{StaticResource TextHintBrush}"
                                                                        Text="إلغاء آخر تعديل" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>

                                                        <!--
                                                            ───────────────────────────────
                                                            إلغاء الحلقة
                                                            ───────────────────────────────
                                                        -->
                                                        <Button
                                                            Height="44"
                                                            Margin="0,2"
                                                            Padding="4,0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Click="BtnCancelEpisode_Click"
                                                            Style="{StaticResource Btn.Ghost}"
                                                            Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisConverter}}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border
                                                                    Grid.Column="0"
                                                                    Width="32"
                                                                    Height="32"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="{StaticResource ErrorLightBrush}"
                                                                    CornerRadius="8">
                                                                    <materialDesign:PackIcon
                                                                        Width="16"
                                                                        Height="16"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="{StaticResource ErrorBrush}"
                                                                        Kind="CloseCircleOutline" />
                                                                </Border>

                                                                <StackPanel
                                                                    Grid.Column="1"
                                                                    Margin="0,0,4,0"
                                                                    VerticalAlignment="Center">
                                                                    <TextBlock
                                                                        FontSize="12"
                                                                        FontWeight="Medium"
                                                                        Foreground="{StaticResource ErrorBrush}"
                                                                        Text="إلغاء الحلقة" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="10"
                                                                        Foreground="{StaticResource TextHintBrush}"
                                                                        Text="إلغاء الحلقة الحالية" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>

                                                        <!--  الفاصل  -->
                                                        <Border
                                                            Height="1"
                                                            Margin="8,8"
                                                            Background="{StaticResource DividerBrush}"
                                                            Opacity="0.5" />

                                                        <!--
                                                            ───────────────────────────────
                                                            تعديل
                                                            ───────────────────────────────
                                                        -->
                                                        <Button
                                                            Height="44"
                                                            Margin="0,2"
                                                            Padding="4,0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Click="BtnEdit_Click"
                                                            Style="{StaticResource Btn.Ghost}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border
                                                                    Grid.Column="0"
                                                                    Width="32"
                                                                    Height="32"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="#FFE3F2FD"
                                                                    CornerRadius="8">
                                                                    <materialDesign:PackIcon
                                                                        Width="16"
                                                                        Height="16"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="#FF1976D2"
                                                                        Kind="PencilOutline" />
                                                                </Border>

                                                                <StackPanel
                                                                    Grid.Column="1"
                                                                    Margin="0,0,4,0"
                                                                    VerticalAlignment="Center">
                                                                    <TextBlock
                                                                        FontSize="12"
                                                                        FontWeight="Medium"
                                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                                        Text="تعديل" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="10"
                                                                        Foreground="{StaticResource TextHintBrush}"
                                                                        Text="تعديل بيانات الحلقة" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>

                                                        <!--
                                                            ───────────────────────────────
                                                            حذف
                                                            ───────────────────────────────
                                                        -->
                                                        <Button
                                                            Height="44"
                                                            Margin="0,2"
                                                            Padding="4,0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Click="BtnDelete_Click"
                                                            Style="{StaticResource Btn.Ghost}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border
                                                                    Grid.Column="0"
                                                                    Width="32"
                                                                    Height="32"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="{StaticResource ErrorLightBrush}"
                                                                    CornerRadius="8">
                                                                    <materialDesign:PackIcon
                                                                        Width="16"
                                                                        Height="16"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="{StaticResource ErrorBrush}"
                                                                        Kind="DeleteOutline" />
                                                                </Border>

                                                                <StackPanel
                                                                    Grid.Column="1"
                                                                    Margin="0,0,4,0"
                                                                    VerticalAlignment="Center">
                                                                    <TextBlock
                                                                        FontSize="12"
                                                                        FontWeight="Medium"
                                                                        Foreground="{StaticResource ErrorBrush}"
                                                                        Text="حذف" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="10"
                                                                        Foreground="{StaticResource TextHintBrush}"
                                                                        Text="حذف الحلقة بشكل نهائي" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>

                                                    </StackPanel>
                                                </Border>
                                            </materialDesign:PopupBox>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--
                ═══════════════════════════════════════════════════════════
                4-ب: عرض الجدول (DataGrid)
                ═══════════════════════════════════════════════════════════
            -->
            <DataGrid
                x:Name="TableView"
                materialDesign:ElevationAssist.Elevation="Dp1"
                AutoGenerateColumns="False"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                HeadersVisibility="Column"
                IsReadOnly="True"
                RowDetailsVisibilityMode="Collapsed"
                SelectionMode="Single"
                Style="{StaticResource MaterialDesignDataGrid}"
                Visibility="Collapsed">

                <DataGrid.Columns>
                    <!--  عمود التحديد المتعدد  -->
                    <DataGridTemplateColumn
                        Width="36"
                        CanUserReorder="False"
                        CanUserSort="False"
                        HeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox
                                    x:Name="SelectAllCheckbox"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Checked="SelectAllCheckbox_Checked"
                                    Style="{StaticResource MaterialDesignCheckBox}"
                                    Unchecked="SelectAllCheckbox_Unchecked" />
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Checked="ItemCheckBox_CheckedChanged"
                                    IsChecked="{Binding IsSelected}"
                                    Style="{StaticResource MaterialDesignCheckBox}"
                                    Unchecked="ItemCheckBox_CheckedChanged" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  شريط الحالة  -->
                    <DataGridTemplateColumn
                        Width="12"
                        CanUserReorder="False"
                        CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="8" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                    <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                    <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  اسم الحلقة  -->
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding EpisodeName}"
                        Header="اسم الحلقة"
                        SortDirection="Ascending" />

                    <!--  البرنامج  -->

                    <DataGridTextColumn
                        Width="1.5*"
                        Binding="{Binding ProgramName}"
                        Header="البرنامج" />

                    <!--  تاريخ التنفيذ  -->
                    <DataGridTemplateColumn
                        Width="1.2*"
                        Header="تاريخ التنفيذ"
                        SortMemberPath="ScheduledExecutionTime">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd'}" />
                                    <Border
                                        Margin="8,0,0,0"
                                        Padding="6,2"
                                        Background="{StaticResource SurfaceVariantBrush}"
                                        CornerRadius="4">
                                        <TextBlock
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  الحالة  -->
                    <DataGridTemplateColumn
                        Width="1.2*"
                        Header="الحالة"
                        SortMemberPath="StatusId">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style BasedOn="{StaticResource StatusChip.Base}" TargetType="Border">
                                            <Setter Property="Height" Value="24" />
                                            <Setter Property="CornerRadius" Value="12" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                    <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                    <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                    <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon
                                            Grid.Column="0"
                                            Width="16"
                                            Height="16"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Foreground="White">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="CalendarClock" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                            <Setter Property="Kind" Value="CheckCircleOutline" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                            <Setter Property="Kind" Value="CloudCheckOutline" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                            <Setter Property="Kind" Value="Web" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                            <Setter Property="Kind" Value="CloseCircleOutline" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            FontWeight="Medium"
                                            Foreground="White"
                                            Text="{Binding StatusText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  الضيوف  -->
                    <DataGridTemplateColumn
                        Width="1*"
                        CanUserSort="False"
                        Header="الضيوف">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,4,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextHintBrush}"
                                        Kind="AccountGroupOutline" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding GuestItems.Count}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  الإجراءات  -->
                    <DataGridTemplateColumn
                        Width="1.5*"
                        CanUserReorder="False"
                        CanUserSort="False"
                        Header="الإجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel
                                    x:Name="ActionsPanel"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Visibility="Hidden">
                                    <Button
                                        Height="28"
                                        Padding="10,0"
                                        Background="{StaticResource HeaderGradientBrush}"
                                        Click="BtnMarkExecuted_Click"
                                        FontSize="{DynamicResource FontSize.Button}"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="تنفيذ"
                                        Visibility="{Binding CanMarkExecuted, Converter={StaticResource BoolToVisConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                Kind="PlayCircleOutline" />
                                            <TextBlock VerticalAlignment="Center" Text="تنفيذ" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Height="28"
                                        Margin="4,0,0,0"
                                        Padding="10,0"
                                        Background="{StaticResource SuccessBrush}"
                                        Click="BtnMarkPublished_Click"
                                        FontSize="{DynamicResource FontSize.Button}"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="نشر رقمي"
                                        Visibility="{Binding CanMarkPublished, Converter={StaticResource BoolToVisConverter}}">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            VerticalAlignment="Center"
                                            Kind="CloudUploadOutline" />
                                    </Button>
                                    <Button
                                        Height="28"
                                        Margin="4,0,0,0"
                                        Padding="10,0"
                                        Background="{StaticResource InfoGradientBrush}"
                                        Click="BtnToggleWebsitePublish_Click"
                                        FontSize="{DynamicResource FontSize.Button}"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="نشر موقع"
                                        Visibility="{Binding CanToggleWebsitePublish, Converter={StaticResource BoolToVisConverter}}">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            VerticalAlignment="Center"
                                            Kind="Web" />
                                    </Button>
                                    <materialDesign:PopupBox Margin="4,0,0,0" PlacementMode="BottomAndAlignRightEdges">
                                        <materialDesign:PopupBox.ToggleContent>
                                            <materialDesign:PackIcon
                                                Width="24"
                                                Height="24"
                                                Cursor="Hand"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="DotsVertical" />
                                        </materialDesign:PopupBox.ToggleContent>
                                        <StackPanel Width="200" Margin="8">
                                            <TextBlock
                                                Margin="0,4,0,12"
                                                HorizontalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Button}"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource PrimaryMainBrush}"
                                                Text="خيارات الحلقة" />

                                            <Button
                                                Margin="0,2"
                                                Click="BtnViewRecords_Click"
                                                Style="{StaticResource Btn.Ghost}"
                                                Visibility="{Binding CanViewRecords, Converter={StaticResource BoolToVisConverter}}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Kind="History" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="عرض السجلات" />
                                                </Grid>
                                            </Button>

                                            <Button
                                                Margin="0,2"
                                                Click="BtnRevert_Click"
                                                Style="{StaticResource Btn.Ghost}"
                                                Visibility="{Binding CanRevert, Converter={StaticResource BoolToVisConverter}}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Kind="Undo" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="تراجع عن الإجراء" />
                                                </Grid>
                                            </Button>

                                            <Button
                                                Margin="0,2"
                                                Click="BtnCancelEpisode_Click"
                                                Style="{StaticResource Btn.Ghost}"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisConverter}}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ErrorBrush}"
                                                        Kind="CloseCircleOutline" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="إلغاء الحلقة" />
                                                </Grid>
                                            </Button>

                                            <Separator Margin="4,8" Background="{StaticResource DividerBrush}" />

                                            <Button
                                                Margin="0,2"
                                                Click="BtnEdit_Click"
                                                Style="{StaticResource Btn.Ghost}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Kind="PencilOutline" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="تعديل" />
                                                </Grid>
                                            </Button>

                                            <Button
                                                Margin="0,2"
                                                Click="BtnDelete_Click"
                                                Style="{StaticResource Btn.Ghost}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ErrorBrush}"
                                                        Kind="DeleteOutline" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ErrorBrush}"
                                                        Text="حذف" />
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </materialDesign:PopupBox>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="ActionsPanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!--
                ═══════════════════════════════════════════════════════════
                4-ج: العرض المختصر (Compact)
                ═══════════════════════════════════════════════════════════
            -->
            <ListBox
                x:Name="CompactView"
                Background="Transparent"
                BorderThickness="0"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                Style="{StaticResource MaterialDesignListBox}"
                Visibility="Collapsed">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="16,10"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="0,0,0,1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceVariantBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <!--  checkbox  -->
                                    <ColumnDefinition Width="8" />
                                    <!--  status dot  -->
                                    <ColumnDefinition Width="2*" />
                                    <!--  name  -->
                                    <ColumnDefinition Width="1.5*" />
                                    <!--  program  -->
                                    <ColumnDefinition Width="1.2*" />
                                    <!--  date  -->
                                    <ColumnDefinition Width="1.2*" />
                                    <!--  status chip  -->
                                    <ColumnDefinition Width="0.8*" />
                                    <!--  guests  -->
                                    <ColumnDefinition Width="1.5*" />
                                    <!--  actions  -->
                                </Grid.ColumnDefinitions>

                                <!--  CheckBox التحديد المتعدد  -->
                                <CheckBox
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Checked="ItemCheckBox_CheckedChanged"
                                    IsChecked="{Binding IsSelected}"
                                    Style="{StaticResource MaterialDesignCheckBox}"
                                    Unchecked="ItemCheckBox_CheckedChanged" />

                                <!--  نقطة الحالة  -->
                                <Border
                                    Width="8"
                                    Height="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                    <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                    <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!--  اسم الحلقة  -->
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource Type.BodyMedium}"
                                    Text="{Binding EpisodeName}"
                                    TextTrimming="CharacterEllipsis" />

                                <!--  البرنامج  -->
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.Caption}"
                                    Text="{Binding ProgramName}"
                                    TextTrimming="CharacterEllipsis" />

                                <!--  التاريخ  -->
                                <StackPanel
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Style="{StaticResource Type.Caption}"
                                        Text="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd'}" />
                                    <TextBlock
                                        Margin="6,0,0,0"
                                        Foreground="{StaticResource TextHintBrush}"
                                        Style="{StaticResource Type.Caption}"
                                        Text="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}" />
                                </StackPanel>

                                <!--  شريحة الحالة  -->
                                <Border
                                    Grid.Column="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style BasedOn="{StaticResource StatusChip.Base}" TargetType="Border">
                                            <Setter Property="Height" Value="22" />
                                            <Setter Property="CornerRadius" Value="11" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                    <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                    <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                    <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon
                                            Grid.Column="0"
                                            Width="16"
                                            Height="16"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Foreground="White">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="CalendarClock" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                            <Setter Property="Kind" Value="CheckCircleOutline" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                            <Setter Property="Kind" Value="CloudCheckOutline" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                            <Setter Property="Kind" Value="Web" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                            <Setter Property="Kind" Value="CloseCircleOutline" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            FontWeight="Medium"
                                            Foreground="White"
                                            Text="{Binding StatusText}" />
                                    </Grid>
                                </Border>

                                <!--  عدد الضيوف  -->
                                <StackPanel
                                    Grid.Column="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,4,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextHintBrush}"
                                        Kind="AccountGroupOutline" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{DynamicResource FontSize.Button}"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding GuestItems.Count}" />
                                </StackPanel>

                                <!--  الإجراءات المختصرة  -->
                                <StackPanel
                                    Grid.Column="6"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        Height="26"
                                        Padding="8,0"
                                        Background="{StaticResource HeaderGradientBrush}"
                                        Click="BtnMarkExecuted_Click"
                                        FontSize="{DynamicResource FontSize.Overline}"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="تنفيذ"
                                        Visibility="{Binding CanMarkExecuted, Converter={StaticResource BoolToVisConverter}}">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Kind="PlayCircleOutline" />
                                    </Button>
                                    <Button
                                        Height="26"
                                        Margin="4,0,0,0"
                                        Padding="8,0"
                                        Background="{StaticResource SuccessBrush}"
                                        Click="BtnMarkPublished_Click"
                                        FontSize="{DynamicResource FontSize.Overline}"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="نشر رقمي"
                                        Visibility="{Binding CanMarkPublished, Converter={StaticResource BoolToVisConverter}}">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Kind="CloudUploadOutline" />
                                    </Button>
                                    <Button
                                        Height="26"
                                        Margin="4,0,0,0"
                                        Padding="8,0"
                                        Background="{StaticResource InfoGradientBrush}"
                                        Click="BtnToggleWebsitePublish_Click"
                                        FontSize="{DynamicResource FontSize.Overline}"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="نشر موقع"
                                        Visibility="{Binding CanToggleWebsitePublish, Converter={StaticResource BoolToVisConverter}}">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Kind="Web" />
                                    </Button>
                                    <materialDesign:PopupBox Margin="4,0,0,0" PlacementMode="BottomAndAlignRightEdges">
                                        <materialDesign:PopupBox.ToggleContent>
                                            <materialDesign:PackIcon
                                                Width="24"
                                                Height="24"
                                                Cursor="Hand"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="DotsVertical" />
                                        </materialDesign:PopupBox.ToggleContent>
                                        <StackPanel Width="200" Margin="8">
                                            <TextBlock
                                                Margin="0,4,0,12"
                                                HorizontalAlignment="Center"
                                                FontSize="{DynamicResource FontSize.Button}"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource PrimaryMainBrush}"
                                                Text="خيارات الحلقة" />

                                            <Button
                                                Margin="0,2"
                                                Click="BtnViewRecords_Click"
                                                Style="{StaticResource Btn.Ghost}"
                                                Visibility="{Binding CanViewRecords, Converter={StaticResource BoolToVisConverter}}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Kind="History" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="عرض السجلات" />
                                                </Grid>
                                            </Button>

                                            <Button
                                                Margin="0,2"
                                                Click="BtnRevert_Click"
                                                Style="{StaticResource Btn.Ghost}"
                                                Visibility="{Binding CanRevert, Converter={StaticResource BoolToVisConverter}}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Kind="Undo" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="تراجع عن الإجراء" />
                                                </Grid>
                                            </Button>

                                            <Button
                                                Margin="0,2"
                                                Click="BtnCancelEpisode_Click"
                                                Style="{StaticResource Btn.Ghost}"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisConverter}}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ErrorBrush}"
                                                        Kind="CloseCircleOutline" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="إلغاء الحلقة" />
                                                </Grid>
                                            </Button>

                                            <Separator Margin="4,8" Background="{StaticResource DividerBrush}" />

                                            <Button
                                                Margin="0,2"
                                                Click="BtnEdit_Click"
                                                Style="{StaticResource Btn.Ghost}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Kind="PencilOutline" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="تعديل" />
                                                </Grid>
                                            </Button>

                                            <Button
                                                Margin="0,2"
                                                Click="BtnDelete_Click"
                                                Style="{StaticResource Btn.Ghost}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <materialDesign:PackIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ErrorBrush}"
                                                        Kind="DeleteOutline" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ErrorBrush}"
                                                        Text="حذف" />
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </materialDesign:PopupBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--  شريط العمليات المجمعة (Batch Action Bar)  -->
            <Border
                x:Name="BatchActionBar"
                Height="56"
                Padding="16,0"
                VerticalAlignment="Bottom"
                Panel.ZIndex="20"
                Background="{StaticResource PrimaryDarkBrush}"
                CornerRadius="12,12,0,0"
                Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            x:Name="TxtSelectedCount"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource FontSize.Label}"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="0 محددة" />
                        <Button
                            Margin="12,0,0,0"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Click="BtnDeselectAll_Click"
                            Content="إلغاء التحديد"
                            FontSize="{DynamicResource FontSize.Overline}"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Style="{StaticResource MaterialDesignFlatButton}" />
                    </StackPanel>

                    <Button
                        x:Name="BtnBatchExecuted"
                        Grid.Column="2"
                        Height="36"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Click="BtnBatchExecuted_Click"
                        FontSize="{DynamicResource FontSize.Button}"
                        Style="{StaticResource Btn.Primary}"
                        ToolTip="تنفيذ الحلقات المحددة"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="PlayCircleOutline" />
                            <TextBlock Margin="6,0,0,0" Text="تنفيذ" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="BtnBatchPublished"
                        Grid.Column="3"
                        Height="36"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Click="BtnBatchPublished_Click"
                        FontSize="{DynamicResource FontSize.Button}"
                        Style="{StaticResource Btn.Primary}"
                        ToolTip="نشر رقمي"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="CloudUploadOutline" />
                            <TextBlock Margin="6,0,0,0" Text="نشر" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="BtnBatchCancel"
                        Grid.Column="5"
                        Height="36"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Click="BtnBatchCancel_Click"
                        FontSize="{DynamicResource FontSize.Button}"
                        Style="{StaticResource Btn.Primary}"
                        ToolTip="إلغاء الحلقات المحددة"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="CloseCircleOutline" />
                            <TextBlock Margin="6,0,0,0" Text="إلغاء" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="BtnBatchDelete"
                        Grid.Column="8"
                        Height="36"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Click="BtnBatchDelete_Click"
                        FontSize="{DynamicResource FontSize.Button}"
                        Style="{StaticResource Btn.Primary}"
                        ToolTip="حذف الحلقات المحددة"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="DeleteOutline" />
                            <TextBlock Margin="6,0,0,0" Text="حذف" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  حالات التحميل والفراغ  -->
            <Grid
                x:Name="LoadingOverlay"
                Panel.ZIndex="10"
                Background="Transparent"
                Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar
                        Width="48"
                        Height="48"
                        Foreground="{StaticResource PrimaryMainBrush}"
                        IsIndeterminate="True"
                        Style="{StaticResource MaterialDesignCircularProgressBar}"
                        Value="0" />
                    <TextBlock
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        FontSize="{DynamicResource FontSize.BodyLarge}"
                        FontWeight="Medium"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="جاري جلب الحلقات..." />
                </StackPanel>
            </Grid>

            <Grid
                x:Name="EmptyStateOverlay"
                Panel.ZIndex="10"
                Background="Transparent"
                Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon
                        Width="80"
                        Height="80"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource DividerBrush}"
                        Kind="TextBoxSearchOutline" />
                    <TextBlock
                        Margin="0,16,0,4"
                        HorizontalAlignment="Center"
                        FontSize="{DynamicResource FontSize.TitleLarge}"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="لا توجد حلقات مطابقة" />
                    <TextBlock
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        FontSize="{DynamicResource FontSize.Label}"
                        Foreground="{StaticResource TextHintBrush}"
                        Text="حاول تغيير الفلاتر أو كلمات البحث" />
                    <Button
                        HorizontalAlignment="Center"
                        Click="BtnAddEpisode_Click"
                        Content="جدولة حلقة جديدة"
                        Style="{StaticResource Btn.Ghost}" />
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
