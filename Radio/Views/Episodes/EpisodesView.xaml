<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="750"
    d:DesignWidth="1100"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">
    <!--  تمت إزالة FlowDirection و Background لأن View.Base يوفرها مركزياً  -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <!--  استخدام التدرج الجاهز من AppColors بدلاً من كتابة ألوان يدوية  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="RadioFm" />
                        <TextBlock
                            Margin="12,0,0,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="المركز الرئيسي للبث" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="المحرك الأساسي لإدارة المحتوى، الجدولة، والانتشار الرقمي" />
                </StackPanel>

                <!--  استخدام ستايل الزر الجاهز بدلاً من كتابة كل الخصائص يدوياً  -->
                <Button
                    x:Name="BtnAddEpisode"
                    Grid.Column="1"
                    Click="BtnAddEpisode_Click"
                    Content="جدولة حلقة جديدة"
                    Style="{StaticResource Btn.AddNew}" />
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. شريط البحث والإحصائيات (KPIs) ═══════  -->
        <!--  مسافات موحدة (24 من الجوانب، 16 بين الأقسام)  -->
        <Grid Grid.Row="1" Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث: استخدام الستايل الموحد (يحتوي بالفعل على أيقونة البحث)  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                materialDesign:HintAssist.Hint="البحث السريع في سجلات البث..."
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  كرت الإحصائية 1: إجمالي الحلقات  -->
            <materialDesign:Card
                Grid.Column="1"
                Margin="0,0,8,0"
                Padding="16,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="{StaticResource SurfaceVariantBrush}"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource PrimaryMainBrush}"
                        Kind="ChartBoxOutline" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextHintBrush}"
                            Text="إجمالي الحلقات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="20"
                            TextAlignment="Center"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!--  كرت الإحصائية 2: تم النشر  -->
            <materialDesign:Card
                Grid.Column="2"
                Margin="0,0,8,0"
                Padding="16,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="{StaticResource SuccessLightBrush}"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource SuccessBrush}"
                        Kind="CloudCheckOutline" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock
                            FontSize="14"
                            TextAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="تم النشر" />
                        <TextBlock
                            x:Name="TxtPublished"
                            FontSize="20"
                            TextAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!--  كرت الإحصائية 3: بانتظار التنفيذ  -->
            <materialDesign:Card
                Grid.Column="3"
                Padding="16,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="{StaticResource WarningLightBrush}"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource WarningBrush}"
                        Kind="ProgressClock" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock
                            FontSize="14"
                            Foreground="{StaticResource WarningBrush}"
                            Text="بانتظار التنفيذ" />
                        <TextBlock
                            x:Name="TxtExecuted"
                            FontSize="20"
                            TextAlignment="Center"
                            Foreground="{StaticResource WarningBrush}"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!--  ═══════ 3. جدول البيانات ═══════  -->
        <materialDesign:Card
            Grid.Row="2"
            Margin="24,8,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="16">

            <!--  استخدام نظام الـ DataGrid الموحد  -->
            <DataGrid
                x:Name="DgEpisodes"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">

                <DataGrid.Columns>

                    <!--  عمود البرنامج  -->
                    <DataGridTemplateColumn
                        Width="160"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="البرنامج">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Width="100"
                                    Height="28"
                                    Padding="16,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource SecondaryLightBrush}"
                                    CornerRadius="14"
                                    Opacity="0.8">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding ProgramName}"
                                        TextAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!--  عمود تفاصيل الحلقة  -->
                    <DataGridTemplateColumn Width="250" Header="تفاصيل الحلقة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding EpisodeName}" />
                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Foreground="{StaticResource TextHintBrush}"
                                            Kind="AccountVoice" />
                                        <TextBlock
                                            Margin="6,0,0,0"
                                            FontSize="11"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding GuestName}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  اليوم (اسم اليوم)  -->
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding ScheduledExecutionTime, StringFormat='dddd', ConverterCulture='ar-SA'}"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="اليوم" />

                    <!--  التاريخ  -->
                    <DataGridTextColumn
                        Width="130"
                        Binding="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd'}"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="التاريخ" />

                    <!--  الوقت  -->
                    <DataGridTextColumn
                        Width="90"
                        Binding="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt' , ConverterCulture='ar-SA'}"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="الوقت" />
                    <!--  عمود حالة المهمة  -->
                    <DataGridTemplateColumn
                        Width="130"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="حالة المهمة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip
                                    x:Name="StatusChip"
                                    HorizontalAlignment="Center"
                                    Content="{Binding StatusText}"
                                    FontSize="11"
                                    FontWeight="Bold">
                                    <materialDesign:Chip.Style>
                                        <Style BasedOn="{StaticResource {x:Type materialDesign:Chip}}" TargetType="materialDesign:Chip">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                    <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CheckAll}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                    <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CheckDecagramOutline}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                    <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=ClockOutline}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:Chip.Style>
                                </materialDesign:Chip>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود مركز العمليات (الأزرار)  -->
                    <DataGridTemplateColumn
                        Width="Auto"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="الإجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                                    <!--  استخدام ستايلات الأيقونات الموحدة  -->
                                    <Button
                                        Click="BtnMarkExecuted_Click"
                                        Foreground="{StaticResource SecondaryMainBrush}"
                                        IsEnabled="{Binding CanMarkExecuted}"
                                        Style="{StaticResource Btn.Icon}"
                                        ToolTip="تأكيد تنفيذ البث">
                                        <materialDesign:PackIcon Kind="PlayCircleOutline" />
                                    </Button>

                                    <Button
                                        Click="BtnMarkPublished_Click"
                                        Foreground="{StaticResource SuccessBrush}"
                                        IsEnabled="{Binding CanMarkPublished}"
                                        Style="{StaticResource Btn.Icon}"
                                        ToolTip="تأكيد النشر الرقمي">
                                        <materialDesign:PackIcon Kind="CloudUploadOutline" />
                                    </Button>

                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource Btn.Icon.Edit}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon Kind="Edit" />
                                    </Button>

                                    <Button
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource Btn.Icon.Delete}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon Kind="Delete" />
                                    </Button>

                                    <!--  باقي الإجراءات في قائمة منسدلة  -->
                                    <materialDesign:PopupBox
                                        PlacementMode="BottomAndAlignCentres"
                                        PopupHorizontalOffset="-60"
                                        StaysOpen="False"
                                        ToolTip="المزيد من الإجراءات">
                                        <Border
                                            MinWidth="200"
                                            Padding="4"
                                            Background="{DynamicResource MaterialDesignPaper}"
                                            CornerRadius="12"
                                            Effect="{DynamicResource MaterialDesignShadowDepth2}">
                                            <StackPanel Orientation="Vertical">

                                                <Button
                                                    Height="40"
                                                    Padding="12,0"
                                                    HorizontalContentAlignment="Right"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="BtnMarkExecuted_Click"
                                                    Cursor="Hand"
                                                    IsEnabled="{Binding CanMarkExecuted}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border
                                                                            x:Name="ItemBorder"
                                                                            Padding="12,8"
                                                                            Background="Transparent"
                                                                            CornerRadius="8"
                                                                            SnapsToDevicePixels="True">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock
                                                                                    VerticalAlignment="Center"
                                                                                    FontFamily="{DynamicResource MaterialDesignFont}"
                                                                                    FontSize="13"
                                                                                    Text="تأكيد التنفيذ" />
                                                                                <materialDesign:PackIcon
                                                                                    Width="20"
                                                                                    Height="20"
                                                                                    Margin="12,0,0,0"
                                                                                    VerticalAlignment="Center"
                                                                                    Foreground="{DynamicResource MaterialDesignBody}"
                                                                                    Kind="PlayCircleOutline" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="Opacity" Value="0.38" />
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button
                                                    Height="40"
                                                    Padding="12,0"
                                                    HorizontalContentAlignment="Right"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="BtnMarkPublished_Click"
                                                    Cursor="Hand"
                                                    IsEnabled="{Binding CanMarkPublished}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border
                                                                            x:Name="ItemBorder"
                                                                            Padding="12,8"
                                                                            Background="Transparent"
                                                                            CornerRadius="8"
                                                                            SnapsToDevicePixels="True">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock
                                                                                    VerticalAlignment="Center"
                                                                                    FontFamily="{DynamicResource MaterialDesignFont}"
                                                                                    FontSize="13"
                                                                                    Text="تأكيد النشر الرقمي" />
                                                                                <materialDesign:PackIcon
                                                                                    Width="20"
                                                                                    Height="20"
                                                                                    Margin="12,0,0,0"
                                                                                    VerticalAlignment="Center"
                                                                                    Foreground="{DynamicResource MaterialDesignBody}"
                                                                                    Kind="CloudUploadOutline" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="Opacity" Value="0.38" />
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                            </StackPanel>
                                        </Border>
                                    </materialDesign:PopupBox>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>