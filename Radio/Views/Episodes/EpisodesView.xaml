<!--
    ═══════════════════════════════════════════════════════════════════════════
    EpisodesView.xaml — المرحلة الأولى: الأساسيات السريعة
    ═══════════════════════════════════════════════════════════════════════════
    التحسينات المُنفَّذة:
    1. إخفاء الأزرار المعطلة (Visibility بدلاً من IsEnabled)
    2. فلاتر سريعة حسب الحالة (Chips) كـ RadioButtons بنمط Tab
    3. توسيع نطاق البحث (ضيوف + ملاحظات + مراسلين)
    4. زيادة عرض شريط الحالة من 5 إلى 8 بكسل
    5. إجراء رئيسي بارز + قائمة ثانوية (Overflow PopupBox)
    6. عداد نتائج البحث والتصفية
    7. اختصارات لوحة المفاتيح
    8. شريط تقدم دورة الحياة (Stepper) داخل البطاقة
    9. ملخص الضيوف كعداد بدلاً من عرض القائمة كاملة
    ═══════════════════════════════════════════════════════════════════════════
-->
<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:local1="clr-namespace:Radio.Converter;assembly=Radio"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="850"
    d:DesignWidth="1100"
    Focusable="True"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <materialDesign:ColorZone
            Padding="24,16"
            materialDesign:ElevationAssist.Elevation="Dp2"
            Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="RadioFm" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="المركز الرئيسي للبث" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Opacity="0.8"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="المحرك الأساسي لإدارة المحتوى، الجدولة، والانتشار الرقمي" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <!--  زر اختصارات لوحة المفاتيح  -->
                    <Button
                        x:Name="BtnKeyboardHelp"
                        Width="36"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="BtnKeyboardHelp_Click"
                        Foreground="White"
                        Style="{StaticResource Btn.Icon}"
                        ToolTip="اختصارات لوحة المفاتيح (Ctrl+K)">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Kind="KeyboardOutline" />
                    </Button>
                    <Button
                        x:Name="BtnAddEpisode"
                        Height="45"
                        Padding="24,0"
                        VerticalAlignment="Center"
                        Click="BtnAddEpisode_Click"
                        Content="جدولة حلقة جديدة"
                        Style="{StaticResource Btn.AddNew}" />
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. شريط البحث والإحصائيات (KPIs) ═══════  -->
        <Grid Grid.Row="1" Margin="24,24,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث الموسّع  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Stretch"
                materialDesign:HintAssist.Hint="بحث في العناوين، البرامج، الضيوف، المراسلين، الملاحظات..."
                materialDesign:TextFieldAssist.HasClearButton="True"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  كرت إجمالي الحلقات  -->
            <materialDesign:Card
                Grid.Column="1"
                Margin="0,0,12,0"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="ChartBoxOutline" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.Caption}"
                            Text="إجمالي الحلقات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            Style="{StaticResource Type.Numeric.Large}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  كرت منشورة  -->
            <materialDesign:Card
                Grid.Column="2"
                Margin="0,0,12,0"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Success}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="CloudCheckOutline" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.Caption}"
                            Text="منشورة" />
                        <TextBlock
                            x:Name="TxtPublished"
                            Foreground="{StaticResource SuccessBrush}"
                            Style="{StaticResource Type.Numeric.Large}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  كرت مجدولة  -->
            <materialDesign:Card
                Grid.Column="3"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Warning}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource WarningBrush}"
                            Kind="ProgressClock" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource TextHintBrush}"
                            Style="{StaticResource Type.Caption}"
                            Text="مجدولة" />
                        <TextBlock
                            x:Name="TxtExecuted"
                            Foreground="{StaticResource WarningBrush}"
                            Style="{StaticResource Type.Numeric.Large}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!--  ═══════ 3. فلاتر الحالة السريعة (Chips) + عداد النتائج ═══════  -->
        <Border
            Grid.Row="2"
            Margin="24,0,24,12"
            Padding="16,10"
            Background="{StaticResource SurfaceVariantBrush}"
            CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextHintBrush}"
                    Style="{StaticResource Type.Caption}"
                    Text="تصفية:" />

                <!--  فلاتر Chips كـ RadioButtons  -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <RadioButton
                        x:Name="FilterAll"
                        Margin="0,0,4,0"
                        Click="StatusFilter_Click"
                        Content="الكل"
                        GroupName="StatusFilter"
                        IsChecked="True"
                        Style="{StaticResource Btn.Tab}" />

                    <RadioButton
                        x:Name="FilterPlanned"
                        Margin="0,0,4,0"
                        Click="StatusFilter_Click"
                        GroupName="StatusFilter"
                        Style="{StaticResource Btn.Tab}">
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="8"
                                Height="8"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource WarningBrush}"
                                CornerRadius="4" />
                            <TextBlock x:Name="ChipPlanned" Text="مجدولة (0)" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="FilterExecuted"
                        Margin="0,0,4,0"
                        Click="StatusFilter_Click"
                        GroupName="StatusFilter"
                        Style="{StaticResource Btn.Tab}">
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="8"
                                Height="8"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource SecondaryMainBrush}"
                                CornerRadius="4" />
                            <TextBlock x:Name="ChipExecuted" Text="منفّذة (0)" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="FilterPublished"
                        Margin="0,0,4,0"
                        Click="StatusFilter_Click"
                        GroupName="StatusFilter"
                        Style="{StaticResource Btn.Tab}">
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="8"
                                Height="8"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource SuccessBrush}"
                                CornerRadius="4" />
                            <TextBlock x:Name="ChipPublished" Text="منشورة رقمياً (0)" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="FilterWebPublished"
                        Margin="0,0,4,0"
                        Click="StatusFilter_Click"
                        GroupName="StatusFilter"
                        Style="{StaticResource Btn.Tab}">
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="8"
                                Height="8"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Background="#2196F3"
                                CornerRadius="4" />
                            <TextBlock x:Name="ChipWebPublished" Text="منشورة على الموقع (0)" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="FilterCancelled"
                        Margin="0,0,4,0"
                        Click="StatusFilter_Click"
                        GroupName="StatusFilter"
                        Style="{StaticResource Btn.Tab}">
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="8"
                                Height="8"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource ErrorBrush}"
                                CornerRadius="4" />
                            <TextBlock x:Name="ChipCancelled" Text="ملغاة (0)" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!--  عداد النتائج  -->
                <TextBlock
                    x:Name="TxtResultCount"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextDisabledBrush}"
                    Style="{StaticResource Type.Caption}"
                    Text="عرض 0 من 0 حلقة" />
            </Grid>
        </Border>

        <!--  ═══════ 4. بطاقات الحلقات (مُحسّنة) ═══════  -->
        <ListBox
            x:Name="DgEpisodes"
            Grid.Row="3"
            Margin="32,8,32,24"
            Background="Transparent"
            BorderThickness="0"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource MaterialDesignListBox}">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,14" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card
                        Padding="0"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        Background="{StaticResource SurfaceBrush}"
                        UniformCornerRadius="14">
                        <materialDesign:Card.Style>
                            <Style TargetType="materialDesign:Card">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:Card.Style>

                        <DockPanel>
                            <!--  ═══ شريط الأزرار الذكي ═══  -->
                            <Border
                                Padding="20,14,20,16"
                                Background="Transparent"
                                DockPanel.Dock="Bottom">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <!--  تنفيذ — للمجدولة فقط  -->
                                        <Button
                                            Height="34"
                                            Padding="16,0"
                                            Background="{StaticResource HeaderGradientBrush}"
                                            Click="BtnMarkExecuted_Click"
                                            Style="{StaticResource Btn.Primary}"
                                            ToolTip="تنفيذ الحلقة"
                                            Visibility="{Binding CanMarkExecuted, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Kind="PlayCircleOutline" />
                                                <TextBlock VerticalAlignment="Center" Text="تنفيذ" />
                                            </StackPanel>
                                        </Button>

                                        <!--  نشر رقمي — للمنفّذة فقط  -->
                                        <Button
                                            Height="34"
                                            Padding="16,0"
                                            Background="{StaticResource SuccessBrush}"
                                            Click="BtnMarkPublished_Click"
                                            Style="{StaticResource Btn.Primary}"
                                            ToolTip="نشر رقمي"
                                            Visibility="{Binding CanMarkPublished, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Kind="CloudUploadOutline" />
                                                <TextBlock VerticalAlignment="Center" Text="نشر رقمي" />
                                            </StackPanel>
                                        </Button>

                                        <!--  نشر على الموقع — للمنشورة فقط  -->
                                        <Button
                                            Height="34"
                                            Padding="16,0"
                                            Background="#2196F3"
                                            Click="BtnToggleWebsitePublish_Click"
                                            Style="{StaticResource Btn.Primary}"
                                            ToolTip="نشر على الموقع"
                                            Visibility="{Binding CanToggleWebsitePublish, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Kind="Web" />
                                                <TextBlock VerticalAlignment="Center" Text="نشر على الموقع" />
                                            </StackPanel>
                                        </Button>

                                        <Border
                                            Width="1"
                                            Height="24"
                                            Margin="14,0"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource DividerBrush}" />

                                        <!--  قائمة الإجراءات الثانوية (Overflow)  -->
                                        <materialDesign:PopupBox
                                            Width="34"
                                            Height="34"
                                            PlacementMode="BottomAndAlignRightEdges"
                                            Style="{StaticResource MaterialDesignPopupBox}"
                                            ToolTip="المزيد من الإجراءات">
                                            <materialDesign:PopupBox.ToggleContent>
                                                <materialDesign:PackIcon
                                                    Width="20"
                                                    Height="20"
                                                    Kind="DotsVertical"
                                                    Foreground="{StaticResource TextSecondaryBrush}" />
                                            </materialDesign:PopupBox.ToggleContent>
                                            <StackPanel Width="180">
                                                <Button Click="BtnViewRecords_Click" Visibility="{Binding CanViewRecords, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Kind="History"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center" />
                                                        <TextBlock VerticalAlignment="Center" Text="عرض السجلات" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="BtnRevert_Click" Visibility="{Binding CanRevert, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Kind="Undo"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center" />
                                                        <TextBlock VerticalAlignment="Center" Text="تراجع عن الإجراء" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="BtnCancelEpisode_Click" Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Kind="Cancel"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center" />
                                                        <TextBlock VerticalAlignment="Center" Text="إلغاء الحلقة" />
                                                    </StackPanel>
                                                </Button>

                                                <Separator Margin="4,4" Background="{StaticResource DividerBrush}" />

                                                <Button Click="BtnEdit_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Kind="Pencil"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center" />
                                                        <TextBlock VerticalAlignment="Center" Text="تعديل التفاصيل" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="BtnDelete_Click" Foreground="{StaticResource ErrorBrush}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Kind="Delete"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center" />
                                                        <TextBlock VerticalAlignment="Center" Text="حذف الحلقة" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </materialDesign:PopupBox>
                                    </StackPanel>

                                    <!--  تعديل سريع + حذف  -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Click="BtnEdit_Click"
                                            Cursor="Hand"
                                            Style="{StaticResource Btn.Icon.Edit}"
                                            ToolTip="تعديل الحلقة">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="PencilOutline" />
                                        </Button>
                                        <Button
                                            Width="36"
                                            Height="36"
                                            Click="BtnDelete_Click"
                                            Cursor="Hand"
                                            Style="{StaticResource Btn.Icon.Delete}"
                                            ToolTip="حذف الحلقة">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Foreground="{StaticResource ErrorBrush}"
                                                Kind="DeleteOutline" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!--  ═══ شريط الحالة الملون (8px بدلاً من 5px) ═══  -->
                            <Border
                                Width="8"
                                CornerRadius="8,0,0,8"
                                DockPanel.Dock="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                <Setter Property="Background" Value="{StaticResource SecondaryMainBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!--  ═══ المحتوى الرئيسي ═══  -->
                            <Grid Margin="20,16,20,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!--  البرنامج + التاريخ + Chip الحالة  -->
                                <Border Padding="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="25,6"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="16"
                                                    Height="16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource SecondaryMainBrush}"
                                                    Kind="RadioFm" />
                                                <TextBlock
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource PrimaryMainBrush}"
                                                    Style="{StaticResource Type.BodyLarge}"
                                                    Text="{Binding ProgramName}" />
                                            </StackPanel>
                                        </Border>
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="16,0,0,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding ScheduledExecutionTime, StringFormat='dddd', ConverterCulture='ar-SA'}" />
                                            <Border
                                                Width="1"
                                                Height="16"
                                                Margin="10,0"
                                                Background="{StaticResource DividerBrush}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd', ConverterCulture='en-US'}" />
                                            <Border
                                                Width="1"
                                                Height="16"
                                                Margin="10,0"
                                                Background="{StaticResource DividerBrush}" />
                                            <Border
                                                Padding="8,4"
                                                Background="{StaticResource SurfaceVariantBrush}"
                                                CornerRadius="6">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,4,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource SecondaryMainBrush}"
                                                        Kind="ClockOutline" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        Style="{StaticResource Type.Caption}"
                                                        Text="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <Border
                                            Grid.Column="2"
                                            Height="28"
                                            Padding="12,0"
                                            CornerRadius="14">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource DividerBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                            <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                            <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                            <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                            <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="14"
                                                    Height="14"
                                                    VerticalAlignment="Center"
                                                    Foreground="White">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                                    <Setter Property="Kind" Value="ClockOutline" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                                    <Setter Property="Kind" Value="CheckAll" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                                    <Setter Property="Kind" Value="CheckDecagramOutline" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                                    <Setter Property="Kind" Value="Web" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                                    <Setter Property="Kind" Value="CloseCircleOutline" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                                <TextBlock
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding StatusText}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!--  عنوان الحلقة + ملخص الضيوف  -->
                                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                    <TextBlock
                                        Style="{StaticResource Type.TitleMedium}"
                                        Text="{Binding EpisodeName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextHintBrush}"
                                            Kind="AccountGroupOutline" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextHintBrush}"
                                            Style="{StaticResource Type.Caption}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} ضيوف">
                                                    <Binding Path="GuestItems.Count" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Margin="16,0,6,0"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource WarningBrush}"
                                            Kind="NoteOutline"
                                            Visibility="{Binding SpecialNotes, Converter={StaticResource NullToCollapsedConverter}}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource WarningBrush}"
                                            Style="{StaticResource Type.Caption}"
                                            Text="يتضمن ملاحظات"
                                            Visibility="{Binding SpecialNotes, Converter={StaticResource NullToCollapsedConverter}}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  شريط تقدم دورة الحياة (Stepper)  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Orientation="Horizontal">
                                    <Border
                                        Width="10"
                                        Height="10"
                                        VerticalAlignment="Center"
                                        CornerRadius="5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderDefaultBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="0">
                                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextDisabledBrush}"
                                        Style="{StaticResource Type.Caption}">
                                        مجدولة
                                    </TextBlock>
                                    <Border
                                        Width="20"
                                        Height="2"
                                        Margin="6,0"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource BorderDefaultBrush}" />
                                    <Border
                                        Width="10"
                                        Height="10"
                                        VerticalAlignment="Center"
                                        CornerRadius="5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderDefaultBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextDisabledBrush}"
                                        Style="{StaticResource Type.Caption}">
                                        منفّذة
                                    </TextBlock>
                                    <Border
                                        Width="20"
                                        Height="2"
                                        Margin="6,0"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource BorderDefaultBrush}" />
                                    <Border
                                        Width="10"
                                        Height="10"
                                        VerticalAlignment="Center"
                                        CornerRadius="5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderDefaultBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextDisabledBrush}"
                                        Style="{StaticResource Type.Caption}">
                                        منشورة
                                    </TextBlock>
                                    <Border
                                        Width="20"
                                        Height="2"
                                        Margin="6,0"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource BorderDefaultBrush}" />
                                    <Border
                                        Width="10"
                                        Height="10"
                                        VerticalAlignment="Center"
                                        CornerRadius="5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderDefaultBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextDisabledBrush}"
                                        Style="{StaticResource Type.Caption}">
                                        منشورة على الموقع
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
