<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <Grid FlowDirection="RightToLeft">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  رأس الصفحة  -->
        <Border
            Background="#2D2D30"
            BorderBrush="#3E3E42"
            BorderThickness="0,0,0,1">
            <Grid Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="#E0E0E0"
                        Text="سجل الحلقات والبث" />
                    <Border
                        Margin="10,0,0,0"
                        Padding="8,2"
                        Background="#03A9F4"
                        CornerRadius="14">
                        <TextBlock
                            x:Name="TxtEpisodesCount"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="0" />
                    </Border>
                </StackPanel>

                <!--  مربع بحث (اختياري – يمكن ربطه لاحقاً)  -->
                <TextBox
                    Grid.Column="1"
                    Width="200"
                    Margin="20,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    materialDesign:HintAssist.Hint="بحث عن حلقة...">
                    <TextBox.Style>
                        <Style BasedOn="{StaticResource MaterialDesignFilledTextBox}" TargetType="TextBox">
                            <Setter Property="Background" Value="#3E3E42" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderBrush" Value="#555" />
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button
                    x:Name="BtnAddEpisode"
                    Grid.Column="2"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="#03A9F4"
                    BorderBrush="#03A9F4"
                    Click="BtnAddEpisode_Click"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    ToolTip="جدولة حلقة جديدة">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            Kind="Plus" />
                        <TextBlock Text="جدولة حلقة جديدة" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  شريط إحصائيات سريع  -->
        <Border
            Grid.Row="1"
            Background="#252526"
            BorderBrush="#3E3E42"
            BorderThickness="0,0,0,1">
            <StackPanel Margin="20,8" Orientation="Horizontal">
                <materialDesign:PackIcon
                    Width="16"
                    Height="16"
                    Foreground="#03A9F4"
                    Kind="Calendar" />
                <TextBlock
                    Margin="6,0,15,0"
                    FontSize="12"
                    Foreground="#AAA"
                    Text="البث القادم: --" />
                <materialDesign:PackIcon
                    Width="16"
                    Height="16"
                    Foreground="#4CAF50"
                    Kind="CheckCircle" />
                <TextBlock
                    Margin="6,0,0,0"
                    FontSize="12"
                    Foreground="#AAA"
                    Text="تم النشر: 0 حلقة" />
            </StackPanel>
        </Border>

        <!--  DataGrid داخل Card  -->
        <materialDesign:Card
            Grid.Row="2"
            Margin="16"
            Background="{DynamicResource MaterialDesignPaper}"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1"
            UniformCornerRadius="12">

            <!--  تعريف موارد محلية للتنسيق  -->
            <materialDesign:Card.Resources>
                <!--  تنسيق النصوص في الخلايا  -->
                <Style x:Key="CenterCellText" TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                </Style>
                <Style x:Key="RightCellText" TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Margin" Value="10,0,0,0" />
                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                </Style>
            </materialDesign:Card.Resources>

            <materialDesign:Card
                Grid.Row="2"
                Margin="16"
                Background="#1A1A22"
                BorderBrush="#333346"
                BorderThickness="1"
                UniformCornerRadius="12">

                <materialDesign:Card.Resources>
                    <!--  تنسيق النصوص في الخلايا  -->
                    <Style x:Key="CenterCellText" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="Foreground" Value="#E0E0E0" />
                    </Style>
                    <Style x:Key="RightCellText" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Right" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="Margin" Value="10,0,0,0" />
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="Foreground" Value="#E0E0E0" />
                    </Style>
                </materialDesign:Card.Resources>

                <DataGrid
                    x:Name="DgEpisodes"
                    AlternatingRowBackground="#27273A"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    CanUserAddRows="False"
                    FlowDirection="RightToLeft"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    GridLinesVisibility="None"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowBackground="#1E1E24"
                    SelectionMode="Single"
                    SelectionUnit="FullRow">

                    <!--  تأثير التمرير (Hover) على الصفوف  -->
                    <DataGrid.RowStyle>
                        <Style BasedOn="{StaticResource MaterialDesignDataGridRow}" TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#33334A" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!--  تنسيق رؤوس الأعمدة (التصميم الجديد)  -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                            <!--  لون خلفية الهيدر المميز جداً  -->
                            <Setter Property="Background" Value="#12131A" />
                            <!--  لون النص المميز  -->
                            <Setter Property="Foreground" Value="#5EAEFF" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="14,12" />
                            <!--  إزالة الحدود لجعله يبدو ككتلة واحدة  -->
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <!--  عمود الإجراءات  -->
                        <DataGridTemplateColumn Width="Auto" Header="الإجراءات">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            Margin="4"
                                            Padding="4"
                                            Click="BtnMarkPublished_Click"
                                            Foreground="#66BB6A"
                                            IsEnabled="{Binding CanMarkPublished}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="نشر">
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                Kind="Upload" />
                                        </Button>
                                        <Button
                                            Margin="4"
                                            Padding="4"
                                            Click="BtnMarkExecuted_Click"
                                            Foreground="#42A5F5"
                                            IsEnabled="{Binding CanMarkExecuted}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="تنفيذ">
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                Kind="PlayCircle" />
                                        </Button>
                                        <Button
                                            Margin="4"
                                            Padding="4"
                                            Click="BtnEdit_Click"
                                            Foreground="#FFA726"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="تعديل">
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                Kind="Pencil" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  عمود البرنامج  -->
                        <DataGridTextColumn
                            Width="150"
                            Binding="{Binding ProgramName}"
                            ElementStyle="{StaticResource RightCellText}"
                            Header="البرنامج">
                            <DataGridTextColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>

                        <!--  عمود عنوان الحلقة  -->
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding EpisodeName}"
                            ElementStyle="{StaticResource RightCellText}"
                            Header="عنوان الحلقة">
                            <DataGridTextColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>

                        <!--  عمود ضيف الحلقة  -->
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding GuestName}"
                            ElementStyle="{StaticResource RightCellText}"
                            Header="ضيف الحلقة">
                            <DataGridTextColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>

                        <!--  عمود تاريخ البث  -->
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd'}"
                            ElementStyle="{StaticResource CenterCellText}"
                            Header="تاريخ البث" />

                        <!--  عمود الحالة  -->
                        <DataGridTemplateColumn Width="120" Header="الحالة">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        x:Name="StatusBorder"
                                        Margin="8,0"
                                        Padding="12,5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#37474F"
                                        CornerRadius="15">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="Medium"
                                            Foreground="#B0BEC5"
                                            Text="{Binding StatusText}" />
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                            <Setter TargetName="StatusBorder" Property="Background" Value="#37474F" />
                                            <Setter TargetName="StatusBorder" Property="TextElement.Foreground" Value="#90A4AE" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                            <Setter TargetName="StatusBorder" Property="Background" Value="#1565C0" />
                                            <Setter TargetName="StatusBorder" Property="TextElement.Foreground" Value="#BBDEFB" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                            <Setter TargetName="StatusBorder" Property="Background" Value="#2E7D32" />
                                            <Setter TargetName="StatusBorder" Property="TextElement.Foreground" Value="#C8E6C9" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                            <Setter TargetName="StatusBorder" Property="Background" Value="#C62828" />
                                            <Setter TargetName="StatusBorder" Property="TextElement.Foreground" Value="#FFCDD2" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>
        </materialDesign:Card>
    </Grid>
</UserControl>