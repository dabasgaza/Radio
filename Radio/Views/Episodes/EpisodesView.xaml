<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="750"
    d:DesignWidth="1100"
    FlowDirection="RightToLeft"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone
            Padding="30,24"
            materialDesign:ElevationAssist.Elevation="Dp3"
            Mode="PrimaryMid">
            <materialDesign:ColorZone.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#1A237E" />
                    <GradientStop Offset="1" Color="#303F9F" />
                </LinearGradientBrush>
            </materialDesign:ColorZone.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="35"
                            Height="35"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="RadioTower" />
                        <TextBlock
                            Margin="15,0"
                            FontSize="32"
                            FontWeight="ExtraBold"
                            Foreground="White"
                            Text="المركز الرئيسي للبث" />
                    </StackPanel>
                    <TextBlock
                        Margin="50,5,0,0"
                        FontSize="14"
                        Foreground="White"
                        Opacity="0.8"
                        Text="المحرك الأساسي لإدارة المحتوى، الجدولة، والانتشار الرقمي" />
                </StackPanel>

                <Button
                    x:Name="BtnAddEpisode"
                    Grid.Column="1"
                    Height="50"
                    Padding="25,0"
                    materialDesign:ButtonAssist.CornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Background="#FFB300"
                    BorderBrush="#FFB300"
                    Click="BtnAddEpisode_Click"
                    Foreground="#1A237E">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="22"
                            Height="22"
                            VerticalAlignment="Center"
                            Kind="PlaylistPlus" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Text="جدولة حلقة جديدة" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1" Margin="30,25,30,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,20,0"
                VerticalAlignment="Center"
                materialDesign:HintAssist.Hint="البحث السريع في سجلات البث..."
                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource BroadcastTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <materialDesign:Card
                Grid.Column="1"
                Margin="5"
                Padding="15,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="#F5F6FA"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Kind="ChartBoxOutline"
                        Opacity="0.6" />
                    <StackPanel Margin="15,0">
                        <TextBlock
                            FontSize="10"
                            FontWeight="Bold"
                            Opacity="0.5"
                            Text="إجمالي الحلقات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card
                Grid.Column="2"
                Margin="5"
                Padding="15,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="#E8F5E9"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SuccessBrush}"
                        Kind="CloudCheckOutline" />
                    <StackPanel Margin="15,0">
                        <TextBlock
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="{DynamicResource SuccessBrush}"
                            Opacity="0.7"
                            Text="تم النشر" />
                        <TextBlock
                            x:Name="TxtPublished"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{DynamicResource SuccessBrush}"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card
                Grid.Column="3"
                Margin="5"
                Padding="15,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="#FFF3E0"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource WarningBrush}"
                        Kind="ProgressClock" />
                    <StackPanel Margin="15,0">
                        <TextBlock
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="{DynamicResource WarningBrush}"
                            Opacity="0.7"
                            Text="بانتظار التنفيذ" />
                        <TextBlock
                            x:Name="TxtExecuted"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{DynamicResource WarningBrush}"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <materialDesign:Card
            Grid.Row="2"
            Margin="30,10,30,30"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="16">
            <DataGrid
                x:Name="DgEpisodes"
                CellStyle="{StaticResource BroadcastPro.DataGridCell}"
                ColumnHeaderStyle="{StaticResource BroadcastPro.DataGridColumnHeader}"
                RowStyle="{StaticResource BroadcastPro.DataGridRow}"
                Style="{StaticResource BroadcastProDataGrid}">

                <DataGrid.Columns>

                    <DataGridTemplateColumn
                        Width="160"
                        CellStyle="{StaticResource CenterCellAligned}"
                        Header="البرنامج">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip
                                    MinWidth="100"
                                    HorizontalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Content="{Binding ProgramName}"
                                    FontSize="14" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="250" Header="تفاصيل الحلقة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Text="{Binding EpisodeName}" />
                                    <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Kind="AccountVoice"
                                            Opacity="0.4" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="11"
                                            Opacity="0.6"
                                            Text="{Binding GuestName}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn
                        Width="140"
                        Binding="{Binding ScheduledExecutionTime, StringFormat='dd MMM yyyy'}"
                        CellStyle="{StaticResource CenterCellAligned}"
                        Header="موعد البث" />

                    <DataGridTemplateColumn Width="130" Header="حالة المهمة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip
                                    x:Name="StatusChip"
                                    HorizontalAlignment="Center"
                                    Content="{Binding StatusText}"
                                    FontSize="11"
                                    FontWeight="Bold">
                                    <materialDesign:Chip.Style>
                                        <Style BasedOn="{StaticResource {x:Type materialDesign:Chip}}" TargetType="materialDesign:Chip">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CheckDecagramOutline}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=ClockOutline}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:Chip.Style>
                                </materialDesign:Chip>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="230" Header="مركز العمليات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnMarkExecuted_Click"
                                        IsEnabled="{Binding CanMarkExecuted}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تأكيد تنفيذ البث">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Foreground="{DynamicResource SecondaryHueMidBrush}"
                                            Kind="PlayCircleOutline" />
                                    </Button>

                                    <Button
                                        Click="BtnMarkPublished_Click"
                                        IsEnabled="{Binding CanMarkPublished}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تأكيد النشر الرقمي">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Foreground="{DynamicResource SuccessBrush}"
                                            Kind="CloudUploadOutline" />
                                    </Button>
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="TrashCanOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>