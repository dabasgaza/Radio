<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="5,0,5,20">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="26"
                FontWeight="Bold"
                Foreground="White"
                Text="سجل الحلقات والبث" />
            <Button
                x:Name="BtnAddEpisode"
                Margin="20,0,0,0"
                HorizontalAlignment="Left"
                materialDesign:ButtonAssist.CornerRadius="5"
                Background="#03A9F4"
                BorderBrush="#03A9F4"
                Click="BtnAddEpisode_Click"
                Content="جدولة حلقة جديدة"
                Foreground="White" />
        </DockPanel>

        <materialDesign:Card
            Grid.Row="1"
            VerticalAlignment="Stretch"
            Background="#1E1E1E"
            UniformCornerRadius="10">
            <DataGrid
                x:Name="DgEpisodes"
                AlternatingRowBackground="#252526"
                AutoGenerateColumns="False"
                Background="Transparent"
                CanUserAddRows="False"
                Foreground="White"
                IsReadOnly="True"
                RowBackground="#1E1E1E">
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#03A9F4" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="Padding" Value="10" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding ProgramName}"
                        CellStyle="{StaticResource LeftCellAligned}"
                        FontWeight="Bold"
                        Header="البرنامج" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding EpisodeName}"
                        CellStyle="{StaticResource LeftCellAligned}"
                        Header="عنوان الحلقة" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd'}"
                        CellStyle="{StaticResource CenterCellAligned}"
                        Header="تاريخ البث" />

                    <DataGridTemplateColumn Width="120" Header="الحالة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    x:Name="StatusBorder"
                                    Padding="8,4"
                                    CornerRadius="10">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding StatusText}" />
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding StatusText}" Value="مخطط لها">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#757575" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="تم التنفيذ">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#03A9F4" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="تم النشر">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#4CAF50" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="180" Header="إجراءات البث">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Height="28"
                                        Margin="2"
                                        Padding="10,0"
                                        Background="#03A9F4"
                                        BorderBrush="#03A9F4"
                                        Click="BtnMarkExecuted_Click"
                                        Content="تنفيذ الإنتاج"
                                        Style="{StaticResource MaterialDesignRaisedButton}">
                                        <!--  Visibility Bindings remains the same  -->
                                    </Button>
                                    <Button
                                        Height="28"
                                        Margin="2"
                                        Padding="10,0"
                                        Background="#4CAF50"
                                        BorderBrush="#4CAF50"
                                        Click="BtnMarkPublished_Click"
                                        Content="نشر رقمي"
                                        Style="{StaticResource MaterialDesignRaisedButton}">
                                        <!--  Visibility Bindings remains the same  -->
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>

</UserControl>
