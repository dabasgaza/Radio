<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Episodes"
    xmlns:local1="clr-namespace:Radio.Converter;assembly=Radio"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="750"
    d:DesignWidth="1100"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="RadioFm" />
                        <TextBlock
                            Margin="12,0,0,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="المركز الرئيسي للبث" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="المحرك الأساسي لإدارة المحتوى، الجدولة، والانتشار الرقمي" />
                </StackPanel>

                <Button
                    x:Name="BtnAddEpisode"
                    Grid.Column="1"
                    Click="BtnAddEpisode_Click"
                    Content="جدولة حلقة جديدة"
                    Style="{StaticResource Btn.AddNew}" />
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. شريط البحث والإحصائيات (KPIs) ═══════  -->
        <Grid Grid.Row="1" Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                materialDesign:HintAssist.Hint="البحث السريع في سجلات البث..."
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  كرت الإحصائية 1: إجمالي الحلقات  -->
            <materialDesign:Card
                Grid.Column="1"
                Margin="0,0,8,0"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="ChartBoxOutline" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextHintBrush}"
                            Text="إجمالي الحلقات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  كرت الإحصائية 2: منشورة  -->
            <materialDesign:Card
                Grid.Column="2"
                Margin="0,0,8,0"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource StatIcon.Success}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="CloudCheckOutline" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextHintBrush}"
                            Text="منشورة" />
                        <TextBlock
                            x:Name="TxtPublished"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  كرت الإحصائية 3: مجدولة  -->
            <materialDesign:Card Grid.Column="3" Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource StatIcon.Warning}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource WarningBrush}"
                            Kind="ProgressClock" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextHintBrush}"
                            Text="مجدولة" />
                        <TextBlock
                            x:Name="TxtExecuted"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!--  ═══════ 3. بطاقات الحلقات ═══════  -->
        <ListBox
            x:Name="DgEpisodes"
            Grid.Row="2"
            Margin="24,8,24,24"
            Background="Transparent"
            BorderThickness="0"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource MaterialDesignListBox}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,12" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card
                        Padding="0"
                        materialDesign:ElevationAssist.Elevation="Dp2"
                        Background="{StaticResource SurfaceBrush}"
                        UniformCornerRadius="12">

                        <Grid>
                            <!--  الشريط الملون الأيسر حسب الحالة  -->
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                CornerRadius="12,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                <Setter Property="Background" Value="{StaticResource SecondaryMainBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة رقمياً">
                                                <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                <Setter Property="Background" Value="#2196F3" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <Grid Margin="18,14,18,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!--  ═══════ المحتوى الرئيسي ═══════  -->
                                <StackPanel>

                                    <!--  الصف 1: البرنامج + التاريخ والوقت + الحالة  -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  شارة البرنامج  -->
                                        <Border
                                            Padding="10,5"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource SecondaryMainBrush}"
                                                    Kind="RadioFm" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    Foreground="{StaticResource PrimaryMainBrush}"
                                                    Text="{Binding ProgramName}" />
                                            </StackPanel>
                                        </Border>

                                        <!--  مجموعة التاريخ والوقت — في الوسط  -->
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">

                                            <!--  اسم اليوم  -->
                                            <Border Padding="10,5" CornerRadius="8">
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="Medium"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding ScheduledExecutionTime, StringFormat='dddd', ConverterCulture='ar-SA'}" />
                                            </Border>

                                            <!--  التاريخ  -->
                                            <TextBlock
                                                Padding="10,5"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Foreground="{StaticResource TextHintBrush}"
                                                Text="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd', ConverterCulture='en-US'}" />

                                            <!--  الوقت  -->
                                            <Border
                                                Padding="10,5"
                                                Background="{StaticResource SurfaceVariantBrush}"
                                                CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Margin="0,0,4,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource SecondaryMainBrush}"
                                                        Kind="ClockOutline" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        Text="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!--  Chip الحالة  -->
                                        <materialDesign:Chip
                                            Grid.Column="2"
                                            Height="28"
                                            Content="{Binding StatusText}"
                                            FontSize="12">
                                            <materialDesign:Chip.Style>
                                                <Style BasedOn="{StaticResource {x:Type materialDesign:Chip}}" TargetType="materialDesign:Chip">
                                                    <Setter Property="FontSize" Value="11" />
                                                    <Setter Property="Height" Value="28" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                            <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=ClockOutline}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                            <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CheckAll}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة رقمياً">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CheckDecagramOutline}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                            <Setter Property="Background" Value="#2196F3" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=Web}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Icon" Value="{materialDesign:PackIcon Kind=CloseCircleOutline}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:Chip.Style>
                                        </materialDesign:Chip>

                                    </Grid>

                                    <!--  الصف 2: عنوان الحلقة  -->
                                    <TextBlock
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Text="{Binding EpisodeName}"
                                        TextTrimming="CharacterEllipsis" />

                                    <!--  عداد الضيوف  -->
                                    <StackPanel
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="1">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="2">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="3">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="4">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="5">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextHintBrush}"
                                            Kind="AccountGroupOutline" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextHintBrush}"
                                            Text="{Binding GuestItems.Count}" />
                                    </StackPanel>

                                    <!--  الصف 3: الضيوف — SharedSizeScope يضمن محاذاة جميع الأعمدة  -->
                                    <ItemsControl
                                        Margin="0,10,0,0"
                                        Grid.IsSharedSizeScope="True"
                                        ItemsSource="{Binding GuestItems}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!--  صف واحد لكل ضيف  -->
                                                <Border
                                                    Margin="0,0,0,6"
                                                    Padding="10,8"
                                                    Background="{StaticResource SurfaceVariantBrush}"
                                                    CornerRadius="8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <!--  SharedSizeGroup يضمن محاذاة جميع الأعمدة بنفس العرض  -->
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="GuestNameCol" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="GuestTimeCol" />
                                                        </Grid.ColumnDefinitions>

                                                        <!--  أيقونة + اسم الضيف  -->
                                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                            <materialDesign:PackIcon
                                                                Width="20"
                                                                Height="20"
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center"
                                                                Foreground="{StaticResource SeconderyGradientBrush}"
                                                                Kind="AccountOutline" />
                                                            <TextBlock
                                                                FontSize="14"
                                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                                Text="{Binding Name}" />
                                                        </StackPanel>

                                                        <!--  الموضوع — يبدأ دائماً من نفس المحاذاة  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            Margin="12,0"
                                                            Padding="10,4"
                                                            VerticalAlignment="Center"
                                                            Background="{StaticResource PrimaryXLightBrush}"
                                                            CornerRadius="5">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Topic}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Topic}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock
                                                                FontSize="13"
                                                                Foreground="{StaticResource PrimaryMainBrush}"
                                                                Text="{Binding Topic}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </Border>

                                                        <!--  وقت الاستضافة — TimeSpanToStringConverter يدعم AM/PM  -->
                                                        <Border
                                                            Grid.Column="2"
                                                            Padding="8,4"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            CornerRadius="5">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HostingTime}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Margin="0,0,5,0"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{StaticResource TextHintBrush}"
                                                                    Kind="ClockOutline" />
                                                                <TextBlock
                                                                    FontSize="13"
                                                                    Foreground="{StaticResource TextHintBrush}"
                                                                    Text="{Binding HostingTime, Converter={StaticResource TimeSpanToStringConverter}}" />
                                                            </StackPanel>
                                                        </Border>

                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  نص احتياطي عند عدم وجود ضيوف  -->
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="13"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="لا يوجد ضيوف مسجلين لهذه الحلقة"
                                        Visibility="Collapsed">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!--  ملاحظات خاصة  -->
                                    <Border
                                        Margin="0,8,0,0"
                                        Padding="10,6"
                                        CornerRadius="6"
                                        Visibility="Collapsed">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource WarningLightBrush}" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SpecialNotes}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpecialNotes}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource WarningBrush}"
                                                Kind="NoteTextOutline" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding SpecialNotes}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>

                                    <!--  سبب الإلغاء  -->
                                    <Border
                                        Margin="0,6,0,0"
                                        Padding="8,5"
                                        Background="{StaticResource ErrorLightBrush}"
                                        CornerRadius="6"
                                        Visibility="{Binding CancellationReason, Converter={StaticResource StringToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource ErrorBrush}"
                                                Kind="Cancel" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{StaticResource ErrorBrush}"
                                                Text="{Binding CancellationReason}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Button
                                                Width="24"
                                                Height="24"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Click="BtnEditCancellationReason_Click"
                                                Style="{StaticResource Btn.Icon}"
                                                ToolTip="تعديل سبب الإلغاء">
                                                <materialDesign:PackIcon
                                                    Width="12"
                                                    Height="12"
                                                    Kind="PencilOutline" />
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <!--  ═══════ شريط الإجراءات السفلي ═══════  -->
                                <Border
                                    Grid.Row="1"
                                    Margin="0,10,0,0"
                                    Padding="8,6"
                                    Background="{StaticResource SurfaceVariantBrush}"
                                    CornerRadius="10">
                                    <Border.Resources>
                                        <Style x:Key="CircleBtn" TargetType="Button">
                                            <Setter Property="Width" Value="36" />
                                            <Setter Property="Height" Value="36" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border
                                                            Width="36"
                                                            Height="36"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="18">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.35" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Resources>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <!--  ══ سير العمل ══  -->
                                        <Border
                                            Padding="8,4"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <Button
                                                    Background="{StaticResource SecondaryMainBrush}"
                                                    Click="BtnMarkExecuted_Click"
                                                    IsEnabled="{Binding CanMarkExecuted}"
                                                    Style="{StaticResource CircleBtn}"
                                                    ToolTip="تنفيذ">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="White"
                                                        Kind="PlayCircleOutline" />
                                                </Button>
                                                <Button
                                                    Margin="8,0,0,0"
                                                    Background="{StaticResource SuccessBrush}"
                                                    Click="BtnMarkPublished_Click"
                                                    IsEnabled="{Binding CanMarkPublished}"
                                                    Style="{StaticResource CircleBtn}"
                                                    ToolTip="نشر">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="White"
                                                        Kind="CloudUploadOutline" />
                                                </Button>
                                                <Button
                                                    Margin="8,0,0,0"
                                                    Background="#2196F3"
                                                    Click="BtnToggleWebsitePublish_Click"
                                                    IsEnabled="{Binding CanToggleWebsitePublish}"
                                                    Style="{StaticResource CircleBtn}"
                                                    ToolTip="موقع">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="White"
                                                        Kind="Web" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                        <Separator Margin="10,0" Style="{StaticResource MaterialDesignSeparator}" />
                                        <!--  ══ تصحيحي ══  -->
                                        <Border
                                            Padding="8,4"
                                            Background="{StaticResource WarningLightBrush}"
                                            CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <Button
                                                    Background="{StaticResource WarningBrush}"
                                                    Click="BtnRevert_Click"
                                                    IsEnabled="{Binding CanRevert}"
                                                    Style="{StaticResource CircleBtn}"
                                                    ToolTip="تراجع">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="White"
                                                        Kind="UndoVariant" />
                                                </Button>
                                                <Button
                                                    Margin="8,0,0,0"
                                                    Background="{StaticResource ErrorBrush}"
                                                    Click="BtnCancelEpisode_Click"
                                                    IsEnabled="{Binding CanCancel}"
                                                    Style="{StaticResource CircleBtn}"
                                                    ToolTip="إلغاء">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="White"
                                                        Kind="Cancel" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                        <Separator Margin="10,0" Style="{StaticResource MaterialDesignSeparator}" />
                                        <!--  ══ إدارة ══  -->
                                        <Border Padding="8,4" CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <Button
                                                    Width="36"
                                                    Height="36"
                                                    Click="BtnEdit_Click"
                                                    Style="{StaticResource Btn.Icon.Edit}"
                                                    ToolTip="تعديل">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Kind="PencilOutline" />
                                                </Button>
                                                <Button
                                                    Width="36"
                                                    Height="36"
                                                    Margin="8,0,0,0"
                                                    Click="BtnDelete_Click"
                                                    Style="{StaticResource Btn.Icon.Delete}"
                                                    ToolTip="حذف">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Kind="DeleteOutline" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
