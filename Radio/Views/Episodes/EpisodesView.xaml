<UserControl
    x:Class="Radio.Views.Episodes.EpisodesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="750"
    d:DesignWidth="1100"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">
    <!--  تمت إزالة FlowDirection و Background لأن View.Base يوفرها مركزياً  -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <!--  استخدام التدرج الجاهز من AppColors بدلاً من كتابة ألوان يدوية  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="RadioFm" />
                        <TextBlock
                            Margin="12,0,0,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="المركز الرئيسي للبث" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="المحرك الأساسي لإدارة المحتوى، الجدولة، والانتشار الرقمي" />
                </StackPanel>

                <!--  استخدام ستايل الزر الجاهز بدلاً من كتابة كل الخصائص يدوياً  -->
                <Button
                    x:Name="BtnAddEpisode"
                    Grid.Column="1"
                    Click="BtnAddEpisode_Click"
                    Content="جدولة حلقة جديدة"
                    Style="{StaticResource Btn.AddNew}" />
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. شريط البحث والإحصائيات (KPIs) ═══════  -->
        <!--  مسافات موحدة (24 من الجوانب، 16 بين الأقسام)  -->
        <Grid Grid.Row="1" Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث: استخدام الستايل الموحد (يحتوي بالفعل على أيقونة البحث)  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                materialDesign:HintAssist.Hint="البحث السريع في سجلات البث..."
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  كرت الإحصائية 1: إجمالي الحلقات  -->
            <materialDesign:Card
                Grid.Column="1"
                Margin="0,0,8,0"
                Padding="16,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="{StaticResource SurfaceVariantBrush}"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource PrimaryMainBrush}"
                        Kind="ChartBoxOutline" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock
                            FontSize="14"
                            Foreground="{StaticResource TextHintBrush}"
                            Text="إجمالي الحلقات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="20"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="0"
                            TextAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!--  كرت الإحصائية 2: تم النشر  -->
            <materialDesign:Card
                Grid.Column="2"
                Margin="0,0,8,0"
                Padding="16,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="{StaticResource SuccessLightBrush}"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource SuccessBrush}"
                        Kind="CloudCheckOutline" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock
                            FontSize="14"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="تم النشر"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="TxtPublished"
                            FontSize="20"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="0"
                            TextAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!--  كرت الإحصائية 3: بانتظار التنفيذ  -->
            <materialDesign:Card
                Grid.Column="3"
                Padding="16,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="{StaticResource WarningLightBrush}"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource WarningBrush}"
                        Kind="ProgressClock" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock
                            FontSize="14"
                            Foreground="{StaticResource WarningBrush}"
                            Text="بانتظار التنفيذ" />
                        <TextBlock
                            x:Name="TxtExecuted"
                            FontSize="20"
                            Foreground="{StaticResource WarningBrush}"
                            Text="0"
                            TextAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!--  ═══════ 3. جدول البيانات ═══════  -->
        <!--  ═══════ 3. بطاقات الحلقات ═══════  -->
        <ListBox
            x:Name="DgEpisodes"
            Grid.Row="2"
            Margin="24,8,24,24"
            Background="Transparent"
            BorderThickness="0"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource MaterialDesignListBox}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card
                        Padding="0"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        Background="{StaticResource SurfaceBrush}"
                        UniformCornerRadius="12">

                        <Grid>
                            <!--  الحدود اليسرى الملونة حسب الحالة  -->
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                CornerRadius="12,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                <Setter Property="Background" Value="{StaticResource SecondaryMainBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <Grid Margin="16,16,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  ═══ المحتوى الرئيسي ═══  -->
                                <StackPanel>

                                    <!--  الصف العلوي: البرنامج + شارة الحالة  -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  شارة البرنامج  -->
                                        <Border
                                            Padding="10,4"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="6">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="14"
                                                    Height="14"
                                                    Margin="0,0,5,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource PrimaryMainBrush}"
                                                    Kind="RadioFm" />
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Foreground="{StaticResource PrimaryMainBrush}"
                                                    Text="{Binding ProgramName}" />
                                            </StackPanel>
                                        </Border>

                                        <!--  شارة الحالة + الوقت  -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">

                                            <Border
                                                Margin="0,0,10,0"
                                                Padding="10,4"
                                                Background="{StaticResource SurfaceVariantBrush}"
                                                CornerRadius="6">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="13"
                                                        Height="13"
                                                        Margin="0,0,4,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource TextHintBrush}"
                                                        Kind="ClockOutline" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        Text="{Binding ScheduledExecutionTime, StringFormat='dddd  dd/MM  hh:mm', ConverterCulture='ar-SA'}" />
                                                </StackPanel>
                                            </Border>

                                            <!--  Chip الحالة  -->
                                            <materialDesign:Chip
                                                Height="26"
                                                Content="{Binding StatusText}"
                                                FontSize="11">
                                                <materialDesign:Chip.Style>
                                                    <Style BasedOn="{StaticResource {x:Type materialDesign:Chip}}" TargetType="materialDesign:Chip">
                                                        <Setter Property="FontSize" Value="11" />
                                                        <Setter Property="Height" Value="26" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                                <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                                <Setter Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                                <Setter Property="Background" Value="{StaticResource SecondaryMainBrush}" />
                                                                <Setter Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                                <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                                                <Setter Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                                <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                                <Setter Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:Chip.Style>
                                            </materialDesign:Chip>

                                        </StackPanel>
                                    </Grid>

                                    <!--  عنوان الحلقة  -->
                                    <TextBlock
                                        Margin="0,10,0,0"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding EpisodeName}" />

                                    <!--  الضيوف  -->
                                    <StackPanel Margin="0,8,0,0">
                                        <!--  رأس الجدول: أيقونة + عنوان (يُخفى عند عدم وجود ضيوف)  -->
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <materialDesign:PackIcon
                                                Width="15"
                                                Height="15"
                                                Margin="0,0,5,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextHintBrush}"
                                                Kind="AccountVoice" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="الضيوف" />
                                        </StackPanel>

                                        <!--  جدول الضيوف  -->
                                        <ItemsControl Margin="20,4,0,0" ItemsSource="{Binding GuestItems}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            MinWidth="60"
                                                            FontSize="12"
                                                            FontWeight="Medium"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            MinWidth="50"
                                                            Margin="8,0,0,0"
                                                            FontSize="11"
                                                            Foreground="{StaticResource TextHintBrush}"
                                                            Text="{Binding HostingTime, StringFormat='hh\\:mm'}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HostingTime}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            Margin="8,0,0,0"
                                                            FontSize="12"
                                                            Foreground="{StaticResource TextHintBrush}"
                                                            Text="{Binding Topic}"
                                                            TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Topic}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Topic}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!--  نص احتياطي عند عدم وجود ضيوف  -->
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding GuestsDisplay}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GuestItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  ملاحظات  -->
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="12"
                                        Foreground="{StaticResource TextHintBrush}"
                                        Text="{Binding SpecialNotes}"
                                        TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </Trigger>
                                                    <Trigger Property="Text" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </StackPanel>

                                <!--  ═══ شريط الإجراءات الجانبي ═══  -->
                                <Border
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Padding="6,0"
                                    Background="{StaticResource SurfaceVariantBrush}"
                                    CornerRadius="8">
                                    <StackPanel VerticalAlignment="Center">

                                        <Button
                                            Width="34"
                                            Height="34"
                                            Padding="0"
                                            Click="BtnMarkExecuted_Click"
                                            Foreground="{StaticResource SecondaryMainBrush}"
                                            IsEnabled="{Binding CanMarkExecuted}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="تنفيذ البث">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                Kind="PlayCircleOutline" />
                                        </Button>

                                        <Button
                                            Width="34"
                                            Height="34"
                                            Padding="0"
                                            Click="BtnMarkPublished_Click"
                                            Foreground="{StaticResource SuccessBrush}"
                                            IsEnabled="{Binding CanMarkPublished}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="النشر الرقمي">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                Kind="CloudUploadOutline" />
                                        </Button>

                                        <Button
                                            Click="BtnToggleWebsitePublish_Click"
                                            Foreground="{StaticResource PrimaryMainBrush}"
                                            IsEnabled="{Binding CanToggleWebsitePublish}"
                                            Style="{StaticResource Btn.Icon}"
                                            ToolTip="النشر عبر الموقع الإلكتروني">
                                            <materialDesign:PackIcon Kind="Web" />
                                        </Button>
                                        <Separator Margin="6,4" Background="{StaticResource DividerBrush}" />

                                        <Button
                                            Width="34"
                                            Height="34"
                                            Padding="0"
                                            Click="BtnEdit_Click"
                                            Style="{StaticResource Btn.Icon.Edit}"
                                            ToolTip="تعديل">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                Kind="PencilOutline" />
                                        </Button>

                                        <Button
                                            Width="34"
                                            Height="34"
                                            Padding="0"
                                            Click="BtnDelete_Click"
                                            Style="{StaticResource Btn.Icon.Delete}"
                                            ToolTip="حذف">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                Kind="DeleteOutline" />
                                        </Button>

                                    </StackPanel>
                                </Border>

                            </Grid>
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>