<mah:MetroWindow
    x:Class="Radio.Views.Episodes.ExecutionLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="توثيق تنفيذ الحلقة"
    Width="540"
    MaxHeight="660"
    SizeToContent="Height"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">
    <!--  تمت إزالة جميع الخصائص المكررة (Background, BorderBrush, GlowBrush, UseNoneWindowStyle)  -->

    <!--  إضافة بطاقة خارجية لتناسب شكل باقي الـ Dialogs  -->
    <materialDesign:Card
        Margin="30"
        Background="{StaticResource SurfaceBrush}"
        UniformCornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ 1. الهيدر (هيدر نجاح مخصص) ═══════  -->
            <!--  استخدام لون ثابت SuccessBrush لأن سياق النافذة هو "إتمام مهمة"  -->
            <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Green}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="CheckDecagram" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Type.TitleLarge.OnColor}" Text="إتمام تنفيذ الحلقة" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="سجّل تفاصيل البث، المدة الفعلية، وأي ملاحظات تقنية" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ 2. المحتوى ═══════  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,24">

                    <!--  حقل المدة  -->
                    <TextBox
                        x:Name="TxtDuration"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="مدة الحلقة الفعلية (بالدقائق) *"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Timer"
                        Style="{StaticResource Input.Text}" />

                    <!--  حقل الملاحظات العامة  -->
                    <TextBox
                        x:Name="TxtNotes"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="تفاصيل سير البث والملاحظات العامة"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="FileDocumentEditOutline"
                        Style="{StaticResource Input.Text.Multiline}" />

                    <!--  حقل المشاكل التقنية  -->
                    <!--  تمت إزالة الـ Card المزيف حوله، الـ Design System الحديث يعتمد على وضوح الـ Hint  -->
                    <TextBox
                        x:Name="TxtIssues"
                        materialDesign:HintAssist.Hint="المشاكل التقنية أو الأعطال (إن وجدت)"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="AlertCircleOutline"
                        Style="{StaticResource Input.Text.Multiline}" />

                    <!--  رسالة توضيحية  -->
                    <Border Margin="0,10" Style="{DynamicResource Card.Info}">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Foreground="#1565C0"
                                Kind="Information"
                                Opacity="0.7" />
                            <TextBlock
                                Margin="12,0"
                                VerticalAlignment="Center"
                                Opacity="0.8"
                                Style="{StaticResource Type.Overline}"
                                Text="* سيتم تحويل حالة الحلقة تلقائياً إلى 'منفذة' عند الحفظ." />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!--  حاوية الإشعارات  -->
            <StackPanel
                x:Name="NotificationHost"
                Grid.Row="1"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Panel.ZIndex="999" />



            <!--  ═══════ 3. الذيل ═══════  -->
            <Border
                Grid.Row="2"
                Padding="24,20"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,16,0"
                Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="إلغاء"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <!--  زر تأكيد التنفيذ (تجاوز لونBtn.Primary ليكون أخضر بنفس هيكلية الزر الأساسي)  -->
                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Background="{StaticResource SuccessBrush}"
                        BorderBrush="{StaticResource SuccessBrush}"
                        Click="BtnSave_Click"
                        Content="تأكيد التنفيذ والحفظ"
                        Style="{StaticResource Btn.Primary}" />

                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>