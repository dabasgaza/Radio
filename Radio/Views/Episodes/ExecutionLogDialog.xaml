<mah:MetroWindow
    x:Class="Radio.Views.Episodes.ExecutionLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="توثيق تنفيذ الحلقة"
    Width="540"
    Height="660"
    Background="{DynamicResource MaterialDesignPaper}"
    BorderBrush="{DynamicResource MaterialDesignDivider}"
    BorderThickness="1"
    FlowDirection="RightToLeft"
    GlowBrush="{DynamicResource SuccessBrush}"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    UseNoneWindowStyle="True"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone
            Padding="20"
            materialDesign:ElevationAssist.Elevation="Dp2"
            Background="{DynamicResource SuccessBrush}"
            Foreground="White"
            Mode="Custom">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon
                    Width="32"
                    Height="32"
                    VerticalAlignment="Center"
                    Kind="CheckDecagram" />

                <StackPanel Grid.Column="1" Margin="16,0">
                    <TextBlock
                        Foreground="White"
                        Style="{StaticResource TitleLarge}"
                        Text="إتمام تنفيذ الحلقة" />
                    <TextBlock
                        FontSize="11"
                        Foreground="White"
                        Opacity="0.9"
                        Text="سجّل تفاصيل البث، المدة الفعلية، وأي ملاحظات تقنية" />
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Click="BtnClose_Click"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="Close" />
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <ScrollViewer
            Grid.Row="1"
            Padding="24,20"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,15">

                <TextBox
                    x:Name="TxtDuration"
                    Margin="0,0,0,24"
                    materialDesign:HintAssist.Hint="مدة الحلقة الفعلية (بالدقائق) *"
                    materialDesign:TextFieldAssist.LeadingIcon="Timer"
                    Style="{StaticResource BroadcastTextBox}" />

                <TextBox
                    x:Name="TxtNotes"
                    Height="120"
                    Margin="0,0,0,24"
                    VerticalContentAlignment="Top"
                    materialDesign:HintAssist.Hint="تفاصيل سير البث والملاحظات العامة"
                    materialDesign:TextFieldAssist.LeadingIcon="FileDocumentEditOutline"
                    AcceptsReturn="True"
                    Style="{StaticResource BroadcastTextBox}"
                    TextWrapping="Wrap" />

                <materialDesign:Card
                    Padding="2"
                    Background="{DynamicResource MaterialDesignDivider}"
                    UniformCornerRadius="8">
                    <TextBox
                        x:Name="TxtIssues"
                        Height="100"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="المشاكل التقنية أو الأعطال (إن وجدت)"
                        materialDesign:TextFieldAssist.LeadingIcon="AlertCircleOutline"
                        AcceptsReturn="True"
                        BorderThickness="0"
                        Style="{StaticResource BroadcastTextBox}"
                        TextWrapping="Wrap" />
                </materialDesign:Card>

                <TextBlock
                    Margin="4,12,0,0"
                    FontSize="11"
                    FontWeight="Medium"
                    Foreground="{DynamicResource SuccessBrush}"
                    Text="* سيتم تحويل حالة الحلقة تلقائياً إلى 'منفذة' عند الحفظ." />
            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Padding="24"
            Background="{DynamicResource MaterialDesignCardBackground}"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="إلغاء"
                    IsCancel="True"
                    Style="{StaticResource CancelFlatButton}" />

                <Button
                    x:Name="BtnSave"
                    Grid.Column="2"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="{DynamicResource SuccessBrush}"
                    BorderBrush="{DynamicResource SuccessBrush}"
                    Click="BtnSave_Click"
                    Content="تأكيد التنفيذ والحفظ"
                    Style="{StaticResource PrimaryActionButton}" />
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>