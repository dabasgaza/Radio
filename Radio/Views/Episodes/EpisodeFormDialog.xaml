<mah:MetroWindow
    x:Class="Radio.Views.Episodes.EpisodeFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات الحلقة"
    Width="600"
    MaxHeight="750"
    SizeToContent="Height"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">
    <!--  تمت إزالة AllowsTransparency و Background لأن Window.Dialog يوفرها  -->
    <!--  تمت إزالة GlowBrush و ShowTitleBar لأن Window.Dialog يلغيها أصلاً  -->

    <materialDesign:Card
        Margin="30"
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource Shadow.Dialog}"
        UniformCornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ 1. الهيدر ═══════  -->
            <!--  استخدام التدرج الأساسي الموحد بدلاً من الألوان العشوائية  -->
            <materialDesign:ColorZone
                Grid.Row="0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="CalendarEdit" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="جدولة حلقة إذاعية" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="يرجى إدخال تفاصيل البرنامج ومواعيد البث" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ 2. المحتوى ═══════  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <!--  مسافات موحدة 24 من الجوانب، و 24 من الأعلى  -->
                <StackPanel Margin="24,24">

                    <!--  صف الـ ComboBoxes  -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  توحيد شكل الـ ComboBox ليتطابق مع Input.Text  -->
                        <ComboBox
                            x:Name="CboPrograms"
                            materialDesign:HintAssist.Hint="البرنامج *"
                            materialDesign:TextFieldAssist.LeadingIcon="Book"
                            DisplayMemberPath="ProgramName"
                            SelectedValuePath="ProgramId"
                            Style="{StaticResource Input.ComboBox}" />

                        <ComboBox
                            x:Name="CboGuests"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="الضيف المشارك"
                            materialDesign:TextFieldAssist.LeadingIcon="AccountVoice"
                            DisplayMemberPath="FullName"
                            SelectedValuePath="GuestId"
                            Style="{StaticResource Input.ComboBox}" />
                    </Grid>

                    <!--  حقل عنوان الحلقة  -->
                    <TextBox
                        x:Name="TxtEpisodeName"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="عنوان الحلقة الرئيسي *"
                        materialDesign:TextFieldAssist.LeadingIcon="PlaylistEdit"
                        Style="{StaticResource Input.Text}" />

                    <!--  صف التاريخ والوقت  -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  توحيد شكل الـ DatePicker  -->
                        <DatePicker
                            x:Name="DpDate"
                            materialDesign:HintAssist.Hint="تاريخ البث"
                            materialDesign:TextFieldAssist.LeadingIcon="CalendarMonthOutline"
                            Style="{StaticResource Input.DatePicker}" />

                        <materialDesign:TimePicker
                            x:Name="TpTime"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="وقت الانطلاق"
                            materialDesign:TextFieldAssist.LeadingIcon="ClockOutline"
                            Style="{StaticResource Input.TimePicker}" />
                    </Grid>

                    <!--  حقل الملاحظات  -->
                    <TextBox
                        x:Name="TxtNotes"
                        materialDesign:HintAssist.Hint="ملاحظات الإنتاج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MessageTextOutline"
                        Style="{StaticResource Input.Text.Multiline}" />

                </StackPanel>
            </ScrollViewer>

            <!--  ═══════ 3. الذيل (تم إصلاحه) ═══════  -->
            <Border
                Grid.Row="2"
                Padding="24,20"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  استخدام ستايل الإلغاء الموحد  -->
                    <Button
                        Grid.Column="0"
                        Content="تراجع"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <!--  استخدام ستايل الزر الأساسي + إضافة الأيقونة بالطريقة الحديثة  -->
                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الحلقة"
                        Style="{StaticResource Btn.Primary}" />

                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>