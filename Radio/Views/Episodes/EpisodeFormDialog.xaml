<mah:MetroWindow
    x:Class="Radio.Views.Episodes.EpisodeFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات الحلقة"
    Width="720"
    MaxHeight="800"
    SizeToContent="Height"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card
        Margin="30"
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource Shadow.Dialog}"
        UniformCornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ 1. الهيدر ═══════  -->
            <materialDesign:ColorZone
                Grid.Row="0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="CalendarEdit" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="جدولة حلقة إذاعية" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="يرجى إدخال تفاصيل البرنامج ومواعيد البث" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ 2. المحتوى ═══════  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,24">

                    <!--  البرنامج  -->
                    <ComboBox
                        x:Name="CboPrograms"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="البرنامج *"
                        materialDesign:TextFieldAssist.LeadingIcon="Book"
                        DisplayMemberPath="ProgramName"
                        SelectedValuePath="ProgramId"
                        Style="{StaticResource Input.ComboBox}" />

                    <!--  عنوان الحلقة  -->
                    <TextBox
                        x:Name="TxtEpisodeName"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="عنوان الحلقة الرئيسي *"
                        materialDesign:TextFieldAssist.LeadingIcon="PlaylistEdit"
                        Style="{StaticResource Input.Text}" />

                    <!--  صف التاريخ والوقت  -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DatePicker
                            x:Name="DpDate"
                            materialDesign:HintAssist.Hint="تاريخ البث"
                            materialDesign:TextFieldAssist.LeadingIcon="CalendarMonthOutline"
                            Style="{StaticResource Input.DatePicker}" />

                        <materialDesign:TimePicker
                            x:Name="TpTime"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="وقت الانطلاق"
                            materialDesign:TextFieldAssist.LeadingIcon="ClockOutline"
                            Style="{StaticResource Input.TimePicker}" />
                    </Grid>

                    <!--  ═══════ قسم الضيوف ═══════  -->
                    <Grid Margin="0,8,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.BodyLarge}"
                            Text="الضيوف المشاركون" />

                        <Button
                            Grid.Column="1"
                            Padding="12,6"
                            Click="BtnAddGuest_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Kind="Plus" />
                                <TextBlock VerticalAlignment="Center" Text="إضافة ضيف" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!--  قائمة الضيوف الديناميكية  -->
                    <ItemsControl ItemsSource="{Binding GuestEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="12"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  اختيار الضيف  -->
                                        <ComboBox
                                            materialDesign:HintAssist.Hint="الضيف"
                                            DisplayMemberPath="FullName"
                                            ItemsSource="{Binding DataContext.AllGuests, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                            SelectedValue="{Binding GuestId, Mode=TwoWay}"
                                            SelectedValuePath="GuestId"
                                            Style="{StaticResource Input.ComboBox}" />

                                        <!--  الموضوع  -->
                                        <TextBox
                                            Grid.Column="2"
                                            materialDesign:HintAssist.Hint="الموضوع"
                                            Style="{StaticResource Input.Text}"
                                            Text="{Binding Topic, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <!--  وقت الاستضافة  -->
                                        <materialDesign:TimePicker
                                            Grid.Column="4"
                                            materialDesign:HintAssist.Hint="الساعة"
                                            SelectedTime="{Binding HostingTime, Mode=TwoWay}"
                                            Style="{StaticResource Input.TimePicker}" />

                                        <!--  زر إزالة  -->
                                        <Button
                                            Grid.Column="6"
                                            VerticalAlignment="Center"
                                            Click="BtnRemoveGuest_Click"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="إزالة الضيف">
                                            <materialDesign:PackIcon Foreground="{DynamicResource MaterialDesignValidationErrorBrush}" Kind="CloseCircleOutline" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  ملاحظات  -->
                    <TextBox
                        x:Name="TxtNotes"
                        materialDesign:HintAssist.Hint="ملاحظات الإنتاج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MessageTextOutline"
                        Style="{StaticResource Input.Text.Multiline}" />

                </StackPanel>
            </ScrollViewer>

            <!--  ═══════ 3. الذيل ═══════  -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="تراجع"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الحلقة"
                        Style="{StaticResource Btn.Primary}" />

                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>