<mah:MetroWindow
    x:Class="Radio.Views.Episodes.EpisodeFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات الحلقة"
    Width="720"
    MaxHeight="800"
    SizeToContent="Height"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card
        Margin="30"
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource Shadow.Dialog}"
        UniformCornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ 1. الهيدر ═══════  -->
            <materialDesign:ColorZone
                Grid.Row="0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="CalendarEdit" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="جدولة حلقة إذاعية" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="يرجى إدخال تفاصيل البرنامج ومواعيد البث" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ 2. المحتوى ═══════  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,24">

                    <!--  البرنامج  -->
                    <ComboBox
                        x:Name="CboPrograms"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="البرنامج *"
                        materialDesign:TextFieldAssist.LeadingIcon="Book"
                        DisplayMemberPath="ProgramName"
                        SelectedValuePath="ProgramId"
                        Style="{StaticResource Input.ComboBox}" />

                    <!--  عنوان الحلقة  -->
                    <TextBox
                        x:Name="TxtEpisodeName"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="عنوان الحلقة الرئيسي *"
                        materialDesign:TextFieldAssist.LeadingIcon="PlaylistEdit"
                        Style="{StaticResource Input.Text}" />

                    <!--  صف التاريخ والوقت  -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DatePicker
                            x:Name="DpDate"
                            materialDesign:HintAssist.Hint="تاريخ البث"
                            materialDesign:TextFieldAssist.LeadingIcon="CalendarMonthOutline"
                            Style="{StaticResource Input.DatePicker}" />

                        <materialDesign:TimePicker
                            x:Name="TpTime"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="وقت الانطلاق"
                            materialDesign:TextFieldAssist.LeadingIcon="ClockOutline"
                            Style="{StaticResource Input.TimePicker}" />
                    </Grid>

                    <!--  ═══════ قسم الضيوف ═══════  -->
                    <TextBlock
                        Margin="0,8,0,10"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PrimaryMainBrush}"
                        Text="الضيوف المشاركون" />

                    <Border
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  ═══ صف الإدخال الثابت — يُفرّغ بعد كل إضافة ═══  -->
                            <Border
                                Padding="12"
                                Background="{StaticResource PrimaryXLightBrush}"
                                CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  اختيار الضيف  -->
                                    <ComboBox
                                        x:Name="CboGuest"
                                        materialDesign:HintAssist.Hint="الضيف"
                                        DisplayMemberPath="FullName"
                                        SelectedValuePath="GuestId"
                                        Style="{StaticResource Input.ComboBox}" />

                                    <!--  الموضوع  -->
                                    <TextBox
                                        x:Name="TxtTopic"
                                        Grid.Column="2"
                                        materialDesign:HintAssist.Hint="الموضوع"
                                        Style="{StaticResource Input.Text}" />

                                    <!--  وقت الاستضافة  -->
                                    <materialDesign:TimePicker
                                        x:Name="TpHostingTime"
                                        Grid.Column="4"
                                        materialDesign:HintAssist.Hint="الساعة"
                                        Style="{StaticResource Input.TimePicker}" />

                                    <!--  زر إضافة / تحديث  -->
                                    <Button
                                        x:Name="BtnAddGuest"
                                        Grid.Column="6"
                                        Width="40"
                                        Height="40"
                                        Click="BtnAddGuest_Click"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="إضافة الضيف للقائمة">
                                        <materialDesign:PackIcon
                                            x:Name="IcoAddGuest"
                                            Foreground="{StaticResource SurfaceBrush}"
                                            Kind="Plus" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!--  ═══ DataGrid — عرض الضيوف المُضافين ═══  -->
                            <DataGrid
                                x:Name="DgGuests"
                                Grid.Row="1"
                                CellStyle="{StaticResource DataGrid.Cell}"
                                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                                ItemsSource="{Binding GuestList}"
                                MouseDoubleClick="DgGuests_MouseDoubleClick"
                                RowStyle="{StaticResource DataGrid.Row}"
                                Style="{StaticResource DataGrid.Main}">

                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding GuestName}"
                                        Header="الضيف" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Topic}"
                                        Header="الموضوع" />
                                    <DataGridTextColumn
                                        Width="130"
                                        Binding="{Binding HostingTimeDisplay}"
                                        Header="الساعة" />
                                    <DataGridTemplateColumn
                                        Width="70"
                                        CanUserResize="False"
                                        CellStyle="{StaticResource DataGrid.Cell.Actions}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Padding="4"
                                                    Click="BtnRemoveGuest_Click"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="إزالة الضيف">
                                                    <materialDesign:PackIcon Foreground="{DynamicResource MaterialDesignValidationErrorBrush}" Kind="CloseCircleOutline" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                        </Grid>
                    </Border>

                    <!--  ملاحظات  -->
                    <TextBox
                        x:Name="TxtNotes"
                        Margin="0,16,0,0"
                        materialDesign:HintAssist.Hint="ملاحظات الإنتاج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MessageTextOutline"
                        Style="{StaticResource Input.Text.Multiline}" />

                </StackPanel>
            </ScrollViewer>

            <!--  ═══════ 3. الذيل ═══════  -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="تراجع"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الحلقة"
                        Style="{StaticResource Btn.Primary}" />

                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>
