<mah:MetroWindow
    x:Class="Radio.Views.Episodes.EpisodeFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="EpisodeFormDialog"
    Width="580"
    Height="660"
    AllowsTransparency="True"
    Background="Transparent"
    GlowBrush="DarkCyan"
    IsWindowDraggable="True"
    ResizeMode="NoResize"
    ShowCloseButton="False"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <mah:MetroWindow.Resources>

        <!--  ══════════════ الألوان (Indigo Cosmic) ══════════════  -->
        <SolidColorBrush x:Key="BgBase" Color="#0C0F16" />
        <SolidColorBrush x:Key="BgInput" Color="#21262F" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A3042" />
        <SolidColorBrush x:Key="TextMain" Color="#E0E4EB" />
        <SolidColorBrush x:Key="TextMuted" Color="#5E6687" />
        <SolidColorBrush x:Key="IndigoMain" Color="#7C4DFF" />
        <SolidColorBrush x:Key="IndigoLight" Color="#B388FF" />
        <SolidColorBrush x:Key="RedAccent" Color="#E54D4D" />

        <!--  ══════════════ التدرجات والتأثيرات ══════════════  -->
        <LinearGradientBrush x:Key="GradIndigoBtn" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#7C4DFF" />
            <GradientStop Offset="1" Color="#B388FF" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradLine" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#7C4DFF" />
            <GradientStop Offset="0.5" Color="#448AFF" />
            <GradientStop Offset="1" Color="#7C4DFF" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradIndigoAvatar" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#7C4DFF" />
            <GradientStop Offset="1" Color="#448AFF" />
        </LinearGradientBrush>
        <DropShadowEffect
            x:Key="GlowIndigo"
            BlurRadius="14"
            Opacity="0.3"
            ShadowDepth="0"
            Color="#7C4DFF" />
        <DropShadowEffect
            x:Key="BtnShadow"
            BlurRadius="18"
            Opacity="0.3"
            ShadowDepth="4"
            Color="#7C4DFF" />
        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="8"
            Opacity="0.4"
            ShadowDepth="2"
            Color="#000000" />

        <!--  ══════════════ تخصيص ألوان حقول MaterialDesign ══════════════  -->
        <SolidColorBrush x:Key="MaterialDesignBrush.Foreground" Color="#E0E4EB" />
        <SolidColorBrush x:Key="MaterialDesignBrush.Background" Color="#21262F" />
        <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#7C4DFF" />

        <!--  ══════════════ زر إغلاق مخصص ══════════════  -->
        <Style x:Key="BtnCloseStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E54D4D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ زر الحفظ ══════════════  -->
        <Style x:Key="BtnSaveStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0C0F16" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="24,0"
                            Background="{StaticResource GradIndigoBtn}"
                            CornerRadius="10"
                            Effect="{StaticResource BtnShadow}"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Margin="0,0,10,0"
                                    Kind="CalendarCheckOutline" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ زر إلغاء ══════════════  -->
        <Style x:Key="BtnCancelStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#5E6687" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#21262F"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="10"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    Kind="Close" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                                <Setter Property="Foreground" Value="#E54D4D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <!--  ═══════════════════════════════════════════  -->
    <!--  التخطيط الرئيسي  -->
    <!--  ═══════════════════════════════════════════  -->
    <Grid Background="#0C0F16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ═══════════ خلفية النافذة ═══════════  -->
        <Border Grid.RowSpan="3" CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#15181F" />
                    <GradientStop Offset="1" Color="#0C0F16" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!--  ═══════════ شريط علوي (Card مدمج) ═══════════  -->
        <Border
            Grid.Row="0"
            Margin="14,14,14,0"
            Background="#181C24"
            BorderBrush="#2A3042"
            BorderThickness="1"
            CornerRadius="12"
            Effect="{StaticResource CardShadow}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  أيقونة + العنوان  -->
                <StackPanel
                    Margin="18,18,0,18"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Width="42"
                        Height="42"
                        Background="{StaticResource GradIndigoAvatar}"
                        CornerRadius="11"
                        Effect="{StaticResource GlowIndigo}">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="CalendarPlusOutline" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="جدولة حلقة جديدة" />
                        <TextBlock
                            Margin="0,3,0,0"
                            FontSize="11"
                            Foreground="#5E6687"
                            Text="حدد البرنامج وموعد البث وتفاصيل الحلقة" />
                    </StackPanel>
                </StackPanel>

                <!--  زر الإغلاق  -->
                <Button
                    Grid.Column="2"
                    Margin="0,0,14,0"
                    Click="BtnClose_Click"
                    Style="{StaticResource BtnCloseStyle}"
                    ToolTip="إغلاق">
                    <materialDesign:PackIcon
                        Width="14"
                        Height="14"
                        Foreground="#5E6687"
                        Kind="Close" />
                </Button>

            </Grid>
        </Border>

        <!--  ═══════════ المحتوى ═══════════  -->
        <ScrollViewer
            Grid.Row="1"
            Margin="14,12,14,8"
            Padding="12,0,12,8"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  البرنامج  -->
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#7C4DFF"
                        Text="البرنامج *" />
                    <ComboBox
                        x:Name="CboPrograms"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="اختر البرنامج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="RadioTower"
                        DisplayMemberPath="ProgramName"
                        SelectedValuePath="ProgramId"
                        Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                </StackPanel>

                <!--  الضيف  -->
                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#5E6687"
                        Text="الضيف المشارك" />
                    <ComboBox
                        x:Name="CboGuests"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="الضيف المشارك (اختياري)"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="AccountVoice"
                        DisplayMemberPath="FullName"
                        SelectedValuePath="GuestId"
                        Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                </StackPanel>

                <!--  اسم الحلقة  -->
                <StackPanel
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#7C4DFF"
                        Text="اسم الحلقة / العنوان *" />
                    <TextBox
                        x:Name="TxtEpisodeName"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="أدخل عنوان الحلقة"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="PlaylistEdit"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </StackPanel>

                <!--  تاريخ البث  -->
                <StackPanel Grid.Row="4" Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#5E6687"
                        Text="تاريخ البث" />
                    <Border
                        Padding="4"
                        Background="#21262F"
                        BorderBrush="#2A3042"
                        BorderThickness="1"
                        CornerRadius="10">
                        <DatePicker
                            x:Name="DpDate"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="14"
                            Foreground="#E0E4EB" />
                    </Border>
                </StackPanel>

                <!--  وقت البث  -->
                <StackPanel Grid.Row="4" Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#5E6687"
                        Text="وقت البث" />
                    <Border
                        Padding="4"
                        Background="#21262F"
                        BorderBrush="#2A3042"
                        BorderThickness="1"
                        CornerRadius="10">
                        <materialDesign:TimePicker
                            x:Name="TpTime"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="14"
                            Foreground="#E0E4EB" />
                    </Border>
                </StackPanel>

                <!--  ملاحظات  -->
                <StackPanel
                    Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,18,0,0">
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="12"
                        FontWeight="Medium"
                        Foreground="#5E6687"
                        Text="ملاحظات خاصة" />
                    <TextBox
                        x:Name="TxtNotes"
                        Height="90"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Foreground="#5E6687"
                        materialDesign:HintAssist.Hint="أي تفاصيل إضافية..."
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="FileDocumentOutline"
                        AcceptsReturn="True"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        TextWrapping="Wrap" />
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!--  ═══════════ التذييل ═══════════  -->
        <Border
            Grid.Row="2"
            Margin="14,0,14,14"
            Padding="14,16"
            Background="#141821"
            BorderBrush="#2A3042"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="إلغاء"
                    IsCancel="True"
                    Style="{StaticResource BtnCancelStyle}" />

                <Button
                    x:Name="BtnSave"
                    Grid.Column="2"
                    Click="BtnSave_Click"
                    Content="حفظ الجدولة"
                    Style="{StaticResource BtnSaveStyle}" />
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>