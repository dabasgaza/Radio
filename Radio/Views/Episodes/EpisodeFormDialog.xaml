<mah:MetroWindow
    x:Class="Radio.Views.Episodes.EpisodeFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات الحلقة"
    Width="600"
    Height="700"
    AllowsTransparency="True"
    Background="Transparent"
    FlowDirection="RightToLeft"
    GlowBrush="#455A64"
    ShowCloseButton="False"
    ShowMaxRestoreButton="False"
    ShowMinButton="False"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <materialDesign:Card
        materialDesign:ElevationAssist.Elevation="Dp2"
        Background="{DynamicResource MaterialDesignPaper}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Padding="24,20"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Foreground="White"
                Mode="Custom"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <materialDesign:ColorZone.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#455A64" />
                        <GradientStop Offset="1" Color="#37474F" />
                    </LinearGradientBrush>
                </materialDesign:ColorZone.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="CalendarEdit" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock
                            x:Name="TxtTitle"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource TitleLarge}"
                            Text="جدولة حلقة إذاعية" />
                        <TextBlock
                            FontSize="11"
                            Foreground="White"
                            Opacity="0.8"
                            Text="يرجى إدخال تفاصيل البرنامج ومواعيد البث" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="28,15"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <Grid Margin="0,10,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            x:Name="CboPrograms"
                            materialDesign:HintAssist.Hint="البرنامج *"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="RadioTower"
                            DisplayMemberPath="ProgramName"
                            SelectedValuePath="ProgramId"
                            Style="{StaticResource BroadcastComboBox}" />

                        <ComboBox
                            x:Name="CboGuests"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="الضيف المشارك"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="AccountVoice"
                            DisplayMemberPath="FullName"
                            SelectedValuePath="GuestId"
                            Style="{StaticResource BroadcastComboBox}" />
                    </Grid>

                    <TextBox
                        x:Name="TxtEpisodeName"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="عنوان الحلقة الرئيسي *"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="PlaylistEdit"
                        Style="{StaticResource BroadcastTextBox}" />

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DatePicker
                            x:Name="DpDate"
                            materialDesign:HintAssist.Hint="تاريخ البث"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="CalendarMonthOutline"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                        <materialDesign:TimePicker
                            x:Name="TpTime"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="وقت الانطلاق"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="ClockOutline"
                            Style="{StaticResource MaterialDesignOutlinedTimePicker}" />
                    </Grid>

                    <TextBox
                        x:Name="TxtNotes"
                        Height="110"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="ملاحظات الإنتاج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MessageTextOutline"
                        AcceptsReturn="True"
                        Style="{StaticResource BroadcastTextBox}"
                        TextWrapping="Wrap" />

                </StackPanel>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="28,24"
                Background="{DynamicResource MaterialDesignDivider}"
                CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="تراجع"
                        IsCancel="True"
                        Style="{StaticResource CancelFlatButton}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp2"
                        Background="#455A64"
                        BorderBrush="#455A64"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الحلقة"
                        Style="{StaticResource PrimaryActionButton}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="CalendarCheck" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>