<UserControl
    x:Class="Radio.Views.Episodes.EpisodeFormControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="860"
    Height="700"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <materialDesign:Card
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource Shadow.Dialog}"
        UniformCornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ 1. الهيدر ═══════  -->
            <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="CalendarEdit" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="جدولة حلقة إذاعية" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="يرجى إدخال تفاصيل البرنامج ومواعيد البث والضيوف والمراسلين" />
                    </StackPanel>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ 2. TabControl ═══════  -->
            <TabControl
                Grid.Row="1"
                materialDesign:ColorZoneAssist.Mode="PrimaryLight"
                Style="{StaticResource Tab.Modern}">

                <!-- ══════════════════════════════════════════
                     Tab 1: المعلومات الأساسية
                ══════════════════════════════════════════ -->
                <TabItem Header="المعلومات الأساسية">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24">

                            <!--  البرنامج  -->
                            <ComboBox
                                x:Name="CbPrograms"
                                Margin="0,0,0,16"
                                materialDesign:HintAssist.Hint="البرنامج الإذاعي *"
                                materialDesign:TextFieldAssist.LeadingIcon="Book"
                                DisplayMemberPath="ProgramName"
                                SelectedValuePath="ProgramId"
                                Style="{StaticResource Input.ComboBox}" />

                            <!--  عنوان الحلقة  -->
                            <TextBox
                                x:Name="TxtEpisodeName"
                                Margin="0,0,0,16"
                                materialDesign:HintAssist.Hint="عنوان الحلقة الرئيسي *"
                                materialDesign:TextFieldAssist.LeadingIcon="PlaylistEdit"
                                Style="{StaticResource Input.Text}" />

                            <!--  التاريخ والوقت  -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <DatePicker
                                    x:Name="DpDate"
                                    materialDesign:HintAssist.Hint="تاريخ البث *"
                                    materialDesign:TextFieldAssist.LeadingIcon="CalendarMonthOutline"
                                    Style="{StaticResource Input.DatePicker}" />

                                <materialDesign:TimePicker
                                    x:Name="TpBroadcastTime"
                                    Grid.Column="2"
                                    materialDesign:HintAssist.Hint="وقت الانطلاق"
                                    materialDesign:TextFieldAssist.LeadingIcon="ClockOutline"
                                    Is24Hours="True"
                                    Style="{StaticResource Input.TimePicker}" />
                            </Grid>

                            <!--  ملاحظات  -->
                            <TextBox
                                x:Name="TxtSpecialNotes"
                                materialDesign:HintAssist.Hint="ملاحظات الإنتاج والتوجيهات الخاصة"
                                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                materialDesign:TextFieldAssist.LeadingIcon="MessageTextOutline"
                                Style="{StaticResource Input.Text.Multiline}" />

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ══════════════════════════════════════════
                     Tab 2: الضيوف
                ══════════════════════════════════════════ -->
                <TabItem Header="الضيوف المشاركون">
                    <Grid Margin="24,16,24,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Margin="0,0,0,10"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Text="الضيوف المشاركون في الحلقة" />

                        <Border
                            Grid.Row="1"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  صف إدخال الضيف  -->
                                <Border
                                    Padding="12"
                                    Background="{StaticResource PrimaryXLightBrush}"
                                    CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox
                                            x:Name="CbAllGuests"
                                            materialDesign:HintAssist.Hint="الضيف"
                                            DisplayMemberPath="FullName"
                                            SelectedValuePath="GuestId"
                                            Style="{StaticResource Input.ComboBox}" />

                                        <TextBox
                                            x:Name="TxtGuestTopic"
                                            Grid.Column="2"
                                            materialDesign:HintAssist.Hint="الموضوع"
                                            Style="{StaticResource Input.Text}" />

                                        <materialDesign:TimePicker
                                            x:Name="TpGuestHostingTime"
                                            Grid.Column="4"
                                            materialDesign:HintAssist.Hint="ساعة الاستضافة"
                                            Is24Hours="True"
                                            Style="{StaticResource Input.TimePicker}" />

                                        <Button
                                            x:Name="BtnAddGuest"
                                            Grid.Column="6"
                                            Width="40"
                                            Height="40"
                                            Click="BtnAddGuest_Click"
                                            Style="{StaticResource Btn.Primary}"
                                            ToolTip="إضافة الضيف للقائمة">
                                            <materialDesign:PackIcon
                                                Foreground="{StaticResource SurfaceBrush}"
                                                Kind="Plus" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!--  جدول الضيوف  -->
                                <DataGrid
                                    x:Name="DgGuests"
                                    Grid.Row="1"
                                    CellStyle="{StaticResource DataGrid.Cell}"
                                    ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                                    RowStyle="{StaticResource DataGrid.Row}"
                                    Style="{StaticResource DataGrid.Main}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding FullName}"
                                            Header="الضيف"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Topic}"
                                            Header="الموضوع" />
                                        <DataGridTextColumn
                                            Width="130"
                                            Binding="{Binding HostingTimeDisplay}"
                                            Header="الساعة"
                                            IsReadOnly="True" />
                                        <DataGridTemplateColumn
                                            Width="70"
                                            CanUserResize="False"
                                            CellStyle="{StaticResource DataGrid.Cell.Actions}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        Padding="4"
                                                        Click="BtnRemoveGuest_Click"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        ToolTip="إزالة الضيف">
                                                        <materialDesign:PackIcon
                                                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                            Kind="CloseCircleOutline" />
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ══════════════════════════════════════════
                     Tab 3: المراسلون
                ══════════════════════════════════════════ -->
                <TabItem Header="المراسلون الميدانيون">
                    <Grid Margin="24,16,24,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Margin="0,0,0,10"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Text="المراسلون الميدانيون المشاركون" />

                        <Border
                            Grid.Row="1"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  صف إدخال المراسل  -->
                                <Border
                                    Padding="12"
                                    Background="{StaticResource PrimaryXLightBrush}"
                                    CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox
                                            x:Name="CbAllCorrespondents"
                                            materialDesign:HintAssist.Hint="المراسل"
                                            DisplayMemberPath="FullName"
                                            SelectedValuePath="CorrespondentId"
                                            Style="{StaticResource Input.ComboBox}" />

                                        <TextBox
                                            x:Name="TxtCorrespondentTopic"
                                            Grid.Column="2"
                                            materialDesign:HintAssist.Hint="موضوع التغطية"
                                            Style="{StaticResource Input.Text}" />

                                        <materialDesign:TimePicker
                                            x:Name="TpCorrespondentHostingTime"
                                            Grid.Column="4"
                                            materialDesign:HintAssist.Hint="وقت الدخول"
                                            Is24Hours="True"
                                            Style="{StaticResource Input.TimePicker}" />

                                        <Button
                                            x:Name="BtnAddCorrespondent"
                                            Grid.Column="6"
                                            Width="40"
                                            Height="40"
                                            Click="BtnAddCorrespondent_Click"
                                            Style="{StaticResource Btn.Primary}"
                                            ToolTip="إضافة المراسل للقائمة">
                                            <materialDesign:PackIcon
                                                Foreground="{StaticResource SurfaceBrush}"
                                                Kind="Plus" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!--  جدول المراسلين  -->
                                <DataGrid
                                    x:Name="DgCorrespondents"
                                    Grid.Row="1"
                                    CellStyle="{StaticResource DataGrid.Cell}"
                                    ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                                    RowStyle="{StaticResource DataGrid.Row}"
                                    Style="{StaticResource DataGrid.Main}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding FullName}"
                                            Header="المراسل"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Topic}"
                                            Header="موضوع التغطية" />
                                        <DataGridTextColumn
                                            Width="130"
                                            Binding="{Binding HostingTimeDisplay}"
                                            Header="وقت الدخول"
                                            IsReadOnly="True" />
                                        <DataGridTemplateColumn
                                            Width="70"
                                            CanUserResize="False"
                                            CellStyle="{StaticResource DataGrid.Cell.Actions}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        Padding="4"
                                                        Click="BtnRemoveCorrespondent_Click"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        ToolTip="إزالة المراسل">
                                                        <materialDesign:PackIcon
                                                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                            Kind="CloseCircleOutline" />
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ══════════════════════════════════════════
                     Tab 4: طاقم التنفيذ
                ══════════════════════════════════════════ -->
                <TabItem Header="طاقم التنفيذ">
                    <Grid Margin="24,16,24,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Margin="0,0,0,10"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Text="طاقم التنفيذ (الاستوديو والإنتاج)" />

                        <Border
                            Grid.Row="1"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  صف إدخال الموظف  -->
                                <Border
                                    Padding="12"
                                    Background="{StaticResource PrimaryXLightBrush}"
                                    CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox
                                            x:Name="CbAllEmployees"
                                            materialDesign:HintAssist.Hint="اختر موظفاً (مخرج · مذيع · فني صوت)"
                                            DisplayMemberPath="FullName"
                                            Style="{StaticResource Input.ComboBox}" />

                                        <Button
                                            x:Name="BtnAddEmployee"
                                            Grid.Column="2"
                                            Width="40"
                                            Height="40"
                                            Click="BtnAddEmployee_Click"
                                            Style="{StaticResource Btn.Primary}"
                                            ToolTip="إضافة للطاقم">
                                            <materialDesign:PackIcon
                                                Foreground="{StaticResource SurfaceBrush}"
                                                Kind="Plus" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!--  جدول الطاقم  -->
                                <DataGrid
                                    x:Name="DgEmployees"
                                    Grid.Row="1"
                                    CellStyle="{StaticResource DataGrid.Cell}"
                                    ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                                    RowStyle="{StaticResource DataGrid.Row}"
                                    Style="{StaticResource DataGrid.Main}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding FullName}"
                                            Header="الموظف"
                                            IsReadOnly="True" />
                                        <DataGridTextColumn
                                            Width="200"
                                            Binding="{Binding StaffRoleName}"
                                            Header="الدور الوظيفي"
                                            IsReadOnly="True" />
                                        <DataGridTemplateColumn
                                            Width="70"
                                            CanUserResize="False"
                                            CellStyle="{StaticResource DataGrid.Cell.Actions}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        Padding="4"
                                                        Click="BtnRemoveEmployee_Click"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        ToolTip="إزالة من الطاقم">
                                                        <materialDesign:PackIcon
                                                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                            Kind="CloseCircleOutline" />
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>

            <!--  ═══════ 3. الذيل ═══════  -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Click="BtnCancel_Click"
                        Content="تراجع"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الحلقة"
                        Style="{StaticResource Btn.Primary}" />
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</UserControl>
