<mah:MetroWindow
    x:Class="Radio.Views.Episodes.EpisodeFormControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="بيانات الحلقة"
    Width="950"
    Height="800"
    FlowDirection="RightToLeft"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <materialDesign:Card
        Style="{StaticResource Card.Form}"
        TextElement.FontFamily="{StaticResource Font.Default}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ 1. الهيدر الأساسي ═══════  -->
            <materialDesign:ColorZone Style="{StaticResource Zone.Header.Dark}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="60"
                        Height="60"
                        Background="#30FFFFFF"
                        CornerRadius="16">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="CalendarEdit" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="18,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="جدولة حلقة إذاعية" />
                        <TextBlock
                            Margin="0,6,0,0"
                            Opacity="0.7"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="يرجى إدخال تفاصيل البرنامج ومواعيد البث والضيوف والمراسلين" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Width="44"
                        Height="44"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ 2. تبويبات أفقية (TabControl Underline) ═══════  -->
            <TabControl
                Grid.Row="1"
                Margin="24,20,24,0"
                Style="{StaticResource Tab.Modern.Underline}">

                <!--  ── التبويب 1: المعلومات الأساسية ──  -->
                <TabItem Style="{StaticResource TabItem.Underline}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource PrimaryMainBrush}"
                                Kind="InformationOutline" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="المعلومات الأساسية" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <!--  شريط لوني علوي  -->
                            <Border
                                Height="3"
                                Margin="0,0,0,16"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource PrimaryMainBrush}"
                                CornerRadius="2" />

                            <!--  برنامج + عنوان الحلقة — صف مزدوج  -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox
                                    x:Name="CbPrograms"
                                    materialDesign:HintAssist.Hint="البرنامج الإذاعي *"
                                    materialDesign:TextFieldAssist.LeadingIcon="Book"
                                    DisplayMemberPath="ProgramName"
                                    SelectedValuePath="ProgramId"
                                    SelectionChanged="CbPrograms_SelectionChanged"
                                    Style="{StaticResource Input.ComboBox}" />

                                <TextBox
                                    x:Name="TxtEpisodeName"
                                    Grid.Column="2"
                                    materialDesign:HintAssist.Hint="عنوان الحلقة الرئيسي *"
                                    materialDesign:TextFieldAssist.LeadingIcon="PlaylistEdit"
                                    Style="{StaticResource Input.Text}" />
                            </Grid>

                            <!--  تاريخ البث + وقت الانطلاق — صف مزدوج  -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <DatePicker
                                    x:Name="DpDate"
                                    materialDesign:HintAssist.Hint="تاريخ البث *"
                                    materialDesign:TextFieldAssist.LeadingIcon="CalendarMonthOutline"
                                    SelectedDateChanged="DpDate_SelectedDateChanged"
                                    Style="{StaticResource Input.DatePicker}" />

                                <materialDesign:TimePicker
                                    x:Name="TpBroadcastTime"
                                    Grid.Column="2"
                                    materialDesign:HintAssist.Hint="وقت الانطلاق"
                                    materialDesign:TextFieldAssist.LeadingIcon="ClockOutline"
                                    Is24Hours="True"
                                    SelectedTimeChanged="TpBroadcastTime_SelectedTimeChanged"
                                    Style="{StaticResource Input.TimePicker}" />
                            </Grid>

                            <!--  لوحة كشف التعارضات  -->
                            <Border
                                x:Name="ConflictPanel"
                                Margin="0,0,0,16"
                                Padding="14,12"
                                CornerRadius="10"
                                Visibility="Collapsed">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="32"
                                        Height="32"
                                        Background="{StaticResource WarningBrush}"
                                        CornerRadius="8">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="White"
                                            Kind="AlertCircleOutline" />
                                    </Border>
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            x:Name="ConflictTitle"
                                            FontSize="{DynamicResource FontSize.Input}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource WarningBrush}"
                                            Text="تعارض محتمل في المواعيد" />
                                        <TextBlock
                                            x:Name="ConflictMessage"
                                            Margin="0,2,0,0"
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="توجد حلقة أخرى في نفس الفترة الزمنية" />
                                    </StackPanel>
                                    <Button
                                        x:Name="BtnConflictDetails"
                                        Grid.Column="2"
                                        Height="30"
                                        Padding="12,0"
                                        Click="BtnConflictDetails_Click"
                                        FontSize="{DynamicResource FontSize.Overline}"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="عرض تفاصيل التعارضات"
                                        Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="14"
                                                Height="14"
                                                Kind="FormatListBulleted" />
                                            <TextBlock Margin="6,0,0,0" Text="التفاصيل" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <!--  ملاحظات الإنتاج  -->
                            <TextBox
                                x:Name="TxtSpecialNotes"
                                materialDesign:HintAssist.Hint="ملاحظات الإنتاج والتوجيهات الخاصة"
                                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                materialDesign:TextFieldAssist.LeadingIcon="MessageTextOutline"
                                Style="{StaticResource Input.Text.Multiline}" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!--  ── التبويب 2: الضيوف المشاركون ──  -->
                <TabItem Style="{StaticResource TabItem.Underline}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryMainBrush}"
                                Kind="AccountGroupOutline" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="الضيوف" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <!--  شريط لوني علوي  -->
                            <Border
                                Height="3"
                                Margin="0,0,0,20"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource SecondaryMainBrush}"
                                CornerRadius="2" />

                            <!--  عنوان القسم + العداد  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="14,10"
                                Background="{StaticResource SecondaryLightBrush}"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource SecondaryMainBrush}"
                                        Kind="AccountGroupOutline" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="{DynamicResource FontSize.Label}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="الضيوف المشاركون" />
                                    <Border
                                        x:Name="GuestBadge"
                                        Grid.Column="2"
                                        Padding="10,4"
                                        Background="{StaticResource SecondaryLightBrush}"
                                        CornerRadius="12">
                                        <TextBlock
                                            x:Name="GuestCountText"
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource SecondaryMainBrush}"
                                            Text="0" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!--  شريط إضافة ضيف  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="16,14"
                                Background="{StaticResource SurfaceVariantBrush}"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox
                                        x:Name="CbAllGuests"
                                        materialDesign:HintAssist.Hint="اختر ضيفاً"
                                        DisplayMemberPath="FullName"
                                        SelectedValuePath="GuestId"
                                        Style="{StaticResource Input.ComboBox}" />

                                    <TextBox
                                        x:Name="TxtGuestTopic"
                                        Grid.Column="2"
                                        materialDesign:HintAssist.Hint="موضوع المشاركة"
                                        Style="{StaticResource Input.Text}" />

                                    <materialDesign:TimePicker
                                        x:Name="TpGuestHostingTime"
                                        Grid.Column="4"
                                        materialDesign:HintAssist.Hint="ساعة الاستضافة"
                                        Is24Hours="True"
                                        Style="{StaticResource Input.TimePicker}" />

                                    <Button
                                        x:Name="BtnAddGuest"
                                        Grid.Column="6"
                                        Width="44"
                                        Height="44"
                                        Click="BtnAddGuest_Click"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="إضافة الضيف للقائمة">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            Foreground="White"
                                            Kind="Plus" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!--  جدول الضيوف  -->
                            <DataGrid
                                x:Name="DgGuests"
                                CellStyle="{StaticResource DataGrid.Cell}"
                                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                                RowStyle="{StaticResource DataGrid.Row}"
                                Style="{StaticResource DataGrid.Main}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding FullName}"
                                        Header="الضيف"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Topic}"
                                        Header="الموضوع" />
                                    <DataGridTextColumn
                                        Width="130"
                                        Binding="{Binding HostingTimeDisplay}"
                                        Header="الساعة"
                                        IsReadOnly="True" />
                                    <DataGridTemplateColumn
                                        Width="70"
                                        CanUserResize="False"
                                        CellStyle="{StaticResource DataGrid.Cell.Actions}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Padding="4"
                                                    Click="BtnRemoveGuest_Click"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="إزالة الضيف">
                                                    <materialDesign:PackIcon Foreground="{DynamicResource MaterialDesignValidationErrorBrush}" Kind="CloseCircleOutline" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!--  ── التبويب 3: المراسلون الميدانيون ──  -->
                <TabItem Style="{StaticResource TabItem.Underline}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource WarningBrush}"
                                Kind="MicrophoneOutline" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="المراسلون" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <!--  شريط لوني علوي  -->
                            <Border
                                Height="3"
                                Margin="0,0,0,20"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource WarningBrush}"
                                CornerRadius="2" />

                            <!--  عنوان القسم + العداد  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="14,10"
                                Background="{StaticResource WarningLightBrush}"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource WarningBrush}"
                                        Kind="MicrophoneOutline" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="{DynamicResource FontSize.Label}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="المراسلون الميدانيون" />
                                    <Border
                                        x:Name="CorrespondentBadge"
                                        Grid.Column="2"
                                        Padding="10,4"
                                        Background="{StaticResource WarningLightBrush}"
                                        CornerRadius="12">
                                        <TextBlock
                                            x:Name="CorrespondentCountText"
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource WarningBrush}"
                                            Text="0" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!--  شريط إضافة مراسل  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="16,14"
                                Background="{StaticResource SurfaceVariantBrush}"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox
                                        x:Name="CbAllCorrespondents"
                                        materialDesign:HintAssist.Hint="اختر مراسلاً"
                                        DisplayMemberPath="FullName"
                                        SelectedValuePath="CorrespondentId"
                                        Style="{StaticResource Input.ComboBox}" />

                                    <TextBox
                                        x:Name="TxtCorrespondentTopic"
                                        Grid.Column="2"
                                        materialDesign:HintAssist.Hint="موضوع التغطية"
                                        Style="{StaticResource Input.Text}" />

                                    <materialDesign:TimePicker
                                        x:Name="TpCorrespondentHostingTime"
                                        Grid.Column="4"
                                        materialDesign:HintAssist.Hint="وقت الدخول"
                                        Is24Hours="True"
                                        Style="{StaticResource Input.TimePicker}" />

                                    <Button
                                        x:Name="BtnAddCorrespondent"
                                        Grid.Column="6"
                                        Width="44"
                                        Height="44"
                                        Click="BtnAddCorrespondent_Click"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="إضافة المراسل للقائمة">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            Foreground="White"
                                            Kind="Plus" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!--  جدول المراسلين  -->
                            <DataGrid
                                x:Name="DgCorrespondents"
                                CellStyle="{StaticResource DataGrid.Cell}"
                                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                                RowStyle="{StaticResource DataGrid.Row}"
                                Style="{StaticResource DataGrid.Main}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding FullName}"
                                        Header="المراسل"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Topic}"
                                        Header="موضوع التغطية" />
                                    <DataGridTextColumn
                                        Width="130"
                                        Binding="{Binding HostingTimeDisplay}"
                                        Header="وقت الدخول"
                                        IsReadOnly="True" />
                                    <DataGridTemplateColumn
                                        Width="70"
                                        CanUserResize="False"
                                        CellStyle="{StaticResource DataGrid.Cell.Actions}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Padding="4"
                                                    Click="BtnRemoveCorrespondent_Click"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="إزالة المراسل">
                                                    <materialDesign:PackIcon Foreground="{DynamicResource MaterialDesignValidationErrorBrush}" Kind="CloseCircleOutline" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!--  ── التبويب 4: طاقم التنفيذ ──  -->
                <TabItem Style="{StaticResource TabItem.Underline}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SuccessBrush}"
                                Kind="Headset" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="طاقم التنفيذ" />
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <!--  شريط لوني علوي  -->
                            <Border
                                Height="3"
                                Margin="0,0,0,20"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource SuccessBrush}"
                                CornerRadius="2" />

                            <!--  عنوان القسم + العداد  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="14,10"
                                Background="{StaticResource SuccessLightBrush}"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource SuccessBrush}"
                                        Kind="Headset" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="{DynamicResource FontSize.Label}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="طاقم التنفيذ" />
                                    <Border
                                        x:Name="StaffBadge"
                                        Grid.Column="2"
                                        Padding="10,4"
                                        Background="{StaticResource SuccessLightBrush}"
                                        CornerRadius="12">
                                        <TextBlock
                                            x:Name="StaffCountText"
                                            FontSize="{DynamicResource FontSize.Overline}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource SuccessBrush}"
                                            Text="0" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!--  شريط إضافة موظف  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="16,14"
                                Background="{StaticResource SurfaceVariantBrush}"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox
                                        x:Name="CbAllEmployees"
                                        materialDesign:HintAssist.Hint="اختر موظفاً (مخرج · مذيع · فني صوت)"
                                        DisplayMemberPath="FullName"
                                        Style="{StaticResource Input.ComboBox}" />

                                    <Button
                                        x:Name="BtnAddEmployee"
                                        Grid.Column="2"
                                        Width="44"
                                        Height="44"
                                        Click="BtnAddEmployee_Click"
                                        Style="{StaticResource Btn.Primary}"
                                        ToolTip="إضافة للطاقم">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            Foreground="White"
                                            Kind="Plus" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!--  جدول طاقم التنفيذ  -->
                            <DataGrid
                                x:Name="DgEmployees"
                                CellStyle="{StaticResource DataGrid.Cell}"
                                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                                RowStyle="{StaticResource DataGrid.Row}"
                                Style="{StaticResource DataGrid.Main}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding FullName}"
                                        Header="الموظف"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="200"
                                        Binding="{Binding StaffRoleName}"
                                        Header="الدور الوظيفي"
                                        IsReadOnly="True" />
                                    <DataGridTemplateColumn
                                        Width="70"
                                        CanUserResize="False"
                                        CellStyle="{StaticResource DataGrid.Cell.Actions}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Padding="4"
                                                    Click="BtnRemoveEmployee_Click"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="إزالة من الطاقم">
                                                    <materialDesign:PackIcon Foreground="{DynamicResource MaterialDesignValidationErrorBrush}" Kind="CloseCircleOutline" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!--  ═══════ 3. الذيل ═══════  -->
            <Border Grid.Row="2" Style="{StaticResource Footer.Form}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  مؤشر الحفظ التلقائي  -->
                    <StackPanel
                        x:Name="PnlAutoSave"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                        <materialDesign:PackIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="CheckCircleOutline" />
                        <TextBlock
                            x:Name="TxtAutoSaveStatus"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource FontSize.Overline}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="تم الحفظ تلقائياً" />
                    </StackPanel>

                    <!--  أزرار الإجراءات  -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button
                            Click="BtnCancel_Click"
                            Content="تراجع"
                            Style="{StaticResource Btn.Cancel}" />
                        <Button
                            x:Name="BtnSave"
                            Margin="12,0,0,0"
                            Click="BtnSave_Click"
                            Style="{StaticResource Btn.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Kind="ContentSaveOutline" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="حفظ بيانات الحلقة" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  حاوية الإشعارات  -->
            <StackPanel
                x:Name="NotificationHost"
                Grid.RowSpan="3"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Panel.ZIndex="999" />
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>
