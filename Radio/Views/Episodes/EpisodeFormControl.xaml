<UserControl
    x:Class="Radio.Views.Episodes.EpisodeFormControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="620"
    d:DesignWidth="900"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon
                    Width="28"
                    Height="28"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextOnPrimaryBrush}"
                    Kind="RadioTower" />
                <StackPanel Margin="14,0,0,0">
                    <TextBlock Style="{StaticResource Type.TitleLarge.OnColor}" Text="إدارة بيانات الحلقة" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="الضيوف · المراسلون · طاقم التنفيذ" />
                </StackPanel>
            </StackPanel>
        </materialDesign:ColorZone>

        <!--  TabControl  -->
        <TabControl
            Grid.Row="1"
            materialDesign:ColorZoneAssist.Mode="PrimaryLight"
            Style="{StaticResource MaterialDesignTabControl}">

            <!-- ══════════════════════════════════════════
                 Tab 1: المعلومات الأساسية
            ══════════════════════════════════════════ -->
            <TabItem Header="المعلومات الأساسية">
                <ScrollViewer Margin="24">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="CbPrograms"
                                materialDesign:HintAssist.Hint="البرنامج الإذاعي *"
                                DisplayMemberPath="ProgramName"
                                SelectedValuePath="ProgramId"
                                Style="{StaticResource Input.ComboBox}" />

                            <DatePicker
                                x:Name="DpDate"
                                Grid.Column="2"
                                materialDesign:HintAssist.Hint="تاريخ البث المجدول *"
                                Style="{StaticResource Input.DatePicker}" />
                        </Grid>

                        <TextBox
                            x:Name="TxtEpisodeName"
                            Margin="0,18,0,0"
                            materialDesign:HintAssist.Hint="عنوان الحلقة / الموضوع الرئيسي *"
                            Style="{StaticResource Input.Text}" />

                        <TextBox
                            x:Name="TxtSpecialNotes"
                            Height="90"
                            Margin="0,18,0,0"
                            materialDesign:HintAssist.Hint="ملاحظات وتوجيهات خاصة للفريق"
                            AcceptsReturn="True"
                            Style="{StaticResource Input.Text.Multiline}"
                            TextWrapping="Wrap"
                            VerticalContentAlignment="Top" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════
                 Tab 2: الضيوف
            ══════════════════════════════════════════ -->
            <TabItem Header="الضيوف">
                <Grid Margin="20,16,20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Input Card  -->
                    <materialDesign:Card
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="CbAllGuests"
                                materialDesign:HintAssist.Hint="اختر ضيفاً"
                                DisplayMemberPath="FullName"
                                Style="{StaticResource Input.ComboBox}" />

                            <TextBox
                                x:Name="TxtGuestTopic"
                                Grid.Column="2"
                                materialDesign:HintAssist.Hint="موضوع المشاركة"
                                Style="{StaticResource Input.Text}" />

                            <materialDesign:TimePicker
                                x:Name="TpGuestHostingTime"
                                Grid.Column="4"
                                materialDesign:HintAssist.Hint="ساعة الاستضافة"
                                Is24Hours="True"
                                Style="{StaticResource MaterialDesignFloatingHintTimePicker}" />

                            <Button
                                Grid.Column="6"
                                Height="52"
                                Padding="20,0"
                                Click="BtnAddGuest_Click"
                                Style="{StaticResource Btn.Primary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        VerticalAlignment="Center"
                                        Kind="AccountPlus" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="إضافة" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </materialDesign:Card>

                    <!--  Guests DataGrid  -->
                    <materialDesign:Card
                        Grid.Row="2"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="10">
                        <DataGrid
                            x:Name="DgGuests"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CellStyle="{StaticResource DataGrid.Cell}"
                            ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                            RowStyle="{StaticResource DataGrid.Row}"
                            Style="{StaticResource DataGrid.Main}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="200"
                                    Binding="{Binding FullName}"
                                    Header="اسم الضيف"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Topic}"
                                    Header="موضوع المشاركة" />
                                <DataGridTextColumn
                                    Width="130"
                                    Binding="{Binding HostingTimeDisplay}"
                                    CellStyle="{StaticResource DataGrid.Cell.Center}"
                                    Header="ساعة الاستضافة"
                                    IsReadOnly="True" />
                                <DataGridTemplateColumn
                                    Width="60"
                                    CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                    Header="حذف">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Click="BtnRemoveGuest_Click"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="حذف">
                                                <materialDesign:PackIcon
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="{DynamicResource ErrorBrush}"
                                                    Kind="TrashCanOutline" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════
                 Tab 3: المراسلون
            ══════════════════════════════════════════ -->
            <TabItem Header="المراسلون الميدانيون">
                <Grid Margin="20,16,20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Input Card  -->
                    <materialDesign:Card
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="CbAllCorrespondents"
                                materialDesign:HintAssist.Hint="اختر مراسلاً"
                                DisplayMemberPath="FullName"
                                Style="{StaticResource Input.ComboBox}" />

                            <TextBox
                                x:Name="TxtCorrespondentTopic"
                                Grid.Column="2"
                                materialDesign:HintAssist.Hint="موضوع التغطية"
                                Style="{StaticResource Input.Text}" />

                            <materialDesign:TimePicker
                                x:Name="TpCorrespondentHostingTime"
                                Grid.Column="4"
                                materialDesign:HintAssist.Hint="وقت الدخول"
                                Is24Hours="True"
                                Style="{StaticResource MaterialDesignFloatingHintTimePicker}" />

                            <Button
                                Grid.Column="6"
                                Height="52"
                                Padding="20,0"
                                Click="BtnAddCorrespondent_Click"
                                Style="{StaticResource Btn.Primary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        VerticalAlignment="Center"
                                        Kind="MapMarkerPlus" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="إضافة" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </materialDesign:Card>

                    <!--  Correspondents DataGrid  -->
                    <materialDesign:Card
                        Grid.Row="2"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="10">
                        <DataGrid
                            x:Name="DgCorrespondents"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CellStyle="{StaticResource DataGrid.Cell}"
                            ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                            RowStyle="{StaticResource DataGrid.Row}"
                            Style="{StaticResource DataGrid.Main}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="200"
                                    Binding="{Binding FullName}"
                                    Header="اسم المراسل"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Topic}"
                                    Header="موضوع التغطية" />
                                <DataGridTextColumn
                                    Width="130"
                                    Binding="{Binding HostingTimeDisplay}"
                                    CellStyle="{StaticResource DataGrid.Cell.Center}"
                                    Header="وقت الدخول"
                                    IsReadOnly="True" />
                                <DataGridTemplateColumn
                                    Width="60"
                                    CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                    Header="حذف">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Click="BtnRemoveCorrespondent_Click"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="حذف">
                                                <materialDesign:PackIcon
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="{DynamicResource ErrorBrush}"
                                                    Kind="TrashCanOutline" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════
                 Tab 4: طاقم التنفيذ
            ══════════════════════════════════════════ -->
            <TabItem Header="طاقم التنفيذ">
                <Grid Margin="20,16,20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Input Card  -->
                    <materialDesign:Card
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="CbAllEmployees"
                                materialDesign:HintAssist.Hint="اختر موظفاً من الطاقم (مخرج · مذيع · فني صوت)"
                                DisplayMemberPath="FullName"
                                Style="{StaticResource Input.ComboBox}" />

                            <Button
                                Grid.Column="2"
                                Height="52"
                                Padding="20,0"
                                Click="BtnAddEmployee_Click"
                                Style="{StaticResource Btn.Primary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        VerticalAlignment="Center"
                                        Kind="AccountCog" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="إضافة للطاقم" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </materialDesign:Card>

                    <!--  Employees DataGrid  -->
                    <materialDesign:Card
                        Grid.Row="2"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="10">
                        <DataGrid
                            x:Name="DgEmployees"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CellStyle="{StaticResource DataGrid.Cell}"
                            ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                            RowStyle="{StaticResource DataGrid.Row}"
                            Style="{StaticResource DataGrid.Main}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding FullName}"
                                    Header="اسم الموظف"
                                    IsReadOnly="True" />
                                <DataGridTextColumn
                                    Width="200"
                                    Binding="{Binding StaffRoleName}"
                                    CellStyle="{StaticResource DataGrid.Cell.Center}"
                                    Header="الدور الوظيفي"
                                    IsReadOnly="True" />
                                <DataGridTemplateColumn
                                    Width="60"
                                    CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                    Header="حذف">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Click="BtnRemoveEmployee_Click"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="حذف">
                                                <materialDesign:PackIcon
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="{DynamicResource ErrorBrush}"
                                                    Kind="TrashCanOutline" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

        </TabControl>

        <!--  Footer Buttons  -->
        <Border
            Grid.Row="2"
            Padding="20,14"
            Background="{DynamicResource MaterialDesignDivider}"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <Button
                    x:Name="BtnSave"
                    Width="140"
                    Height="40"
                    Click="BtnSave_Click"
                    Style="{StaticResource Btn.Primary}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center"
                            Kind="ContentSave" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="حفظ البيانات" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="BtnCancel"
                    Width="100"
                    Margin="12,0,0,0"
                    Click="BtnCancel_Click"
                    Content="إلغاء"
                    Style="{StaticResource Btn.Cancel}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
