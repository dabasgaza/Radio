<UserControl
    x:Class="Radio.Views.Episodes.PublishingRecordsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Style="{StaticResource View.Base}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر ═══════  -->
        <materialDesign:ColorZone
            Padding="24,16"
            materialDesign:ElevationAssist.Elevation="Dp2"
            Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="ClipboardTextOutline" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="سجلات النشر" />
                    </StackPanel>
                    <TextBlock
                        Margin="36,4,0,0"
                        Opacity="0.8"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="عرض وتعديل جميع سجلات التنفيذ والنشر الرقمي ونشر الموقع الإلكتروني" />
                </StackPanel>

                <!--  زر إعادة تحميل السجلات  -->
                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="BtnRefresh_Click"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="إعادة تحميل السجلات">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        Foreground="White"
                        Kind="Refresh" />
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <!--  Stats Dashboard  -->
        <UniformGrid
            Grid.Row="1"
            Margin="24,20,24,0"
            Columns="3">
            <materialDesign:Card Margin="0,0,12,0" Style="{StaticResource Card.Stat}">
                <StackPanel>
                    <Border Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="LayersOutline" />
                    </Border>
                    <TextBlock Style="{StaticResource Type.Caption}" Text="إجمالي السجلات" />
                    <TextBlock
                        x:Name="TxtTotalRecords"
                        Style="{StaticResource Type.Numeric.Large}"
                        Text="0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="6,0" Style="{StaticResource Card.Stat}">
                <StackPanel>
                    <Border Style="{StaticResource StatIcon.Success}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="CalendarCheck" />
                    </Border>
                    <TextBlock Style="{StaticResource Type.Caption}" Text="سجلات اليوم" />
                    <TextBlock
                        x:Name="TxtTodayRecords"
                        Style="{StaticResource Type.Numeric.Large}"
                        Text="0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="12,0,0,0" Style="{StaticResource Card.Stat}">
                <StackPanel>
                    <Border Style="{StaticResource StatIcon.Info}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource InfoBrush}"
                            Kind="GlobeModel" />
                    </Border>
                    <TextBlock Style="{StaticResource Type.Caption}" Text="تغطية المنصات" />
                    <TextBlock
                        x:Name="TxtPlatformCoverage"
                        Style="{StaticResource Type.Numeric.Large}"
                        Text="0" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <!--  ═══════ 2. شريط البحث والفلترة ═══════  -->
        <Grid Grid.Row="2" Margin="24,20,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                VerticalAlignment="Stretch"
                materialDesign:HintAssist.Hint="البحث في السجلات (اسم الحلقة، البرنامج، الضيف...)"
                materialDesign:TextFieldAssist.HasClearButton="True"
                materialDesign:TextFieldAssist.PrefixText="🔍"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  فلتر النوع  -->
            <ComboBox
                x:Name="CmbRecordType"
                Grid.Column="2"
                VerticalAlignment="Stretch"
                materialDesign:HintAssist.Hint="نوع السجل"
                materialDesign:TextFieldAssist.LeadingIcon="FilterOutline"
                SelectedIndex="0"
                SelectionChanged="CmbRecordType_SelectionChanged"
                Style="{StaticResource Input.ComboBox}">
                <ComboBoxItem Content="الكل" Tag="All" />
                <ComboBoxItem Content="✅ التنفيذ" Tag="Execution" />
                <ComboBoxItem Content="📱 النشر الرقمي" Tag="SocialMedia" />
                <ComboBoxItem Content="🌐 نشر الموقع" Tag="Website" />
            </ComboBox>
        </Grid>

        <!--  ═══════ 3. قائمة السجلات ═══════  -->
        <ListBox
            x:Name="DgRecords"
            Grid.Row="3"
            Margin="24,8,24,24"
            Background="Transparent"
            BorderThickness="0"
            MouseDoubleClick="DgRecords_MouseDoubleClick"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource MaterialDesignListBox}">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,12" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card
                        Padding="0"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        Background="{StaticResource SurfaceBrush}"
                        UniformCornerRadius="12">

                        <materialDesign:Card.Style>
                            <Style TargetType="materialDesign:Card">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:Card.Style>

                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  أيقونة النوع  -->
                            <Border
                                Width="44"
                                Height="44"
                                VerticalAlignment="Center"
                                Background="{Binding RecordColor}"
                                CornerRadius="10"
                                Opacity="0.1" />
                            <materialDesign:PackIcon
                                Width="22"
                                Height="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{Binding RecordColor}"
                                Kind="{Binding RecordIcon}" />

                            <!--  تفاصيل السجل  -->
                            <StackPanel
                                Grid.Column="1"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Style="{StaticResource Type.BodyLarge}"
                                    Text="{Binding Summary}"
                                    TextTrimming="CharacterEllipsis" />
                                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextHintBrush}"
                                        Kind="MovieEditOutline" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Style="{StaticResource Type.Caption}"
                                        TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding EpisodeName, Mode=OneWay}" />
                                        <Run Text=" | " />
                                        <Run Text="{Binding ProgramName, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextHintBrush}"
                                        Kind="ClockOutline" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        Foreground="{StaticResource TextHintBrush}"
                                        Style="{StaticResource Type.Overline}">
                                        <Run Text="{Binding RecordedBy, Mode=OneWay}" />
                                        <Run Text=" • " />
                                        <Run Text="{Binding RecordDate, StringFormat='yyyy/MM/dd hh:mm tt', Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!--  شارة النوع  -->
                            <Border
                                Grid.Column="2"
                                Padding="12,6"
                                VerticalAlignment="Center"
                                CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource DividerBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecordType}" Value="Execution">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RecordType}" Value="SocialMedia">
                                                <Setter Property="Background" Value="#E3F2FD" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RecordType}" Value="Website">
                                                <Setter Property="Background" Value="#EDE7F6" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style BasedOn="{StaticResource Type.Overline}" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                            <Setter Property="Text" Value="—" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RecordType}" Value="Execution">
                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                    <Setter Property="Text" Value="تنفيذ الحلقة" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RecordType}" Value="SocialMedia">
                                                    <Setter Property="Foreground" Value="#1565C0" />
                                                    <Setter Property="Text" Value="نشر رقمي" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RecordType}" Value="Website">
                                                    <Setter Property="Foreground" Value="#6A1B9A" />
                                                    <Setter Property="Text" Value="نشر الموقع" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!--  زر التعديل  -->
                            <Button
                                Grid.Column="3"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center"
                                Click="BtnEditRecord_Click"
                                Style="{StaticResource Btn.Icon.Edit}"
                                ToolTip="تعديل السجل">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Kind="Pencil" />
                            </Button>

                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
