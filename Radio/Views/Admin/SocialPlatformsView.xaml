<UserControl
    x:Class="Radio.Views.Admin.SocialPlatformsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Width="1000"
    Height="700"
    Style="{StaticResource View.Base}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════ 1. الهيدر (Header) ═══════  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="FacebookWorkplace" />
                        <TextBlock
                            Margin="12,0,0,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إدارة منصات التواصل الاجتماعي" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="تنظيم قنوات النشر الرقمي وربطها بدورة البث الإذاعي" />
                </StackPanel>

                <Button
                    x:Name="BtnAddNew"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="BtnAddNew_Click"
                    Style="{StaticResource Btn.AddNew}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlusThick" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="إضافة منصة" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <!--  ═══════ 2. شريط البحث والإحصائيات ═══════  -->
        <Grid Grid.Row="1" Margin="24,20,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Stretch"
                materialDesign:HintAssist.Hint="البحث باسم المنصة..."
                materialDesign:TextFieldAssist.HasClearButton="True"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <materialDesign:Card
                Grid.Column="1"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="ShareVariant" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextHintBrush}"
                            Text="إجمالي المنصات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!--  ═══════ 3. جدول البيانات ═══════  -->
        <materialDesign:Card
            Grid.Row="2"
            Margin="24,10,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="14">
            <DataGrid
                x:Name="DataGrid"
                AutoGenerateColumns="False"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                IsReadOnly="True"
                RowStyle="{StaticResource DataGrid.Row}"
                SelectionMode="Single"
                Style="{StaticResource DataGrid.Main}">

                <DataGrid.Columns>
                    <!--  عمود اسم المنصة مع أيقونة  -->
                    <DataGridTemplateColumn
                        Width="*"
                        CellStyle="{StaticResource DataGrid.Cell.First}"
                        Header="اسم المنصة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="34"
                                        Height="34"
                                        Background="{StaticResource PrimaryXLightBrush}"
                                        CornerRadius="8">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource PrimaryMainBrush}"
                                            Kind="{Binding Icon, TargetNullValue=ShareVariant, FallbackValue=ShareVariant}" />
                                    </Border>
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود رمز الأيقونة  -->
                    <DataGridTemplateColumn
                        Width="200"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="رمز الأيقونة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    MinWidth="80"
                                    Padding="12,5"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    CornerRadius="14">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Text="{Binding Icon, TargetNullValue=—}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الإجراءات  -->
                    <DataGridTemplateColumn
                        Width="150"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource Btn.Icon.Edit}"
                                        Tag="{Binding}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Margin="8,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource Btn.Icon.Delete}"
                                        Tag="{Binding}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="DeleteOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!--  شريط التحميل  -->
        <ProgressBar
            x:Name="ProgressBar"
            Grid.Row="2"
            Margin="24,10,24,0"
            VerticalAlignment="Top"
            IsIndeterminate="True"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
