<UserControl
    x:Class="Radio.Views.Home.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="750"
    d:DesignWidth="1200"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24,28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ═══════════════ 1. HERO WELCOME BANNER ═══════════════  -->
            <Border
                Grid.Row="0"
                Margin="0,0,0,24"
                Background="{StaticResource HeaderGradientBrush}"
                CornerRadius="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Clock Circle  -->
                    <Border
                        Width="88"
                        Height="88"
                        Margin="24"
                        Background="#18FFFFFF"
                        CornerRadius="44">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                x:Name="TxtClock"
                                HorizontalAlignment="Center"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="00:00:00" />
                        </StackPanel>
                    </Border>

                    <!--  Greeting + Subtitle  -->
                    <StackPanel
                        Grid.Column="1"
                        Margin="0,24"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtGreeting"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="مرحباً بك" />
                        <TextBlock
                            x:Name="TxtDate"
                            Margin="0,4,0,0"
                            FontSize="13"
                            Foreground="#CCFFFFFF"
                            Text="..." />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="13"
                            Foreground="#AAFFFFFF"
                            Text="نظرة عامة على سير العمل والنشاط الميداني لليوم" />
                    </StackPanel>

                    <!--  Broadcast Status  -->
                    <Border
                        Grid.Column="2"
                        Height="32"
                        Margin="0,0,24,0"
                        Padding="14,0"
                        VerticalAlignment="Center"
                        Background="#20FFFFFF"
                        CornerRadius="16">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                x:Name="BroadcastDot"
                                Width="8"
                                Height="8"
                                VerticalAlignment="Center"
                                Fill="{StaticResource SuccessBrush}" />
                            <TextBlock
                                x:Name="TxtBroadcastStatus"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="لا يوجد بث مباشر" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!--  ═══════════════ 2. PREMIUM STAT CARDS ═══════════════  -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Card 1: Today's Episodes  -->
                <Border
                    Margin="6,0"
                    Background="White"
                    CornerRadius="16"
                    Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetProperty="Opacity"
                                        To="0.08"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="48"
                            Height="48"
                            Background="{StaticResource PrimaryXLightBrush}"
                            CornerRadius="14">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource PrimaryMainBrush}"
                                Kind="CalendarStar" />
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="TxtTodayCount"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="0" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="حلقات اليوم" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Card 2: Scheduled Guests  -->
                <Border
                    Grid.Column="1"
                    Margin="6,0"
                    Background="White"
                    CornerRadius="16"
                    Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="48"
                            Height="48"
                            Background="{StaticResource SuccessLightBrush}"
                            CornerRadius="14">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SuccessBrush}"
                                Kind="AccountVoice" />
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="TxtGuestCount"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="0" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="ضيوف مجدولين" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Card 3: Pending Execution  -->
                <Border
                    Grid.Column="2"
                    Margin="6,0"
                    Background="White"
                    CornerRadius="16"
                    Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="48"
                            Height="48"
                            Background="{StaticResource WarningLightBrush}"
                            CornerRadius="14">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource WarningBrush}"
                                Kind="History" />
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="TxtPendingLogs"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="0" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="سجلات قيد التنفيذ" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Card 4: Active Users  -->
                <Border
                    Grid.Column="3"
                    Margin="6,0"
                    Background="White"
                    CornerRadius="16"
                    Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="48"
                            Height="48"
                            Background="{StaticResource InfoLightBrush}"
                            CornerRadius="14">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource InfoBrush}"
                                Kind="ShieldAccount" />
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="TxtActiveUsers"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="0" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="مستخدمين نشطين" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!--  ═══════════════ 3. CONTENT AREA ═══════════════  -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  ═══ Right: Today's Episodes Table ═══  -->
                <Border
                    Margin="0,0,12,0"
                    Background="White"
                    CornerRadius="16"
                    Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <Grid Margin="0,0,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Grid Margin="20,20,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon
                                VerticalAlignment="Center"
                                Foreground="{StaticResource PrimaryMainBrush}"
                                Kind="PlaylistPlay" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="حلقات اليوم" />
                            <Border
                                Grid.Column="2"
                                Height="24"
                                MinWidth="24"
                                Padding="8,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource PrimaryXLightBrush}"
                                CornerRadius="12">
                                <TextBlock
                                    x:Name="TxtEpisodeCountBadge"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource PrimaryMainBrush}"
                                    Text="0" />
                            </Border>
                        </Grid>

                        <!--  DataGrid  -->
                        <DataGrid
                            x:Name="DgTodayEpisodes"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            AutoGenerateColumns="False"
                            CellStyle="{StaticResource DataGrid.Cell}"
                            ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                            IsReadOnly="True"
                            Style="{StaticResource DataGrid.Main}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="80"
                                    Binding="{Binding ScheduledExecutionTime, StringFormat=hh:mm tt}"
                                    Header="الوقت" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding EpisodeName}"
                                    Header="الحلقة" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding ProgramName}"
                                    Header="البرنامج" />
                                <DataGridTemplateColumn Width="120" Header="الحالة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Height="24"
                                                Padding="10,0"
                                                CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                                <Setter Property="Background" Value="{StaticResource ErrorLightBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <TextBlock.Text>
                                                        <Binding Path="StatusText" />
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!--  ═══ Left: Announcement + Active Programs ═══  -->
                <StackPanel Grid.Column="1" Margin="12,0,0,0">

                    <!--  Announcement Card (Glass)  -->
                    <Border
                        Padding="24"
                        Background="{StaticResource DialogHeaderInfoBrush}"
                        CornerRadius="16">
                        <Grid>
                            <materialDesign:PackIcon
                                Width="80"
                                Height="80"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="InformationOutline"
                                Opacity="0.1" />
                            <StackPanel>
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="ملاحظة النظام" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="12"
                                    Foreground="#DDFFFFFF"
                                    Text="يرجى مراجعة كافة سجلات التنفيذ قبل نهاية الدوام الرسمي لضمان أرشفة التقارير بشكل صحيح."
                                    TextWrapping="Wrap" />
                                <Button
                                    Margin="0,14,0,0"
                                    Padding="16,6"
                                    HorizontalAlignment="Right"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Background="#22FFFFFF"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Foreground="White"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            VerticalAlignment="Center"
                                            Kind="ArrowLeft" />
                                        <TextBlock
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="فتح التقارير" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Active Programs Card  -->
                    <Border
                        Margin="0,16,0,0"
                        Padding="20"
                        Background="White"
                        CornerRadius="16"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Header  -->
                            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource PrimaryMainBrush}"
                                    Kind="RadioTower" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="البرامج النشطة" />
                            </StackPanel>

                            <!--  Programs List  -->
                            <ItemsControl x:Name="IcActivePrograms" Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    Text="{Binding ProgramName}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource PrimaryMainBrush}"
                                                    Text="{Binding TotalEpisodes}" />
                                            </Grid>
                                            <ProgressBar
                                                Grid.Row="1"
                                                Height="5"
                                                Margin="0,6,0,0"
                                                materialDesign:TransitionAssist.DisableTransitions="False"
                                                Background="{StaticResource DividerBrush}"
                                                BorderThickness="0"
                                                Foreground="{StaticResource PrimaryMainBrush}"
                                                Maximum="{Binding TotalEpisodes}"
                                                Value="{Binding PublishedEpisodes}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
