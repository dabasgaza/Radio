<mah:MetroWindow
    x:Class="Radio.Views.Employees.EmployeeFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="{Binding Title, RelativeSource={RelativeSource Self}}"
    Width="520"
    Height="450"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card Margin="30" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <materialDesign:ColorZone Padding="24,20" Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Kind="AccountBadge" />

                    <StackPanel Grid.Column="1" Margin="16,0">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="{Binding Title, RelativeSource={RelativeSource Self}}" />
                        <TextBlock Style="{StaticResource Type.BodyMedium.OnColor}" Text="أدخل البيانات الأساسية للموظف" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  Form fields  -->
            <ScrollViewer
                Grid.Row="1"
                Padding="28,20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBox
                        x:Name="TxtFullName"
                        materialDesign:HintAssist.Hint="الاسم الكامل *"
                        materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                        Style="{StaticResource Input.Text}" />

                    <ComboBox
                        x:Name="CmbStaffRole"
                        materialDesign:HintAssist.Hint="الدور الوظيفي"
                        materialDesign:TextFieldAssist.LeadingIcon="BadgeAccountOutline"
                        DisplayMemberPath="RoleName"
                        SelectedValuePath="StaffRoleId"
                        Style="{StaticResource Input.ComboBox}" />

                    <TextBox
                        x:Name="TxtNotes"
                        Height="100"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="ملاحظات"
                        materialDesign:TextFieldAssist.LeadingIcon="NoteOutline"
                        AcceptsReturn="True"
                        Style="{StaticResource Input.Text.Multiline}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!--  Footer  -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="إلغاء"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ الموظف"
                        Style="{StaticResource Btn.Primary}" />
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>