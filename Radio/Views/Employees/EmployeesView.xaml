<UserControl
    x:Class="Radio.Views.Employees.EmployeesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="35"
                            Height="35"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="AccountGroup" />
                        <TextBlock
                            Margin="15,0"
                            Style="{StaticResource Type.Headline.OnColor}"
                            Text="منظومة إدارة الموظفين" />
                    </StackPanel>
                    <TextBlock
                        Margin="50,5,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="إدارة ملفات الموظفين، تتبع البيانات الوظيفية، وتنظيم الهيكل الإداري" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Click="BtnAdd_Click"
                    Style="{StaticResource Btn.AddNew}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon VerticalAlignment="Center" Kind="Plus" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="موظف جديد" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <!--  Quick Stats  -->
        <UniformGrid
            Grid.Row="1"
            Margin="24,20,24,0"
            Columns="3">
            <materialDesign:Card Margin="0,0,12,0" Style="{StaticResource Card.Stat}">
                <StackPanel>
                    <Border Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="AccountMultiple" />
                    </Border>
                    <TextBlock Style="{StaticResource Type.Caption}" Text="إجمالي الموظفين" />
                    <TextBlock
                        x:Name="TxtTotalEmployees"
                        Style="{StaticResource Type.Numeric.Large}"
                        Text="0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="6,0" Style="{StaticResource Card.Stat}">
                <StackPanel>
                    <Border Style="{StaticResource StatIcon.Success}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="AccountCheck" />
                    </Border>
                    <TextBlock Style="{StaticResource Type.Caption}" Text="الموظفين النشطين" />
                    <TextBlock
                        x:Name="TxtActiveEmployees"
                        Style="{StaticResource Type.Numeric.Large}"
                        Text="0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="12,0,0,0" Style="{StaticResource Card.Stat}">
                <StackPanel>
                    <Border Style="{StaticResource StatIcon.Warning}">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource WarningBrush}"
                            Kind="ShieldAccount" />
                    </Border>
                    <TextBlock Style="{StaticResource Type.Caption}" Text="الأدوار المشغولة" />
                    <TextBlock
                        x:Name="TxtOccupiedRoles"
                        Style="{StaticResource Type.Numeric.Large}"
                        Text="0" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <!--  Search  -->
        <Grid Grid.Row="2" Margin="24,20,24,10">
            <TextBox
                x:Name="TxtSearch"
                materialDesign:HintAssist.Hint="بحث عن موظف..."
                materialDesign:TextFieldAssist.PrefixText="🔍"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />
        </Grid>

        <!--  DataGrid  -->
        <materialDesign:Card
            Grid.Row="3"
            Margin="24,10,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="12">
            <DataGrid
                x:Name="DgEmployees"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding FullName}"
                        Header="الاسم الكامل" />
                    <DataGridTextColumn
                        Width="180"
                        Binding="{Binding StaffRoleName}"
                        Header="الدور الوظيفي" />
                    <DataGridTextColumn
                        Width="200"
                        Binding="{Binding Notes}"
                        Header="ملاحظات" />
                    <DataGridTemplateColumn
                        Width="100"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource Btn.Icon.Edit}"
                                        Tag="{Binding EmployeeId}">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Kind="Pencil" />
                                    </Button>
                                    <Button
                                        Margin="8,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource Btn.Icon.Delete}"
                                        Tag="{Binding EmployeeId}">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Kind="Delete" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>