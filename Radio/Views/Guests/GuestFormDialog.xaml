<mah:MetroWindow
    x:Class="Radio.Views.Guests.GuestFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بيانات الضيف"
    Width="600"
    Height="620"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card Margin="30" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Padding="24,20" Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="AccountVoice" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إضافة ضيف جديد" />
                        <TextBlock Style="{StaticResource Type.BodyMedium.OnColor}" Text="أدخل البيانات التعريفية للضيف وتفاصيل التواصل" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="28,20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="TxtName"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="الاسم الكامل *"
                            materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                            Style="{StaticResource Input.Text}" />

                        <TextBox
                            x:Name="TxtOrg"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="المؤسسة / الجهة"
                            materialDesign:TextFieldAssist.LeadingIcon="Domain"
                            Style="{StaticResource Input.Text}" />
                    </Grid>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="TxtPhone"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="رقم الهاتف"
                            materialDesign:TextFieldAssist.LeadingIcon="PhoneOutline"
                            Style="{StaticResource Input.Text}" />

                        <TextBox
                            x:Name="TxtEmail"
                            Grid.Column="2"
                            Grid.ColumnSpan="3"
                            materialDesign:HintAssist.Hint="البريد الإلكتروني"
                            materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                            Style="{StaticResource Input.Text}" />
                    </Grid>

                    <TextBox
                        x:Name="TxtBio"
                        Height="120"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="نبذة تعريفية أو تخصص الضيف"
                        materialDesign:TextFieldAssist.LeadingIcon="CardAccountDetailsOutline"
                        AcceptsReturn="True"
                        Style="{StaticResource Input.Text.Multiline}"
                        TextWrapping="Wrap" />

                    <Border Margin="0,10" Style="{DynamicResource Card.Info}">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Foreground="#1565C0"
                                Kind="Information"
                                Opacity="0.7" />
                            <TextBlock
                                Margin="12,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Opacity="0.8"
                                Text="* البيانات الأساسية تساعد في عمليات الأرشفة والبحث لاحقاً. " />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>


            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="تجاهل"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الضيف"
                        Style="{StaticResource Btn.Primary}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="AccountCheckOutline" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>