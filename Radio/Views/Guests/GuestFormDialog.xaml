<mah:MetroWindow
    x:Class="Radio.Views.Guests.GuestFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Guests"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="إضافة الضيوف"
    Width="800"
    Height="550"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="25">
        <StackPanel>
            <TextBlock
                x:Name="TxtTitle"
                Margin="0,0,0,25"
                FontSize="22"
                FontWeight="Bold"
                Foreground="#4CAF50"
                Text="ملف الضيف" />
            <TextBox
                x:Name="TxtName"
                Margin="0,0,0,15"
                materialDesign:HintAssist.Hint="الاسم الكامل *"
                Foreground="White"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
            <TextBox
                x:Name="TxtOrg"
                Margin="0,0,0,15"
                materialDesign:HintAssist.Hint="المؤسسة / الجهة"
                Foreground="White"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
            <TextBox
                x:Name="TxtPhone"
                Margin="0,0,0,15"
                materialDesign:HintAssist.Hint="رقم الهاتف"
                Foreground="White"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
            <TextBox
                x:Name="TxtEmail"
                Margin="0,0,0,15"
                materialDesign:HintAssist.Hint="البريد الإلكتروني"
                Foreground="White"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
            <TextBox
                x:Name="TxtBio"
                Height="80"
                Margin="0,0,0,25"
                materialDesign:HintAssist.Hint="نبذة تعريفية"
                AcceptsReturn="True"
                Foreground="White"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                TextWrapping="Wrap" />

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Margin="0,0,10,0"
                    BorderBrush="Gray"
                    Content="إلغاء"
                    Foreground="White"
                    IsCancel="True"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                <Button
                    x:Name="BtnSave"
                    Background="#4CAF50"
                    BorderBrush="#4CAF50"
                    Click="BtnSave_Click"
                    Content="حفظ البيانات"
                    Foreground="White" />
            </StackPanel>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
