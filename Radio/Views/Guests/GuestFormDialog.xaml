<mah:MetroWindow
    x:Class="Radio.Views.Guests.GuestFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بيانات الضيف"
    Width="600"
    Height="620"
    AllowsTransparency="True"
    Background="Transparent"
    FlowDirection="RightToLeft"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    UseNoneWindowStyle="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <materialDesign:Card
        Margin="30"
        materialDesign:ElevationAssist.Elevation="Dp2"
        Background="{DynamicResource MaterialDesignPaper}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Padding="24,20"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Foreground="White"
                Mode="Custom">
                <materialDesign:ColorZone.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#00695C" />
                        <GradientStop Offset="1" Color="#004D40" />
                    </LinearGradientBrush>
                </materialDesign:ColorZone.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="AccountVoice" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock
                            x:Name="TxtTitle"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource TitleLarge}"
                            Text="إضافة ضيف جديد" />
                        <TextBlock
                            FontSize="11"
                            Foreground="White"
                            Opacity="0.8"
                            Text="أدخل البيانات التعريفية للضيف وتفاصيل التواصل" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="28,20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="TxtName"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="الاسم الكامل *"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                            Style="{StaticResource BroadcastTextBox}" />

                        <TextBox
                            x:Name="TxtOrg"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="المؤسسة / الجهة"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="Domain"
                            Style="{StaticResource BroadcastTextBox}" />
                    </Grid>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="TxtPhone"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="رقم الهاتف"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="PhoneOutline"
                            Style="{StaticResource BroadcastTextBox}" />

                        <TextBox
                            x:Name="TxtEmail"
                            Grid.Column="2"
                            Grid.ColumnSpan="3"
                            materialDesign:HintAssist.Hint="البريد الإلكتروني"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                            Style="{StaticResource BroadcastTextBox}" />
                    </Grid>

                    <TextBox
                        x:Name="TxtBio"
                        Height="120"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="نبذة تعريفية أو تخصص الضيف"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="CardAccountDetailsOutline"
                        AcceptsReturn="True"
                        Style="{StaticResource BroadcastTextBox}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="5,10,0,0"
                        FontSize="10"
                        Opacity="0.6"
                        Text="* البيانات الأساسية تساعد في عمليات الأرشفة والبحث لاحقاً." />
                </StackPanel>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="28,24"
                Background="{DynamicResource MaterialDesignDivider}"
                CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="تجاهل"
                        IsCancel="True"
                        Style="{StaticResource CancelFlatButton}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp2"
                        Background="#00695C"
                        BorderBrush="#00695C"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات الضيف"
                        Style="{StaticResource PrimaryActionButton}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="AccountCheckOutline" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>