<UserControl
    x:Class="Radio.Views.Guests.GuestsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone
            Grid.Row="0"
            Padding="24,20"
            materialDesign:ElevationAssist.Elevation="Dp2"
            Mode="PrimaryMid">
            <materialDesign:ColorZone.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#1976D2" />
                    <GradientStop Offset="1" Color="#1565C0" />
                </LinearGradientBrush>
            </materialDesign:ColorZone.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="28"
                        Foreground="White"
                        Style="{StaticResource HeadlineLarge}"
                        Text="قاعدة بيانات الضيوف" />
                    <TextBlock
                        Foreground="White"
                        Opacity="0.8"
                        Style="{StaticResource BodyMedium}"
                        Text="إدارة سجلات الشخصيات والمؤسسات المتعاونة مع الإذاعة" />
                </StackPanel>

                <Button
                    x:Name="BtnAddGuest"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Background="White"
                    Click="BtnAddGuest_Click"
                    Foreground="#1565C0"
                    Style="{StaticResource PrimaryActionButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlusOutline" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="إضافة ضيف جديد" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1" Margin="24,20,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,16,0"
                materialDesign:HintAssist.Hint="بحث بالاسم، المؤسسة، أو رقم الهاتف..."
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource BroadcastTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <materialDesign:Card
                Grid.Column="1"
                Margin="4,0"
                Padding="12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                UniformCornerRadius="10">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Kind="AccountGroup" />
                    <StackPanel Margin="12,0">
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            Text="إجمالي الضيوف" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="18"
                            FontWeight="Bold"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card
                Grid.Column="2"
                Margin="4,0"
                Padding="12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                UniformCornerRadius="10">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SecondaryHueMidBrush}"
                        Kind="Domain" />
                    <StackPanel Margin="12,0">
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            Text="المؤسسات" />
                        <TextBlock
                            x:Name="TxtOrgs"
                            FontSize="18"
                            FontWeight="Bold"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <materialDesign:Card
            Grid.Row="2"
            Margin="24,10,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="12">
            <DataGrid
                x:Name="DgGuests"
                CellStyle="{StaticResource BroadcastPro.DataGridCell}"
                ColumnHeaderStyle="{StaticResource BroadcastPro.DataGridColumnHeader}"
                RowStyle="{StaticResource BroadcastPro.DataGridRow}"
                Style="{StaticResource BroadcastProDataGrid}">

                <DataGrid.Columns>
                    <DataGridTemplateColumn
                        Width="350"
                        CellStyle="{StaticResource BroadcastPro.DataGridCell.FirstColumn}"
                        Header="الاسم الكامل">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource SuccessBrush}"
                                        Kind="AccountCircleOutline"
                                        Opacity="0.5" />
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding FullName}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="180"
                        CellStyle="{StaticResource CenterCellAligned}"
                        Header="جهة العمل">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip
                                    MinWidth="80"
                                    HorizontalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Content="{Binding Organization}"
                                    FontSize="11" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding PhoneNumber}"
                        Header="رقم التواصل" />

                    <DataGridTextColumn
                        Width="0"
                        Binding="{Binding EmailAddress}"
                        Header="البريد الإلكتروني" />

                    <DataGridTemplateColumn Width="180" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Margin="8,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="TrashCanOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>