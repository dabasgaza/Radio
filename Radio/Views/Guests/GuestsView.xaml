<UserControl
    x:Class="Radio.Views.Guests.GuestsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Guests"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="10,0,10,20">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="26"
                FontWeight="Bold"
                Foreground="White"
                Text="قاعدة بيانات الضيوف" />
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <TextBox
                    x:Name="TxtSearch"
                    Width="250"
                    Margin="20,0,0,0"
                    materialDesign:HintAssist.Foreground="Gray"
                    materialDesign:HintAssist.Hint="بحث بالاسم أو الهاتف..."
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Search"
                    Foreground="White"
                    TextChanged="TxtSearch_TextChanged" />
                <Button
                    x:Name="BtnAddGuest"
                    Margin="20,0,0,0"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Background="#8BCAEC"
                    BorderBrush="#9ED3DC"
                    Click="BtnAddGuest_Click"
                    Content="إضافة ضيف"
                    Foreground="White" />
            </StackPanel>
        </DockPanel>

        <materialDesign:Card
            Grid.Row="1"
            Background="#1E1E1E"
            UniformCornerRadius="10">
            <DataGrid
                x:Name="DgGuests"
                AlternatingRowBackground="#252526"
                AutoGenerateColumns="False"
                Background="Transparent"
                CanUserAddRows="False"
                Foreground="White"
                IsReadOnly="True"
                RowBackground="#1E1E1E">
                <!--  تخصيص ترويسة الجدول بلون المديول  -->
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#8BCAEC" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="Padding" Value="10" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding FullName}"
                        CellStyle="{StaticResource LeftCellAligned}"
                        Header="الاسم الكامل" />
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding Organization}"
                        CellStyle="{StaticResource LeftCellAligned}"
                        Header="المؤسسة" />
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding PhoneNumber}"
                        CellStyle="{StaticResource CenterCellAligned}"
                        Header="رقم الهاتف" />
                    <DataGridTemplateColumn Width="120" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        x:Name="BtnEdit"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="BtnEdit_Click"
                                        Foreground="#03A9F4"
                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon Kind="Pencil" />
                                    </Button>
                                    <Button
                                        x:Name="BtnDelete"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="BtnDelete_Click"
                                        Foreground="#FF5252"
                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon Kind="Delete" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>

</UserControl>
