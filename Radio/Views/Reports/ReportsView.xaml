<UserControl
    x:Class="Radio.Views.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    FlowDirection="RightToLeft"
    Language="ar-SA"
    Style="{Binding UserControlStyle}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20" Background="{DynamicResource MaterialDesignDivider}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  المربعات العلوية  -->
                <RowDefinition Height="Auto" />
                <!--  جدول اليوم  -->
                <RowDefinition Height="Auto" />
                <!--  إحصائيات البرامج  -->
            </Grid.RowDefinitions>

            <!--  1. مربعات الإحصائيات السريعة  -->
            <UniformGrid
                Grid.Row="0"
                Margin="0,0,0,25"
                Columns="3">
                <materialDesign:Card
                    Margin="10"
                    Padding="20"
                    Background="#1E1E1E"
                    UniformCornerRadius="10">
                    <StackPanel>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            Foreground="Gray"
                            Kind="CalendarClock" />
                        <TextBlock
                            Margin="0,10,0,0"
                            Foreground="Gray"
                            Text="حلقات قيد التخطيط" />
                        <TextBlock
                            x:Name="TxtPlannedCount"
                            FontSize="35"
                            FontWeight="Black"
                            Foreground="White"
                            Text="0" />
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Margin="10"
                    Padding="20"
                    Background="#1E1E1E"
                    UniformCornerRadius="10">
                    <StackPanel>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            Foreground="#03A9F4"
                            Kind="MovieCheck" />
                        <TextBlock
                            Margin="0,10,0,0"
                            Foreground="Gray"
                            Text="حلقات تم تنفيذها" />
                        <TextBlock
                            x:Name="TxtExecutedCount"
                            FontSize="35"
                            FontWeight="Black"
                            Foreground="#03A9F4"
                            Text="0" />
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Margin="10"
                    Padding="20"
                    Background="#1E1E1E"
                    UniformCornerRadius="10">
                    <StackPanel>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            Foreground="#4CAF50"
                            Kind="CloudUpload" />
                        <TextBlock
                            Margin="0,10,0,0"
                            Foreground="Gray"
                            Text="حلقات تم نشرها" />
                        <TextBlock
                            x:Name="TxtPublishedCount"
                            FontSize="35"
                            FontWeight="Black"
                            Foreground="#4CAF50"
                            Text="0" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!--  2. جدول بث اليوم  -->
            <StackPanel Grid.Row="1" Margin="10,0,10,30">
                <TextBlock
                    Margin="0,0,0,15"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="📅 جدول بث اليوم" />
                <materialDesign:Card Background="#1E1E1E" UniformCornerRadius="10">
                    <DataGrid
                        x:Name="DgToday"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        Foreground="White"
                        IsReadOnly="True">
                        <DataGrid.ColumnHeaderStyle>
                            <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#3F51B5" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="80"
                                Binding="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}"
                                CellStyle="{StaticResource CenterCellAligned}"
                                Header="الوقت" />
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding ProgramName}"
                                CellStyle="{StaticResource LeftCellAligned}"
                                FontWeight="Bold"
                                Header="البرنامج" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding EpisodeName}"
                                CellStyle="{StaticResource LeftCellAligned}"
                                Header="عنوان الحلقة" />
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding GuestName}"
                                CellStyle="{StaticResource CenterCellAligned}"
                                Foreground="Lime"
                                Header="الضيف" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding StatusText}"
                                CellStyle="{StaticResource CenterCellAligned}"
                                Header="الحالة" />
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>
            </StackPanel>

            <!--  3. تحليل أداء البرامج  -->
            <StackPanel Grid.Row="2" Margin="10,30,10,10">
                <TextBlock
                    Margin="0,0,0,15"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="📊 البرامج الأكثر إنتاجاً" />
                <materialDesign:Card Background="#1E1E1E" UniformCornerRadius="10">
                    <DataGrid
                        x:Name="DgProgramStats"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        Foreground="White"
                        IsReadOnly="True">
                        <DataGrid.ColumnHeaderStyle>
                            <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Gold" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding ProgramName}"
                                CellStyle="{StaticResource LeftCellAligned}"
                                Header="اسم البرنامج" />
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding Category}"
                                CellStyle="{StaticResource CenterCellAligned}"
                                Header="الفئة" />
                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding TotalEpisodes}"
                                CellStyle="{StaticResource CenterCellAligned}"
                                Header="إجمالي الحلقات" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding PublishedEpisodes}"
                                CellStyle="{StaticResource CenterCellAligned}"
                                Foreground="Lime"
                                Header="المنشورة" />
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>