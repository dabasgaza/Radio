<UserControl
    x:Class="Radio.Views.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
            ═══════════════════════════════════════════════
            PAGE HEADER
            ═══════════════════════════════════════════════
        -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="FileReport" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Style="{StaticResource Type.TitleLarge.OnColor}"
                        Text="مركز التقارير والإحصائيات" />
                </StackPanel>
                <TextBlock
                    Margin="44,4,0,0"
                    Style="{StaticResource Type.BodyMedium.OnColor}"
                    Text="ملخص أداء البث، حالة النشر، وتحليلات البرامج الإذاعية" />
            </StackPanel>
        </materialDesign:ColorZone>

        <!--
            ═══════════════════════════════════════════════
            CONTENT
            ═══════════════════════════════════════════════
        -->
        <ScrollViewer
            Grid.Row="1"
            Padding="24,16"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  ── KPI STRIP (Compact Inline Stats) ──  -->
                <Border
                    Margin="0,0,0,24"
                    Padding="6"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1"
                    CornerRadius="12">

                    <UniformGrid Columns="4">

                        <!--  KPI 1: Planned  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="{DynamicResource PrimaryHueLightBrush}"
                                        CornerRadius="10">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="CalendarClock" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Type.Caption}" Text="قيد التخطيط" />
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock
                                                x:Name="TxtPlannedCount"
                                                Style="{StaticResource Type.Numeric.Large}"
                                                Text="0" />
                                            <TextBlock
                                                x:Name="TxtPlannedPct"
                                                Margin="6,4,0,0"
                                                VerticalAlignment="Bottom"
                                                Style="{StaticResource Type.Overline}"
                                                Text="0%" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <ProgressBar
                                    x:Name="PbPlanned"
                                    Height="4"
                                    Margin="0,8,0,0"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                                    Maximum="100"
                                    Value="0" />
                            </StackPanel>
                        </Border>

                        <!--  KPI 2: Executed  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="#E8F5E9"
                                        CornerRadius="10">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="#2E7D32"
                                            Kind="CheckDecagramOutline" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Type.Caption}" Text="منفّذة" />
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock
                                                x:Name="TxtExecutedCount"
                                                Style="{StaticResource Type.Numeric.Large}"
                                                Text="0" />
                                            <TextBlock
                                                x:Name="TxtExecutedPct"
                                                Margin="6,4,0,0"
                                                VerticalAlignment="Bottom"
                                                Style="{StaticResource Type.Overline}"
                                                Text="0%" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <ProgressBar
                                    x:Name="PbExecuted"
                                    Height="4"
                                    Margin="0,8,0,0"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Foreground="#2E7D32"
                                    Maximum="100"
                                    Value="0" />
                            </StackPanel>
                        </Border>

                        <!--  KPI 3: Published  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="#E3F2FD"
                                        CornerRadius="10">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="#1565C0"
                                            Kind="CloudCheckOutline" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Type.Caption}" Text="منشورة رقمياً" />
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock
                                                x:Name="TxtPublishedCount"
                                                Style="{StaticResource Type.Numeric.Large}"
                                                Text="0" />
                                            <TextBlock
                                                x:Name="TxtPublishedPct"
                                                Margin="6,4,0,0"
                                                VerticalAlignment="Bottom"
                                                Style="{StaticResource Type.Overline}"
                                                Text="0%" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <ProgressBar
                                    x:Name="PbPublished"
                                    Height="4"
                                    Margin="0,8,0,0"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Foreground="#1565C0"
                                    Maximum="100"
                                    Value="0" />
                            </StackPanel>
                        </Border>

                        <!--  KPI 4: Cancelled  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="#FCE4EC"
                                        CornerRadius="10">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="#B71C1C"
                                            Kind="CalendarRemove" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Type.Caption}" Text="ملغاة" />
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock
                                                x:Name="TxtCancelledCount"
                                                Style="{StaticResource Type.Numeric.Large}"
                                                Text="0" />
                                            <TextBlock
                                                x:Name="TxtCancelledPct"
                                                Margin="6,4,0,0"
                                                VerticalAlignment="Bottom"
                                                Style="{StaticResource Type.Overline}"
                                                Text="0%" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <ProgressBar
                                    x:Name="PbCancelled"
                                    Height="4"
                                    Margin="0,8,0,0"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Foreground="#B71C1C"
                                    Maximum="100"
                                    Value="0" />
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                </Border>

                <!--  ── TODAY BROADCAST TABLE ──  -->
                <StackPanel Margin="4,0,0,8" Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="20"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        CornerRadius="2" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.BodyLarge}"
                        Text="جدول بث اليوم" />
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Kind="Broadcast" />
                </StackPanel>

                <Border
                    Margin="0,0,0,24"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,0,0"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <DataGrid
                        x:Name="DgToday"
                        MinHeight="200"
                        CellStyle="{StaticResource DataGrid.Cell}"
                        ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                        RowStyle="{StaticResource DataGrid.Row}"
                        Style="{StaticResource DataGrid.Main}">
                        <DataGrid.Columns>

                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="الوقت" />

                            <DataGridTemplateColumn
                                Width="250"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="البرنامج">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Margin="8,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                Kind="RadioTower" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Text="{Binding ProgramName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="250"
                                Binding="{Binding EpisodeName}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="عنوان الحلقة" />

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding GuestsDisplay}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="الضيوف" />

                            <DataGridTemplateColumn
                                Width="120"
                                CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                Header="الحالة">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            x:Name="StatusBorder"
                                            Height="26"
                                            Padding="14,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource MaterialDesignDivider}"
                                            CornerRadius="13">
                                            <TextBlock
                                                x:Name="StatusText"
                                                VerticalAlignment="Center"
                                                FontWeight="Medium"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding StatusText}"
                                                TextAlignment="Center" />
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#1B5E20" />
                                                <Setter TargetName="StatusText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#00695C" />
                                                <Setter TargetName="StatusText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#E65100" />
                                                <Setter TargetName="StatusText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!--  ── PROGRAM STATS TABLE ──  -->
                <StackPanel Margin="4,0,0,8" Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="20"
                        Background="#00897B"
                        CornerRadius="2" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.TitleMedium}"
                        Text="إحصائيات البرامج الأكثر إنتاجاً" />
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="#00897B"
                        Kind="ChartBar" />
                </StackPanel>

                <Border
                    Margin="0,0,0,16"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,0,0"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <DataGrid
                        x:Name="DgProgramStats"
                        MinHeight="200"
                        CellStyle="{StaticResource DataGrid.Cell}"
                        ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                        RowStyle="{StaticResource DataGrid.Row}"
                        Style="{StaticResource DataGrid.Main}">
                        <DataGrid.Columns>

                            <DataGridTextColumn
                                Width="250"
                                Binding="{Binding ProgramName}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="اسم البرنامج" />

                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding Category}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="الفئة" />

                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding TotalEpisodes}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="إجمالي الحلقات" />

                            <DataGridTemplateColumn
                                Width="120"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="المنشورة">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Height="26"
                                            Padding="14,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#1B5E20"
                                            CornerRadius="13">
                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="13"
                                                    Height="13"
                                                    Foreground="#A5D6A7"
                                                    Kind="Check" />
                                                <TextBlock
                                                    Margin="5,0,0,0"
                                                    Foreground="White"
                                                    Style="{StaticResource Type.BodyMedium}"
                                                    Text="{Binding PublishedEpisodes}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!--  ── TOP GUESTS REPORT ──  -->
                <StackPanel Margin="4,8,0,8" Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="20"
                        Background="{StaticResource SecondaryMainBrush}"
                        CornerRadius="2" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.TitleMedium}"
                        Text="الضيوف الأكثر ظهوراً" />
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource SecondaryMainBrush}"
                        Kind="AccountStar" />
                </StackPanel>

                <Border
                    Margin="0,0,0,24"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <DataGrid
                        x:Name="DgTopGuests"
                        MinHeight="160"
                        CellStyle="{StaticResource DataGrid.Cell}"
                        ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                        RowStyle="{StaticResource DataGrid.Row}"
                        Style="{StaticResource DataGrid.Main}">
                        <DataGrid.Columns>

                            <!--  الترتيب  -->
                            <DataGridTemplateColumn
                                Width="60"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="#">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="28"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="14">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource PrimaryMainBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding Rank}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="200"
                                Binding="{Binding FullName}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="اسم الضيف" />

                            <DataGridTextColumn
                                Width="180"
                                Binding="{Binding Organization}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="الجهة" />

                            <!--  عدد الظهورات  -->
                            <DataGridTemplateColumn
                                Width="120"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="عدد الظهورات">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Height="28"
                                            Padding="14,0"
                                            HorizontalAlignment="Center"
                                            Background="{StaticResource SecondaryLightBrush}"
                                            CornerRadius="14">
                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="13"
                                                    Height="13"
                                                    Foreground="{StaticResource InfoBrush}"
                                                    Kind="Microphone" />
                                                <TextBlock
                                                    Margin="5,0,0,0"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource InfoBrush}"
                                                    Style="{StaticResource Type.BodySmall}"
                                                    Text="{Binding AppearanceCount}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding LastTopic}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="آخر موضوع" />

                            <DataGridTextColumn
                                Width="160"
                                Binding="{Binding LastAppearance, StringFormat='yyyy/MM/dd'}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="آخر ظهور" />

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!--  ── CANCELLED EPISODES REPORT ──  -->
                <StackPanel Margin="4,0,0,8" Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="20"
                        Background="{StaticResource ErrorBrush}"
                        CornerRadius="2" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.TitleMedium}"
                        Text="الحلقات الملغاة وأسبابها" />
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource ErrorBrush}"
                        Kind="CalendarRemove" />
                </StackPanel>

                <Border
                    Margin="0,0,0,24"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <DataGrid
                        x:Name="DgCancelled"
                        MinHeight="160"
                        CellStyle="{StaticResource DataGrid.Cell}"
                        ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                        RowStyle="{StaticResource DataGrid.Row}"
                        Style="{StaticResource DataGrid.Main}">
                        <DataGrid.Columns>

                            <DataGridTextColumn
                                Width="160"
                                Binding="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd  hh:mm tt'}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="التاريخ المجدول" />

                            <DataGridTemplateColumn
                                Width="180"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="البرنامج">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Margin="8,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="15"
                                                Height="15"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                Kind="RadioTower" />
                                            <TextBlock
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding ProgramName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="200"
                                Binding="{Binding EpisodeName}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="عنوان الحلقة" />

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding CancellationReason}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="سبب الإلغاء" />

                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding CancelledBy}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="ألغاها" />

                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding CancelledAt, StringFormat='yyyy/MM/dd'}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="تاريخ الإلغاء" />

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!--  ── DATE RANGE REPORT ──  -->
                <StackPanel Margin="4,8,0,8" Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="20"
                        Background="#7B1FA2"
                        CornerRadius="2" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.TitleMedium}"
                        Text="تقرير الحلقات حسب الفترة الزمنية" />
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="#7B1FA2"
                        Kind="CalendarSearch" />
                </StackPanel>

                <!--  Filter Bar  -->
                <Border
                    Margin="0,0,0,12"
                    Padding="16,12"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <WrapPanel VerticalAlignment="Center">

                        <StackPanel
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                Kind="CalendarStart" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Opacity="0.6"
                                Text="من: " />
                            <DatePicker
                                x:Name="DpFrom"
                                Width="150"
                                Margin="6,0,0,0"
                                materialDesign:HintAssist.Hint="تاريخ البداية"
                                Style="{StaticResource MaterialDesignDatePicker}" />
                        </StackPanel>

                        <StackPanel
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                Kind="CalendarEnd" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Opacity="0.6"
                                Text="إلى: " />
                            <DatePicker
                                x:Name="DpTo"
                                Width="150"
                                Margin="6,0,0,0"
                                materialDesign:HintAssist.Hint="تاريخ النهاية"
                                Style="{StaticResource MaterialDesignDatePicker}" />
                        </StackPanel>

                        <Button
                            x:Name="BtnSearch"
                            Margin="8,0,0,0"
                            Padding="20,8"
                            Click="BtnSearch_Click"
                            Content="بحث"
                            Style="{StaticResource MaterialDesignRaisedButton}" />

                        <Button
                            x:Name="BtnReset"
                            Margin="8,0,0,0"
                            Padding="20,8"
                            Click="BtnReset_Click"
                            Content="إعادة تعيين"
                            Style="{StaticResource Btn.Cancel}" />

                        <Button
                            x:Name="BtnExport"
                            Margin="8,0,0,0"
                            Padding="20,8"
                            Click="BtnExport_Click"
                            IsEnabled="False"
                            Style="{StaticResource Btn.Secondary}"
                            ToolTip="تصدير النتائج إلى Excel">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Kind="MicrosoftExcel" />
                                <TextBlock VerticalAlignment="Center" Text="تصدير Excel" />
                            </StackPanel>
                        </Button>

                        <!--  Summary chips  -->
                        <StackPanel
                            x:Name="PnlSearchSummary"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                            <Border
                                Padding="10,4"
                                Background="{DynamicResource PrimaryHueLightBrush}"
                                CornerRadius="12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                        Kind="Information" />
                                    <TextBlock
                                        x:Name="TxtSearchSummary"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                        Style="{StaticResource Type.Caption}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </WrapPanel>
                </Border>

                <!--  Results Table  -->
                <Border
                    Margin="0,0,0,24"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <DataGrid
                        x:Name="DgDateRange"
                        MinHeight="120"
                        CellStyle="{StaticResource DataGrid.Cell}"
                        ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                        RowStyle="{StaticResource DataGrid.Row}"
                        Style="{StaticResource DataGrid.Main}">
                        <DataGrid.Columns>

                            <DataGridTextColumn
                                Width="160"
                                Binding="{Binding ScheduledExecutionTime, StringFormat='yyyy/MM/dd  hh:mm tt'}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="التاريخ والوقت" />

                            <DataGridTemplateColumn
                                Width="200"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="البرنامج">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Margin="8,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="15"
                                                Height="15"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                Kind="RadioTower" />
                                            <TextBlock
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding ProgramName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="220"
                                Binding="{Binding EpisodeName}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="عنوان الحلقة" />

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding GuestsDisplay}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="الضيوف" />

                            <DataGridTemplateColumn
                                Width="110"
                                CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                Header="الحالة">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            x:Name="StatusBorder2"
                                            Height="26"
                                            Padding="12,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource MaterialDesignDivider}"
                                            CornerRadius="13">
                                            <TextBlock
                                                x:Name="StatusText2"
                                                VerticalAlignment="Center"
                                                FontWeight="Medium"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Style="{StaticResource Type.Overline}"
                                                Text="{Binding StatusText}"
                                                TextAlignment="Center" />
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                <Setter TargetName="StatusBorder2" Property="Background" Value="#1B5E20" />
                                                <Setter TargetName="StatusText2" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                <Setter TargetName="StatusBorder2" Property="Background" Value="#00695C" />
                                                <Setter TargetName="StatusText2" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                <Setter TargetName="StatusBorder2" Property="Background" Value="#E65100" />
                                                <Setter TargetName="StatusText2" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="ملغاة">
                                                <Setter TargetName="StatusBorder2" Property="Background" Value="#B71C1C" />
                                                <Setter TargetName="StatusText2" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة على الموقع">
                                                <Setter TargetName="StatusBorder2" Property="Background" Value="#1565C0" />
                                                <Setter TargetName="StatusText2" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
