<UserControl
    x:Class="Radio.Views.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    FlowDirection="RightToLeft"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone
            Padding="24,20"
            materialDesign:ElevationAssist.Elevation="Dp2"
            Mode="PrimaryMid">
            <StackPanel>
                <TextBlock
                    FontSize="28"
                    Foreground="White"
                    Style="{StaticResource HeadlineLarge}"
                    Text="مركز التقارير والإحصائيات" />
                <TextBlock
                    Foreground="White"
                    Opacity="0.8"
                    Style="{StaticResource BodyMedium}"
                    Text="ملخص أداء البث، حالة النشر، وتحليلات البرامج الإذاعية" />
            </StackPanel>
        </materialDesign:ColorZone>

        <ScrollViewer
            Grid.Row="1"
            Padding="24,15"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,15">

                <UniformGrid Margin="0,10,0,30" Columns="3">
                    <materialDesign:Card
                        Margin="8"
                        Padding="20"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="12">
                        <StackPanel>
                            <materialDesign:PackIcon
                                Width="28"
                                Height="28"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                Kind="CalendarClock" />
                            <TextBlock
                                Margin="0,12,0,4"
                                FontSize="12"
                                Opacity="0.6"
                                Text="حلقات قيد التخطيط" />
                            <TextBlock
                                x:Name="TxtPlannedCount"
                                FontSize="32"
                                FontWeight="Bold"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Text="0" />
                            <ProgressBar
                                Height="2"
                                Margin="0,8,0,0"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                Value="100" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card
                        Margin="8"
                        Padding="20"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="12">
                        <StackPanel>
                            <materialDesign:PackIcon
                                Width="28"
                                Height="28"
                                Foreground="{DynamicResource SuccessBrush}"
                                Kind="CheckDecagramOutline" />
                            <TextBlock
                                Margin="0,12,0,4"
                                FontSize="12"
                                Opacity="0.6"
                                Text="إجمالي الحلقات المنفذة" />
                            <TextBlock
                                x:Name="TxtExecutedCount"
                                FontSize="32"
                                FontWeight="Bold"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Text="0" />
                            <ProgressBar
                                Height="2"
                                Margin="0,8,0,0"
                                Foreground="{DynamicResource SuccessBrush}"
                                Value="100" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card
                        Margin="8"
                        Padding="20"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="12">
                        <StackPanel>
                            <materialDesign:PackIcon
                                Width="28"
                                Height="28"
                                Foreground="{DynamicResource SecondaryHueMidBrush}"
                                Kind="CloudCheckOutline" />
                            <TextBlock
                                Margin="0,12,0,4"
                                FontSize="12"
                                Opacity="0.6"
                                Text="تم نشرها رقمياً" />
                            <TextBlock
                                x:Name="TxtPublishedCount"
                                FontSize="32"
                                FontWeight="Bold"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Text="0" />
                            <ProgressBar
                                Height="2"
                                Margin="0,8,0,0"
                                Foreground="{DynamicResource SecondaryHueMidBrush}"
                                Value="100" />
                        </StackPanel>
                    </materialDesign:Card>
                </UniformGrid>

                <TextBlock
                    Margin="8,0,0,12"
                    Style="{StaticResource TitleLarge}"
                    Text="جدول بث اليوم" />
                <materialDesign:Card
                    Margin="0,0,0,30"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="12">
                    <DataGrid
                        x:Name="DgToday"
                        MinHeight="200"
                        CellStyle="{StaticResource BroadcastPro.DataGridCell}"
                        ColumnHeaderStyle="{StaticResource BroadcastPro.DataGridColumnHeader}"
                        RowStyle="{StaticResource BroadcastPro.DataGridRow}"
                        Style="{StaticResource BroadcastProDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}"
                                Header="الوقت" />
                            <DataGridTemplateColumn Width="180" Header="البرنامج">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                VerticalAlignment="Center"
                                                Kind="RadioTower"
                                                Opacity="0.5" />
                                            <TextBlock
                                                Margin="8,0"
                                                VerticalAlignment="Center"
                                                FontWeight="SemiBold"
                                                Text="{Binding ProgramName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding EpisodeName}"
                                Header="عنوان الحلقة" />
                            <DataGridTemplateColumn Width="120" Header="الحالة">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource MaterialDesignDivider}"
                                            Content="{Binding StatusText}"
                                            FontSize="11" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>

                <TextBlock
                    Margin="8,0,0,12"
                    Style="{StaticResource TitleLarge}"
                    Text="إحصائيات البرامج الأكثر إنتاجاً" />
                <materialDesign:Card
                    Margin="0,0,0,20"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="12">
                    <DataGrid
                        x:Name="DgProgramStats"
                        MinHeight="200"
                        CellStyle="{StaticResource BroadcastPro.DataGridCell}"
                        RowStyle="{StaticResource BroadcastPro.DataGridRow}"
                        Style="{StaticResource BroadcastProDataGrid}">

                        <DataGrid.ColumnHeaderStyle>
                            <Style BasedOn="{StaticResource BroadcastPro.DataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#455A64" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="#37474F" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding ProgramName}"
                                CellStyle="{StaticResource BroadcastPro.DataGridCell.FirstColumn}"
                                Header="اسم البرنامج" />
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding Category}"
                                Header="الفئة" />
                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding TotalEpisodes}"
                                Header="إجمالي الحلقات" />
                            <DataGridTemplateColumn Width="120" Header="المنشورة">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource SuccessBrush}"
                                            Content="{Binding PublishedEpisodes}"
                                            Foreground="White" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>