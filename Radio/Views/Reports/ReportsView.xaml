<UserControl
    x:Class="Radio.Views.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
            ═══════════════════════════════════════════════
            PAGE HEADER
            ═══════════════════════════════════════════════
        -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="FileReport" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Style="{StaticResource Type.TitleLarge.OnColor}"
                        Text="مركز التقارير والإحصائيات" />
                </StackPanel>
                <TextBlock
                    Margin="44,4,0,0"
                    Style="{StaticResource Type.BodyMedium.OnColor}"
                    Text="ملخص أداء البث، حالة النشر، وتحليلات البرامج الإذاعية" />
            </StackPanel>
        </materialDesign:ColorZone>

        <!--
            ═══════════════════════════════════════════════
            CONTENT
            ═══════════════════════════════════════════════
        -->
        <ScrollViewer
            Grid.Row="1"
            Padding="24,16"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  ── KPI STRIP (Compact Inline Stats) ──  -->
                <Border
                    Margin="0,0,0,24"
                    Padding="6"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1"
                    CornerRadius="12">

                    <UniformGrid Columns="4">

                        <!--  KPI 1: Planned  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="40"
                                    Height="40"
                                    Background="{DynamicResource PrimaryHueLightBrush}"
                                    CornerRadius="10">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                        Kind="CalendarClock" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="10.5"
                                        Opacity="0.5"
                                        Text="قيد التخطيط" />
                                    <TextBlock
                                        x:Name="TxtPlannedCount"
                                        FontSize="22"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Text="0"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  KPI 2: Executed  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="40"
                                    Height="40"
                                    Background="#E8F5E9"
                                    CornerRadius="10">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#2E7D32"
                                        Kind="CheckDecagramOutline" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="10.5"
                                        Opacity="0.5"
                                        Text="منفّذة"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        x:Name="TxtExecutedCount"
                                        FontSize="22"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Text="0"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  KPI 3: Published  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="40"
                                    Height="40"
                                    Background="#E3F2FD"
                                    CornerRadius="10">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#1565C0"
                                        Kind="CloudCheckOutline" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="10.5"
                                        Opacity="0.5"
                                        Text="منشورة رقمياً"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        x:Name="TxtPublishedCount"
                                        FontSize="22"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Text="0"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  KPI 4: Today's Date  -->
                        <Border Padding="16,14" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="40"
                                    Height="40"
                                    Background="#FFF3E0"
                                    CornerRadius="10">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#E65100"
                                        Kind="CalendarToday" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="10.5"
                                        Opacity="0.5"
                                        Text="تاريخ اليوم" />
                                    <TextBlock
                                        x:Name="TxtTodayDate"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Text="--"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                </Border>

                <!--  ── TODAY BROADCAST TABLE ──  -->
                <StackPanel Margin="4,0,0,8" Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="20"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        CornerRadius="2" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.BodyLarge}"
                        Text="جدول بث اليوم" />
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Kind="Broadcast" />
                </StackPanel>

                <Border
                    Margin="0,0,0,24"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,0,0"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <DataGrid
                        x:Name="DgToday"
                        MinHeight="200"
                        CellStyle="{StaticResource DataGrid.Cell}"
                        ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                        RowStyle="{StaticResource DataGrid.Row}"
                        Style="{StaticResource DataGrid.Main}">
                        <DataGrid.Columns>

                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding ScheduledExecutionTime, StringFormat='hh:mm tt'}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="الوقت" />

                            <DataGridTemplateColumn
                                Width="250"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="البرنامج">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Margin="8,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                Kind="RadioTower" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Text="{Binding ProgramName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="350"
                                Binding="{Binding EpisodeName}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="عنوان الحلقة" />

                            <DataGridTemplateColumn
                                Width="120"
                                CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                Header="الحالة">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            x:Name="StatusBorder"
                                            Height="26"
                                            Padding="14,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource MaterialDesignDivider}"
                                            CornerRadius="13">
                                            <TextBlock
                                                x:Name="StatusText"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="Medium"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Text="{Binding StatusText}"
                                                TextAlignment="Center" />
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منفّذة">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#1B5E20" />
                                                <Setter TargetName="StatusText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="منشورة">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#00695C" />
                                                <Setter TargetName="StatusText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="مجدولة">
                                                <Setter TargetName="StatusBorder" Property="Background" Value="#E65100" />
                                                <Setter TargetName="StatusText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!--  ── PROGRAM STATS TABLE ──  -->
                <StackPanel Margin="4,0,0,8" Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="20"
                        Background="#00897B"
                        CornerRadius="2" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.TitleMedium}"
                        Text="إحصائيات البرامج الأكثر إنتاجاً" />
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="#00897B"
                        Kind="ChartBar" />
                </StackPanel>

                <Border
                    Margin="0,0,0,16"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,0,0"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.12"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <DataGrid
                        x:Name="DgProgramStats"
                        MinHeight="200"
                        CellStyle="{StaticResource DataGrid.Cell}"
                        ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                        RowStyle="{StaticResource DataGrid.Row}"
                        Style="{StaticResource DataGrid.Main}">
                        <DataGrid.Columns>

                            <DataGridTextColumn
                                Width="250"
                                Binding="{Binding ProgramName}"
                                CellStyle="{StaticResource DataGrid.Cell.Left}"
                                Header="اسم البرنامج" />

                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding Category}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="الفئة" />

                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding TotalEpisodes}"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="إجمالي الحلقات" />

                            <DataGridTemplateColumn
                                Width="120"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="المنشورة">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Height="26"
                                            Padding="14,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#1B5E20"
                                            CornerRadius="13">
                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="13"
                                                    Height="13"
                                                    Foreground="#A5D6A7"
                                                    Kind="Check" />
                                                <TextBlock
                                                    Margin="5,0,0,0"
                                                    FontSize="14"
                                                    Foreground="White"
                                                    Text="{Binding PublishedEpisodes}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
