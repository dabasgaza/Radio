<mah:MetroWindow
    x:Class="Radio.Views.Common.ReasonInputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="سبب العملية"
    Width="450"
    Height="220"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Style="{StaticResource Window.Main}"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="TxtPrompt"
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="14"
            FontWeight="SemiBold"
            Text="يرجى إدخال سبب العملية:" />

        <TextBox
            x:Name="TxtReason"
            Grid.Row="1"
            mah:TextBoxHelper.Watermark="اكتب السبب هنا..."
            AcceptsReturn="True"
            MaxLength="500"
            Style="{StaticResource MaterialDesignFilledTextBox}"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />

        <StackPanel
            Grid.Row="2"
            Margin="0,16,0,0"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Button
                x:Name="BtnOk"
                Width="90"
                Margin="0,0,10,0"
                Content="موافق"
                IsDefault="True"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button
                Width="90"
                Content="إلغاء"
                IsCancel="True"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>
    </Grid>

</mah:MetroWindow>
