<mah:MetroWindow
    x:Class="Radio.Views.Common.ConcurrencyDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Common"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ConcurrencyDialog"
    Width="800"
    Height="450"
    Style="{StaticResource Window.Main}"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock
                Foreground="Orange"
                Style="{StaticResource Type.TitleLarge}"
                Text="⚠️ تم اكتشاف تعارض!" />
            <TextBlock
                Margin="0,5,0,0"
                Opacity="0.7"
                Text="قام زميل آخر بتعديل هذا السجل للتو. إليك القيم الحالية في النظام:"
                TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="ItemsDiff">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,2"
                            Padding="10"
                            Background="#3E3E42"
                            CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="Gray"
                                    Text="{Binding Key}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Foreground="Cyan"
                                    Text="{Binding Value}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel
            Grid.Row="2"
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,10,0"
                Content="إلغاء وتحديث بياناتي"
                IsCancel="True"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
            <Button
                x:Name="BtnForceSave"
                Background="Orange"
                BorderBrush="Orange"
                Content="حفظ بياناتي على أي حال (دعس)" />
        </StackPanel>
    </Grid>

</mah:MetroWindow>
