<UserControl
    x:Class="Radio.Views.Programs.ProgramsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Programs"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="900"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════════ الرأس والعنوان ═══════════  -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Style="{StaticResource TitleLarge}" Text="إدارة البرامج" />
                <TextBlock
                    Margin="0,4,0,0"
                    Foreground="#757575"
                    Style="{StaticResource BodyMedium}"
                    Text="تنظيم وجدولة البرامج الإذاعية وفقاً للفئات" />
            </StackPanel>

            <!--  زر إضافة (باستخدام الـ Style المركزي)  -->
            <Button
                Name="BtnAddProgram"
                Grid.Column="1"
                Click="BtnAddProgram_Click"
                Style="{StaticResource PrimaryActionButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Kind="Plus" />
                    <TextBlock VerticalAlignment="Center" Text="إضافة برنامج جديد" />
                </StackPanel>
            </Button>
        </Grid>

        <!--  ═══════════ البحث وبطاقات الإحصائيات (KPIs) ═══════════  -->
        <StackPanel
            Grid.Row="1"
            Margin="10,0,10,24"
            VerticalAlignment="Center"
            Orientation="Horizontal">

            <!--  حقل البحث (باستخدام الـ Style المركزي)  -->
            <TextBox
                Name="TxtSearch"
                Width="350"
                Margin="0,0,16,8"
                VerticalAlignment="Bottom"
                materialDesign:HintAssist.Hint="بحث باسم البرنامج أو الفئة..."
                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource BroadcastTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  بطاقة: إجمالي البرامج  -->
            <materialDesign:Card
                Width="220"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Style="{StaticResource BroadcastCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        Background="#E8EAF6"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#303F9F"
                            Kind="RadioTower" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="#757575"
                            Text="إجمالي البرامج" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#212121"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  بطاقة: الفئات  -->
            <materialDesign:Card
                Width="220"
                VerticalAlignment="Center"
                Style="{StaticResource BroadcastCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        Background="#E1F5FE"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#0288D1"
                            Kind="TagMultipleOutline" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="#757575"
                            Text="الفئات" />
                        <TextBlock
                            x:Name="TxtCategories"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#0288D1"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <!--  ═══════════ جدول البيانات (باستخدام الـ Style المركزي) ═══════════  -->
        <DataGrid
            x:Name="DgPrograms"
            Grid.Row="2"
            VerticalAlignment="Stretch"
            AutoGenerateColumns="False"
            ColumnHeaderStyle="{StaticResource BroadcastPro.DataGridColumnHeader}"
            IsReadOnly="True"
            ItemsSource="{Binding ProgramsList}"
            RowStyle="{StaticResource BroadcastPro.DataGridRow}"
            Style="{StaticResource BroadcastProDataGrid}">

            <DataGrid.Columns>

                <!--  عمود اسم البرنامج  -->
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding ProgramName}"
                    ElementStyle="{StaticResource DataGridTextStyle}"
                    Header="البرنامج" />

                <!--  عمود الفئة (باستخدام Chip بسيط مطابق للثيم الفاتح)  -->
                <DataGridTemplateColumn Width="200" Header="الفئة">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border
                                MinWidth="100"
                                Margin="0,4"
                                Padding="14,5"
                                HorizontalAlignment="Center"
                                Background="#81D4FA"
                                CornerRadius="14">
                                <!--  ظل مسطح خفيف جداً لرفع الشارة عن سطح الجدول  -->
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="6"
                                        Opacity="0.15"
                                        ShadowDepth="2"
                                        Color="#000000" />
                                </Border.Effect>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="Black"
                                    Text="{Binding Category}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!--  عمود الإجراءات (أزرار مسطحة بمواصفات MD)  -->
                <DataGridTemplateColumn Width="200" Header="إجراءات">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Margin="20,0"
                                    Click="BtnEdit_Click"
                                    Foreground="#1565C0"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="تعديل">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Kind="Pencil" />
                                </Button>
                                <Button
                                    Click="BtnDelete_Click"
                                    Foreground="#B00020"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="حذف">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Kind="Delete" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>