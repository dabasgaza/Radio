<UserControl
    x:Class="Radio.Views.Programs.ProgramsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="650"
    d:DesignWidth="1000"
    FlowDirection="RightToLeft"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone
            Padding="30,24"
            materialDesign:ElevationAssist.Elevation="Dp3"
            Mode="Custom">
            <materialDesign:ColorZone.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#1A237E" />
                    <GradientStop Offset="1" Color="#3F51B5" />
                </LinearGradientBrush>
            </materialDesign:ColorZone.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="RadioTower" />
                        <TextBlock
                            Margin="15,0"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="منظومة إدارة البرامج" />
                    </StackPanel>
                    <TextBlock
                        Margin="47,4,0,0"
                        Foreground="White"
                        Opacity="0.7"
                        Text="تنسيق الخارطة البرامجية، تصنيف المحتوى، وإحصائيات الإنتاج" />
                </StackPanel>

                <Button
                    x:Name="BtnAddProgram"
                    Grid.Column="1"
                    Height="45"
                    Padding="20,0"
                    VerticalAlignment="Center"
                    materialDesign:ButtonAssist.CornerRadius="10"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Background="White"
                    BorderThickness="0"
                    Click="BtnAddProgram_Click"
                    Foreground="#1A237E">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon VerticalAlignment="Center" Kind="PlusThick" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontWeight="Bold"
                            Text="برنامج جديد" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1" Margin="25,20,25,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,20,0"
                VerticalAlignment="Center"
                materialDesign:HintAssist.Hint="بحث سريع بالاسم أو الفئة..."
                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource BroadcastTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <materialDesign:Card
                Grid.Column="1"
                Margin="5"
                Padding="15,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="40"
                        Height="40"
                        Background="#101A237E"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#1A237E"
                            Kind="PlaylistMusicOutline" />
                    </Border>
                    <StackPanel Margin="15,0">
                        <TextBlock
                            FontSize="10"
                            Opacity="0.5"
                            Text="إجمالي البرامج" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card
                Grid.Column="2"
                Margin="5"
                Padding="15,12"
                materialDesign:ElevationAssist.Elevation="Dp1"
                UniformCornerRadius="12">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="40"
                        Height="40"
                        Background="#100097A7"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#0097A7"
                            Kind="TagMultiple" />
                    </Border>
                    <StackPanel Margin="15,0">
                        <TextBlock
                            FontSize="10"
                            Opacity="0.5"
                            Text="الفئات النشطة" />
                        <TextBlock
                            x:Name="TxtCategories"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#0097A7"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <materialDesign:Card
            Grid.Row="2"
            Margin="25,10,25,25"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="15">
            <DataGrid
                x:Name="DgPrograms"
                CellStyle="{StaticResource BroadcastPro.DataGridCell}"
                ColumnHeaderStyle="{StaticResource BroadcastPro.DataGridColumnHeader}"
                RowStyle="{StaticResource BroadcastPro.DataGridRow}"
                Style="{StaticResource BroadcastProDataGrid}">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="*" Header="البرنامج">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        VerticalAlignment="Center"
                                        Kind="Microphone"
                                        Opacity="0.3" />
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="{Binding ProgramName}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="200" Header="التصنيف">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Content="{Binding Category}"
                                    FontSize="11"
                                    FontWeight="Medium"
                                    Icon="{materialDesign:PackIcon Kind=ShapeOutline}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="150" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="Pencil" />
                                    </Button>
                                    <Button
                                        Margin="10,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="DeleteOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>