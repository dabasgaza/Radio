<UserControl
    x:Class="Radio.Views.Programs.ProgramsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="650"
    d:DesignWidth="1000"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="RadioTower" />
                        <TextBlock
                            Margin="15,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="منظومة إدارة البرامج" />
                    </StackPanel>
                    <TextBlock
                        Margin="47,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="تنسيق الخارطة البرامجية، تصنيف المحتوى، وإحصائيات الإنتاج" />
                </StackPanel>

                <Button
                    x:Name="BtnAddProgram"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="BtnAddProgram_Click"
                    Content="إضافة برنامج جديد"
                    Style="{StaticResource Btn.AddNew}" />
            </Grid>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1" Margin="25,20,25,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,20,0"
                materialDesign:HintAssist.Hint="بحث سريع بالاسم أو الفئة..."
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <materialDesign:Card
                Grid.Column="1"
                Margin="5"
                Background="{StaticResource SuccessLightBrush}"
                Style="{StaticResource Card.Stat}">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="40"
                        Height="40"
                        Background="{StaticResource AppBackgroundBrush}"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource InfoBrush}"
                            Kind="PlaylistMusicOutline" />
                    </Border>
                    <StackPanel Margin="15,0">
                        <TextBlock
                            FontSize="10"
                            Opacity="0.5"
                            Text="إجمالي البرامج" />
                        <TextBlock
                            x:Name="TxtTotal"
                            HorizontalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card
                Grid.Column="2"
                Margin="5"
                Background="{StaticResource WarningLightBrush}"
                Style="{StaticResource Card.Stat}">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="40"
                        Height="40"
                        Background="{StaticResource AppBackgroundBrush}"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="TagMultiple" />
                    </Border>
                    <StackPanel Margin="15,0">
                        <TextBlock
                            FontSize="10"
                            Opacity="0.5"
                            Text="الفئات النشطة" />
                        <TextBlock
                            x:Name="TxtCategories"
                            HorizontalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <materialDesign:Card
            Grid.Row="2"
            Margin="25,10,25,25"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="15">
            <DataGrid
                x:Name="DgPrograms"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Width="200" Header="البرنامج">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        VerticalAlignment="Center"
                                        Kind="Microphone"
                                        Opacity="0.3" />
                                    <TextBlock
                                        Margin="12,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        Text="{Binding ProgramName}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="200"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="التصنيف">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip
                                    Width="100"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource MaterialDesignDivider}"
                                    Content="{Binding Category}"
                                    FontSize="14"
                                    Icon="{materialDesign:PackIcon Kind=ShapeOutline}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="150"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="Pencil" />
                                    </Button>
                                    <Button
                                        Margin="10,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="DeleteOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>