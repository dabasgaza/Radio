<UserControl
    x:Class="Radio.Views.Programs.ProgramsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Programs"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Style="{StaticResource UserControlStyle}"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- تنسيقات النصوص بلوحة الألوان الجديدة -->
        <Style x:Key="RightCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <!-- أبيض مائل للأزرق الفاتح -->
        </Style>
        <Style x:Key="CenterCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- منطقة الهيدر والتحكم -->
        <Grid Grid.Row="0" Margin="8,10,8,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- عنوان الصفحة مع أيقونة البث -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon 
                    Kind="RadioTower" 
                    Width="32" 
                    Height="32" 
                    Foreground="#22D3EE" 
                    Margin="0,0,12,0" 
                    VerticalAlignment="Center"/>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#FFFFFF"
                    Text="إدارة البرامج" />
            </StackPanel>

            <!-- زر الإضافة بلون السيان المميز -->
            <Button
                x:Name="BtnAddProgram"
                Grid.Column="1"
                Height="38"
                Padding="20,0"
                VerticalAlignment="Center"
                materialDesign:ButtonAssist.CornerRadius="8"
                Background="#22D3EE"
                BorderBrush="#22D3EE"
                Click="BtnAddProgram_Click"
                Content="إضافة برنامج جديد"
                Foreground="#0F172A"
                FontWeight="SemiBold"
                FontSize="14"
                Cursor="Hand"/>
        </Grid>

        <!-- بطاقة الجدول بلوحة الأزرق النيلي العميق -->
        <materialDesign:Card
            Grid.Row="1"
            Margin="8,0"
            Background="#0F172A"
            BorderBrush="#334155"
            BorderThickness="1"
            UniformCornerRadius="12">

            <DataGrid
                x:Name="DgPrograms"
                AutoGenerateColumns="False"
                Background="Transparent"
                CanUserAddRows="False"
                Foreground="{DynamicResource MaterialDesignBody}"
                GridLinesVisibility="None"
                IsReadOnly="True"
                RowBackground="#1E293B"
                AlternatingRowBackground="#283548"
                HeadersVisibility="Column"
                RowHeight="50"
                SelectionUnit="FullRow"
                SelectionMode="Single">

                <!-- تأثير التمرير (Hover) -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- ترويسة الجدول -->
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0F172A" />
                        <Setter Property="Foreground" Value="#22D3EE" />
                        <!-- سيان للترويسة -->
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="14,12" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <!-- عمود اسم البرنامج -->
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ProgramName}"
                        Header="اسم البرنامج"
                        ElementStyle="{StaticResource RightCellText}">
                        <DataGridTextColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <!-- عمود الفئة -->
                    <DataGridTextColumn
                        Width="200"
                        Binding="{Binding Category}"
                        Header="الفئة"
                        ElementStyle="{StaticResource CenterCellText}" />

                    <!-- عمود الإجراءات -->
                    <DataGridTemplateColumn Width="Auto" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button
                                        Margin="4"
                                        Padding="5"
                                        Click="BtnEdit_Click"
                                        Foreground="#22D3EE"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل البرنامج"
                                        Cursor="Hand">
                                        <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>