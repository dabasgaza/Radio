<UserControl
    x:Class="Radio.Views.Programs.ProgramsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Programs"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="900"
    FlowDirection="RightToLeft"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  ══════════════ الألوان الأساسية ══════════════  -->
        <SolidColorBrush x:Key="BgBase" Color="#0C0F16" />
        <SolidColorBrush x:Key="BgSurface" Color="#141821" />
        <SolidColorBrush x:Key="BgElevated" Color="#1C2130" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A3042" />
        <SolidColorBrush x:Key="TextMain" Color="#E4E8F1" />
        <SolidColorBrush x:Key="TextMuted" Color="#5E6687" />

        <!--  ألوان مميزة للبرامج  -->
        <SolidColorBrush x:Key="CyanAccent" Color="#22D3EE" />
        <SolidColorBrush x:Key="NavyAccent" Color="#1E3A5F" />
        <SolidColorBrush x:Key="AmberAccent" Color="#D4943A" />
        <SolidColorBrush x:Key="RedAccent" Color="#E54D4D" />

        <!--  ══════════════ التدرجات ══════════════  -->
        <LinearGradientBrush x:Key="GradCyanBtn" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#22D3EE" />
            <GradientStop Offset="1" Color="#06B6D4" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradLine" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#22D3EE" />
            <GradientStop Offset="1" Color="#D4943A" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradCyanAvatar" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#22D3EE" />
            <GradientStop Offset="1" Color="#1E88E5" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradNavyBadge" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#1E3A5F" />
            <GradientStop Offset="1" Color="#0F2744" />
        </LinearGradientBrush>

        <!--  ══════════════ التأثيرات ══════════════  -->
        <DropShadowEffect
            x:Key="GlowCyan"
            BlurRadius="10"
            Opacity="0.2"
            ShadowDepth="0"
            Color="#22D3EE" />
        <DropShadowEffect
            x:Key="GlowCyanBtn"
            BlurRadius="18"
            Opacity="0.3"
            ShadowDepth="4"
            Color="#22D3EE" />
        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="24"
            Opacity="0.25"
            ShadowDepth="4"
            Color="#000000" />

        <!--  ══════════════ نمط صف DataGrid ══════════════  -->
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C2130" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#242A3A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ══════════════ نمط خلية DataGrid ══════════════  -->
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,18" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#E4E8F1" />
            <Setter Property="FontSize" Value="14" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E4E8F1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ══════════════ نمط رأس العمود ══════════════  -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#181D28" />
            <Setter Property="Foreground" Value="#5E6687" />
            <Setter Property="Padding" Value="14,16" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SeparatorVisibility" Value="Collapsed" />
        </Style>

        <!--  ══════════════ أزرار الإجراءات ══════════════  -->
        <Style x:Key="BtnActionCyan" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22D3EE" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#22D3EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnActionRed" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E54D4D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ بطاقة إحصائية ══════════════  -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#141821" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="#2A3042" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!--  ══════════════ زر الإضافة ══════════════  -->
        <Style x:Key="BtnAddStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0C0F16" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="20,10"
                            Background="{StaticResource GradCyanBtn}"
                            CornerRadius="10"
                            Effect="{StaticResource GlowCyanBtn}"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Kind="Plus" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!--  ═══════════════════════════════════════════  -->
    <!--  التخطيط الرئيسي  -->
    <!--  ═══════════════════════════════════════════  -->
    <Grid Background="#0C0F16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════════ الرأس ═══════════  -->
        <Grid Grid.Row="0" Margin="28,28,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    FontSize="26"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="إدارة البرامج" />
                <TextBlock
                    Margin="0,5,0,0"
                    FontSize="13"
                    Foreground="#5E6687"
                    Text="تنظيم وجدولة البرامج الإذاعية وفقاً للفئات" />
                <Border
                    Width="55"
                    Height="3"
                    Margin="0,14,0,0"
                    Background="{StaticResource GradLine}"
                    CornerRadius="2">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.5"
                            ShadowDepth="0"
                            Color="#22D3EE" />
                    </Border.Effect>
                </Border>
            </StackPanel>

            <Button
                x:Name="BtnAddProgram"
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="BtnAddProgram_Click"
                Content="إضافة برنامج جديد"
                Style="{StaticResource BtnAddStyle}" />
        </Grid>

        <!--  ═══════════ شريط البحث والإحصائيات ═══════════  -->
        <Grid Grid.Row="1" Margin="28,18,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,12,0"
                materialDesign:HintAssist.Foreground="#5E6687"
                materialDesign:HintAssist.Hint="بحث باسم البرنامج أو الفئة..."
                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                FontSize="14"
                Foreground="#E4E8F1"
                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  إجمالي البرامج  -->
            <Border
                Grid.Column="1"
                Margin="6,0"
                Style="{StaticResource StatCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="38"
                        Height="38"
                        Background="#22D3EE12"
                        CornerRadius="9">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#22D3EE"
                            Kind="RadioTower" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="10"
                            Foreground="#5E6687"
                            Text="إجمالي البرامج" />
                        <TextBlock
                            x:Name="TxtTotal"
                            Margin="0,2,0,0"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#E4E8F1"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  الفئات  -->
            <Border
                Grid.Column="2"
                Margin="12,0,0,0"
                Style="{StaticResource StatCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="38"
                        Height="38"
                        Background="#D4943A12"
                        CornerRadius="9">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#D4943A"
                            Kind="TagMultipleOutline" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="10"
                            Foreground="#5E6687"
                            Text="الفئات" />
                        <TextBlock
                            x:Name="TxtCategories"
                            Margin="0,2,0,0"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#D4943A"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  ═══════════ جدول البيانات ═══════════  -->
        <Border
            Grid.Row="2"
            Margin="28,16,28,28"
            Background="#141821"
            BorderBrush="#2A3042"
            BorderThickness="1"
            CornerRadius="14"
            Effect="{StaticResource CardShadow}">
            <DataGrid
                x:Name="DgPrograms"
                AutoGenerateColumns="False"
                Background="Transparent"
                CanUserAddRows="False"
                CellStyle="{StaticResource DgCell}"
                ColumnHeaderStyle="{StaticResource DgHeader}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                IsReadOnly="True"
                MinRowHeight="50"
                RowStyle="{StaticResource DgRow}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectionMode="Single"
                SelectionUnit="FullRow">

                <DataGrid.Columns>

                    <!--  عمود البرنامج: أفاتار + اسم  -->
                    <DataGridTemplateColumn Width="*" Header="البرنامج">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <Border
                                        Width="30"
                                        Height="30"
                                        Background="{StaticResource GradCyanAvatar}"
                                        CornerRadius="19"
                                        Effect="{StaticResource GlowCyan}">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="White"
                                            Kind="Radio" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            Foreground="#E4E8F1"
                                            Text="{Binding ProgramName}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الفئة: شارة نيلية  -->
                    <DataGridTemplateColumn Width="200" Header="الفئة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="14,6"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource GradNavyBadge}"
                                    BorderBrush="#22D3EE20"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Foreground="#22D3EE"
                                            Kind="TagOutline" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="Medium"
                                            Foreground="#22D3EE"
                                            Text="{Binding Category}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الإجراءات  -->
                    <DataGridTemplateColumn Width="100" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource BtnActionCyan}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="15"
                                            Height="15"
                                            Foreground="#5E6687"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Margin="6,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource BtnActionRed}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="15"
                                            Height="15"
                                            Foreground="#5E6687"
                                            Kind="TrashCanOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>