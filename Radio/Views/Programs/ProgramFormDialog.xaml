<mah:MetroWindow
    x:Class="Radio.Views.Programs.ProgramFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة البرامج"
    Width="600"
    Height="620"
    AllowsTransparency="True"
    Background="Transparent"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    UseNoneWindowStyle="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <materialDesign:Card
        Margin="30"
        materialDesign:ElevationAssist.Elevation="Dp2"
        Background="{DynamicResource MaterialDesignPaper}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Padding="24,20"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Foreground="White"
                Mode="Custom">
                <materialDesign:ColorZone.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#006064" />
                        <GradientStop Offset="1" Color="#004D40" />
                    </LinearGradientBrush>
                </materialDesign:ColorZone.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="RadioTower" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock
                            x:Name="TxtTitle"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource TitleLarge}"
                            Text="إعداد البرنامج الإذاعي" />
                        <TextBlock
                            FontSize="11"
                            Foreground="White"
                            Opacity="0.8"
                            Text="أدخل البيانات التعريفية للبرنامج وتصنيفه" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="CloseButton_Click"
                        Foreground="White"
                        Opacity="0.7"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="28,20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <TextBox
                        x:Name="TxtName"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="اسم البرنامج الإذاعي *"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MicrophoneVariant"
                        Style="{StaticResource BroadcastTextBox}" />

                    <TextBox
                        x:Name="TxtCategory"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="تصنيف المحتوى (سياسي، أدبي...)"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TagOutline"
                        Style="{StaticResource BroadcastTextBox}" />

                    <TextBox
                        x:Name="TxtDesc"
                        Height="130"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="نبذة تعريفية عن البرنامج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TextSubject"
                        AcceptsReturn="True"
                        Style="{StaticResource BroadcastTextBox}"
                        TextWrapping="Wrap" />

                </StackPanel>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="28,24"
                Background="{DynamicResource MaterialDesignDivider}"
                CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="إلغاء"
                        IsCancel="True"
                        Style="{StaticResource CancelFlatButton}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp2"
                        Background="#006064"
                        BorderBrush="#006064"
                        Click="BtnSave_Click"
                        Content="اعتماد البرنامج"
                        Style="{StaticResource PrimaryActionButton}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="ContentSaveCheckOutline" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>