<mah:MetroWindow
    x:Class="Radio.Views.Programs.ProgramFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="ProgramFormDialog"
    Width="600"
    Height="620"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowCloseButton="False"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">


    <!--  ═══════════ التخطيط الرئيسي ═══════════  -->
    <!--  استخدام MaterialDesignCardBackground يعطي النافذة خلفية مرتفعة قليلاً عن النافذة الأم (مظهر حواري احترافي)  -->
    <Grid Margin="40" Background="{DynamicResource MaterialDesignCardBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ═══════════ الرأس (بدون تدرجات أو توهج) ═══════════  -->
        <Border
            Grid.Row="0"
            Padding="0,24,0,20"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="48"
                    Height="48"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    CornerRadius="12">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Kind="RadioTower" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="TxtTitle"
                        Style="{StaticResource TitleLarge}"
                        Text="إضافة برنامج جديد" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Style="{StaticResource BodyMedium}"
                        Text="أدخل تفاصيل البرنامج الإذاعي" />
                </StackPanel>

                <!--  زر إغلاق النافذة (أيقونة X)  -->
                <Button
                    Grid.Column="2"
                    Click="CloseButton_Click"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="Close" />
                </Button>
            </Grid>
        </Border>

        <!--  ═══════════ المحتوى (الحقول) ═══════════  -->
        <ScrollViewer
            Grid.Row="1"
            Margin="10"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  اسم البرنامج  -->
                <TextBox
                    x:Name="TxtName"
                    Margin="0,8"
                    materialDesign:HintAssist.Hint="اسم البرنامج *"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Radio"
                    Style="{StaticResource BroadcastTextBox}" />

                <!--  الفئة  -->
                <TextBox
                    x:Name="TxtCategory"
                    Margin="0,16"
                    materialDesign:HintAssist.Hint="الفئة (مثلاً: سياسي، ثقافي)"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="TagMultipleOutline"
                    Style="{StaticResource BroadcastTextBox}" />

                <!--  وصف البرنامج  -->
                <TextBox
                    x:Name="TxtDesc"
                    Height="120"
                    Margin="0,16"
                    VerticalContentAlignment="Top"
                    materialDesign:HintAssist.Hint="وصف البرنامج"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="FileDocumentOutline"
                    AcceptsReturn="True"
                    Style="{StaticResource BroadcastTextBox}"
                    TextWrapping="Wrap" />

            </StackPanel>
        </ScrollViewer>

        <!--  ═══════════ التذييل (الأزرار) ═══════════  -->
        <Border
            Grid.Row="2"
            Margin="10"
            Padding="0,16,0,0"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="0,1,0,0">
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  زر الإلغاء (Flat Button باللون الرمادي)  -->
                <Button
                    Grid.Column="0"
                    Content="إلغاء"
                    IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatButton}" />

                <!--  زر الحفظ (باستخدام الـ Style المركزي المتوافق مع المواصفات)  -->
                <Button
                    x:Name="BtnSave"
                    Grid.Column="2"
                    Click="BtnSave_Click"
                    Style="{StaticResource PrimaryActionButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Kind="ContentSaveOutline" />
                        <TextBlock VerticalAlignment="Center" Text="حفظ البيانات" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>