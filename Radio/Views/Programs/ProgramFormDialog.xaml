<mah:MetroWindow
    x:Class="Radio.Views.Programs.ProgramFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة البرامج"
    Width="600"
    MaxHeight="700"
    SizeToContent="Height"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">
    <!--  تمت إزالة AllowsTransparency و Background لأنها موجودة داخل Window.Dialog  -->

    <materialDesign:Card
        Margin="30"
        Effect="{StaticResource Shadow.Dialog}"
        Style="{StaticResource Card.Form}"
        UniformCornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══════ 1. الهيدر ═══════  -->
            <!--  إضافة CornerRadius ليتطابق مع حواف الكارت الخارجية  -->
            <materialDesign:ColorZone
                Grid.Row="0"
                Mode="Custom"
                Style="{StaticResource Zone.Header.Primary}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="RadioTower" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إعداد البرنامج الإذاعي" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="أدخل البيانات التعريفية للبرنامج وتصنيفه" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="CloseButton_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  ═══════ 2. المحتوى ═══════  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <!--  مسافة موحدة 28 من الجوانب، و 24 من الأعلى والأسفل  -->
                <StackPanel Margin="28,24">

                    <TextBox
                        x:Name="TxtName"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="اسم البرنامج الإذاعي *"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MicrophoneVariant"
                        Style="{StaticResource Input.Text}" />

                    <TextBox
                        x:Name="TxtCategory"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="تصنيف المحتوى (سياسي، أدبي...)"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TagOutline"
                        Style="{StaticResource Input.Text}" />

                    <TextBox
                        x:Name="TxtDesc"
                        Height="120"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="نبذة تعريفية عن البرنامج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TextSubject"
                        AcceptsReturn="True"
                        Style="{StaticResource Input.Text.Multiline}"
                        TextWrapping="Wrap" />

                </StackPanel>
            </ScrollViewer>

            <!--  ═══════ 3. الذيل (تم إصلاحه بالكامل) ═══════  -->
            <Border
                Grid.Row="2"
                Padding="28,20"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,16,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="إلغاء"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <!--  تم استخدام الطريقة الاحترافية لإضافة الأيقونة في MDIX  -->
                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Style="{StaticResource Btn.Primary}">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Kind="ContentSaveCheckOutline" />
                            <TextBlock VerticalAlignment="Center" Text="اعتماد البرنامج" />
                        </StackPanel>

                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>