<UserControl
    x:Class="Radio.Views.Programs.ProgramFormControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="500"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp8" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <materialDesign:ColorZone Mode="Custom" Style="{StaticResource Zone.Header.Primary}">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextOnPrimaryBrush}"
                        Kind="RadioTower" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إعداد البرنامج الإذاعي" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="أدخل البيانات التعريفية للبرنامج وتصنيفه" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        CommandParameter="{x:Null}"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  Content  -->
            <ScrollViewer
                Grid.Row="1"
                MaxHeight="500"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24">
                    <TextBox
                        x:Name="TxtName"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="اسم البرنامج الإذاعي *"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MicrophoneVariant"
                        Style="{StaticResource Input.Text}" />

                    <TextBox
                        x:Name="TxtCategory"
                        Margin="0,0,0,16"
                        materialDesign:HintAssist.Hint="تصنيف المحتوى (سياسي، أدبي...)"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TagOutline"
                        Style="{StaticResource Input.Text}" />

                    <TextBox
                        x:Name="TxtDesc"
                        Height="120"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="نبذة تعريفية عن البرنامج"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TextSubject"
                        AcceptsReturn="True"
                        Style="{StaticResource Input.Text.Multiline}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!--  Footer  -->
            <Border
                Grid.Row="2"
                Padding="28,20"
                Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        CommandParameter="{x:Null}"
                        Content="إلغاء"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Style="{StaticResource Btn.Primary}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Kind="ContentSaveCheckOutline" />
                            <TextBlock VerticalAlignment="Center" Text="اعتماد البرنامج" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</UserControl>
