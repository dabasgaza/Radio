<mah:MetroWindow
    x:Class="Radio.Views.Programs.ProgramFormControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="500"
    Height="700"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp8" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <materialDesign:ColorZone
                CornerRadius="16,16,0,0"
                Mode="Custom"
                Style="{StaticResource Zone.Header.Primary}">
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Glowing Icon Border Wrapper  -->
                    <Border
                        Width="40"
                        Height="40"
                        VerticalAlignment="Center"
                        Background="#20FFFFFF"
                        CornerRadius="20">
                        <materialDesign:PackIcon
                            Width="22"
                            Height="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="RadioTower" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إعداد البرنامج الإذاعي" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Opacity="0.8"
                            Style="{StaticResource Type.BodyMedium.OnColor}"
                            Text="أدخل البيانات التعريفية للبرنامج وتصنيفه" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!--  Content  -->
            <ScrollViewer
                Grid.Row="1"
                MaxHeight="500"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24">

                    <!--  Program Name  -->
                    <TextBox
                        x:Name="TxtName"
                        Margin="0,0,0,20"
                        materialDesign:HintAssist.Hint="اسم البرنامج الإذاعي *"
                        materialDesign:TextFieldAssist.CharacterCounterVisibility="Visible"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MicrophoneVariant"
                        MaxLength="100"
                        Style="{StaticResource Input.Text}" />

                    <!--  Content Category  -->
                    <TextBox
                        x:Name="TxtCategory"
                        Margin="0,0,0,20"
                        materialDesign:HintAssist.Hint="تصنيف المحتوى (سياسي، أدبي، رياضي...) *"
                        materialDesign:TextFieldAssist.CharacterCounterVisibility="Visible"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TagOutline"
                        MaxLength="50"
                        Style="{StaticResource Input.Text}" />

                    <!--  Brief Description  -->
                    <TextBox
                        x:Name="TxtDesc"
                        Height="120"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="نبذة تعريفية عن البرنامج"
                        materialDesign:TextFieldAssist.CharacterCounterVisibility="Visible"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="TextSubject"
                        AcceptsReturn="True"
                        MaxLength="500"
                        Style="{StaticResource Input.Text.Multiline}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!--  Footer  -->
            <Border
                Grid.Row="2"
                Padding="28,20"
                Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="إلغاء"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Style="{StaticResource Btn.Primary}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Kind="ContentSaveCheckOutline" />
                            <TextBlock VerticalAlignment="Center" Text="اعتماد البرنامج" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  Loading Overlay  -->
            <Grid
                x:Name="LoadingOverlay"
                Grid.RowSpan="3"
                Background="#A0FFFFFF"
                Visibility="Collapsed">
                <Border Background="Transparent" CornerRadius="16">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar
                            Width="48"
                            Height="48"
                            Margin="16"
                            Foreground="{DynamicResource PrimaryMainBrush}"
                            IsIndeterminate="True"
                            Style="{StaticResource MaterialDesignCircularProgressBar}"
                            Value="0" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource PrimaryMainBrush}"
                            Style="{StaticResource Type.BodyMedium}"
                            Text="جاري حفظ البيانات..." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:Card>

</mah:MetroWindow>
