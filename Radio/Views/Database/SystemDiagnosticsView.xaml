<UserControl
    x:Class="Radio.Views.Database.SystemDiagnosticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource RadiusMedium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryDarkBrush}"
                        Style="{StaticResource Type.Headline}"
                        Text="مراقبة النظام وأداء العمليات (Diagnostics Dashboard)" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodyMedium}"
                        Text="تتبع أحداث النظام المنظمة، وتحليل أداء استعلامات SQL، وتشخيص الأخطاء والمشاكل بكفاءة وسلاسة عالية." />
                </StackPanel>

                <materialDesign:PackIcon
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource PrimaryMainBrush}"
                    Kind="MonitorDashboard" />
            </Grid>
        </Border>

        <!--  Tabbed Dashboard Content  -->
        <TabControl Grid.Row="1" Style="{StaticResource Tab.Modern}">

            <!--  Tab 1: Dashboard Overview  -->
            <TabItem Header="لوحة المراقبة العامة">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Summary Cards  -->
                    <UniformGrid
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        Columns="4">
                        <!--  Card 1: Total Logs  -->
                        <materialDesign:Card
                            Margin="0,0,12,0"
                            Padding="16"
                            Background="{DynamicResource PrimaryXLightBrush}"
                            BorderBrush="{DynamicResource PrimaryLightBrush}"
                            BorderThickness="1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <materialDesign:PackIcon
                                    Width="28"
                                    Height="28"
                                    Foreground="{DynamicResource PrimaryMainBrush}"
                                    Kind="ListBoxOutline" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodySmall}"
                                    Text="إجمالي الأحداث المسجلة" />
                                <TextBlock
                                    x:Name="TxtTotalLogs"
                                    Margin="0,4,0,0"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryDarkBrush}"
                                    Text="0" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!--  Card 2: Total Errors  -->
                        <materialDesign:Card
                            Margin="0,0,12,0"
                            Padding="16"
                            Background="{DynamicResource ErrorLightBrush}"
                            BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <materialDesign:PackIcon
                                    Width="28"
                                    Height="28"
                                    Foreground="{DynamicResource ErrorBrush}"
                                    Kind="AlertCircleOutline" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodySmall}"
                                    Text="الأخطاء والعيوب المكتشفة" />
                                <TextBlock
                                    x:Name="TxtTotalErrors"
                                    Margin="0,4,0,0"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource ErrorBrush}"
                                    Text="0" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!--  Card 3: Total SQL Queries  -->
                        <materialDesign:Card
                            Margin="0,0,12,0"
                            Padding="16"
                            Background="{DynamicResource InfoLightBrush}"
                            BorderBrush="{DynamicResource InfoBrush}"
                            BorderThickness="1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <materialDesign:PackIcon
                                    Width="28"
                                    Height="28"
                                    Foreground="{DynamicResource InfoBrush}"
                                    Kind="DatabaseSearch" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodySmall}"
                                    Text="استعلامات قاعدة البيانات" />
                                <TextBlock
                                    x:Name="TxtTotalQueries"
                                    Margin="0,4,0,0"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource InfoBrush}"
                                    Text="0" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!--  Card 4: Slow Queries  -->
                        <materialDesign:Card
                            Padding="16"
                            Background="{DynamicResource WarningLightBrush}"
                            BorderBrush="{DynamicResource WarningBrush}"
                            BorderThickness="1"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <materialDesign:PackIcon
                                    Width="28"
                                    Height="28"
                                    Foreground="{DynamicResource WarningBrush}"
                                    Kind="TimerAlertOutline" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodySmall}"
                                    Text="الاستعلامات البطيئة (&gt;100ms)" />
                                <TextBlock
                                    x:Name="TxtSlowQueries"
                                    Margin="0,4,0,0"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource WarningBrush}"
                                    Text="0" />
                            </StackPanel>
                        </materialDesign:Card>
                    </UniformGrid>

                    <!--  Metrics and Health Charts  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Health & Performance Details  -->
                        <materialDesign:Card
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            Padding="16"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,16"
                                    FontWeight="Bold"
                                    Style="{StaticResource Type.TitleMedium}"
                                    Text="مؤشرات كفاءة الاستعلامات وقاعدة البيانات" />

                                <Grid Margin="0,8">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="متوسط سرعة استجابة قاعدة البيانات (SQL)" />
                                    <TextBlock
                                        x:Name="TxtAvgQueryTime"
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="0.0 ms" />
                                </Grid>
                                <ProgressBar
                                    x:Name="ProgressQueryTime"
                                    Height="8"
                                    Margin="0,0,0,16"
                                    Background="{DynamicResource DividerBrush}"
                                    Foreground="{DynamicResource PrimaryMainBrush}"
                                    Maximum="100"
                                    Value="20" />

                                <Grid Margin="0,8">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="نسبة الاستعلامات البطيئة من الإجمالي" />
                                    <TextBlock
                                        x:Name="TxtSlowQueryRatio"
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource WarningBrush}"
                                        Text="0%" />
                                </Grid>
                                <ProgressBar
                                    x:Name="ProgressSlowRatio"
                                    Height="8"
                                    Margin="0,0,0,16"
                                    Background="{DynamicResource DividerBrush}"
                                    Foreground="{DynamicResource WarningBrush}"
                                    Maximum="100"
                                    Value="10" />

                                <Grid Margin="0,8">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="معدل استقرار النظام (خالٍ من الأخطاء)" />
                                    <TextBlock
                                        x:Name="TxtStabilityRate"
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource SuccessBrush}"
                                        Text="100%" />
                                </Grid>
                                <ProgressBar
                                    x:Name="ProgressStability"
                                    Height="8"
                                    Margin="0,0,0,16"
                                    Background="{DynamicResource DividerBrush}"
                                    Foreground="{DynamicResource SuccessBrush}"
                                    Maximum="100"
                                    Value="95" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!--  Server connection & Seq Info  -->
                        <materialDesign:Card
                            Grid.Column="1"
                            Padding="16"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,16"
                                    FontWeight="Bold"
                                    Style="{StaticResource Type.TitleMedium}"
                                    Text="معلومات خادم التتبع والربط" />

                                <StackPanel Margin="0,8" Orientation="Horizontal">
                                    <TextBlock
                                        Width="130"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="خادم Seq النشط:" />
                                    <TextBlock
                                        x:Name="TxtSeqServerUrl"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource PrimaryMainBrush}"
                                        Text="http://localhost:5341" />
                                </StackPanel>

                                <StackPanel Margin="0,8" Orientation="Horizontal">
                                    <TextBlock
                                        Width="130"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="حالة الاتصال بالخادم:" />
                                    <Border
                                        x:Name="BorderStatus"
                                        Padding="6,2"
                                        Background="{DynamicResource SuccessLightBrush}"
                                        BorderBrush="{DynamicResource SuccessBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <TextBlock
                                            x:Name="TxtStatusText"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource SuccessBrush}"
                                            Text="متصل / محاكاة افتراضية" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Margin="0,8" Orientation="Horizontal">
                                    <TextBlock
                                        Width="130"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="مستوى التسجيل:" />
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" Text="Information (أو أعلى)" />
                                </StackPanel>

                                <Button
                                    Margin="0,24,0,0"
                                    HorizontalAlignment="Left"
                                    Click="BtnRefreshAll_Click"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,8,0"
                                            Kind="Refresh" />
                                        <TextBlock Text="تحديث كافة البيانات" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>

            <!--  Tab 2: Logs Viewer  -->
            <TabItem Header="سجل أحداث النظام">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Filters  -->
                    <materialDesign:Card
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        Padding="12"
                        UniformCornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodySmall}"
                                    Text="مستوى السجل" />
                                <ComboBox
                                    x:Name="ComboLogLevels"
                                    SelectionChanged="ComboLogLevels_SelectionChanged"
                                    Style="{StaticResource Input.ComboBox}">
                                    <ComboBoxItem Content="الكل" Tag="" />
                                    <ComboBoxItem Content="معلومات (Information)" Tag="Information" />
                                    <ComboBoxItem Content="تحذيرات (Warning)" Tag="Warning" />
                                    <ComboBoxItem Content="أخطاء (Error)" Tag="Error" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodySmall}"
                                    Text="بحث في محتوى السجلات" />
                                <TextBox
                                    x:Name="TxtSearchLogs"
                                    materialDesign:HintAssist.Hint="ابحث عن نص، دالة، أو استعلام معين..."
                                    Style="{StaticResource Input.Search}"
                                    TextChanged="TxtSearchLogs_TextChanged" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Click="BtnResetLogsFilters_Click"
                                    Style="{StaticResource Btn.Icon}"
                                    ToolTip="إعادة تعيين الفلاتر">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Kind="FilterOff" />
                                </Button>
                                <Button
                                    Height="36"
                                    Click="BtnClearLogs_Click"
                                    Style="{StaticResource Btn.Danger}"
                                    ToolTip="مسح كافة سجلات الأخطاء">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            Kind="DeleteSweep" />
                                        <TextBlock VerticalAlignment="Center" Text="مسح السجلات" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!--  Data Grid & Details  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3.2*" />
                            <ColumnDefinition Width="1.8*" />
                        </Grid.ColumnDefinitions>

                        <!--  Grid  -->
                        <materialDesign:Card
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            Padding="8"
                            UniformCornerRadius="12">
                            <DataGrid
                                x:Name="GridLogs"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                IsReadOnly="True"
                                SelectionChanged="GridLogs_SelectionChanged"
                                SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="110"
                                        Binding="{Binding Timestamp, StringFormat='dd-MM HH:mm:ss'}"
                                        Header="الوقت" />

                                    <DataGridTemplateColumn Width="95" Header="المستوى">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="Information">
                                                                    <Setter Property="Background" Value="{DynamicResource InfoLightBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                    <Setter Property="Background" Value="{DynamicResource WarningLightBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                    <Setter Property="Background" Value="{DynamicResource ErrorLightBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Level}" Value="Information">
                                                                        <Setter Property="Foreground" Value="{DynamicResource InfoBrush}" />
                                                                        <Setter Property="Text" Value="معلومات" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                                        <Setter Property="Text" Value="تحذير" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                                        <Setter Property="Text" Value="خطأ" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Message}"
                                        Header="المحتوى" />
                                    <DataGridTextColumn
                                        Width="180"
                                        Binding="{Binding SourceContext}"
                                        Header="المصدر" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </materialDesign:Card>

                        <!--  Detail Panel  -->
                        <materialDesign:Card
                            Grid.Column="1"
                            Padding="16"
                            UniformCornerRadius="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Margin="0,0,0,12"
                                    FontWeight="Bold"
                                    Style="{StaticResource Type.TitleMedium}"
                                    Text="تفاصيل الحدث البرمجي" />

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PanelLogDetail" Visibility="Collapsed">
                                        <TextBlock
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Style="{StaticResource Type.BodySmall}"
                                            Text="المصدر البرمجي (Context):" />
                                        <TextBlock
                                            x:Name="TxtDetailContext"
                                            Margin="0,4,0,12"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            Text="Source"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Style="{StaticResource Type.BodySmall}"
                                            Text="الرسالة:" />
                                        <Border
                                            Margin="0,4,0,12"
                                            Padding="10"
                                            Background="{DynamicResource SurfaceVariantBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <TextBox
                                                x:Name="TxtDetailMessage"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                IsReadOnly="True"
                                                Text="Message"
                                                TextWrapping="Wrap" />
                                        </Border>

                                        <StackPanel x:Name="PanelSqlSection" Visibility="Collapsed">
                                            <TextBlock
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Style="{StaticResource Type.BodySmall}"
                                                Text="استعلام SQL المتأثر:" />
                                            <Border
                                                Margin="0,4,0,12"
                                                Padding="10"
                                                Background="{DynamicResource SurfaceVariantBrush}"
                                                BorderBrush="{DynamicResource DividerBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <TextBox
                                                    x:Name="TxtDetailSql"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource PrimaryDarkBrush}"
                                                    IsReadOnly="True"
                                                    Text="SELECT..."
                                                    TextWrapping="Wrap" />
                                            </Border>

                                            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    Style="{StaticResource Type.BodySmall}"
                                                    Text="زمن التنفيذ:" />
                                                <TextBlock
                                                    x:Name="TxtDetailDuration"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    Text="15ms" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel x:Name="PanelExceptionSection" Visibility="Collapsed">
                                            <TextBlock
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                Style="{StaticResource Type.BodySmall}"
                                                Text="تفاصيل الاستثناء (Exception):" />
                                            <Border
                                                Margin="0,4,0,12"
                                                Padding="10"
                                                Background="{DynamicResource ErrorLightBrush}"
                                                BorderBrush="{DynamicResource ErrorBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <TextBox
                                                    x:Name="TxtDetailException"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource ErrorDarkBrush}"
                                                    IsReadOnly="True"
                                                    Text="Exception details..."
                                                    TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                <TextBlock
                                    x:Name="TxtLogPlaceholder"
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextDisabledBrush}"
                                    Style="{StaticResource Type.BodyMedium}"
                                    Text="اختر حدثاً من القائمة لعرض تفاصيله الكاملة." />
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>

            <!--  Tab 3: SQL Performance  -->
            <TabItem Header="أداء قاعدة البيانات">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Alert message about Slow Queries  -->
                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        Padding="12"
                        Background="{DynamicResource WarningLightBrush}"
                        BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon
                                Grid.Column="0"
                                Width="20"
                                Height="20"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource WarningDarkBrush}"
                                Kind="AlertDecagram" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource WarningDarkBrush}"
                                Style="{StaticResource Type.BodyMedium}"
                                Text="يعرض هذا القسم كافة استعلامات قاعدة البيانات المنفذة. يتم تظليل الاستعلامات التي تستغرق أكثر من 100ms لتسهيل تعقب وتحسين الأداء." />
                        </Grid>
                    </Border>

                    <!--  SQL Log list  -->
                    <materialDesign:Card
                        Grid.Row="1"
                        Padding="8"
                        UniformCornerRadius="12">
                        <DataGrid
                            x:Name="GridSqlPerformance"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            IsReadOnly="True"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="110"
                                    Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                    Header="الوقت" />

                                <DataGridTemplateColumn Width="120" Header="الحالة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="6,2"
                                                HorizontalAlignment="Left"
                                                CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSlowQuery}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource WarningLightBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSlowQuery}" Value="False">
                                                                <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSlowQuery}" Value="True">
                                                                    <Setter Property="FontWeight" Value="Bold" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                                    <Setter Property="Text" Value="استعلام بطيء" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSlowQuery}" Value="False">
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    <Setter Property="Text" Value="طبيعي" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Width="120"
                                    Binding="{Binding DurationMs, StringFormat='{}{0:F1} ms'}"
                                    FontWeight="Bold"
                                    Header="زمن التنفيذ" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Sql}"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    Header="استعلام SQL" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
