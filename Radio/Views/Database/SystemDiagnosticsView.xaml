<UserControl
    x:Class="Radio.Views.Database.SystemDiagnosticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryDarkBrush}"
                        Style="{StaticResource Type.Headline}"
                        Text="مراقبة النظام وأداء العمليات (Seq Dashboard)" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodyMedium}"
                        Text="تتبع أحداث النظام المنظمة، وتحليل أداء استعلامات SQL، وتشخيص الأخطاء والمشاكل بكفاءة عالية." />
                </StackPanel>

                <materialDesign:PackIcon
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource PrimaryMainBrush}"
                    Kind="MonitorDashboard" />
            </Grid>
        </Border>

        <!-- Tabbed Dashboard Content -->
        <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignNavigationRailTabControl}">
            
            <!-- Tab 1: Dashboard Overview -->
            <TabItem Header="لوحة المراقبة العامة">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Summary Cards -->
                    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,16">
                        <!-- Card 1: Total Logs -->
                        <materialDesign:Card Margin="0,0,12,0" Padding="16" Background="#E8EAF6">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ListBoxOutline" Width="28" Height="28" Foreground="#3F51B5" />
                                <TextBlock Text="إجمالي الأحداث المسجلة" Margin="0,8,0,0" Foreground="#5C6BC0" Style="{StaticResource Type.BodySmall}" />
                                <TextBlock x:Name="TxtTotalLogs" Text="0" FontWeight="Bold" FontSize="28" Foreground="#303F9F" Margin="0,4,0,0" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Card 2: Total Errors -->
                        <materialDesign:Card Margin="0,0,12,0" Padding="16" Background="#FFEBEE">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="28" Height="28" Foreground="#F44336" />
                                <TextBlock Text="الأخطاء والعيوب المكتشفة" Margin="0,8,0,0" Foreground="#E57373" Style="{StaticResource Type.BodySmall}" />
                                <TextBlock x:Name="TxtTotalErrors" Text="0" FontWeight="Bold" FontSize="28" Foreground="#D32F2F" Margin="0,4,0,0" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Card 3: Total SQL Queries -->
                        <materialDesign:Card Margin="0,0,12,0" Padding="16" Background="#E0F7FA">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="DatabaseSearch" Width="28" Height="28" Foreground="#00BCD4" />
                                <TextBlock Text="استعلامات قاعدة البيانات" Margin="0,8,0,0" Foreground="#4DD0E1" Style="{StaticResource Type.BodySmall}" />
                                <TextBlock x:Name="TxtTotalQueries" Text="0" FontWeight="Bold" FontSize="28" Foreground="#0097A7" Margin="0,4,0,0" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Card 4: Slow Queries -->
                        <materialDesign:Card Padding="16" Background="#FFF3E0">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="TimerAlertOutline" Width="28" Height="28" Foreground="#FF9800" />
                                <TextBlock Text="الاستعلامات البطيئة (>100ms)" Margin="0,8,0,0" Foreground="#FFB74D" Style="{StaticResource Type.BodySmall}" />
                                <TextBlock x:Name="TxtSlowQueries" Text="0" FontWeight="Bold" FontSize="28" Foreground="#F57C00" Margin="0,4,0,0" />
                            </StackPanel>
                        </materialDesign:Card>
                    </UniformGrid>

                    <!-- Metrics and Health Charts -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Health & Performance Details -->
                        <materialDesign:Card Grid.Column="0" Margin="0,0,12,0" Padding="16">
                            <StackPanel>
                                <TextBlock Text="مؤشرات كفاءة الاستعلامات وقاعدة البيانات" FontWeight="Bold" Margin="0,0,0,16" Style="{StaticResource Type.TitleMedium}" />
                                
                                <Grid Margin="0,8">
                                    <TextBlock Text="متوسط سرعة استجابة قاعدة البيانات (SQL)" HorizontalAlignment="Left" />
                                    <TextBlock x:Name="TxtAvgQueryTime" Text="0.0 ms" FontWeight="Bold" HorizontalAlignment="Right" />
                                </Grid>
                                <ProgressBar x:Name="ProgressQueryTime" Value="20" Maximum="100" Height="8" Margin="0,0,0,16" Foreground="{DynamicResource PrimaryMainBrush}" />

                                <Grid Margin="0,8">
                                    <TextBlock Text="نسبة الاستعلامات البطيئة من الإجمالي" HorizontalAlignment="Left" />
                                    <TextBlock x:Name="TxtSlowQueryRatio" Text="0%" FontWeight="Bold" HorizontalAlignment="Right" />
                                </Grid>
                                <ProgressBar x:Name="ProgressSlowRatio" Value="10" Maximum="100" Height="8" Margin="0,0,0,16" Foreground="#FF9800" />

                                <Grid Margin="0,8">
                                    <TextBlock Text="معدل استقرار النظام (خالٍ من الأخطاء)" HorizontalAlignment="Left" />
                                    <TextBlock x:Name="TxtStabilityRate" Text="100%" FontWeight="Bold" HorizontalAlignment="Right" />
                                </Grid>
                                <ProgressBar x:Name="ProgressStability" Value="95" Maximum="100" Height="8" Margin="0,0,0,16" Foreground="#2E7D32" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Server connection & Seq Info -->
                        <materialDesign:Card Grid.Column="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="معلومات خادم التتبع والربط" FontWeight="Bold" Margin="0,0,0,16" Style="{StaticResource Type.TitleMedium}" />
                                
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="خادم Seq النشط:" FontWeight="SemiBold" Width="130" />
                                    <TextBlock x:Name="TxtSeqServerUrl" Text="http://localhost:5341" Foreground="{DynamicResource PrimaryMainBrush}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="حالة الاتصال بالخادم:" FontWeight="SemiBold" Width="130" />
                                    <Border CornerRadius="4" Padding="6,2" Background="#E8F5E9" x:Name="BorderStatus">
                                        <TextBlock Text="متصل / محاكاة افتراضية" Foreground="#2E7D32" FontWeight="Bold" FontSize="11" x:Name="TxtStatusText" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="مستوى التسجيل:" FontWeight="SemiBold" Width="130" />
                                    <TextBlock Text="Information (أو أعلى)" />
                                </StackPanel>

                                <Button Margin="0,16,0,0" HorizontalAlignment="Left" Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Click="BtnRefreshAll_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" />
                                        <TextBlock Text="تحديث كافة البيانات" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Logs Viewer -->
            <TabItem Header="سجل أحداث النظام">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Filters -->
                    <materialDesign:Card Grid.Row="0" Margin="0,0,0,16" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="مستوى السجل" Style="{StaticResource Type.BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <ComboBox x:Name="ComboLogLevels" SelectionChanged="ComboLogLevels_SelectionChanged">
                                    <ComboBoxItem Content="الكل" Tag="" />
                                    <ComboBoxItem Content="معلومات (Information)" Tag="Information" />
                                    <ComboBoxItem Content="تحذيرات (Warning)" Tag="Warning" />
                                    <ComboBoxItem Content="أخطاء (Error)" Tag="Error" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="بحث في محتوى السجلات" Style="{StaticResource Type.BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox x:Name="TxtSearchLogs" materialDesign:HintAssist.Hint="ابحث عن نص، دالة، أو استعلام معين..." TextChanged="TxtSearchLogs_TextChanged" />
                            </StackPanel>

                            <Button Grid.Column="2" VerticalAlignment="Bottom" Style="{StaticResource MaterialDesignOutlinedButton}" Click="BtnResetLogsFilters_Click">
                                <materialDesign:PackIcon Kind="FilterOff" Width="16" Height="16" />
                            </Button>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Data Grid & Details -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <!-- Grid -->
                        <materialDesign:Card Grid.Column="0" Margin="0,0,12,0" Padding="8">
                            <DataGrid x:Name="GridLogs" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridLogs_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الوقت" Binding="{Binding Timestamp, StringFormat='dd-MM HH:mm:ss'}" Width="100" />
                                    
                                    <DataGridTemplateColumn Header="المستوى" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="Information">
                                                                    <Setter Property="Background" Value="#E3F2FD" />
                                                                    <Setter Property="Child">
                                                                        <Setter.Value>
                                                                            <TextBlock Text="معلومات" Foreground="#1565C0" FontWeight="SemiBold" FontSize="11" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                    <Setter Property="Background" Value="#FFF3E0" />
                                                                    <Setter Property="Child">
                                                                        <Setter.Value>
                                                                            <TextBlock Text="تحذير" Foreground="#EF6C00" FontWeight="SemiBold" FontSize="11" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                    <Setter Property="Background" Value="#FFEBEE" />
                                                                    <Setter Property="Child">
                                                                        <Setter.Value>
                                                                            <TextBlock Text="خطأ" Foreground="#C62828" FontWeight="SemiBold" FontSize="11" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="المحتوى" Binding="{Binding Message}" Width="*" />
                                    <DataGridTextColumn Header="المصدر" Binding="{Binding SourceContext}" Width="150" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </materialDesign:Card>

                        <!-- Detail Panel -->
                        <materialDesign:Card Grid.Column="1" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="تفاصيل الحدث المالي والبرمجي" FontWeight="Bold" Style="{StaticResource Type.TitleMedium}" Margin="0,0,0,12" />

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PanelLogDetail" Visibility="Collapsed">
                                        <TextBlock Text="المصدر البرمجي (Context):" FontWeight="Bold" Style="{StaticResource Type.BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock x:Name="TxtDetailContext" Text="Source" TextWrapping="Wrap" Margin="0,4,0,12" FontWeight="SemiBold" />

                                        <TextBlock Text="الرسالة:" FontWeight="Bold" Style="{StaticResource Type.BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <Border Background="{DynamicResource DividerBrush}" Padding="8" CornerRadius="4" Margin="0,4,0,12">
                                            <TextBlock x:Name="TxtDetailMessage" Text="Message" TextWrapping="Wrap" />
                                        </Border>

                                        <StackPanel x:Name="PanelSqlSection" Visibility="Collapsed">
                                            <TextBlock Text="استعلام SQL المتأثر:" FontWeight="Bold" Style="{StaticResource Type.BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <Border Background="#F5F5F5" Padding="8" CornerRadius="4" Margin="0,4,0,12">
                                                <TextBlock x:Name="TxtDetailSql" Text="SELECT..." FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Foreground="#1A237E" />
                                            </Border>
                                            
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <TextBlock Text="زمن التنفيذ:" FontWeight="Bold" Style="{StaticResource Type.BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                                                <TextBlock x:Name="TxtDetailDuration" Text="15ms" FontWeight="Bold" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel x:Name="PanelExceptionSection" Visibility="Collapsed">
                                            <TextBlock Text="تفاصيل الاستثناء (Exception):" FontWeight="Bold" Style="{StaticResource Type.BodySmall}" Foreground="#C62828" />
                                            <Border Background="#FFEBEE" Padding="8" CornerRadius="4" Margin="0,4,0,12">
                                                <TextBlock x:Name="TxtDetailException" Text="Exception details..." FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Foreground="#B71C1C" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                <TextBlock x:Name="TxtLogPlaceholder" Grid.Row="1" Text="اختر حداً من القائمة لعرض تفاصيله الكاملة." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextDisabledBrush}" />
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 3: SQL Performance -->
            <TabItem Header="أداء قاعدة البيانات">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Alert message about Slow Queries -->
                    <Border Grid.Row="0" Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertDecagram" Width="20" Height="20" Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="يعرض هذا القسم كافة استعلامات قاعدة البيانات المنفذة. يتم تظليل الاستعلامات التي تستغرق أكثر من 100ms باللون البرتقالي لتسهيل تعقب وتحسين الأداء." VerticalAlignment="Center" Foreground="#E65100" Style="{StaticResource Type.BodyMedium}" />
                        </StackPanel>
                    </Border>

                    <!-- SQL Log list -->
                    <materialDesign:Card Grid.Row="1" Padding="8">
                        <DataGrid x:Name="GridSqlPerformance" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الوقت" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="100" />
                                
                                <DataGridTemplateColumn Header="الحالة" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSlowQuery}" Value="True">
                                                                <Setter Property="Background" Value="#FFE0B2" />
                                                                <Setter Property="Child">
                                                                    <Setter.Value>
                                                                        <TextBlock Text="استعلام بطيء" Foreground="#E65100" FontWeight="Bold" FontSize="11" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSlowQuery}" Value="False">
                                                                <Setter Property="Background" Value="#E8F5E9" />
                                                                <Setter Property="Child">
                                                                    <Setter.Value>
                                                                        <TextBlock Text="طبيعي" Foreground="#2E7D32" FontWeight="SemiBold" FontSize="11" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="زمن التنفيذ" Binding="{Binding DurationMs, StringFormat='{}{0:F1} ms'}" Width="110" FontWeight="Bold" />
                                <DataGridTextColumn Header="استعلام SQL" Binding="{Binding Sql}" Width="*" FontFamily="Consolas" FontSize="11" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</UserControl>
