<UserControl
    x:Class="Radio.Views.Database.DatabaseManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:Radio.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converter:FileSizeConverter x:Key="FileSizeConverter" />

        <DropShadowEffect
            x:Key="SoftShadow"
            BlurRadius="18"
            Opacity="0.12"
            ShadowDepth="2"
            Color="#000000" />

        <Style x:Key="SectionCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="UniformCornerRadius" Value="18" />
            <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
        </Style>

        <Style x:Key="ActionButtonBaseStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style
            x:Key="InlineIconTextButtonStyle"
            BasedOn="{StaticResource MaterialDesignFlatButton}"
            TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="StatusChipText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <materialDesign:Card
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="20"
            Background="{DynamicResource SurfaceBrush}"
            Effect="{StaticResource SoftShadow}"
            UniformCornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryDarkBrush}"
                        Text="إدارة قاعدة البيانات" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="13.5"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="النسخ الاحتياطي، الاستعادة، والجدولة التلقائية في واجهة واحدة واضحة وسريعة."
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Width="54"
                    Height="54"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{DynamicResource PrimaryMainBrush}"
                    CornerRadius="16">
                    <materialDesign:PackIcon
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Kind="DatabaseSettings" />
                </Border>
            </Grid>
        </materialDesign:Card>

        <!--  Main Content  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel  -->
            <ScrollViewer
                Grid.Column="0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!--  Quick Actions  -->
                    <materialDesign:Card Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Margin="0,0,8,0"
                                    DockPanel.Dock="Right"
                                    Foreground="{DynamicResource PrimaryMainBrush}"
                                    Kind="LightningBoltOutline" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="العمليات الفورية" />
                            </DockPanel>

                            <Button
                                x:Name="BtnQuickBackup"
                                Click="BtnQuickBackup_Click"
                                Style="{StaticResource Btn.Primary}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Kind="DatabasePlus" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="نسخ احتياطي فوري" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="BtnChooseAndRestore"
                                Click="BtnChooseAndRestore_Click"
                                Style="{StaticResource Btn.AddNew}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Kind="DatabaseRefresh" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="استعادة من ملف" />
                                </Grid>
                            </Button>

                            <Separator Margin="0,8,0,8" />

                            <Button
                                x:Name="BtnInitializeDb"
                                Click="BtnInitializeDb_Click"
                                Style="{StaticResource Btn.Danger}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Foreground="White"
                                        Kind="AlertOctagon" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="White"
                                        Text="تهيئة قاعدة البيانات" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>

                    <!--  Scheduler  -->
                    <materialDesign:Card Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Margin="0,0,8,0"
                                    DockPanel.Dock="Right"
                                    Foreground="{DynamicResource PrimaryMainBrush}"
                                    Kind="CalendarClock" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="إعدادات الجدولة" />
                            </DockPanel>

                            <CheckBox
                                x:Name="ChkEnabled"
                                Content="تفعيل النسخ الاحتياطي التلقائي"
                                IsChecked="True"
                                Style="{StaticResource MaterialDesignCheckBox}" />

                            <CheckBox
                                x:Name="ChkCloudSync"
                                Margin="0,8,0,14"
                                Content="تفعيل النسخ الاحتياطي السحابي"
                                IsChecked="True"
                                Style="{StaticResource MaterialDesignCheckBox}" />

                            <TextBlock
                                Margin="0,0,0,6"
                                FontSize="12.5"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="دورية النسخ التلقائي" />
                            <ComboBox
                                x:Name="ComboInterval"
                                Margin="0,0,0,12"
                                SelectedIndex="1"
                                Style="{StaticResource Input.ComboBox}">
                                <ComboBoxItem Content="كل 6 ساعات" Tag="6" />
                                <ComboBoxItem Content="يومي (كل 24 ساعة)" Tag="24" />
                                <ComboBoxItem Content="أسبوعي (كل 168 ساعة)" Tag="168" />
                            </ComboBox>

                            <TextBlock
                                Margin="0,0,0,6"
                                FontSize="12.5"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="فترة الاحتفاظ بالنسخ (أيام)" />
                            <TextBox
                                x:Name="TxtRetentionDays"
                                Margin="0,0,0,14"
                                materialDesign:HintAssist.Hint="مثال: 30"
                                Style="{StaticResource Input.Text}"
                                Text="30" />

                            <Button
                                x:Name="BtnSaveConfig"
                                Click="BtnSaveConfig_Click"
                                Style="{StaticResource Btn.Secondary}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Kind="ContentSave" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="حفظ الإعدادات" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </ScrollViewer>

            <!--  Right Panel  -->
            <materialDesign:Card
                Grid.Column="2"
                Padding="18"
                Background="{DynamicResource SurfaceBrush}"
                Effect="{StaticResource SoftShadow}"
                Style="{StaticResource Card.Elevated}"
                UniformCornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Top Bar  -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,2,8,0"
                                Foreground="{DynamicResource PrimaryMainBrush}"
                                Kind="History" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="سجل عمليات النسخ الاحتياطي" />
                        </StackPanel>

                        <Button
                            x:Name="BtnRefreshHistory"
                            Grid.Column="1"
                            Click="BtnRefreshHistory_Click"
                            Style="{StaticResource InlineIconTextButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,6,0"
                                    Kind="Refresh" />
                                <TextBlock Text="تحديث" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!--  History Grid  -->
                    <Border
                        Grid.Row="1"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        ClipToBounds="True"
                        CornerRadius="14">
                        <DataGrid
                            x:Name="GridHistory"
                            AlternatingRowBackground="#06000000"
                            AutoGenerateColumns="False"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderThickness="0"
                            CanUserAddRows="False"
                            CellStyle="{StaticResource DataGrid.Cell}"
                            ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"
                            RowHeaderWidth="0"
                            RowStyle="{StaticResource DataGrid.Row}"
                            SelectionMode="Single"
                            Style="{StaticResource DataGrid.Main}"
                            VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="160"
                                    Binding="{Binding CreatedAt, StringFormat='dd-MM-yyyy HH:mm:ss'}"
                                    Header="التاريخ" />

                                <DataGridTextColumn
                                    Width="120"
                                    Binding="{Binding BackupType}"
                                    Header="النوع" />

                                <DataGridTextColumn
                                    Width="110"
                                    Binding="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                    Header="الحجم" />

                                <DataGridTemplateColumn Width="110" Header="الحالة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="8,4"
                                                HorizontalAlignment="Center"
                                                CornerRadius="999">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFF2F2F2" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                <Setter Property="Background" Value="#E8F5E9" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                <Setter Property="Background" Value="#FFEBEE" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style BasedOn="{StaticResource StatusChipText}" TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                            <Setter Property="Text" Value="غير معروف" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                                    <Setter Property="Text" Value="ناجح" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Foreground" Value="#C62828" />
                                                                    <Setter Property="Text" Value="فشل" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding BackupPath}"
                                    Header="المسار المحلي" />

                                <DataGridTemplateColumn Width="190" Header="العمليات">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <Button
                                                    Margin="0,0,6,0"
                                                    Padding="10,4"
                                                    Click="BtnRestoreRow_Click"
                                                    Content="استعادة"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    ToolTip="استعادة قاعدة البيانات إلى هذه النسخة" />
                                                <Button
                                                    Padding="10,4"
                                                    Click="BtnSyncRow_Click"
                                                    Content="مزامنة سحابية"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    ToolTip="مزامنة النسخة المحلية إلى السحابة" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>