<UserControl
    x:Class="Radio.Views.Database.DatabaseManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FlowDirection="RightToLeft"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converter:FileSizeConverter x:Key="FileSizeConverter" xmlns:converter="clr-namespace:Radio.Converter" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryDarkBrush}"
                        Style="{StaticResource Type.HeadlineSmall}"
                        Text="إدارة قاعدة البيانات" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Style="{StaticResource Type.BodyMedium}"
                        Text="أدوات إدارة قاعدة البيانات: النسخ الاحتياطي، الاستعادة، وجدولة العمليات التلقائية." />
                </StackPanel>

                <materialDesign:PackIcon
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource PrimaryMainBrush}"
                    Kind="DatabaseSettings" />
            </Grid>
        </Border>

        <!-- Main Content Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: Controls & Settings -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                
                <!-- Actions Card -->
                <materialDesign:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontWeight="Bold"
                            Style="{StaticResource Type.TitleMedium}"
                            Text="العمليات الفورية" />

                        <Button
                            x:Name="BtnQuickBackup"
                            Margin="0,0,0,8"
                            Click="BtnQuickBackup_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="DatabasePlus" />
                                <TextBlock Text="نسخ احتياطي فوري" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="BtnChooseAndRestore"
                            Margin="0,0,0,8"
                            Click="BtnChooseAndRestore_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="DatabaseRefresh" />
                                <TextBlock Text="استعادة من ملف..." />
                            </StackPanel>
                        </Button>

                        <Separator Margin="0,8" />

                        <Button
                            x:Name="BtnInitializeDb"
                            Background="{DynamicResource ErrorBrush}"
                            BorderBrush="{DynamicResource ErrorBrush}"
                            Click="BtnInitializeDb_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Foreground="White"
                                    Kind="AlertOctagon" />
                                <TextBlock Foreground="White" Text="تهيئة قاعدة البيانات" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Configuration/Scheduler Settings Card -->
                <materialDesign:Card Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontWeight="Bold"
                            Style="{StaticResource Type.TitleMedium}"
                            Text="إعدادات الجدولة والنسخ التلقائي" />

                        <CheckBox
                            x:Name="ChkEnabled"
                            Content="تفعيل النسخ الاحتياطي التلقائي"
                            IsChecked="True"
                            Style="{StaticResource MaterialDesignCheckBox}" />

                        <CheckBox
                            x:Name="ChkCloudSync"
                            Margin="0,8,0,12"
                            Content="تفعيل النسخ الاحتياطي السحابي"
                            IsChecked="True"
                            Style="{StaticResource MaterialDesignCheckBox}" />

                        <TextBlock
                            Margin="0,8,0,4"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Style="{StaticResource Type.BodySmall}"
                            Text="دورية النسخ التلقائي (بالساعات)" />
                        
                        <ComboBox
                            x:Name="ComboInterval"
                            Margin="0,0,0,12"
                            SelectedIndex="1">
                            <ComboBoxItem Content="كل 6 ساعات" Tag="6" />
                            <ComboBoxItem Content="يومي (كل 24 ساعة)" Tag="24" />
                            <ComboBoxItem Content="أسبوعي (كل 168 ساعة)" Tag="168" />
                        </ComboBox>

                        <TextBlock
                            Margin="0,4,0,4"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Style="{StaticResource Type.BodySmall}"
                            Text="فترة الاحتفاظ بالنسخ (أيام)" />
                        
                        <TextBox
                            x:Name="TxtRetentionDays"
                            Margin="0,0,0,16"
                            materialDesign:HintAssist.Hint="مثال: 30"
                            Text="30" />

                        <Button
                            x:Name="BtnSaveConfig"
                            Click="BtnSaveConfig_Click"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="ContentSave" />
                                <TextBlock Text="حفظ الإعدادات" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>

            <!-- Main Panel: Backup History -->
            <Grid Grid.Column="1">
                <materialDesign:Card Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                FontWeight="Bold"
                                Style="{StaticResource Type.TitleLarge}"
                                Text="سجل عمليات النسخ الاحتياطي" />

                            <Button
                                x:Name="BtnRefreshHistory"
                                Grid.Column="1"
                                Padding="8,4"
                                Click="BtnRefreshHistory_Click"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,4,0"
                                        Kind="Refresh" />
                                    <TextBlock Text="تحديث" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <DataGrid
                            x:Name="GridHistory"
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            IsReadOnly="True"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="150"
                                    Binding="{Binding CreatedAt, StringFormat='dd-MM-yyyy HH:mm:ss'}"
                                    Header="التاريخ" />
                                
                                <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding BackupType}"
                                    Header="النوع" />

                                <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                    Header="الحجم" />

                                <DataGridTemplateColumn Width="100" Header="الحالة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="6,2"
                                                CornerRadius="4"
                                                HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                <Setter Property="Background" Value="#E8F5E9" />
                                                                <Setter Property="Child">
                                                                    <Setter.Value>
                                                                        <TextBlock Foreground="#2E7D32" Text="ناجح" FontWeight="SemiBold"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                <Setter Property="Background" Value="#FFEBEE" />
                                                                <Setter Property="Child">
                                                                    <Setter.Value>
                                                                        <TextBlock Foreground="#C62828" Text="فشل" FontWeight="SemiBold"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding BackupPath}"
                                    Header="المسار المحلي" />

                                <DataGridTemplateColumn Width="180" Header="العمليات">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button
                                                    Margin="0,0,4,0"
                                                    Padding="4,2"
                                                    Click="BtnRestoreRow_Click"
                                                    Content="استعادة"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    ToolTip="استعادة قاعدة البيانات إلى هذه النسخة" />
                                                <Button
                                                    Padding="4,2"
                                                    Click="BtnSyncRow_Click"
                                                    Content="مزامنة سحابية"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    ToolTip="مزامنة النسخة المحلية إلى السحابة" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
