<UserControl
    x:Class="Radio.Views.Database.DatabaseManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converter:FileSizeConverter xmlns:converter="clr-namespace:Radio.Converter" x:Key="FileSizeConverter" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid Margin="{StaticResource SpacingLarge}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header Card with Gradient  -->
            <materialDesign:Card
                Grid.Row="0"
                Margin="0,0,0,24"
                Padding="32"
                materialDesign:ElevationAssist.Elevation="Dp2"
                Background="{DynamicResource HeaderGradientBrush}"
                UniformCornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="48"
                                Height="48"
                                Margin="0,0,14,0"
                                Background="#33FFFFFF"
                                CornerRadius="{StaticResource RadiusMedium}">
                                <materialDesign:PackIcon
                                    Width="26"
                                    Height="26"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Kind="DatabaseSettings" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    Foreground="White"
                                    Style="{StaticResource Type.Headline}"
                                    Text="إدارة قاعدة البيانات" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    Foreground="#DDDDDD"
                                    Style="{StaticResource Type.BodyMedium.Secondary}"
                                    Text="أدوات إدارة قاعدة البيانات: النسخ الاحتياطي، الاستعادة، وجدولة العمليات التلقائية." />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!--  Decorative icon  -->
                    <Border
                        Grid.Column="1"
                        Width="56"
                        Height="56"
                        VerticalAlignment="Center"
                        Background="#22FFFFFF"
                        CornerRadius="{StaticResource RadiusFull}">
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#99FFFFFF"
                            Kind="DatabaseCog" />
                    </Border>
                </Grid>
            </materialDesign:Card>

            <!--  Two-column: Quick Actions + Settings  -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Quick Actions Card  -->
                <materialDesign:Card
                    Grid.Column="0"
                    Padding="24"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource StatIcon.Primary}">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource PrimaryMainBrush}"
                                    Kind="LightningBolt" />
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Style="{StaticResource Type.TitleMedium}"
                                Text="العمليات الفورية" />
                        </Grid>

                        <Button
                            x:Name="BtnQuickBackup"
                            Height="40"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Stretch"
                            Click="BtnQuickBackup_Click"
                            Style="{StaticResource Btn.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="DatabasePlus" />
                                <TextBlock
                                    Foreground="White"
                                    Style="{StaticResource Type.BodyMedium}"
                                    Text="نسخ احتياطي فوري" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="BtnChooseAndRestore"
                            Height="40"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Stretch"
                            Click="BtnChooseAndRestore_Click"
                            Style="{StaticResource Btn.AddNew}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="DatabaseRefresh" />
                                <TextBlock Style="{StaticResource Type.BodyMedium}" Text="استعادة من ملف..." />
                            </StackPanel>
                        </Button>

                        <Border
                            Height="1"
                            Margin="0,0,0,10"
                            Background="{DynamicResource DividerBrush}" />

                        <Button
                            x:Name="BtnInitializeDb"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Click="BtnInitializeDb_Click"
                            Style="{StaticResource Btn.Danger}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Foreground="White"
                                    Kind="AlertOctagon" />
                                <TextBlock
                                    Foreground="White"
                                    Style="{StaticResource Type.BodyMedium}"
                                    Text="تهيئة قاعدة البيانات" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>

                <!--  Settings Card  -->
                <materialDesign:Card
                    Grid.Column="2"
                    Padding="24"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource StatIcon.Primary}">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource SecondaryMainBrush}"
                                    Kind="Cog" />
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Style="{StaticResource Type.TitleMedium}"
                                Text="إعدادات الجدولة والنسخ التلقائي" />
                        </Grid>

                        <!--  Auto-backup toggle  -->
                        <Border
                            Padding="{StaticResource SpacingSmall}"
                            Background="{DynamicResource PrimaryXLightBrush}"
                            CornerRadius="{StaticResource RadiusMedium}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Style="{StaticResource Type.BodyMedium}"
                                        Text="الالنسخ الاحتياطي التلقائي" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Style="{StaticResource Type.Caption}"
                                        Text="تشغيل نسخ احتياطي دوري تلقائي" />
                                </StackPanel>
                                <ToggleButton
                                    x:Name="ChkEnabled"
                                    Grid.Column="1"
                                    IsChecked="True"
                                    Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                            </Grid>
                        </Border>

                        <!--  Cloud sync toggle  -->
                        <Border
                            Margin="0,8,0,0"
                            Padding="{StaticResource SpacingSmall}"
                            Background="{DynamicResource InfoLightBrush}"
                            CornerRadius="{StaticResource RadiusMedium}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Style="{StaticResource Type.BodyMedium}"
                                        Text="المزامنة السحابية" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Style="{StaticResource Type.Caption}"
                                        Text="رفع النسخ الاحتياطية إلى السحابة تلقائياً" />
                                </StackPanel>
                                <ToggleButton
                                    x:Name="ChkCloudSync"
                                    Grid.Column="1"
                                    IsChecked="True"
                                    Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                            </Grid>
                        </Border>

                        <Grid Margin="0,16,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodyMedium.Secondary}"
                                    Text="دورية النسخ (ساعات)" />
                                <ComboBox
                                    x:Name="ComboInterval"
                                    Padding="{StaticResource SpacingSmall}"
                                    FontSize="{DynamicResource FontSize.Input}"
                                    SelectedIndex="1">
                                    <ComboBoxItem Content="كل 6 ساعات" Tag="6" />
                                    <ComboBoxItem Content="يومي (24 ساعة)" Tag="24" />
                                    <ComboBoxItem Content="أسبوعي (168 ساعة)" Tag="168" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource Type.BodyMedium.Secondary}"
                                    Text="الاحتفاظ (أيام)" />
                                <TextBox
                                    x:Name="TxtRetentionDays"
                                    Padding="{StaticResource SpacingSmall}"
                                    materialDesign:HintAssist.Hint="مثال: 30"
                                    Style="{StaticResource BroadcastTextBox}"
                                    Text="30" />
                            </StackPanel>
                        </Grid>

                        <Button
                            x:Name="BtnSaveConfig"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Click="BtnSaveConfig_Click"
                            Style="{StaticResource Btn.Secondary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="ContentSave" />
                                <TextBlock Style="{StaticResource Type.BodyMedium}" Text="حفظ الإعدادات" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!--  History DataGrid Card  -->
            <materialDesign:Card
                Grid.Row="2"
                materialDesign:ElevationAssist.Elevation="Dp1"
                UniformCornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  History Header  -->
                    <Border
                        Grid.Row="0"
                        Padding="24,18"
                        Style="{StaticResource Card.Info}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Width="32"
                                    Height="32"
                                    Background="{DynamicResource PrimaryXLightBrush}"
                                    CornerRadius="{StaticResource RadiusSmall}">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource PrimaryMainBrush}"
                                        Kind="History" />
                                </Border>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Style="{StaticResource Type.TitleMedium}"
                                    Text="سجل عمليات النسخ الاحتياطي" />
                            </Grid>

                            <Button
                                x:Name="BtnRefreshHistory"
                                Grid.Column="1"
                                Height="32"
                                Padding="12,0"
                                Click="BtnRefreshHistory_Click"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,8,0"
                                        Kind="Refresh" />
                                    <TextBlock Style="{StaticResource Type.BodyMedium}" Text="تحديث" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!--  DataGrid  -->
                    <DataGrid
                        x:Name="GridHistory"
                        Grid.Row="1"
                        ItemsSource="{Binding}"
                        Style="{StaticResource DataGrid.Main}">
                        <!--  Using shared DataGrid.Main style, no need for inline DataGrid.Resources  -->
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding CreatedAt, StringFormat='dd-MM-yyyy HH:mm:ss'}"
                                Header="التاريخ" />

                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding BackupType}"
                                Header="النوع" />

                            <DataGridTextColumn
                                Width="90"
                                Binding="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                Header="الحجم" />

                            <DataGridTemplateColumn
                                Width="110"
                                CellStyle="{StaticResource DataGrid.Cell.Center}"
                                Header="الحالة"
                                HeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="10,4"
                                            HorizontalAlignment="Left"
                                            CornerRadius="6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                                            <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Background" Value="{DynamicResource ErrorLightBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon
                                                    Width="14"
                                                    Height="14"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                    <Setter Property="Kind" Value="CheckCircle" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Kind" Value="CloseCircle" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                                <TextBlock Grid.Column="1" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style BasedOn="{StaticResource Type.BodyMedium}" TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    <Setter Property="Text" Value="ناجح" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                                    <Setter Property="Text" Value="فشل" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding BackupPath}"
                                Header="المسار المحلي" />

                            <DataGridTemplateColumn
                                Width="240"
                                CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                Header="العمليات"
                                HeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,2" Orientation="Horizontal">
                                            <Button
                                                Height="30"
                                                Margin="0,0,6,0"
                                                Padding="10,0"
                                                Click="BtnRestoreRow_Click"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                ToolTip="استعادة قاعدة البيانات إلى هذه النسخة">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,8,0"
                                                        Kind="Restore" />
                                                    <TextBlock Style="{StaticResource Type.BodyMedium}" Text="استعادة" />
                                                </StackPanel>
                                            </Button>
                                            <Button
                                                Height="30"
                                                Padding="10,0"
                                                Click="BtnSyncRow_Click"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                ToolTip="مزامنة النسخة المحلية إلى السحابة">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,8,0"
                                                        Kind="CloudUpload" />
                                                    <TextBlock Style="{StaticResource Type.BodyMedium}" Text="مزامنة سحابية" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>