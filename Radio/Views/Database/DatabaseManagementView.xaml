<UserControl
    x:Class="Radio.Views.Database.DatabaseManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converter:FileSizeConverter xmlns:converter="clr-namespace:Radio.Converter" x:Key="FileSizeConverter" />

        <!--  قالب حالة النسخ الاحتياطي (مبسط وأكثر كفاءة)  -->
        <DataTemplate x:Key="StatusCellTemplate">
            <Border
                Padding="8,4"
                HorizontalAlignment="Center"
                CornerRadius="12">
                <TextBlock
                    FontSize="11"
                    FontWeight="Medium"
                    TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="غير معروف" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Success">
                                    <Setter Property="Text" Value="ناجح" />
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                    <Setter Property="Text" Value="فشل" />
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Success">
                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                <Setter Property="Background" Value="{StaticResource ErrorLightBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  الرأس  -->
        <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
            <Grid Margin="8,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="DatabaseSettings" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إدارة قاعدة البيانات" />
                    </StackPanel>
                    <TextBlock
                        Margin="40,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="أدوات إدارة قاعدة البيانات: النسخ الاحتياطي، الاستعادة، وجدولة العمليات التلقائية." />
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!--  المحتوى الرئيسي  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,20,24,10">
                <Grid.ColumnDefinitions>
                    <!--  عمود الإعدادات: يتكيف مع حجم الشاشة بدل العرض الثابت  -->
                    <ColumnDefinition
                        Width="1.5*"
                        MinWidth="300"
                        MaxWidth="450" />
                    <!--  عمود السجل  -->
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <!--  اللوحة اليمنى: الإعدادات والتحكم  -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">

                    <!--  بطاقة العمليات الفورية  -->
                    <materialDesign:Card
                        Margin="0,0,0,16"
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="12">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,16"
                                Style="{StaticResource Type.TitleMedium}"
                                Text="العمليات الفورية" />

                            <Button
                                x:Name="BtnQuickBackup"
                                Margin="0,0,0,12"
                                Click="BtnQuickBackup_Click"
                                Style="{StaticResource Btn.Primary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Kind="DatabasePlus" />
                                    <TextBlock Text="نسخ احتياطي فوري" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="BtnChooseAndRestore"
                                Margin="0,0,0,12"
                                Click="BtnChooseAndRestore_Click"
                                Style="{StaticResource Btn.AddNew}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Kind="DatabaseRefresh" />
                                    <TextBlock Text="استعادة من ملف..." />
                                </StackPanel>
                            </Button>

                            <Separator Margin="0,4,0,12" />

                            <Button
                                x:Name="BtnInitializeDb"
                                Click="BtnInitializeDb_Click"
                                Style="{StaticResource Btn.Danger}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Foreground="White"
                                        Kind="AlertOctagon" />
                                    <TextBlock Foreground="White" Text="تهيئة قاعدة البيانات" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>

                    <!--  بطاقة إعدادات الجدولة  -->
                    <materialDesign:Card
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp1"
                        UniformCornerRadius="12">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,16"
                                Style="{StaticResource Type.TitleMedium}"
                                Text="إعدادات الجدولة والنسخ التلقائي" />

                            <CheckBox
                                x:Name="ChkEnabled"
                                Content="تفعيل النسخ الاحتياطي التلقائي"
                                IsChecked="True"
                                Style="{StaticResource MaterialDesignCheckBox}" />

                            <CheckBox
                                x:Name="ChkCloudSync"
                                Margin="0,8,0,16"
                                Content="تفعيل النسخ الاحتياطي السحابي"
                                IsChecked="True"
                                Style="{StaticResource MaterialDesignCheckBox}" />

                            <TextBlock
                                Margin="0,0,0,8"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Style="{StaticResource Type.BodySmall}"
                                Text="دورية النسخ التلقائي (بالساعات)" />

                            <ComboBox
                                x:Name="ComboInterval"
                                Margin="0,0,0,16"
                                SelectedIndex="1"
                                Style="{StaticResource Input.ComboBox}">
                                <ComboBoxItem Content="كل 6 ساعات" Tag="6" />
                                <ComboBoxItem Content="يومي (كل 24 ساعة)" Tag="24" />
                                <ComboBoxItem Content="أسبوعي (كل 168 ساعة)" Tag="168" />
                            </ComboBox>

                            <TextBlock
                                Margin="0,0,0,8"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Style="{StaticResource Type.BodySmall}"
                                Text="فترة الاحتفاظ بالنسخ (أيام)" />

                            <TextBox
                                x:Name="TxtRetentionDays"
                                Margin="0,0,0,16"
                                materialDesign:HintAssist.Hint="مثال: 30"
                                Style="{StaticResource Input.Text}"
                                Text="30" />

                            <Button
                                x:Name="BtnSaveConfig"
                                Click="BtnSaveConfig_Click"
                                Style="{StaticResource Btn.Secondary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Kind="ContentSave" />
                                    <TextBlock Text="حفظ الإعدادات" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>

                </StackPanel>

                <!--  اللوحة اليسرى: السجل  -->
                <materialDesign:Card
                    Grid.Column="1"
                    Padding="16"
                    materialDesign:ElevationAssist.Elevation="Dp1"
                    UniformCornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  رأس السجل  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource Type.TitleLarge}"
                                Text="سجل عمليات النسخ الاحتياطي" />

                            <Button
                                x:Name="BtnRefreshHistory"
                                Grid.Column="1"
                                Padding="8,4"
                                Click="BtnRefreshHistory_Click"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,4,0"
                                        Kind="Refresh" />
                                    <TextBlock Text="تحديث" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!--  جدول البيانات  -->
                        <DataGrid
                            x:Name="GridHistory"
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CellStyle="{StaticResource DataGrid.Cell}"
                            ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                            IsReadOnly="True"
                            RowStyle="{StaticResource DataGrid.Row}"
                            SelectionMode="Single"
                            Style="{StaticResource DataGrid.Main}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="Auto"
                                    MinWidth="140"
                                    Binding="{Binding CreatedAt, StringFormat='dd-MM-yyyy HH:mm:ss'}"
                                    Header="التاريخ" />

                                <DataGridTextColumn
                                    Width="Auto"
                                    MinWidth="90"
                                    Binding="{Binding BackupType}"
                                    Header="النوع" />

                                <DataGridTextColumn
                                    Width="Auto"
                                    MinWidth="80"
                                    Binding="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                    Header="الحجم" />

                                <DataGridTemplateColumn
                                    Width="Auto"
                                    MinWidth="90"
                                    CellTemplate="{StaticResource StatusCellTemplate}"
                                    Header="الحالة" />

                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding BackupPath}"
                                    Header="المسار المحلي" />

                                <!--  عمود العمليات: تم تحويله لأيقونات لتوفير المساحة ومنح مظهر عصري  -->
                                <DataGridTemplateColumn
                                    Width="Auto"
                                    MinWidth="100"
                                    Header="العمليات">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <Button
                                                    Margin="0,0,4,0"
                                                    Padding="4,2"
                                                    Click="BtnRestoreRow_Click"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="استعادة قاعدة البيانات إلى هذه النسخة">
                                                    <materialDesign:PackIcon
                                                        Width="20"
                                                        Height="20"
                                                        Kind="Restore" />
                                                </Button>
                                                <Button
                                                    Padding="4,2"
                                                    Click="BtnSyncRow_Click"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="مزامنة النسخة المحلية إلى السحابة">
                                                    <materialDesign:PackIcon
                                                        Width="20"
                                                        Height="20"
                                                        Kind="CloudSync" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>