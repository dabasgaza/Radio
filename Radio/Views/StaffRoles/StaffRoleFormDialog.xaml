<mah:MetroWindow x:Class="Radio.Views.StaffRoles.StaffRoleFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="{Binding Title, RelativeSource={RelativeSource Self}}"
    Width="420" Height="280"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card Margin="30" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <materialDesign:ColorZone Padding="24,20" Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Width="28" Height="28" VerticalAlignment="Center" Kind="BadgeAccountOutline"/>

                    <TextBlock Grid.Column="1" x:Name="TxtTitle" Margin="12,0"
                               Style="{StaticResource Type.TitleLarge.OnColor}"
                               Text="{Binding Title, RelativeSource={RelativeSource Self}}"/>

                    <Button Grid.Column="2" Click="BtnClose_Click" Foreground="White"
                            Opacity="0.6" Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close"/>
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!-- Field -->
            <StackPanel Grid.Row="1" Margin="28,20" VerticalAlignment="Center">
                <TextBox x:Name="TxtRoleName"
                         materialDesign:HintAssist.Hint="اسم الدور الوظيفي *"
                         materialDesign:TextFieldAssist.LeadingIcon="BadgeAccountOutline"
                         Style="{StaticResource Input.Text}"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="إلغاء" IsCancel="True" Style="{StaticResource Btn.Cancel}"/>
                    <Button x:Name="BtnSave" Grid.Column="2" Click="BtnSave_Click"
                            Content="حفظ" Style="{StaticResource Btn.Primary}"/>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>