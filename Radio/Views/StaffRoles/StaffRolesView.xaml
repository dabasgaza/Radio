<UserControl
    x:Class="Radio.Views.StaffRoles.StaffRolesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
            <DockPanel>
                <materialDesign:PackIcon
                    Width="28"
                    Height="28"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Kind="BadgeAccount" />
                <TextBlock
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="المسميات الوظيفية" />
                <Button
                    HorizontalAlignment="Left"
                    Click="BtnAdd_Click"
                    Content="إضافة دور"
                    DockPanel.Dock="Left"
                    Style="{StaticResource Btn.AddNew}" />
            </DockPanel>
        </materialDesign:ColorZone>

        <!--  DataGrid  -->
        <materialDesign:Card
            Grid.Row="1"
            Margin="24,20,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="12">
            <DataGrid
                x:Name="DgRoles"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding RoleName}"
                        Header="اسم الدور الوظيفي" />
                    <DataGridTemplateColumn
                        Width="120"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Width="34"
                                        Height="34"
                                        Margin="2"
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource Btn.Primary}"
                                        Tag="{Binding StaffRoleId}">
                                        <materialDesign:PackIcon Kind="Pencil" />
                                    </Button>
                                    <Button
                                        Width="34"
                                        Height="34"
                                        Margin="2"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource Btn.Cancel}"
                                        Tag="{Binding StaffRoleId}">
                                        <materialDesign:PackIcon Kind="Delete" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>