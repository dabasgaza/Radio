<UserControl x:Class="Radio.Views.StaffRoles.StaffRolesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Style="{StaticResource View.Base}"
             FlowDirection="RightToLeft">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
            <DockPanel>
                <materialDesign:PackIcon Kind="BadgeAccount" Width="28" Height="28"
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="المسميات الوظيفية" FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center" DockPanel.Dock="Right"/>
                <Button Style="{StaticResource Btn.AddNew}"
                        DockPanel.Dock="Left" HorizontalAlignment="Left"
                        Content="إضافة دور"
                        Click="BtnAdd_Click"/>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="1" Margin="24,20,24,24"
                              UniformCornerRadius="12"
                              materialDesign:ElevationAssist.Elevation="Dp1">
            <DataGrid x:Name="DgRoles"
                      Style="{StaticResource DataGrid.Main}"
                      RowStyle="{StaticResource DataGrid.Row}"
                      CellStyle="{StaticResource DataGrid.Cell}"
                      ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم الدور الوظيفي" Binding="{Binding RoleName}" Width="*"/>
                    <DataGridTemplateColumn Header="إجراءات"
                                            CellStyle="{StaticResource DataGrid.Cell.Actions}"
                                            Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource Btn.Primary}"
                                            Width="34" Height="34" Margin="2"
                                            Tag="{Binding StaffRoleId}"
                                            Click="BtnEdit_Click">
                                        <materialDesign:PackIcon Kind="Pencil"/>
                                    </Button>
                                    <Button Style="{StaticResource Btn.Cancel}"
                                            Width="34" Height="34" Margin="2"
                                            Tag="{Binding StaffRoleId}"
                                            Click="BtnDelete_Click">
                                        <materialDesign:PackIcon Kind="Delete"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>