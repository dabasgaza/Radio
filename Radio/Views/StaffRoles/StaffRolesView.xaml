<UserControl
    x:Class="Radio.Views.StaffRoles.StaffRolesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
            <DockPanel>
                <materialDesign:PackIcon
                    Width="24"
                    Height="24"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Kind="BadgeAccount" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource Type.TitleLarge}"
                    Text="أدوار الموظفين" />
                <Button
                    HorizontalAlignment="Left"
                    Click="BtnAdd_Click"
                    Content="إضافة دور"
                    DockPanel.Dock="Left"
                    Style="{StaticResource Btn.AddNew}" />
            </DockPanel>
        </materialDesign:ColorZone>

        <!--  Stats  -->
        <materialDesign:Card
            Grid.Row="1"
            Width="250"
            Margin="24,20,24,0"
            HorizontalAlignment="Right"
            Style="{StaticResource Card.Stat}">
            <StackPanel>
                <Border Style="{StaticResource StatIcon.Primary}">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource PrimaryMainBrush}"
                        Kind="ShieldStar" />
                </Border>
                <TextBlock Style="{StaticResource Type.Caption}" Text="إجمالي الأدوار الوظيفية" />
                <TextBlock
                    x:Name="TxtTotalRoles"
                    Style="{StaticResource Type.Numeric.Large}"
                    Text="0" />
            </StackPanel>
        </materialDesign:Card>

        <!--  DataGrid  -->
        <materialDesign:Card
            Grid.Row="2"
            Margin="24,10,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="12">
            <DataGrid
                x:Name="DgRoles"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding RoleName}"
                        Header="اسم الدور الوظيفي" />
                    <DataGridTemplateColumn
                        Width="100"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource Btn.Icon.Edit}"
                                        Tag="{Binding StaffRoleId}">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Kind="Pencil" />
                                    </Button>
                                    <Button
                                        Margin="8,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource Btn.Icon.Delete}"
                                        Tag="{Binding StaffRoleId}">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Kind="Delete" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>