<mah:MetroWindow
    x:Class="Radio.Views.Correspondents.CorrespondentFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات المراسل"
    Width="560"
    Height="650"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card Margin="30" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Padding="24,20" Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="AccountTie" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock
                            x:Name="TxtHeader"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="بيانات المراسل الميداني" />
                        <TextBlock Style="{StaticResource Type.BodyMedium.OnColor}" Text="سجّل بيانات التواصل والمناطق الجغرافية المكلف بها" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="28,20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <TextBox
                        x:Name="TxtName"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="اسم المراسل الثلاثي *"
                        materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                        Style="{StaticResource Input.Text}" />

                    <TextBox
                        x:Name="TxtPhone"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="رقم التواصل (هاتف/واتساب) *"
                        materialDesign:TextFieldAssist.LeadingIcon="PhoneOutline"
                        Style="{StaticResource Input.Text}" />

                    <TextBox
                        x:Name="TxtLocations"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="النطاق الجغرافي للتغطية"
                        materialDesign:TextFieldAssist.LeadingIcon="MapMarkerRadiusOutline"
                        AcceptsReturn="True"
                        Style="{StaticResource Input.Text.Multiline}"
                        TextWrapping="Wrap" />

                    <Border Margin="0,10" Style="{StaticResource Card.Info}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Foreground="#1565C0"
                                Kind="Information"
                                Opacity="0.7" />
                            <TextBlock
                                Margin="12,0"
                                VerticalAlignment="Center"
                                Opacity="0.8"
                                Style="{StaticResource Type.Caption}"
                                Text="* الحقول المطلوبة لضمان دقة قاعدة بيانات الكوادر." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="تجاهل"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="اعتماد وحفظ البيانات"
                        Style="{StaticResource Btn.Primary}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="AccountCheckOutline" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>