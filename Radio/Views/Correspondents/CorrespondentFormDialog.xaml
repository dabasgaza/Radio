<mah:MetroWindow
    x:Class="Radio.Views.Correspondents.CorrespondentFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات المراسل"
    Width="560"
    Height="580"
    AllowsTransparency="True"
    Background="Transparent"
    FlowDirection="RightToLeft"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    UseNoneWindowStyle="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <materialDesign:Card
        Margin="30"
        materialDesign:ElevationAssist.Elevation="Dp2"
        Background="{DynamicResource MaterialDesignPaper}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Padding="24,20"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Foreground="White"
                Mode="Custom">
                <materialDesign:ColorZone.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#673AB7" />
                        <GradientStop Offset="1" Color="#512DA8" />
                    </LinearGradientBrush>
                </materialDesign:ColorZone.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="AccountTie" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock
                            x:Name="TxtHeader"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource TitleLarge}"
                            Text="بيانات المراسل الميداني" />
                        <TextBlock
                            FontSize="11"
                            Foreground="White"
                            Opacity="0.8"
                            Text="سجّل بيانات التواصل والمناطق الجغرافية المكلف بها" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="28,20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <TextBox
                        x:Name="TxtName"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="اسم المراسل الثلاثي *"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                        Style="{StaticResource BroadcastTextBox}" />

                    <TextBox
                        x:Name="TxtPhone"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="رقم التواصل (هاتف/واتساب) *"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="PhoneOutline"
                        Style="{StaticResource BroadcastTextBox}" />

                    <TextBox
                        x:Name="TxtLocations"
                        Height="120"
                        VerticalContentAlignment="Top"
                        materialDesign:HintAssist.Hint="النطاق الجغرافي للتغطية"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="MapMarkerRadiusOutline"
                        AcceptsReturn="True"
                        Style="{StaticResource BroadcastTextBox}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="5,10,0,0"
                        FontSize="10"
                        Opacity="0.6"
                        Text="* الحقول المطلوبة لضمان دقة قاعدة بيانات الكوادر." />
                </StackPanel>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="28,24"
                Background="{DynamicResource MaterialDesignDivider}"
                CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="تجاهل"
                        IsCancel="True"
                        Style="{StaticResource CancelFlatButton}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp2"
                        Background="#673AB7"
                        BorderBrush="#673AB7"
                        Click="BtnSave_Click"
                        Content="اعتماد وحفظ البيانات"
                        Style="{StaticResource PrimaryActionButton}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="AccountCheckOutline" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>