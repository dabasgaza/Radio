<mah:MetroWindow
    x:Class="Radio.Views.Correspondents.CorrespondentFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة بيانات المراسل"
    Width="560"
    Height="580"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    UseNoneWindowStyle="True"
    ShowTitleBar="False"
    FlowDirection="RightToLeft"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card Margin="30" 
                         UniformCornerRadius="16" 
                         materialDesign:ElevationAssist.Elevation="Dp2"
                         Background="{DynamicResource MaterialDesignPaper}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Padding="24,20"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Foreground="White"
                Mode="Custom">
                <materialDesign:ColorZone.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#673AB7" />
                        <GradientStop Offset="1" Color="#512DA8" />
                    </LinearGradientBrush>
                </materialDesign:ColorZone.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="AccountTie" Width="35" Height="35" VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock x:Name="TxtHeader" 
                                   Text="بيانات المراسل الميداني" 
                                   Style="{StaticResource TitleLarge}" 
                                   Foreground="White" 
                                   FontWeight="Bold" />
                        <TextBlock Text="سجّل بيانات التواصل والمناطق الجغرافية المكلف بها" 
                                   FontSize="11" 
                                   Opacity="0.8" 
                                   Foreground="White" />
                    </StackPanel>

                    <Button Grid.Column="2" 
                            Click="BtnClose_Click" 
                            Style="{StaticResource MaterialDesignIconButton}" 
                            Foreground="White" Opacity="0.6">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer Grid.Row="1" Padding="28,20" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10 15">

                    <TextBox x:Name="TxtName"
                             Margin="0,0,0,24"
                             materialDesign:HintAssist.Hint="اسم المراسل الثلاثي *"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                             Style="{StaticResource BroadcastTextBox}" />

                    <TextBox x:Name="TxtPhone"
                             Margin="0,0,0,24"
                             materialDesign:HintAssist.Hint="رقم التواصل (هاتف/واتساب) *"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="PhoneOutline"
                             Style="{StaticResource BroadcastTextBox}" />

                    <TextBox x:Name="TxtLocations"
                             Height="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             materialDesign:HintAssist.Hint="النطاق الجغرافي للتغطية"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="MapMarkerRadiusOutline"
                             Style="{StaticResource BroadcastTextBox}" />

                    <TextBlock Text="* الحقول المطلوبة لضمان دقة قاعدة بيانات الكوادر." 
                               FontSize="10" 
                               Opacity="0.6" 
                               Margin="5,10,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="28,24" Background="{DynamicResource MaterialDesignDivider}" CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="تجاهل"
                            IsCancel="True"
                            Style="{StaticResource CancelFlatButton}" />

                    <Button x:Name="BtnSave"
                            Grid.Column="2"
                            Click="BtnSave_Click"
                            Content="اعتماد وحفظ البيانات"
                            Background="#673AB7"
                            BorderBrush="#673AB7"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp2"
                            Style="{StaticResource PrimaryActionButton}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountCheckOutline" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>