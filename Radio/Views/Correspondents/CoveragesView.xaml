<UserControl
    x:Class="Radio.Views.Correspondents.CoverageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Correspondents"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="950"
    FlowDirection="RightToLeft"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  ══════════════ الألوان الأساسية (رمادي) ══════════════  -->
        <SolidColorBrush x:Key="BgBase" Color="#111419" />
        <SolidColorBrush x:Key="BgSurface" Color="#181C24" />
        <SolidColorBrush x:Key="BgElevated" Color="#21262F" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2C323E" />
        <SolidColorBrush x:Key="TextMain" Color="#E0E4EB" />
        <SolidColorBrush x:Key="TextMuted" Color="#515B6E" />

        <!--  ألوان لكسر الغامق (بدون بنفسجي)  -->
        <SolidColorBrush x:Key="TealAccent" Color="#3D9DA6" />
        <SolidColorBrush x:Key="AmberAccent" Color="#D4943A" />
        <SolidColorBrush x:Key="GreenAccent" Color="#00D4AA" />
        <SolidColorBrush x:Key="RedAccent" Color="#E54D4D" />

        <!--  ══════════════ التدرجات ══════════════  -->
        <LinearGradientBrush x:Key="GradLine" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#3D9DA6" />
            <GradientStop Offset="0.5" Color="#D4943A" />
            <GradientStop Offset="1" Color="#00D4AA" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradAccentBtn" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#00D4AA" />
            <GradientStop Offset="1" Color="#448AFF" />
        </LinearGradientBrush>

        <!--  ══════════════ التأثيرات ══════════════  -->
        <DropShadowEffect
            x:Key="GlowTeal"
            BlurRadius="10"
            Opacity="0.2"
            ShadowDepth="0"
            Color="#3D9DA6" />
        <DropShadowEffect
            x:Key="GlowGreen"
            BlurRadius="10"
            Opacity="0.2"
            ShadowDepth="0"
            Color="#00D4AA" />
        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="24"
            Opacity="0.25"
            ShadowDepth="4"
            Color="#000000" />

        <!--  ══════════════ نمط البحث ══════════════  -->
        <!--  ══════════════ نمط البحث (تلقائي 100% بدون Code-Behind) ══════════════  -->
        <!--  ══════════════ نمط البحث (متوافق مع كل إصدارات المكتبة) ══════════════  -->
        <!--  ══════════════ نمط البحث (مضمون 100% - لا أخطاء قاموس) ══════════════  -->
