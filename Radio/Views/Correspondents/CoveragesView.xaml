<UserControl
    x:Class="Radio.Views.Correspondents.CoverageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextOnPrimaryBrush}"
                            Kind="Radar" />
                        <TextBlock
                            Margin="12,0,0,0"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="سجل التغطيات الميدانية" />
                    </StackPanel>
                    <TextBlock
                        Margin="44,4,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="المهام الخارجية وتنسيق عمل المراسلين" />
                </StackPanel>


                <Button
                    x:Name="BtnAdd"
                    Grid.Column="1"
                    Click="BtnAddCoverage_Click"
                    Style="{StaticResource Btn.AddNew}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="SatelliteUplink" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="إضافة تغطية جديدة" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1" Margin="24,15,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="0.8*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                Margin="0,0,12,0"
                materialDesign:HintAssist.Hint="بحث سريع..."
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <ComboBox
                x:Name="CboLocation"
                Grid.Column="1"
                Margin="0,0,12,0"
                materialDesign:HintAssist.Hint="تصفية الموقع"
                materialDesign:TextFieldAssist.LeadingIcon="MapMarkerOutline"
                SelectionChanged="CboLocation_SelectionChanged"
                Style="{StaticResource Input.ComboBox}" />

            <materialDesign:Card
                Grid.Column="2"
                Margin="0,0,12,0"
                Padding="8,2"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                UniformCornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DatePicker
                        x:Name="DpFromDate"
                        Grid.Column="0"
                        materialDesign:HintAssist.Hint="من تاريخ"
                        materialDesign:TextFieldAssist.LeadingIcon="CalendarImportOutline"
                        BorderThickness="0"
                        Style="{StaticResource Input.DatePicker}" />

                    <materialDesign:PackIcon
                        Grid.Column="1"
                        Margin="4,0"
                        VerticalAlignment="Center"
                        Kind="ArrowLeftThin"
                        Opacity="0.3" />

                    <DatePicker
                        x:Name="DpToDate"
                        Grid.Column="2"
                        materialDesign:HintAssist.Hint="إلى تاريخ"
                        materialDesign:TextFieldAssist.LeadingIcon="CalendarExportOutline"
                        BorderThickness="0"
                        Style="{StaticResource Input.DatePicker}" />
                </Grid>
            </materialDesign:Card>

            <Button
                Grid.Column="3"
                Width="45"
                Height="45"
                Margin="0,0,12,0"
                Click="BtnClearFilters_Click"
                Style="{StaticResource MaterialDesignIconButton}"
                ToolTip="تفريغ كافة الفلاتر">
                <materialDesign:PackIcon
                    Width="22"
                    Height="22"
                    Kind="FilterOffOutline"
                    Opacity="0.6" />
            </Button>

            <materialDesign:Card
                Grid.Column="4"
                Padding="12,0"
                materialDesign:ElevationAssist.Elevation="Dp1"
                Background="{DynamicResource PrimaryHueLightBrush}"
                UniformCornerRadius="10">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        Opacity="0.8"
                        Text="النتائج:" />
                    <TextBlock
                        x:Name="TxtTotal"
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Type.Numeric.Medium}"
                        Text="0" />
                </StackPanel>
            </materialDesign:Card>
        </Grid>
        <materialDesign:Card
            Grid.Row="2"
            Margin="24,10,24,24"
            materialDesign:ElevationAssist.Elevation="Dp1"
            UniformCornerRadius="12">
            <DataGrid
                x:Name="DgCoverages"
                CellStyle="{StaticResource DataGrid.Cell}"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Width="180" Header="المراسل الميداني">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        VerticalAlignment="Center"
                                        Kind="AccountTieOutline"
                                        Opacity="0.6" />
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding CorrespondentName}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn
                        Width="350"
                        Binding="{Binding Topic}"
                        Header="موضوع التغطية" />

                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding Location}"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="موقع التغطية" />

                    <DataGridTemplateColumn
                        Width="140"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="موعد المهمة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="{Binding ScheduledDate, StringFormat=yyyy/MM/dd}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="{Binding ScheduledTime, StringFormat=hh:mm tt}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="200"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Margin="8,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Kind="TrashCanOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>