<UserControl
    x:Class="Radio.Views.Correspondents.CoverageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Correspondents"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  تنسيقات النصوص بلوحة الألوان السحرية  -->
        <Style x:Key="RightCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="#EDE9FE" />
            <!--  أبيض مائل للبنفسجي الفاتح جداً  -->
        </Style>
        <Style x:Key="CenterCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="#EDE9FE" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  منطقة الهيدر والتحكم  -->
        <Grid Grid.Row="0" Margin="8,10,8,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  عنوان الصفحة مع لمسة البث المباشر  -->
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <materialDesign:PackIcon
                    Width="32"
                    Height="32"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Foreground="#00E676"
                    Kind="SatelliteUplink" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#FFFFFF"
                    Text="سجل التغطيات الميدانية" />
            </StackPanel>

            <!--  زر الإضافة (بتصميم Live)  -->
            <Button
                x:Name="BtnAdd"
                Grid.Column="1"
                Height="40"
                Padding="24,0"
                VerticalAlignment="Center"
                materialDesign:ButtonAssist.CornerRadius="20"
                Background="#00E676"
                BorderBrush="#00E676"
                Click="BtnAddCoverage_Click"
                Content="● إضافة تغطية"
                Cursor="Hand"
                FontSize="14"
                FontWeight="Bold"
                Foreground="#1B1B2F" />
        </Grid>

        <!--  بطاقة الجدول بلوحة البنفسجي السحري  -->
        <materialDesign:Card
            Grid.Row="1"
            Margin="8,0"
            Background="#1E1D27"
            BorderBrush="#3D3A4A"
            BorderThickness="1"
            UniformCornerRadius="12">

            <DataGrid
                x:Name="DgCoverages"
                AlternatingRowBackground="#2E2C3A"
                AutoGenerateColumns="False"
                Background="Transparent"
                CanUserAddRows="False"
                Foreground="{DynamicResource MaterialDesignBody}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                IsReadOnly="True"
                RowBackground="#262430"
                SelectionMode="Single"
                SelectionUnit="FullRow">

                <!--  تأثير التمرير (Hover) بتوهج خفيف  -->
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource MaterialDesignDataGridRow}" TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#38354A" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!--  ترويسة الجدول (اللمسة السحرية)  -->
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1A1924" />
                        <Setter Property="Foreground" Value="#00E676" />
                        <!--  أخضر نيون للترويسة  -->
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="14,14" />
                        <!--  اللمسة السحرية: خط متوهج في الأسفل بدل تلوين الخلفية بالكامل  -->
                        <Setter Property="BorderThickness" Value="0,0,0,2" />
                        <Setter Property="BorderBrush" Value="#00E676" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <!--  عمود المراسل  -->
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding CorrespondentName}"
                        ElementStyle="{StaticResource RightCellText}"
                        Header="المراسل">
                        <DataGridTextColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <!--  عمود الموضوع  -->
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Topic}"
                        ElementStyle="{StaticResource RightCellText}"
                        Header="الموضوع">
                        <DataGridTextColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <!--  عمود الموقع  -->
                    <DataGridTextColumn
                        Width="130"
                        Binding="{Binding Location}"
                        ElementStyle="{StaticResource CenterCellText}"
                        Header="الموقع" />

                    <!--  عمود الضيف  -->
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding GuestName}"
                        ElementStyle="{StaticResource RightCellText}"
                        Header="الضيف">
                        <DataGridTextColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <!--  عمود الموعد  -->
                    <DataGridTextColumn
                        Width="170"
                        Binding="{Binding ScheduledTime, StringFormat='yyyy/MM/dd HH:mm'}"
                        ElementStyle="{StaticResource CenterCellText}"
                        Header="الموعد" />

                    <!--  عمود الإجراءات بألوان سحرية  -->
                    <DataGridTemplateColumn Width="Auto" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <!--  تعديل بلون بنفسجي فاتح  -->
                                    <Button
                                        Margin="4"
                                        Padding="5"
                                        Click="BtnEdit_Click"
                                        Cursor="Hand"
                                        Foreground="#B39DDB"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل التغطية">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            Kind="Pencil" />
                                    </Button>
                                    <!--  حذف بلون أحمر هادئ متناسق  -->
                                    <Button
                                        Margin="4"
                                        Padding="5"
                                        Click="BtnDelete_Click"
                                        Cursor="Hand"
                                        Foreground="#FF5252"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف التغطية">
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            Kind="Delete" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>