<UserControl
    x:Class="Radio.Views.Correspondents.CoverageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Correspondents"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="550"
    d:DesignWidth="950"
    FlowDirection="RightToLeft"
    Style="{StaticResource UserControlStyle}">
    
    
    <!--  ═══════════ التخطيط الرئيسي ═══════════ -->
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════════ الرأس والعنوان ═══════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Style="{StaticResource TitleLarge}" Text="سجل التغطيات الميدانية" />
                <TextBlock
                    Margin="0,4,0,0"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Style="{StaticResource BodyMedium}"
                    Text="متابعة وإدارة التغطيات والمهام الميدانية" />
            </StackPanel>

            <Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="BtnAddCoverage_Click"
                Style="{StaticResource PrimaryActionButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Kind="Add" />
                    <TextBlock VerticalAlignment="Center" Text="إضافة تغطية" />
                </StackPanel>
            </Button>
        </Grid>

        <!--  ═══════════ البحث والفلاتر ═══════════ -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,24"
            Orientation="Horizontal">

            <!-- حقل البحث -->
            <TextBox
                x:Name="TxtSearch"
                Width="350"
                Margin="0,0,16,0"
                materialDesign:HintAssist.Hint="بحث بالموضوع أو المرسل..."
                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource BroadcastTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <!-- فلتر الموقع -->
            <Border
                Margin="0,0,16,0"
                Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                BorderBrush="{DynamicResource MaterialDesignTextFieldBoxBorderBrush}"
                CornerRadius="8"
                Padding="12,8">
                <Grid Margin="0,0,0,10">
                    <ComboBox
                        x:Name="CboLocation"
                        HorizontalAlignment="Stretch"
                        FontSize="13"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        SelectionChanged="CboLocation_SelectionChanged" />
                    <TextBlock
                        x:Name="LocationPlaceholder"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource MaterialDesignHint}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Value="-1" Binding="{Binding SelectedIndex, ElementName=CboLocation}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Value="1" Binding="{Binding Text.Length, ElementName=CboLocation}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- فلتر التاريخ -->
            <Border
                Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                BorderBrush="{DynamicResource MaterialDesignTextFieldBoxBorderBrush}"
                CornerRadius="8"
                Padding="12,8">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DatePicker
                        x:Name="DpDate"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="13"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        SelectedDateChanged="DpDate_SelectedDateChanged" />
                    <materialDesign:PackIcon
                        Grid.Column="1"
                        Width="16"
                        Height="16"
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Kind="CalendarMonth" />
                </Grid>
            </Border>

            <!-- زر مسح الفلاتر -->
            <Button
                Width="38"
                Height="38"
                Margin="0,0,0,0"
                Click="BtnClearFilters_Click"
                Style="{StaticResource CancelFlatButton}"
                ToolTip="مسح الفلاتر">
                <materialDesign:PackIcon
                    Width="16"
                    Height="16"
                    Margin="0,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Kind="FilterRemoveOutline" />
            </Button>

            <!-- بطاقة إجمالي -->
            <materialDesign:Card
                Width="160"
                Margin="0,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource BroadcastCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="32"
                        Height="32"
                        Background="#E8F5E9"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            Foreground="#43A047">                            تبدأ بدلاً
                        </materialDesign:PackIcon>
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Text="تغطيات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="#2E7D32"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <!--  ═══════════ جدول البيانات ═══════════  -->
        <DataGrid
            x:Name="DgCoverages"
            Grid.Row="2"
            VerticalAlignment="Stretch"
            AutoGenerateColumns="False"
            CellStyle="{StaticResource BroadcastPro.DataGridCell}"
            ColumnHeaderStyle="{StaticResource BroadcastPro.DataGridColumnHeader}"
            GridLinesVisibility="None"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding CoveragesList}"
            RowStyle="{StaticResource BroadcastPro.DataGridRow}"
            SelectionMode="Single"
            SelectionUnit="FullRow">

            <DataGrid.Columns>

                <!--  عمود المراسل -->
                <DataGridTemplateColumn Width="150" Header="المراسل">
                    <DataGridTemplateColumn.CellTemplate>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Border
                                Width="30"
                                Height="30"
                                Background="#3D9DA618"
                                CornerRadius="15">
                                <materialDesign:PackIcon
                                    Width="14"
                                    Height="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Kind="Account" />
                            </Border>
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Text="{Binding CorrespondentName}" />
                        </StackPanel>
                    </DataTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

                <!--  عمود الموضوع -->
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Topic}"
                    ElementStyle="{StaticResource DataGridTextStyle}"
                    Header="الموضوع" />

                <!--  عمود الموقع (شارات مسطحة فاتحة) -->
                <DataGridTemplateColumn Width="150" Header="الموقع">
                    <DataGridTemplateColumn.CellTemplate>
                        <ItemsControl ItemsSource="{Binding LocationsList}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="4,2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Background="#E8F5E9"
                                        CornerRadius="12"
                                        Padding="10,4">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="Medium"
                                            Foreground="#2E7D32"
                                            Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!--  عمود الضيف -->
            <DataGridTextColumn
                Width="150"
                Binding="{Binding GuestName}"
                ElementStyle="{StaticResource DataGridTextStyle}"
                Header="الضيف" />

            <!--  عمود التاريخ والوقت  -->
            <DataGridTemplateColumn Width="140" Header="الموعد">
                <DataGridTemplateColumn.CellTemplate>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource MaterialDesignBody}"
                            Text="{Binding ScheduledDate, StringFormat='yyyy/MM/dd'}" />
                        <TextBlock
                            Margin="0,3,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Text="{Binding ScheduledTime, StringFormat='hh:mm tt'}" />
                    </StackPanel>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!--  عمود الإجراءات -->
            <DataGridTemplateColumn Width="90" Header="إجراءات">
                <DataGridTemplateColumn.CellTemplate>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button
                            Click="BtnEdit_Click"
                            Foreground="#1565C0"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="تعديل">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Kind="Pencil" />
                        </Button>
                        <Button
                            Margin="6,0,0,0"
                            Click="BtnDelete_Click"
                            Foreground="#B00020"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="حذف">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Kind="Delete" />
                        </Button>
                    </StackPanel>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

        </DataGrid.Columns>
    </DataGrid>
</Grid>

</UserControl>