        <!--  ══════════════ نمط التاريخ ══════════════  -->
        <Style x:Key="DateField" TargetType="DatePicker">
            <Setter Property="Background" Value="#181C24" />
            <Setter Property="Foreground" Value="#E0E4EB" />
            <Setter Property="BorderBrush" Value="#2C323E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Border
                                x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True" />
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter
                                    x:Name="PART_TextBox"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding SelectedDate}" />
                                <materialDesign:PackIcon
                                    Grid.Column="1"
                                    Width="16"
                                    Height="16"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="#515B6E"
                                    Kind="Calendar" />
                            </Grid>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                Placement="Bottom"
                                StaysOpen="False" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#363D4B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ زر الإضافة ══════════════  -->
        <Style x:Key="BtnAddStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="18,9"
                            Background="{StaticResource GradAccentBtn}"
                            CornerRadius="8"
                            Effect="{StaticResource GlowGreen}"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Kind="Plus" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ أنماط DataGrid ══════════════  -->
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C2130" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#242A3A" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#E0E4EB" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E0E4EB" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#181D28" />
            <Setter Property="Foreground" Value="#515B6E" />
            <Setter Property="Padding" Value="12,14" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SeparatorVisibility" Value="Collapsed" />
        </Style>

        <!--  ══════════════ أزرار الإجراءات ══════════════  -->
        <Style x:Key="BtnActionTeal" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2C323E"
                            BorderThickness="1"
                            CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D9DA6" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D9DA6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnActionRed" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2C323E"
                            BorderThickness="1"
                            CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E54D4D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ بطاقة إحصائية ══════════════  -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#181C24" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="#2C323E" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <!--  ═══════════════════════════════════════════════  -->
    <!--  التخطيط الرئيسي  -->
    <!--  ═══════════════════════════════════════════════  -->
    <Grid Background="#111419">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════════ الرأس ═══════════  -->
        <Grid Grid.Row="0" Margin="24,24,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock
                    FontSize="26"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="سجل التغطيات الميدانية" />
                <TextBlock
                    Margin="0,5,0,0"
                    FontSize="13"
                    Foreground="#515B6E"
                    Text="متابعة وإدارة جميع التغطيات والمهام الميدانية" />
                <Border
                    Width="50"
                    Height="3"
                    Margin="0,14,0,0"
                    Background="{StaticResource GradLine}"
                    CornerRadius="2">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.5"
                            ShadowDepth="0"
                            Color="#3D9DA6" />
                    </Border.Effect>
                </Border>
            </StackPanel>
            <Button
                x:Name="BtnAdd"
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="BtnAddCoverage_Click"
                Content="إضافة تغطية"
                Style="{StaticResource BtnAddStyle}" />
        </Grid>

        <!--  ═══════════ شريط البحث والإحصائيات ═══════════  -->
        <Grid Grid.Row="1" Margin="24,18,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث العام  -->
            <Border
                Grid.Column="0"
                Margin="0,0,10,0"
                Background="#181C24"
                BorderBrush="#2C323E"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <TextBox
                        x:Name="TxtSearch"
                        Padding="38,10"
                        materialDesign:HintAssist.Hint="بحث بالموضوع أو المراسل..."
                        materialDesign:HintAssist.IsFloating="True"
                        TextChanged="TxtSearch_TextChanged" />
                </Grid>
            </Border>

            <!--  فلتر الموقع  -->
            <Border
                Grid.Column="1"
                Margin="0,0,10,0"
                Background="#181C24"
                BorderBrush="#2C323E"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <ComboBox
                        x:Name="CboLocation"
                        Padding="38,8,10,8"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Segoe UI"
                        FontSize="13"
                        Foreground="#E0E4EB"
                        IsEditable="True"
                        SelectionChanged="CboLocation_SelectionChanged"
                        StaysOpenOnEdit="True" />
                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="#D4943A"
                        IsHitTestVisible="False"
                        Kind="MapMarkerOutline" />
                    <TextBlock
                        x:Name="LocationPlaceholder"
                        Margin="38,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#3E4858"
                        IsHitTestVisible="False"
                        Text="فلتر الموقع">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=CboLocation}" Value="-1">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=CboLocation}" Value="1">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!--  فلتر التاريخ  -->
            <Border
                Grid.Column="2"
                Margin="0,0,10,0"
                Padding="6"
                Background="#181C24"
                BorderBrush="#2C323E"
                BorderThickness="1"
                CornerRadius="8">
                <DatePicker
                    x:Name="DpDate"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    Foreground="#E0E4EB"
                    SelectedDateChanged="DpDate_SelectedDateChanged" />
            </Border>

            <!--  زر مسح الفلاتر  -->
            <Button
                Grid.Column="3"
                Width="38"
                Height="38"
                Margin="0,0,10,0"
                Click="BtnClearFilters_Click"
                Cursor="Hand"
                ToolTip="مسح الفلاتر">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#21262F"
                            BorderBrush="#2C323E"
                            BorderThickness="1"
                            CornerRadius="8">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="#515B6E"
                                Kind="FilterRemoveOutline" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!--  بطاقة إجمالي  -->
            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="32"
                        Height="32"
                        Background="#00D4AA12"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#00D4AA"
                            Kind="SatelliteUplink" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="9"
                            Foreground="#515B6E"
                            Text="تغطيات" />
                        <TextBlock
                            x:Name="TxtTotal"
                            Margin="0,1,0,0"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#00D4AA"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  ═══════════ جدول البيانات ═══════════  -->
        <Border
            Grid.Row="2"
            Margin="24,16,24,24"
            Background="#181C24"
            BorderBrush="#2C323E"
            BorderThickness="1"
            CornerRadius="14"
            Effect="{StaticResource CardShadow}">
            <DataGrid
                x:Name="DgCoverages"
                AutoGenerateColumns="False"
                Background="Transparent"
                CanUserAddRows="False"
                CellStyle="{StaticResource DgCell}"
                ColumnHeaderStyle="{StaticResource DgHeader}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                IsReadOnly="True"
                RowStyle="{StaticResource DgRow}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectionMode="Single"
                SelectionUnit="FullRow">

                <DataGrid.Columns>

                    <!--  عمود المراسل  -->
                    <DataGridTemplateColumn Width="150" Header="المراسل">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <Border
                                        Width="30"
                                        Height="30"
                                        Background="#3D9DA618"
                                        CornerRadius="15">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="#3D9DA6"
                                            Kind="Account" />
                                    </Border>
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="#E0E4EB"
                                        Text="{Binding CorrespondentName}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الموضوع  -->
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Topic}"
                        Header="الموضوع" />

                    <!--  عمود الموقع (شارة)  -->
                    <DataGridTemplateColumn Width="120" Header="الموقع">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="10,4"
                                    HorizontalAlignment="Center"
                                    Background="#D4943A12"
                                    CornerRadius="5">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="#D4943A"
                                        Text="{Binding Location}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الضيف  -->
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding GuestName}"
                        Header="الضيف" />

                    <!--  عمود التاريخ والوقت معاً  -->
                    <DataGridTemplateColumn Width="140" Header="الموعد">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="13"
                                        Foreground="#E0E4EB"
                                        Text="{Binding ScheduledTime, StringFormat='yyyy/MM/dd'}" />
                                    <TextBlock
                                        Margin="0,3,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#515B6E"
                                        Text="{Binding ScheduledTime, StringFormat='hh:mm tt'}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الإجراءات  -->
                    <DataGridTemplateColumn Width="90" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource BtnActionTeal}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Foreground="#515B6E"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Margin="6,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource BtnActionRed}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="14"
                                            Height="14"
                                            Foreground="#515B6E"
                                            Kind="TrashCanOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>