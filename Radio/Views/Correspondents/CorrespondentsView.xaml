<UserControl
    x:Class="Radio.Views.Correspondents.CorrespondentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1100"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  1. Header Section  -->
        <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="40"
                            Height="40"
                            Background="#33FFFFFF"
                            CornerRadius="10">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="AccountTieVoice" />
                        </Border>
                        <TextBlock
                            Margin="15,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="دليل المراسلين الميدانيين" />
                    </StackPanel>
                    <TextBlock
                        Margin="55,6,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="إدارة بيانات المراسلين، أرقام التواصل، ومناطق التغطية الخاصة بكل مراسل" />
                </StackPanel>
                <Button
                    x:Name="BtnAdd"
                    Grid.Column="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Click="BtnAdd_Click"
                    Style="{StaticResource Btn.AddNew}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Kind="PlusThick" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="إضافة مراسل جديد" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <!--  2. Toolbar: Search & Stats  -->
        <Grid Grid.Row="1" Margin="24,20,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Search Bar  -->
            <TextBox
                x:Name="TxtSearch"
                Grid.Column="0"
                materialDesign:HintAssist.Hint="ابحث باسم المراسل أو رقم الهاتف..."
                materialDesign:TextFieldAssist.HasClearButton="True"
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  Stats Cards  -->
            <materialDesign:Card
                Grid.Column="1"
                Margin="16,0,0,0"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StatIcon.Primary}">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryMainBrush}"
                            Kind="AccountGroup" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Type.Caption}" Text="إجمالي المراسلين" />
                        <TextBlock
                            x:Name="TxtTotal"
                            Style="{StaticResource Type.Numeric.Medium}"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card
                Grid.Column="2"
                Margin="16,0,0,0"
                Padding="16,12"
                Style="{StaticResource Card.Stat}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StatIcon.Success}">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SuccessBrush}"
                            Kind="CheckCircleOutline" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Type.Caption}" Text="مراسلون نشطون" />
                        <TextBlock
                            x:Name="TxtActive"
                            Style="{StaticResource Type.Numeric.Medium}"
                            Text="0" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!--  3. DataGrid Section  -->
        <Grid Grid.Row="2" Margin="24,0,24,24">
            <!--  Empty State (يظهر عندما لا توجد بيانات)  -->
            <Grid x:Name="EmptyStatePanel" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border
                        Width="80"
                        Height="80"
                        Background="{StaticResource SurfaceVariantBrush}"
                        CornerRadius="40">
                        <materialDesign:PackIcon
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextDisabledBrush}"
                            Kind="AccountSearch" />
                    </Border>
                    <TextBlock
                        Margin="0,16,0,8"
                        HorizontalAlignment="Center"
                        Style="{StaticResource Type.TitleMedium}"
                        Text="لا يوجد مراسلون حالياً" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource Type.BodyMedium.Secondary}"
                        Text="يمكنك إضافة مراسل جديد للبدء في إدارة التغطيات الميدانية" />
                    <Button
                        Margin="0,20,0,0"
                        Click="BtnAdd_Click"
                        Content="إضافة مراسل جديد"
                        Style="{StaticResource Btn.Secondary}" />
                </StackPanel>
            </Grid>

            <!--  Main DataGrid  -->
            <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp1" UniformCornerRadius="16">
                <DataGrid
                    x:Name="DgCorrespondents"
                    Background="Transparent"
                    BorderThickness="0"
                    ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                    RowHeight="70"
                    RowStyle="{StaticResource DataGrid.Row}"
                    Style="{StaticResource DataGrid.Main}">
                    <DataGrid.Columns>
                        <!--  Column 1: Name & Phone (With Avatar)  -->
                        <DataGridTemplateColumn Width="2.5*" Header="بيانات المراسل">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="16,0" Orientation="Horizontal">
                                        <!--  Avatar Circle  -->
                                        <Border
                                            Width="42"
                                            Height="42"
                                            Background="{StaticResource PrimaryXLightBrush}"
                                            CornerRadius="21">
                                            <materialDesign:PackIcon
                                                Width="22"
                                                Height="22"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource PrimaryMainBrush}"
                                                Kind="Account" />
                                        </Border>
                                        <!--  Text Info  -->
                                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                            <TextBlock
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Style="{StaticResource Type.BodyLarge}"
                                                Text="{Binding FullName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="14"
                                                    Height="14"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource TextHintBrush}"
                                                    Kind="PhoneOutline" />
                                                <TextBlock
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Style="{StaticResource Type.Caption}"
                                                    Text="{Binding PhoneNumber, TargetNullValue='لا يوجد رقم'}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Column 2: Locations (Styled as Chips)  -->
                        <DataGridTemplateColumn
                            Width="2*"
                            CellStyle="{StaticResource DataGrid.Cell.Center}"
                            Header="مناطق التغطية">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        MaxWidth="250"
                                        Padding="12,6"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource SurfaceVariantBrush}"
                                        BorderBrush="{StaticResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource WarningBrush}"
                                                Kind="MapMarkerRadius" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                HorizontalAlignment="Center"
                                                FontWeight="Medium"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Style="{StaticResource Type.Caption}"
                                                Text="{Binding AssignedLocations, TargetNullValue='غير محدد'}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  Column 3: Actions (Clean PopupBox)  -->
                        <!--  Column 3: Actions (Inline Buttons)  -->
                        <DataGridTemplateColumn
                            Width="160"
                            CellStyle="{StaticResource DataGrid.Cell.Actions}"
                            Header="إجراءات">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                            Width="36"
                                            Height="36"
                                            Click="BtnEdit_Click"
                                            Style="{StaticResource Btn.Icon.Edit}"
                                            ToolTip="تعديل البيانات">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                Kind="PencilOutline" />
                                        </Button>
                                        <Button
                                            Width="36"
                                            Height="36"
                                            Margin="10,0,0,0"
                                            Click="BtnDelete_Click"
                                            Style="{StaticResource Btn.Icon.Delete}"
                                            ToolTip="حذف المراسل">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                Kind="DeleteOutline" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>