<UserControl
    x:Class="Radio.Views.Correspondents.CorrespondentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Correspondents"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="900"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  ══════════════ الألوان ══════════════  -->
        <SolidColorBrush x:Key="BgBase" Color="#0C0F16" />
        <SolidColorBrush x:Key="BgSurface" Color="#141821" />
        <SolidColorBrush x:Key="BgElevated" Color="#1C2130" />
        <SolidColorBrush x:Key="BgHover" Color="#242A3A" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A3042" />
        <SolidColorBrush x:Key="TextMain" Color="#E4E8F1" />
        <SolidColorBrush x:Key="TextMuted" Color="#5E6687" />

        <!--  ألوان مُضافة لكسر الغامق  -->
        <SolidColorBrush x:Key="TealAccent" Color="#3D9DA6" />
        <SolidColorBrush x:Key="AmberAccent" Color="#D4943A" />
        <SolidColorBrush x:Key="VioletAccent" Color="#7C4DFF" />

        <!--  ══════════════ التدرجات ══════════════  -->
        <LinearGradientBrush x:Key="GradAccent" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#00D4AA" />
            <GradientStop Offset="1" Color="#448AFF" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradLine" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#3D9DA6" />
            <GradientStop Offset="0.5" Color="#D4943A" />
            <GradientStop Offset="1" Color="#7C4DFF" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradViolet" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#7C4DFF" />
            <GradientStop Offset="1" Color="#E040FB" />
        </LinearGradientBrush>

        <!--  ══════════════ التأثيرات ══════════════  -->
        <DropShadowEffect
            x:Key="GlowTeal"
            BlurRadius="10"
            Opacity="0.2"
            ShadowDepth="0"
            Color="#3D9DA6" />
        <DropShadowEffect
            x:Key="GlowViolet"
            BlurRadius="10"
            Opacity="0.2"
            ShadowDepth="0"
            Color="#7C4DFF" />
        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="24"
            Opacity="0.25"
            ShadowDepth="4"
            Color="#000000" />

        <!--  ══════════════ نمط البحث ══════════════  -->
        <!--  ══════════════ نمط البحث (مُصلح بالكامل) ══════════════  -->
        <Style x:Key="SearchField" TargetType="TextBox">
            <Setter Property="Background" Value="#141821" />
            <Setter Property="Foreground" Value="#E4E8F1" />
            <Setter Property="CaretBrush" Value="#3D9DA6" />
            <Setter Property="BorderBrush" Value="#2A3042" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <!--  مسافة داخلية من اليسار فقط (الأيقونة داخل القالب)  -->
            <Setter Property="Padding" Value="16,10,12,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!--  خلفية وحدود  -->
                            <Border
                                x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True" />

                            <!--  أيقونة البحث (ثابتة داخلياً)  -->
                            <materialDesign:PackIcon
                                Grid.Column="0"
                                Width="18"
                                Height="18"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="#3E4858"
                                IsHitTestVisible="False"
                                Kind="Magnify" />

                            <!--  النص المُدخل  -->
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="40,0,12,0"
                                VerticalAlignment="Center"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Disabled" />

                            <!--  نص Placeholder يختفي عند الكتابة  -->
                            <TextBlock
                                x:Name="Placeholder"
                                Margin="40,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="#3E4858"
                                IsHitTestVisible="False"
                                Text="ابحث باسم المراسل..." />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!--  عند التركيز  -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D9DA6" />
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <!--  عند التمرير  -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#353B4A" />
                            </Trigger>
                            <!--  عند وجود نص  -->
                            <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="0">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="1">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  ══════════════ زر الإضافة ══════════════  -->
        <Style x:Key="BtnAddStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="20,10"
                            Background="{StaticResource GradAccent}"
                            CornerRadius="10"
                            Effect="{StaticResource GlowTeal}"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Kind="Plus" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ نمط صف DataGrid ══════════════  -->
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C2130" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#242A3A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ══════════════ نمط خلية DataGrid ══════════════  -->
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#E4E8F1" />
            <Setter Property="FontSize" Value="14" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E4E8F1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ══════════════ نمط رأس العمود ══════════════  -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#181D28" />
            <Setter Property="Foreground" Value="#5E6687" />
            <Setter Property="Padding" Value="14,14" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SeparatorVisibility" Value="Collapsed" />
        </Style>

        <!--  ══════════════ أزرار الإجراءات (ثلاثة أنماط منفصلة) ══════════════  -->

        <!--  زر التغطيات (بنفسجي)  -->
        <Style x:Key="BtnActionViolet" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7C4DFF" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C4DFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  زر التعديل (فيروزي)  -->
        <Style x:Key="BtnActionTeal" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D9DA6" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D9DA6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  زر الحذف (أحمر)  -->
        <Style x:Key="BtnActionRed" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#1C2130"
                            BorderBrush="#2A3042"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E54D4D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ بطاقة إحصائية ══════════════  -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#141821" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="#2A3042" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <!--  ═══════════════════════════════════════════════  -->
    <!--  التخطيط الرئيسي  -->
    <!--  ═══════════════════════════════════════════════  -->
    <Grid Background="#0C0F16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════════ الرأس ═══════════  -->
        <Grid Grid.Row="0" Margin="28,28,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="إدارة المراسلين الميدانيين" />
                <TextBlock
                    Margin="0,5,0,0"
                    FontSize="13"
                    Foreground="#5E6687"
                    Text="إضافة وتعديل وإدارة المراسلين ومهامهم التغطوية" />
                <Border
                    Width="55"
                    Height="3"
                    Margin="0,14,0,0"
                    Background="{StaticResource GradLine}"
                    CornerRadius="2">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.5"
                            ShadowDepth="0"
                            Color="#3D9DA6" />
                    </Border.Effect>
                </Border>
            </StackPanel>

            <Button
                x:Name="BtnAdd"
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="BtnAdd_Click"
                Content="إضافة مراسل"
                Style="{StaticResource BtnAddStyle}" />
        </Grid>

        <!--  ═══════════ شريط البحث والإحصائيات ═══════════  -->
        <Grid Grid.Row="1" Margin="28,20,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  حقل البحث  -->
            <Border
                Grid.Column="0"
                Margin="0,0,12,0"
                Background="#141821"
                BorderBrush="#2A3042"
                BorderThickness="1"
                CornerRadius="10">
                <TextBox
                    x:Name="TxtSearch"
                    Style="{StaticResource SearchField}"
                    TextChanged="TxtSearch_TextChanged" />
            </Border>

            <!--  إجمالي المراسلين  -->
            <Border
                Grid.Column="1"
                Margin="6,0"
                Style="{StaticResource StatCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="38"
                        Height="38"
                        Background="#3D9DA612"
                        CornerRadius="9">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#3D9DA6"
                            Kind="AccountGroup" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="10"
                            Foreground="#5E6687"
                            Text="الإجمالي" />
                        <TextBlock
                            x:Name="TxtTotal"
                            Margin="0,2,0,0"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#E4E8F1"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  مراسلون نشطون  -->
            <Border
                Grid.Column="2"
                Margin="6,0"
                Style="{StaticResource StatCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="38"
                        Height="38"
                        Background="#D4943A12"
                        CornerRadius="9">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#D4943A"
                            Kind="MapMarkerRadius" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="10"
                            Foreground="#5E6687"
                            Text="في الميدان" />
                        <TextBlock
                            x:Name="TxtActive"
                            Margin="0,2,0,0"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#D4943A"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  مناطق التغطية  -->
            <Border
                Grid.Column="3"
                Margin="12,0,0,0"
                Style="{StaticResource StatCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="38"
                        Height="38"
                        Background="#7C4DFF12"
                        CornerRadius="9">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#7C4DFF"
                            Kind="MapCheck" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="10"
                            Foreground="#5E6687"
                            Text="مناطق" />
                        <TextBlock
                            x:Name="TxtLocations"
                            Margin="0,2,0,0"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#7C4DFF"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  ═══════════ جدول البيانات ═══════════  -->
        <Border
            Grid.Row="2"
            Margin="28,18,28,28"
            Background="#141821"
            BorderBrush="#2A3042"
            BorderThickness="1"
            CornerRadius="14"
            Effect="{StaticResource CardShadow}">
            <DataGrid
                x:Name="DgCorrespondents"
                AutoGenerateColumns="False"
                Background="Transparent"
                CanUserAddRows="False"
                CellStyle="{StaticResource DgCell}"
                ColumnHeaderStyle="{StaticResource DgHeader}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                IsReadOnly="True"
                RowStyle="{StaticResource DgRow}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectionMode="Single"
                SelectionUnit="FullRow">

                <DataGrid.Columns>

                    <!--  عمود المراسل: أفاتار + اسم + هاتف  -->
                    <DataGridTemplateColumn Width="*" Header="المراسل">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <Border
                                        Width="38"
                                        Height="38"
                                        Background="{StaticResource GradViolet}"
                                        CornerRadius="19"
                                        Effect="{StaticResource GlowViolet}">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="White"
                                            Kind="Account" />
                                    </Border>
                                    <StackPanel Margin="14,0,0,0">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#E4E8F1"
                                            Text="{Binding FullName}" />
                                        <TextBlock
                                            Margin="0,3,0,0"
                                            FontSize="12"
                                            Foreground="#5E6687"
                                            Text="{Binding PhoneNumber}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود المناطق: شارات ملونة  -->
                    <DataGridTemplateColumn Width="260" Header="المناطق المكلف بها">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding LocationsList}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Margin="0,4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,6,4"
                                                Padding="10,4"
                                                Background="#3D9DA615"
                                                CornerRadius="6">
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Foreground="#3D9DA6"
                                                    Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  عمود الإجراءات  -->
                    <DataGridTemplateColumn Width="140" Header="إجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <!--  التغطيات (بنفسجي)  -->
                                    <Button
                                        Click="BtnCoverage_Click"
                                        Style="{StaticResource BtnActionViolet}"
                                        ToolTip="التغطيات">
                                        <materialDesign:PackIcon
                                            Width="15"
                                            Height="15"
                                            Foreground="#5E6687"
                                            Kind="MapMarkerCheck" />
                                    </Button>
                                    <!--  تعديل (فيروزي)  -->
                                    <Button
                                        Margin="6,0,0,0"
                                        Click="BtnEdit_Click"
                                        Style="{StaticResource BtnActionTeal}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="15"
                                            Height="15"
                                            Foreground="#5E6687"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <!--  حذف (أحمر)  -->
                                    <Button
                                        Margin="6,0,0,0"
                                        Click="BtnDelete_Click"
                                        Style="{StaticResource BtnActionRed}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="15"
                                            Height="15"
                                            Foreground="#5E6687"
                                            Kind="TrashCanOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>