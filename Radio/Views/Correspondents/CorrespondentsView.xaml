<UserControl
    x:Class="Radio.Views.Correspondents.CorrespondentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1100"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style
            x:Key="LuxuryColumnHeader"
            BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
            TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                    <Setter Property="Foreground" Value="#1E293B" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone
            Grid.Row="0"
            Padding="30,24"
            materialDesign:ElevationAssist.Elevation="Dp4"
            Foreground="White"
            Mode="Custom">

            <materialDesign:ColorZone.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#1A237E" />
                    <GradientStop Offset="1" Color="#283593" />
                </LinearGradientBrush>
            </materialDesign:ColorZone.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="#82B1FF"
                            Kind="AccountTieVoice" />
                        <TextBlock
                            Margin="15,0"
                            VerticalAlignment="Center"
                            FontSize="28"
                            FontWeight="ExtraBold"
                            Text="إدارة المراسلين الميدانيين" />
                    </StackPanel>
                    <TextBlock
                        Margin="47,5,0,0"
                        FontSize="13"
                        Opacity="0.7"
                        Text="تنسيق العمليات الميدانية، متابعة المواقع، وإدارة بيانات التواصل الرسمية" />
                </StackPanel>

                <Button
                    x:Name="BtnAdd"
                    Grid.Column="1"
                    Height="50"
                    Padding="25,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    materialDesign:ButtonAssist.CornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Background="#FFB300"
                    BorderThickness="0"
                    Click="BtnAdd_Click"
                    Foreground="#1A237E">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Kind="PlusThick" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Text="إضافة مراسل جديد" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>
        <Grid
            Grid.Row="1"
            Margin="30,20"
            HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Width="400"
                HorizontalAlignment="Right"
                materialDesign:HintAssist.Hint="البحث عن اسم أو منطقة..."
                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                materialDesign:TextFieldAssist.LeadingIcon="Search"
                Style="{StaticResource BroadcastTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <StackPanel
                Grid.Column="1"
                Margin="40,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <StackPanel Margin="20,0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Foreground="#64748B"
                        Text="إجمالي الكادر" />
                    <TextBlock
                        x:Name="TxtTotal"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="#1E293B"
                        Text="0" />
                </StackPanel>
                <Border
                    Width="1"
                    Height="25"
                    Margin="10,0"
                    Background="#CBD5E1" />
                <StackPanel Margin="20,0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Foreground="#64748B"
                        Text="في التغطية" />
                    <TextBlock
                        x:Name="TxtActive"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="#3F51B5"
                        Text="0" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <materialDesign:Card
            Grid.Row="2"
            Margin="30,0,30,30"
            materialDesign:ElevationAssist.Elevation="Dp0"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            UniformCornerRadius="16">
            <DataGrid
                x:Name="DgCorrespondents"
                Background="White"
                CellStyle="{StaticResource BroadcastPro.DataGridCell}"
                ColumnHeaderStyle="{StaticResource LuxuryColumnHeader}"
                RowHeight="65"
                RowStyle="{StaticResource BroadcastPro.DataGridRow}"
                Style="{StaticResource BroadcastProDataGrid}">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="*" Header="المراسل الميداني">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <Border
                                        Width="38"
                                        Height="38"
                                        Background="#F1F5F9"
                                        CornerRadius="10">
                                        <materialDesign:PackIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="#64748B"
                                            Kind="Account" />
                                    </Border>
                                    <StackPanel Margin="15,0" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="#1E293B"
                                            Text="{Binding FullName}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#94A3B8"
                                            Text="{Binding PhoneNumber}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="220" Header="مناطق التغطية">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="12,5"
                                    HorizontalAlignment="Center"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="#475569"
                                        Text="{Binding AssignedLocations}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="150" Header="خيارات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Width="35"
                                        Height="35"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Foreground="#64748B"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Width="35"
                                        Height="35"
                                        Margin="8,0"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Foreground="#EF4444"
                                            Kind="DeleteOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>