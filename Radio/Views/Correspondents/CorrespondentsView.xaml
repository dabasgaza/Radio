<UserControl
    x:Class="Radio.Views.Correspondents.CorrespondentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Correspondents"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="900"
    Style="{StaticResource UserControlStyle}"
    mc:Ignorable="d">

    <!--  تم حذف كامل الـ Resources المحلية بالكامل  -->

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══════════ الرأس والعنوان ═══════════  -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Style="{StaticResource TitleLarge}" Text="إدارة المراسلين الميدانيين" />
                <TextBlock
                    Margin="0,4,0,0"
                    Foreground="#757575"
                    Style="{StaticResource BodyMedium}"
                    Text="إضافة وتعيين المراسلين ومهامهم في مناطق التغطية" />
            </StackPanel>

            <Button
                Name="BtnAdd"
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="BtnAdd_Click"
                Style="{StaticResource PrimaryActionButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Kind="Plus" />
                    <TextBlock VerticalAlignment="Center" Text="إضافة مراسل جديد" />
                </StackPanel>
            </Button>
        </Grid>

        <!--  ═══════════ البحث وبطاقات الإحصائيات ═══════════  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,24"
            Orientation="Horizontal">

            <!--  حقل البحث  -->
            <TextBox
                x:Name="TxtSearch"
                Width="350"
                Margin="0,0,16,0"
                materialDesign:HintAssist.Hint="بحث باسم المراسل أو المناطق..."
                materialDesign:TextFieldAssist.HasLeadingIcon="True"
                materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                Style="{StaticResource BroadcastTextBox}"
                TextChanged="TxtSearch_TextChanged" />

            <!--  بطاقة: إجمالي المراسلين  -->
            <materialDesign:Card
                Width="200"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Style="{StaticResource BroadcastCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        Background="#E8EAF6"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#303F9F"
                            Kind="AccountGroup" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="#757575"
                            Text="الإجمالي" />
                        <TextBlock
                            x:Name="TxtTotal"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#212121"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  بطاقة: مراسلون نشطون (باستخدام لون الـ Secondary)  -->
            <materialDesign:Card
                Width="200"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Style="{StaticResource BroadcastCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        Background="#E1F5FE"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#0288D1"
                            Kind="MapMarkerRadius" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="#757575"
                            Text="في الميدان" />
                        <TextBlock
                            x:Name="TxtActive"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#0288D1"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!--  بطاقة: مناطق التغطية  -->
            <materialDesign:Card
                Width="200"
                VerticalAlignment="Center"
                Style="{StaticResource BroadcastCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="48"
                        Height="48"
                        Background="#FFF3E0"
                        CornerRadius="8">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#F57F17"
                            Kind="MapMarkerCheck" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            Foreground="#757575"
                            Text="مناطق التغطية" />
                        <TextBlock
                            x:Name="TxtLocations"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#F57F17"
                            Text="0" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <!--  ═══════════ جدول البيانات ═══════════  -->
        <DataGrid
            x:Name="DgCorrespondents"
            Grid.Row="2"
            VerticalAlignment="Stretch"
            AutoGenerateColumns="False"
            CellStyle="{StaticResource BroadcastPro.DataGridCell}"
            ColumnHeaderStyle="{StaticResource BroadcastPro.DataGridColumnHeader}"
            IsReadOnly="True"
            ItemsSource="{Binding CorrespondentsList}"
            RowStyle="{StaticResource BroadcastPro.DataGridRow}"
            Style="{StaticResource BroadcastProDataGrid}">

            <DataGrid.Columns>

                <!--  عمود المراسل  -->
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding FullName}"
                    ElementStyle="{StaticResource DataGridTextStyle}"
                    Header="المراسل" />

                <!--  عمود الهاتف  -->
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding PhoneNumber}"
                    CellStyle="{StaticResource CenterCellAligned}"
                    Header="رقم الهاتف" />

                <!--  عمود المناطق (شارات مسطحة)  -->
                <DataGridTemplateColumn Width="200" Header="المناطق المكلف بها">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding LocationsList}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="4,2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="10,4"
                                            Background="#E1F5FE"
                                            CornerRadius="12">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="Medium"
                                                Foreground="#0288D1"
                                                Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!--  عمود الإجراءات  -->
                <DataGridTemplateColumn Width="180" Header="إجراءات">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Click="BtnCoverage_Click"
                                    Foreground="#1565C0"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="التغطيات">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Kind="MapMarkerCheck" />
                                </Button>
                                <Button
                                    Click="BtnEdit_Click"
                                    Foreground="#1565C0"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="تعديل">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Kind="Pencil" />
                                </Button>
                                <Button
                                    Click="BtnDelete_Click"
                                    Foreground="#B00020"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="حذف">
                                    <materialDesign:PackIcon
                                        Width="20"
                                        Height="20"
                                        Kind="Delete" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>