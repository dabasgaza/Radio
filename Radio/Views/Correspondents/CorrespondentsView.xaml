<UserControl
    x:Class="Radio.Views.Correspondents.CorrespondentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1100"
    FlowDirection="RightToLeft"
    Style="{StaticResource View.Base}"
    mc:Ignorable="d">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Grid.Row="0" Style="{StaticResource Zone.Header.Primary}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SurfaceBrush}"
                            Kind="AccountTieVoice" />
                        <TextBlock
                            Margin="15,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إدارة المراسلين الميدانيين" />
                    </StackPanel>
                    <TextBlock
                        Margin="47,5,0,0"
                        Style="{StaticResource Type.BodyMedium.OnColor}"
                        Text="تنسيق العمليات الميدانية، متابعة المواقع، وإدارة بيانات التواصل الرسمية" />
                </StackPanel>

                <Button
                    x:Name="BtnAdd"
                    Grid.Column="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Click="BtnAdd_Click"
                    Style="{StaticResource Btn.AddNew}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Kind="PlusThick" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Text="إضافة مراسل جديد" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:ColorZone>
        <Grid
            Grid.Row="1"
            Margin="30,20"
            HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TxtSearch"
                Width="400"
                HorizontalAlignment="Right"
                materialDesign:HintAssist.Hint="البحث عن اسم أو منطقة..."
                materialDesign:TextFieldAssist.LeadingIcon="Search"
                Style="{StaticResource Input.Search}"
                TextChanged="TxtSearch_TextChanged" />

            <StackPanel
                Grid.Column="1"
                Margin="40,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <StackPanel Margin="20,0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Foreground="#64748B"
                        Text="إجمالي الكادر" />
                    <TextBlock
                        x:Name="TxtTotal"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource SuccessBrush}"
                        Style="{StaticResource Type.Numeric.Medium}"
                        Text="0" />
                </StackPanel>
                <Border
                    Width="1"
                    Height="25"
                    Margin="10,0"
                    Background="#CBD5E1" />
                <StackPanel Margin="20,0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Foreground="#64748B"
                        Text="في التغطية" />
                    <TextBlock
                        x:Name="TxtActive"
                        HorizontalAlignment="Center"
                        Style="{StaticResource Type.Numeric.Medium}"
                        Text="0" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <materialDesign:Card
            Grid.Row="2"
            Margin="30,0,30,30"
            materialDesign:ElevationAssist.Elevation="Dp0"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            UniformCornerRadius="16">
            <DataGrid
                x:Name="DgCorrespondents"
                Background="White"
                ColumnHeaderStyle="{StaticResource DataGrid.ColumnHeader.Center}"
                RowHeight="65"
                RowStyle="{StaticResource DataGrid.Row}"
                Style="{StaticResource DataGrid.Main}">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="*" Header="المراسل الميداني">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <Border
                                        Width="38"
                                        Height="38"
                                        Style="{StaticResource Chip.Primary}">
                                        <materialDesign:PackIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource PrimaryMainBrush}"
                                            Kind="Account" />
                                    </Border>
                                    <StackPanel Margin="15,0" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="15"
                                            Foreground="#1E293B"
                                            Text="{Binding FullName}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#94A3B8"
                                            Text="{Binding PhoneNumber}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="220"
                        CellStyle="{StaticResource DataGrid.Cell.Center}"
                        Header="مناطق التغطية">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    MinWidth="100"
                                    Padding="12,5"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource HeaderGradientBrush}"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource TextOnPrimaryBrush}"
                                        Text="{Binding AssignedLocations}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn
                        Width="150"
                        CellStyle="{StaticResource DataGrid.Cell.Actions}"
                        Header="الإجراءات">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Width="35"
                                        Height="35"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="تعديل">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Foreground="#64748B"
                                            Kind="PencilOutline" />
                                    </Button>
                                    <Button
                                        Width="35"
                                        Height="35"
                                        Margin="8,0"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="حذف">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Foreground="#EF4444"
                                            Kind="DeleteOutline" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>