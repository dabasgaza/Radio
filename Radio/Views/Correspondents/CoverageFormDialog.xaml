<mah:MetroWindow
    x:Class="Radio.Views.Correspondents.CoverageFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Radio.Views.Correspondents"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CoverageFormDialog"
    Width="580"
    Height="560"
    AllowsTransparency="True"
    Background="Transparent"
    GlowBrush="DarkCyan"
    ResizeMode="NoResize"
    ShowCloseButton="False"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <mah:MetroWindow.Resources>

        <!--  ══════════════ الألوان (Material Blue) ══════════════  -->
        <SolidColorBrush x:Key="BgBase" Color="#111419" />
        <SolidColorBrush x:Key="BgSurface" Color="#181C24" />
        <SolidColorBrush x:Key="BgInput" Color="#21262F" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2C323E" />
        <SolidColorBrush x:Key="BorderFocus" Color="#42A5F5" />
        <SolidColorBrush x:Key="TextMain" Color="#E0E4EB" />
        <SolidColorBrush x:Key="TextMuted" Color="#515B6E" />
        <SolidColorBrush x:Key="BlueMain" Color="#42A5F5" />
        <SolidColorBrush x:Key="BlueDark" Color="#1E88E5" />
        <SolidColorBrush x:Key="BlueLight" Color="#90CAF9" />
        <SolidColorBrush x:Key="RedAccent" Color="#E54D4D" />

        <!--  ══════════════ التدرجات ══════════════  -->
        <LinearGradientBrush x:Key="GradBlueBtn" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#42A5F5" />
            <GradientStop Offset="1" Color="#1E88E5" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradLine" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#42A5F5" />
            <GradientStop Offset="1" Color="#90CAF9" />
        </LinearGradientBrush>

        <!--  ══════════════ التأثيرات ══════════════  -->
        <DropShadowEffect
            x:Key="GlowBlue"
            BlurRadius="14"
            Opacity="0.25"
            ShadowDepth="0"
            Color="#42A5F5" />
        <DropShadowEffect
            x:Key="BtnShadow"
            BlurRadius="18"
            Opacity="0.3"
            ShadowDepth="4"
            Color="#42A5F5" />

        <!--  ══════════════ تسمية الحقل ══════════════  -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#515B6E" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <!--  ══════════════ نمط حقول الإدخال (آمن) ══════════════  -->
        <Style x:Key="FormField" TargetType="TextBox">
            <Setter Property="Background" Value="#21262F" />
            <Setter Property="Foreground" Value="#E0E4EB" />
            <Setter Property="CaretBrush" Value="#42A5F5" />
            <Setter Property="BorderBrush" Value="#2C323E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border
                                x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True" />
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Disabled" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#42A5F5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#363D4B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ نمط القائمة المنسدلة (آمن) ══════════════  -->
        <Style x:Key="ComboField" TargetType="ComboBox">
            <Setter Property="Background" Value="#21262F" />
            <Setter Property="Foreground" Value="#E0E4EB" />
            <Setter Property="BorderBrush" Value="#2C323E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border
                                x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True" />
                            <ToggleButton
                                x:Name="PART_Toggle"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                ClickMode="Press"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Grid Margin="{TemplateBinding Padding}" IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter
                                    x:Name="PART_ContentPresenter"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    TextBlock.Foreground="{TemplateBinding Foreground}" />
                                <materialDesign:PackIcon
                                    x:Name="ArrowIcon"
                                    Grid.Column="1"
                                    Width="18"
                                    Height="18"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="#515B6E"
                                    Kind="ChevronDown"
                                    RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    Margin="0,4,0,0"
                                    Background="#21262F"
                                    BorderBrush="#2C323E"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#42A5F5" />
                                <Setter TargetName="ArrowIcon" Property="Foreground" Value="#42A5F5" />
                                <Setter TargetName="ArrowIcon" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#363D4B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E0E4EB" />
                    <Setter Property="Padding" Value="14,10" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border
                                    x:Name="Bd"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#242A3A" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#42A5F518" />
                                        <Setter Property="Foreground" Value="#42A5F5" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!--  ══════════════ زر حفظ ══════════════  -->
        <Style x:Key="BtnSaveStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="20,0"
                            Background="{StaticResource GradBlueBtn}"
                            CornerRadius="10"
                            Effect="{StaticResource BtnShadow}"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="ContentSaveOutline" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══════════════ زر إلغاء ══════════════  -->
        <Style x:Key="BtnCancelStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#515B6E" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="#21262F"
                            BorderBrush="#2C323E"
                            BorderThickness="1"
                            CornerRadius="10"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    Kind="Close" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E54D4D" />
                                <Setter Property="Foreground" Value="#E54D4D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </mah:MetroWindow.Resources>

    <!--  ═══════════════════════════════════════════  -->
    <!--  التخطيط الرئيسي  -->
    <!--  ═══════════════════════════════════════════  -->
    <Grid Background="#111419">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ═══════════ خلفية النافذة ═══════════  -->
        <Border Grid.RowSpan="3" CornerRadius="14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#15181F" />
                    <GradientStop Offset="1" Color="#111419" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!--  ═══════════ الرأس ═══════════  -->
        <Border
            Grid.Row="0"
            Padding="26,24,26,20"
            BorderBrush="#2C323E"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="48"
                    Height="48"
                    Background="{StaticResource GradBlueBtn}"
                    CornerRadius="13"
                    Effect="{StaticResource GlowBlue}">
                    <materialDesign:PackIcon
                        Width="22"
                        Height="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Kind="SatelliteUplink" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="TxtTitle"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="إضافة تغطية ميدانية" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="12"
                        Foreground="#515B6E"
                        Text="أدخل تفاصيل التغطية والموعد والمراسل المكلف" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  ═══════════ المحتوى ═══════════  -->
        <ScrollViewer
            Grid.Row="1"
            Padding="26,20,26,8"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  المراسل  -->
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="المراسل المكلف *" />
                    <Grid>
                        <ComboBox
                            x:Name="CboCorrespondents"
                            Padding="40,11"
                            DisplayMemberPath="FullName"
                            SelectedValuePath="CorrespondentId"
                            Style="{StaticResource ComboField}" />
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="#515B6E"
                            IsHitTestVisible="False"
                            Kind="AccountOutline" />
                    </Grid>
                </StackPanel>

                <!--  الضيف  -->
                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="الضيف المرتبط" />
                    <Grid>
                        <ComboBox
                            x:Name="CboGuests"
                            Padding="40,11"
                            DisplayMemberPath="FullName"
                            SelectedValuePath="GuestId"
                            Style="{StaticResource ComboField}" />
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="#515B6E"
                            IsHitTestVisible="False"
                            Kind="AccountVoice" />
                    </Grid>
                </StackPanel>

                <!--  الموضوع  -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="موضوع التغطية *" />
                    <Grid>
                        <TextBox
                            x:Name="TxtTopic"
                            Padding="40,11"
                            Style="{StaticResource FormField}" />
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="#42A5F5"
                            IsHitTestVisible="False"
                            Kind="TextBoxOutline" />
                    </Grid>
                </StackPanel>

                <!--  الموقع  -->
                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="الموقع الجغرافي" />
                    <Grid>
                        <TextBox
                            x:Name="TxtLocation"
                            Padding="40,11"
                            Style="{StaticResource FormField}" />
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="#D4943A"
                            IsHitTestVisible="False"
                            Kind="MapMarkerOutline" />
                    </Grid>
                </StackPanel>

                <!--  التاريخ  -->
                <StackPanel Grid.Row="4" Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="تاريخ التغطية" />
                    <Grid>
                        <Border
                            Padding="4"
                            Background="#21262F"
                            BorderBrush="#2C323E"
                            BorderThickness="1"
                            CornerRadius="10">
                            <DatePicker
                                x:Name="DpDate"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Segoe UI"
                                FontSize="14"
                                Foreground="#E0E4EB" />
                        </Border>
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="#90CAF9"
                            IsHitTestVisible="False"
                            Kind="CalendarOutline" />
                    </Grid>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!--  ═══════════ التذييل ═══════════  -->
        <Border
            Grid.Row="2"
            Padding="26,14,26,22"
            BorderBrush="#2C323E"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="إلغاء"
                    IsCancel="True"
                    Style="{StaticResource BtnCancelStyle}" />

                <Button
                    x:Name="BtnSave"
                    Grid.Column="2"
                    Click="BtnSave_Click"
                    Content="حفظ التغطية"
                    Style="{StaticResource BtnSaveStyle}" />
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>