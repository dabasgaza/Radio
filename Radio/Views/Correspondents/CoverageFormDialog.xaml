<mah:MetroWindow
    x:Class="Radio.Views.Correspondents.CoverageFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة التغطية الميدانية"
    Width="600"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    FlowDirection="RightToLeft"
    ShowTitleBar="False"
    Style="{StaticResource BasicWindowStyle}"
    UseNoneWindowStyle="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <materialDesign:Card
        Margin="30"
        materialDesign:ElevationAssist.Elevation="Dp2"
        Background="{DynamicResource MaterialDesignPaper}"
        UniformCornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Padding="24,20"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Foreground="White"
                Mode="Custom">
                <materialDesign:ColorZone.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#3949AB" />
                        <GradientStop Offset="1" Color="#283593" />
                    </LinearGradientBrush>
                </materialDesign:ColorZone.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="SatelliteUplink" Width="35" Height="35" VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock x:Name="TxtTitle" 
                                   Text="إضافة تغطية ميدانية" 
                                   Style="{StaticResource TitleLarge}" 
                                   Foreground="White" 
                                   FontWeight="Bold" />
                        <TextBlock Text="تنسيق المهام الخارجية وتكليف المراسلين" 
                                   FontSize="11" 
                                   Opacity="0.8" 
                                   Foreground="White" />
                    </StackPanel>

                    <Button Grid.Column="2" 
                            Click="BtnClose_Click" 
                            Style="{StaticResource MaterialDesignIconButton}" 
                            Foreground="White" Opacity="0.6">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer Grid.Row="1" Padding="28,15" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10 15">

                    <Grid Margin="0,10,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="CboCorrespondents"
                                  Grid.Column="0"
                                  materialDesign:HintAssist.Hint="المراسل المكلف *"
                                  materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                  materialDesign:TextFieldAssist.LeadingIcon="AccountTieVoiceOutline"
                                  Style="{StaticResource BroadcastComboBox}"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="CorrespondentId" />

                        <ComboBox x:Name="CboGuests"
                                  Grid.Column="2"
                                  materialDesign:HintAssist.Hint="الضيف المستهدف"
                                  materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                  materialDesign:TextFieldAssist.LeadingIcon="MicrophoneOutline"
                                  Style="{StaticResource BroadcastComboBox}"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="GuestId" />
                    </Grid>

                    <TextBox x:Name="TxtTopic"
                             Margin="0,0,0,24"
                             materialDesign:HintAssist.Hint="موضوع أو عنوان التغطية *"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="FileDocumentEditOutline"
                             Style="{StaticResource BroadcastTextBox}" />

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtLocation"
                                 Grid.Column="0"
                                 materialDesign:HintAssist.Hint="الموقع الجغرافي"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="MapMarkerPath"
                                 Style="{StaticResource BroadcastTextBox}" />

                        <DatePicker x:Name="DpDate"
                                    Grid.Column="2"
                                    materialDesign:HintAssist.Hint="تاريخ التغطية"
                                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                    materialDesign:TextFieldAssist.LeadingIcon="CalendarClockOutline"
                                    Style="{StaticResource BroadcastDatePicker}" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="28,24" Background="{DynamicResource MaterialDesignDivider}" CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="الغاء"
                            IsCancel="True"
                            Style="{StaticResource CancelFlatButton}" />

                    <Button x:Name="BtnSave"
                            Grid.Column="2"
                            Click="BtnSave_Click"
                            Content="حفظ بيانات التغطية"
                            Background="#3F51B5"
                            BorderBrush="#3F51B5"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp2"
                            Style="{StaticResource PrimaryActionButton}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckAll" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>