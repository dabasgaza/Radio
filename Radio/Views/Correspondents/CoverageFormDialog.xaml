<mah:MetroWindow
    x:Class="Radio.Views.Correspondents.CoverageFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="إدارة التغطية الميدانية"
    Width="600"
    Height="600"
    Style="{StaticResource Window.Dialog}"
    WindowStartupLocation="CenterScreen">

    <materialDesign:Card Margin="30" Style="{StaticResource Card.Form}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Style="{StaticResource Zone.Header.Primary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="35"
                        Height="35"
                        VerticalAlignment="Center"
                        Kind="SatelliteUplink" />

                    <StackPanel Grid.Column="1" Margin="18,0">
                        <TextBlock
                            x:Name="TxtTitle"
                            Style="{StaticResource Type.TitleLarge.OnColor}"
                            Text="إضافة تغطية ميدانية" />
                        <TextBlock Style="{StaticResource Type.BodyMedium.OnColor}" Text="تنسيق المهام الخارجية وتكليف المراسلين" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="BtnClose_Click"
                        Foreground="White"
                        Opacity="0.6"
                        Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ScrollViewer
                Grid.Row="1"
                Padding="28,15"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,15">

                    <Grid Margin="0,10,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            x:Name="CboCorrespondents"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="المراسل المكلف *"
                            materialDesign:TextFieldAssist.LeadingIcon="AccountTieVoiceOutline"
                            DisplayMemberPath="FullName"
                            SelectedValuePath="CorrespondentId"
                            Style="{StaticResource Input.ComboBox}" />

                        <ComboBox
                            x:Name="CboGuests"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="الضيف المستهدف"
                            materialDesign:TextFieldAssist.LeadingIcon="MicrophoneOutline"
                            DisplayMemberPath="FullName"
                            SelectedValuePath="GuestId"
                            Style="{StaticResource Input.ComboBox}" />
                    </Grid>

                    <TextBox
                        x:Name="TxtTopic"
                        Margin="0,0,0,24"
                        materialDesign:HintAssist.Hint="موضوع أو عنوان التغطية *"
                        materialDesign:TextFieldAssist.LeadingIcon="FileDocumentEditOutline"
                        Style="{StaticResource Input.Text}" />

                    <TextBox
                        x:Name="TxtLocation"
                        materialDesign:HintAssist.Hint="الموقع الجغرافي"
                        materialDesign:TextFieldAssist.LeadingIcon="MapMarkerPath"
                        Style="{StaticResource Input.Text}" />


                    <Grid Margin="0,24,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DatePicker
                            x:Name="DpDate"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="تاريخ التغطية"
                            materialDesign:TextFieldAssist.LeadingIcon="CalendarClockOutline"
                            Style="{StaticResource Input.DatePicker}" />

                        <materialDesign:TimePicker
                            x:Name="DpTime"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="وقت التغطية"
                            materialDesign:TextFieldAssist.LeadingIcon="ClockOutline"
                            Style="{StaticResource Input.TimePicker}" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource Window.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="الغاء"
                        IsCancel="True"
                        Style="{StaticResource Btn.Cancel}" />

                    <Button
                        x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Content="حفظ بيانات التغطية"
                        Style="{StaticResource Btn.Primary}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon VerticalAlignment="Center" Kind="CheckAll" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</mah:MetroWindow>