<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">

    <Style x:Key="BasicWindowStyle" TargetType="{x:Type mah:MetroWindow}">
        <Setter Property="Background" Value="#303030" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource MaterialDesignBody}" />

        <!--  إضافات جديدة لتوافق أفضل مع MahApps + Dark Theme  -->
        <Setter Property="GlowBrush" Value="{DynamicResource AccentColorBrush}" />
        <Setter Property="WindowTitleBrush" Value="{DynamicResource WindowTitleColorBrush}" />
        <Setter Property="NonActiveWindowTitleBrush" Value="{DynamicResource MaterialDesignPaper}" />

        <Setter Property="FlowDirection" Value="RightToLeft" />
        <Setter Property="FontFamily" Value="Hacen Tunisia" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="UserControlStyle" TargetType="{x:Type UserControl}">
        <Setter Property="Background" Value="#303030" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
        <Setter Property="FontFamily" Value="Hacen Tunisia" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <!--  DataGrid styles (ما زالت تعمل كما هي مع التحديثات الجديدة)  -->
    <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#6FD7FF" />
        <!--  يمكنك تغييره إلى DynamicResource إذا أردت  -->
    </Style>

    <Style BasedOn="{StaticResource MaterialDesignDataGridRow}" TargetType="{x:Type DataGridRow}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightForegroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Style أساسي لكل الـ Cells مع التحكم في الحدود (مهم جدًا للتناسق)  -->
    <Style BasedOn="{StaticResource MaterialDesignDataGridCell}" TargetType="{x:Type DataGridCell}">
        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
        <Setter Property="BorderThickness" Value="0" />
        <!--  سنتحكم فيه من الـ DataGrid  -->
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  CenterCellAligned - محدث  -->
    <Style
        x:Key="CenterCellAligned"
        BasedOn="{StaticResource MaterialDesignDataGridCell}"
        TargetType="{x:Type DataGridCell}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextBlock.TextAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!--  CenterCellAlignedAndBackColor2 - محدث  -->
    <Style
        x:Key="CenterCellAlignedAndBackColor2"
        BasedOn="{StaticResource CenterCellAligned}"
        TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightForegroundBrush}" />
    </Style>

    <!--  LeftCellAligned - محدث  -->
    <Style
        x:Key="LeftCellAligned"
        BasedOn="{StaticResource MaterialDesignDataGridCell}"
        TargetType="{x:Type DataGridCell}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextBlock.TextAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="10,0,0,0" />
    </Style>
    <!--  DataGrid Grid Lines - حل شامل ومتناسق  -->
    <Style BasedOn="{StaticResource MaterialDesignDataGrid}" TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
        <Setter Property="RowBackground" Value="{DynamicResource MaterialDesignPaper}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource MaterialDesignPaper}" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <!--<Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource MaterialDesignDivider}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource MaterialDesignDivider}" />
        <Setter Property="BorderThickness" Value="0" />-->
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>
</ResourceDictionary>