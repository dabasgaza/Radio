<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">

    <!--  BasicWindowStyle  -->
    <Style x:Key="BasicWindowStyle" TargetType="{x:Type mah:MetroWindow}">
        <!--  تم إصلاح اللون الثابت #303030 واستبداله بلون الخلفية الرسمي من Material Design  -->
        <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource MaterialDesignBody}" />

        <Setter Property="GlowBrush" Value="{DynamicResource AccentColorBrush}" />
        <Setter Property="WindowTitleBrush" Value="{DynamicResource WindowTitleColorBrush}" />
        <Setter Property="NonActiveWindowTitleBrush" Value="{DynamicResource MaterialDesignPaper}" />

        <Setter Property="FlowDirection" Value="RightToLeft" />
        <Setter Property="FontFamily" Value="Hacen Tunisia" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <!--  UserControlStyle  -->
    <Style x:Key="UserControlStyle" TargetType="{x:Type UserControl}">
        <!--  تم إصلاح اللون الثابت #303030 ليستجيب للثيم الفاتح والداكن  -->
        <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
        <Setter Property="FontFamily" Value="Hacen Tunisia" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

