<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        ╔══════════════════════════════════════════════════════════════════╗
        ║  ✅ السر: يجب تعريف هذه الستايلات قبل BroadcastProDataGrid    ║
        ║  في نفس ResourceDictionary أو في قاموس يُدمج قبله              ║
        ╚══════════════════════════════════════════════════════════════════╝
    -->

    <!--
        ══════════════════════════════════════════════
        COLUMN HEADER STYLE
        ✅ تعريف مستقل بـ x:Key — لا BasedOn داخل Setter
        ✅ ألوان صحيحة: #303F9F + White = 7.5:1 WCAG AAA
        ══════════════════════════════════════════════
    -->
    <Style
        x:Key="BroadcastPro.DataGridColumnHeader"
        BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
        TargetType="DataGridColumnHeader">

        <Setter Property="Background" Value="#303F9F" />
        <!--  Indigo 700 ✅  -->
        <Setter Property="Foreground" Value="#FFFFFF" />
        <!--  White — 7.5:1 ✅  -->
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="SeparatorVisibility" Value="Collapsed" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />

        <!--
            ✅ هذا Trigger مهم: يمنع MDIX من تلوين الـ hover بشكل مختلف
            ويحافظ على الـ header bg حتى عند التمرير بالفأرة
        -->
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3949AB" />
                <!--  Indigo 600  -->
                <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>

            <!--  Sort indicator color  -->
            <Trigger Property="SortDirection" Value="Ascending">
                <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>
            <Trigger Property="SortDirection" Value="Descending">
                <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>
        </Style.Triggers>
    </Style>


    <!--
        ══════════════════════════════════════════════
        ROW STYLE
        ✅ تعريف مستقل — يحل مشكلة عدم التطبيق
        ══════════════════════════════════════════════
    -->
    <Style
        x:Key="BroadcastPro.DataGridRow"
        BasedOn="{StaticResource MaterialDesignDataGridRow}"
        TargetType="DataGridRow">

        <Setter Property="MinHeight" Value="50" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />

        <Style.Triggers>

            <!--  Alternating row — خلفية خفيفة Indigo 4%  -->
            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                <Setter Property="Background" Value="#0A3F51B5" />
            </Trigger>

            <!--  Hover — Indigo 8%  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#143F51B5" />
            </MultiTrigger>

            <!--  Selected — Indigo 16%  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#293F51B5" />
                <!--
                    ⚠️ لا تضع BorderThickness هنا — لا يظهر على DataGridRow
                    الـ left border يتم في CellStyle أدناه (الخلية الأولى فقط)
                -->
                <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightForegroundBrush}" />
            </Trigger>

            <!--  Disabled  -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>

        </Style.Triggers>
    </Style>


    <!--
        ══════════════════════════════════════════════
        CELL STYLE
        ✅ Left border على الخلية الأولى عند التحديد
        ✅ Custom ControlTemplate لإزالة focus rectangle MDIX
        ══════════════════════════════════════════════
    -->
    <Style x:Key="BroadcastPro.DataGridCell" TargetType="DataGridCell">

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />

        <!--
            ✅ ControlTemplate مخصص:
            - يزيل الـ focus rectangle المزعج من MDIX
            - يمكّن Left Border على الخلية الأولى (عبر مشغّل مرتبط بـ IsSelected)
        -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border
                        x:Name="CellBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <!--  ✅ إزالة focus outline الافتراضي  -->
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>

            <!--  نص على الصف المحدد  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            </Trigger>
        </Style.Triggers>
    </Style>


    <!--
        ══════════════════════════════════════════════
        LEFT BORDER للصف المحدد — الحل الصحيح
        استخدم DataGridTemplateColumn كأول عمود
        أو استخدم هذا الـ Attached Style على العمود الأول
        ══════════════════════════════════════════════
    -->
    <!--
        في XAML الـ DataGrid، العمود الأول يأخذ هذا الـ CellStyle:

        <DataGrid.Columns>
            <DataGridTextColumn Header="..." Binding="..."
                CellStyle="{StaticResource BroadcastPro.DataGridCell.FirstColumn}" />
            ...
        </DataGrid.Columns>
    -->
    <Style
        x:Key="BroadcastPro.DataGridCell.FirstColumn"
        BasedOn="{StaticResource BroadcastPro.DataGridCell}"
        TargetType="DataGridCell">
        <Setter Property="FontSize" Value="15" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="BorderThickness" Value="3,0,0,0" />
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>


    <!--
        ══════════════════════════════════════════════
        DataGrid الرئيسي — يرجع إلى الستايلات بـ StaticResource
        ══════════════════════════════════════════════
    -->
    <Style
        x:Key="BroadcastProDataGrid"
        BasedOn="{StaticResource MaterialDesignDataGrid}"
        TargetType="{x:Type DataGrid}">

        <Setter Property="AlternationCount" Value="2" />
        <Setter Property="MinRowHeight" Value="50" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Regular" />

        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="materialDesign:DataGridAssist.CellPadding" Value="16,12" />
        <Setter Property="materialDesign:DataGridAssist.CornerRadius" Value="8" />

        <!--  ✅ Reference مستقل — لا inline styles  -->
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource BroadcastPro.DataGridColumnHeader}" />
        <Setter Property="RowStyle" Value="{StaticResource BroadcastPro.DataGridRow}" />
        <Setter Property="CellStyle" Value="{StaticResource BroadcastPro.DataGridCell}" />

        <Setter Property="materialDesign:ScrollViewerAssist.IgnorePadding" Value="True" />
    </Style>

</ResourceDictionary>