<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        ═══════════════════════════════════════════════════════════
        NavRail.Container — حاوية شريط التنقل الجانبي
        الاستخدام: Border في يمين MainWindow (DockPanel.Dock="Right" بسبب RTL)
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="NavRail.Container" TargetType="Border">
        <Setter Property="Width" Value="90" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        NavRail.Item — عنصر تنقل رئيسي في الشريط الجانبي (RadioButton)
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="NavRail.Item" TargetType="RadioButton">
        <Setter Property="Height" Value="64" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="GroupName" Value="NavRail" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <!--  مؤشر التحديد العمودي (يمين في RTL)  -->
                        <Border
                            x:Name="ActiveIndicator"
                            Width="4"
                            Height="24"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            CornerRadius="0,4,4,0" />
                        <!--  محتوى العنصر: أيقونة + نص  -->
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical">
                            <ContentPresenter
                                x:Name="IconContent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="ItemLabel"
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="{TemplateBinding FontSize}"
                                FontWeight="{TemplateBinding FontWeight}"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Tag}" />
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ActiveIndicator" Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter TargetName="ItemLabel" Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ActiveIndicator" Property="Background" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter TargetName="ItemLabel" Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter TargetName="ItemLabel" Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        NavRail.GroupItem — عنصر مجموعة قابل للتوسيع (RadioButton)
        مثل NavRail.Item لكن مع أيقونة Chevron
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="NavRail.GroupItem" TargetType="RadioButton">
        <Setter Property="Height" Value="64" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="GroupName" Value="NavRail" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <!--  مؤشر التحديد العمودي  -->
                        <Border
                            x:Name="ActiveIndicator"
                            Width="4"
                            Height="24"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            CornerRadius="0,4,4,0" />
                        <!--  Chevron أيقونة  -->
                        <materialDesign:PackIcon
                            x:Name="ChevronIcon"
                            Width="10"
                            Height="10"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Kind="ChevronDown"
                            Opacity="0.5"
                            RenderTransformOrigin="0.5,0.5">
                            <materialDesign:PackIcon.RenderTransform>
                                <RotateTransform Angle="0" />
                            </materialDesign:PackIcon.RenderTransform>
                        </materialDesign:PackIcon>
                        <!--  محتوى العنصر: أيقونة + نص  -->
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical">
                            <ContentPresenter
                                x:Name="IconContent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="ItemLabel"
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="{TemplateBinding FontSize}"
                                FontWeight="{TemplateBinding FontWeight}"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Tag}" />
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ActiveIndicator" Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter TargetName="ItemLabel" Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ActiveIndicator" Property="Background" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter TargetName="ItemLabel" Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter TargetName="ItemLabel" Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        NavRail.SubItem — عنصر فرعي داخل مجموعة (RadioButton)
        أصغر حجماً، بمسافة بداية لليسار
        GroupName منفصل (NavRailSub) ليكون RadioButton واحد فقط نشط
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="NavRail.SubItem" TargetType="RadioButton">
        <Setter Property="Height" Value="44" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="GroupName" Value="NavRailSub" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        NavRail.SectionHeader — عنوان مجموعة في الشريط الجانبي
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="NavRail.SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="8.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,8,0,2" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        NavRail.Divider — فاصل أفقي بين المجموعات
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="NavRail.Divider" TargetType="Separator">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,6" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource DividerBrush}" />
    </Style>
</ResourceDictionary>
