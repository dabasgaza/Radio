
<!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║                         TextBlock.xaml                                  ║
    ║           نظام Typography الموحّد — Material Design Type Scale           ║
    ║  المقياس:                                                                ║
    ║   Display  → 36sp   عناوين ضخمة (صفحات رئيسية، شاشة البداية)          ║
    ║   Headline → 26sp   عناوين القسم                                        ║
    ║   Title    → 18-14sp عنوان النافذة / الـ Card                           ║
    ║   Label    → 14sp   نص الأزرار والعلامات                               ║
    ║   Body     → 16/14/12sp النصوص الاعتيادية                              ║
    ║   Caption  → 12sp   نصوص توضيحية، تواريخ، ملاحظات                     ║
    ║   Overline → 11sp   تصنيفات ورؤوس جداول                                ║
    ║                                                                          ║
    ║  التبعيات: AppColors.xaml, AppFonts.xaml                                ║
    ║  الخطوط: يتم استخدام Font.Primary من AppFonts.xaml (Tajawal)           ║
    ╚══════════════════════════════════════════════════════════════════════════╝
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════
        DISPLAY — 36sp Light | للشاشات الفارغة والترحيب
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Display}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Light}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.Display}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        HEADLINE — 26sp Regular | عنوان القسم الرئيسي
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.Headline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Headline}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Regular}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.Headline}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  Bold variant للـ Headline على الخلفية الملونة (ColorZone)  -->
    <Style
        x:Key="Type.Headline.OnColor"
        BasedOn="{StaticResource Type.Headline}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        TITLE LARGE — 18sp Medium | عنوان النافذة / Dialog header
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.TitleLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.TitleLarge}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Medium}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.TitleLarge}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style
        x:Key="Type.TitleLarge.OnColor"
        BasedOn="{StaticResource Type.TitleLarge}"
        TargetType="TextBlock">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        TITLE MEDIUM — 14sp Medium | عناوين البطاقات والإحصائيات
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.TitleMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.TitleMedium}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Medium}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.TitleMedium}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        TITLE SMALL — 13sp Medium | عناوين الأقسام الفرعية
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.TitleSmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.TitleSmall}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Medium}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.TitleSmall}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        BODY LARGE — 13sp Regular | نص القراءة الرئيسي
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.BodyLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyMedium}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Regular}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.BodyLarge}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        BODY MEDIUM — 11sp Regular | النص الاعتيادي في الواجهة
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.BodyMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Regular}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.BodyMedium}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  نص صغير أساسي  -->
    <Style x:Key="Type.BodySmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Regular}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.BodySmall}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  نص ثانوي / مساعد  -->
    <Style
        x:Key="Type.BodyMedium.Secondary"
        BasedOn="{StaticResource Type.BodyMedium}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <!--  نص على خلفية ملونة  -->
    <Style
        x:Key="Type.BodyMedium.OnColor"
        BasedOn="{StaticResource Type.BodyMedium}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        LABEL — 11sp Medium | نص الأزرار والشرائح
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Label}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Medium}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.Label}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  Label للشريط والأقسام الجانبية  -->
    <Style
        x:Key="Type.Label.Section"
        BasedOn="{StaticResource Type.Label}"
        TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Section}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Opacity" Value="0.55" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        CAPTION — 10sp Regular | نصوص توضيحية، تواريخ، وصف الحالة
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Regular}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.Caption}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  Caption على خلفية ملونة  -->
    <Style
        x:Key="Type.Caption.OnColor"
        BasedOn="{StaticResource Type.Caption}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Opacity" Value="0.75" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        OVERLINE — 9sp Medium | رؤوس الجداول، التصنيفات
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.Overline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Overline}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Medium}" />
        <Setter Property="LineHeight" Value="{DynamicResource LineHeight.Overline}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        NUMERIC — أرقام الإحصاء في البطاقات
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.Numeric.Large" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Numeric.Large}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Type.Numeric.Medium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Numeric.Medium}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        CLOCK — ساعة الوقت الحقيقي في الـ Header
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.Clock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Clock}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        DATA GRID CELL TEXT — نص خلايا الجداول
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Type.DataGrid.Cell" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.DataGrid}" />
        <Setter Property="FontWeight" Value="Regular" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  نص الخلية الأولى (اسم السجل)  -->
    <Style
        x:Key="Type.DataGrid.CellPrimary"
        BasedOn="{StaticResource Type.DataGrid.Cell}"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.DataGrid}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

</ResourceDictionary>
