<!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║                          DataGrid.xaml                                  ║
    ║             جداول البيانات — WPF + MaterialDesignInXAML                 ║
    ║                                                                          ║
    ║  الأنواع:                                                                ║
    ║   • DataGrid.Main          — الجدول الرئيسي (يُستخدم في جميع Views)    ║
    ║   • DataGrid.ColumnHeader  — رأس العمود                                 ║
    ║   • DataGrid.Row           — صف البيانات                                ║
    ║   • DataGrid.Cell          — خلية البيانات                              ║
    ║   • DataGrid.Cell.First    — الخلية الأولى (مع مؤشر التحديد)           ║
    ║   • DataGrid.Cell.Center   — خلية توسيط (أرقام، حالات، إجراءات)        ║
    ║   • DataGrid.Cell.Actions  — خلية الأزرار (تعديل/حذف)                 ║
    ║                                                                          ║
    ║  التبعيات: AppColors.xaml                                                ║
    ╚══════════════════════════════════════════════════════════════════════════╝
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.ColumnHeader — رأس العمود
        WCAG AA: #1A237E (Indigo 800) على أبيض = 11.3:1 ✅
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="DataGrid.ColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>
                        <Border
                            x:Name="HeaderBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="0,0,0,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource PrimaryMainBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="DataGrid.ColumnHeader.Right"
        BasedOn="{StaticResource DataGrid.ColumnHeader}"
        TargetType="DataGridColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>

    <Style
        x:Key="DataGrid.ColumnHeader.Center"
        BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
        TargetType="DataGridColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>




    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.Row — صف البيانات
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="DataGrid.Row"
        BasedOn="{StaticResource MaterialDesignDataGridRow}"
        TargetType="DataGridRow">

        <Setter Property="MinHeight" Value="52" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />

        <Style.Triggers>
            <!--  صفوف متناوبة — Zebra Striping (باستخدام Brush آمن)  -->
            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource RowAlternateBrush}" />
            </Trigger>

            <!--  Hover على صف غير محدد (باستخدام Brush آمن)  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
            </MultiTrigger>

            <!--  صف محدد — لون خفيف مع الحفاظ على قراءة النص  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Trigger>

            <!--  صف معطّل  -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
                <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.Cell — خلية البيانات الأساسية
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="DataGrid.Cell" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeInput}" />

        <!--  Template مخصص يزيل focus rectangle المزعج  -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border
                        x:Name="CellBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <!--  إزالة focus outline  -->
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
            <!--  الحفاظ على لون النص عند التحديد  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.Cell.First — الخلية الأولى
        تُضاف لها مؤشر اليسار (RTL: يمين) عند التحديد
        الاستخدام: عمود الاسم / العنوان في كل جدول
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="DataGrid.Cell.First"
        BasedOn="{StaticResource DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="Medium" />

        <Style.Triggers>
            <!--  مؤشر أزرق على يمين الخلية عند تحديد الصف  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="BorderThickness" Value="0,0,3,0" />
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryMainBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.Cell.Center — خلية توسيط
        الاستخدام: أرقام، تواريخ، حالات، شرائح Chip
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="DataGrid.Cell.Center"
        BasedOn="{StaticResource DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="DataGrid.Cell.Left"
        BasedOn="{StaticResource DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="DataGrid.Cell.Right"
        BasedOn="{StaticResource DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.Cell.Actions — خلية أزرار الإجراءات
        الاستخدام: عمود "تعديل / حذف" في نهاية الجدول
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="DataGrid.Cell.Actions"
        BasedOn="{StaticResource DataGrid.Cell.Center}"
        TargetType="DataGridCell">
        <Setter Property="Padding" Value="8,0" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.Cell.Highlighted — خلية ملوّنة (مشروع / نظام ذو خلفية مزدوجة)
        الاستخدام: تمييز خلية معينة بلون Primary خفيف
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="DataGrid.Cell.Highlighted"
        BasedOn="{StaticResource DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        DataGrid.Main — الجدول الرئيسي الموحّد
        الاستخدام: جميع Views (برامج، حلقات، ضيوف، مستخدمين...)
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="DataGrid.Main"
        BasedOn="{StaticResource MaterialDesignDataGrid}"
        TargetType="{x:Type DataGrid}">

        <!--  الخصائص الوظيفية  -->
        <Setter Property="AlternationCount" Value="2" />
        <Setter Property="MinRowHeight" Value="52" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="CanUserReorderColumns" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />

        <!--  المظهر  -->
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0" />

        <!--  Material Design Assist  -->
        <Setter Property="materialDesign:DataGridAssist.CellPadding" Value="16,0" />
        <Setter Property="materialDesign:ScrollViewerAssist.IgnorePadding" Value="True" />

        <!--  ربط الستايلات المستقلة  -->
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource DataGrid.ColumnHeader}" />
        <Setter Property="RowStyle" Value="{StaticResource DataGrid.Row}" />
        <Setter Property="CellStyle" Value="{StaticResource DataGrid.Cell}" />

    </Style>

</ResourceDictionary>
