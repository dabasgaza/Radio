<!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║                          ListBox.xaml                                   ║
    ║             قوائم العرض — WPF + MaterialDesignInXAML                    ║
    ║  الأنواع:                                                                ║
    ║   • List.Default     — قائمة عرض بيانات عادية                          ║
    ║   • List.Navigation  — قائمة تنقل جانبية                               ║
    ║   • List.Selectable  — قائمة بتحديد مفرد                               ║
    ║   • List.MultiSelect — قائمة بتحديد متعدد                              ║
    ║   • ListBoxItem.Default — عنصر القائمة الأساسي                         ║
    ║   • ListBoxItem.Nav     — عنصر التنقل                                   ║
    ║                                                                          ║
    ║  التبعيات: AppColors.xaml                                                ║
    ╚══════════════════════════════════════════════════════════════════════════╝
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        ═══════════════════════════════════════════════════════════
        ListBoxItem.Default — عنصر القائمة الأساسي
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="ListBoxItem.Default" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border
                        x:Name="ItemBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverOverlayBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        ListBoxItem.Nav — عنصر التنقل الجانبي
        الاستخدام: القوائم الجانبية، الأقسام
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="ListBoxItem.Nav" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border
                        x:Name="NavBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <!--  خط التنشيط على اليمين (RTL)  -->
                            <Border
                                x:Name="ActiveIndicator"
                                Width="3"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Background="{StaticResource PrimaryMainBrush}"
                                CornerRadius="0,2,2,0"
                                Visibility="Collapsed" />
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource HoverOverlayBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryMainBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        List.Default — قائمة عرض بيانات عادية
        الاستخدام: قوائم عامة داخل البطاقات
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="List.Default" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ListBoxItem.Default}" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        List.Navigation — قائمة التنقل الجانبية
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="List.Navigation"
        BasedOn="{StaticResource List.Default}"
        TargetType="ListBox">
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ListBoxItem.Nav}" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        List.Selectable — قائمة بتحديد مفرد (مع إطار)
        الاستخدام: قوائم الفلترة، لوحات الاختيار
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="List.Selectable"
        BasedOn="{StaticResource List.Default}"
        TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        List.MultiSelect — قائمة تحديد متعدد
        ═══════════════════════════════════════════════════════════
    -->
    <Style
        x:Key="List.MultiSelect"
        BasedOn="{StaticResource List.Selectable}"
        TargetType="ListBox">
        <Setter Property="SelectionMode" Value="Multiple" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        Chip.Status — شرائح الحالة المتميزة (Border-based)
        الاستخدام: بديل لـ MaterialDesign:Chip لتجنب مشاكل الاقتطاع ودعم التدرجات
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="StatusChip.Base" TargetType="Border">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Height" Value="28" />
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  نسخة الـ RadioButton من ستايل الـ Chip  -->
    <Style x:Key="StatusChip.Radio" TargetType="RadioButton">
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="160" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="16">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="White" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="StatusChip.Planned"
        BasedOn="{StaticResource StatusChip.Base}"
        TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
    </Style>

    <Style
        x:Key="StatusChip.Executed"
        BasedOn="{StaticResource StatusChip.Base}"
        TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SeconderyGradientBrush}" />
    </Style>

    <Style
        x:Key="StatusChip.Published"
        BasedOn="{StaticResource StatusChip.Base}"
        TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SuccessGradientBrush}" />
    </Style>

    <Style
        x:Key="StatusChip.WebPublished"
        BasedOn="{StaticResource StatusChip.Base}"
        TargetType="Border">
        <Setter Property="Background" Value="{StaticResource InfoGradientBrush}" />
    </Style>

    <Style
        x:Key="StatusChip.Cancelled"
        BasedOn="{StaticResource StatusChip.Base}"
        TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
    </Style>

    <!--  ستايلات متوافقة مع التسميات القديمة لضمان عدم الكسر  -->
    <Style
        x:Key="Chip.Active"
        BasedOn="{StaticResource StatusChip.Published}"
        TargetType="Border" />
    <Style
        x:Key="Chip.Inactive"
        BasedOn="{StaticResource StatusChip.Planned}"
        TargetType="Border" />
    <Style
        x:Key="Chip.Warning"
        BasedOn="{StaticResource StatusChip.Executed}"
        TargetType="Border" />
    <Style
        x:Key="Chip.Error"
        BasedOn="{StaticResource StatusChip.Cancelled}"
        TargetType="Border" />
    <Style
        x:Key="Chip.Primary"
        BasedOn="{StaticResource StatusChip.WebPublished}"
        TargetType="Border" />

</ResourceDictionary>
