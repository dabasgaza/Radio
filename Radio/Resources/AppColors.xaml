<!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║                         AppColors.xaml                                  ║
    ║                 نظام الألوان والـ Design Tokens                          ║
    ║  المصدر: Material Design 3 + WCAG 2.1 AA                                ║
    ║  الثيم:  Indigo Primary / Light Blue Secondary / Light Mode              ║
    ╚══════════════════════════════════════════════════════════════════════════╝
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ═══════════════════════════════════════════════════════════
        1. BRAND PALETTE — الألوان الأساسية الثابتة
        ═══════════════════════════════════════════════════════════
    -->

    <!--  Primary — Indigo (Modern Premium Indigo)  -->
    <Color x:Key="Primary900Color">#1E1B4B</Color>
    <Color x:Key="Primary800Color">#312E81</Color>
    <Color x:Key="Primary700Color">#3730A3</Color>
    <Color x:Key="Primary600Color">#4F46E5</Color>
    <Color x:Key="Primary500Color">#6366F1</Color>
    <Color x:Key="Primary400Color">#818CF8</Color>
    <Color x:Key="Primary300Color">#A5B4FC</Color>
    <Color x:Key="Primary200Color">#C7D2FE</Color>
    <Color x:Key="Primary100Color">#E0E7FF</Color>
    <Color x:Key="Primary50Color">#EEF2F6</Color>

    <!--  Secondary — Teal/Cyan (Modern Premium Secondary)  -->
    <Color x:Key="Secondary700Color">#0F766E</Color>
    <Color x:Key="Secondary500Color">#14B8A6</Color>
    <Color x:Key="Secondary300Color">#5EEAD4</Color>
    <Color x:Key="Secondary100Color">#CCFBF1</Color>
    <Color x:Key="Secondary50Color">#F0FDFA</Color>

    <!--  Neutral — Grey Scale (Slate Grey)  -->
    <Color x:Key="Neutral900Color">#0F172A</Color>
    <Color x:Key="Neutral800Color">#1E293B</Color>
    <Color x:Key="Neutral700Color">#334155</Color>
    <Color x:Key="Neutral600Color">#475569</Color>
    <Color x:Key="Neutral400Color">#94A3B8</Color>
    <Color x:Key="Neutral300Color">#CBD5E1</Color>
    <Color x:Key="Neutral200Color">#E2E8F0</Color>
    <Color x:Key="Neutral100Color">#F1F5F9</Color>
    <Color x:Key="Neutral50Color">#F8FAFC</Color>

    <!--  Surface / Background  -->
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceVariantColor">#F1F5F9</Color>
    <Color x:Key="BackgroundColor">#F8FAFC</Color>

    <!--
        ═══════════════════════════════════════════════════════════
        2. SEMANTIC COLORS — ألوان الحالة والمعنى (MD3 Style)
        ═══════════════════════════════════════════════════════════
    -->

    <!--  Success — Emerald Green  -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="SuccessLightColor">#ECFDF5</Color>
    <Color x:Key="SuccessDarkColor">#065F46</Color>

    <!--  Warning — Amber/Orange  -->
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningLightColor">#FFFBEB</Color>
    <Color x:Key="WarningDarkColor">#92400E</Color>

    <!--  Error — Rose Red  -->
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="ErrorLightColor">#FEF2F2</Color>
    <Color x:Key="ErrorDarkColor">#991B1B</Color>

    <!--  Info — Sky Blue  -->
    <Color x:Key="InfoColor">#0EA5E9</Color>
    <Color x:Key="InfoLightColor">#F0F9FF</Color>

    <!--  On-Air — Live Broadcast Red  -->
    <Color x:Key="OnAirColor">#F43F5E</Color>
    <Color x:Key="OnAirGlowColor">#FDA4AF</Color>

    <!--
        ═══════════════════════════════════════════════════════════
        3. ROLE-BASED BRUSHES — الفراشي المعيارية
        ═══════════════════════════════════════════════════════════
    -->

    <!--  Primary Brushes  -->
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource Primary800Color}" />
    <SolidColorBrush x:Key="PrimaryMainBrush" Color="{StaticResource Primary600Color}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource Primary400Color}" />
    <SolidColorBrush x:Key="PrimaryXLightBrush" Color="{StaticResource Primary50Color}" />

    <!--  Secondary Brushes  -->
    <SolidColorBrush x:Key="SecondaryMainBrush" Color="{StaticResource Secondary500Color}" />
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="{StaticResource Secondary100Color}" />

    <!--  Surface / Background Brushes  -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}" />
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource BackgroundColor}" />

    <!--  Text Brushes  -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource Neutral900Color}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Neutral700Color}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource Neutral400Color}" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextHintBrush" Color="{StaticResource Neutral600Color}" />
    <SolidColorBrush
        x:Key="OverlayScrimBrush"
        Opacity="0.45"
        Color="Black" />

    <!--  Border / Divider Brushes  -->
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource Neutral300Color}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource Primary600Color}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Neutral200Color}" />

    <!--  State Brushes  -->
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#0F6366F1" />
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#1F6366F1" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource Primary50Color}" />
    <SolidColorBrush x:Key="FocusRingBrush" Color="{StaticResource Primary400Color}" />

    <!--  MD3 Aliases for Navigation System  -->
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource Primary50Color}" />
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="{StaticResource Primary800Color}" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource Neutral700Color}" />
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="{StaticResource Secondary100Color}" />
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="{StaticResource Secondary500Color}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceColor}" />

    <!--  Semantic Brushes  -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="ErrorLightBrush" Color="{StaticResource ErrorLightColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}" />

    <!--  On-Air Brushes  -->
    <SolidColorBrush x:Key="OnAirBrush" Color="{StaticResource OnAirColor}" />
    <SolidColorBrush x:Key="OnAirGlowBrush" Color="{StaticResource OnAirGlowColor}" />


    <!--  Row State Brushes (للجداول)  -->
    <SolidColorBrush x:Key="RowAlternateBrush" Color="#F8FAFC" />
    <!--  خلفية صفوف متناوبة خفيفة جداً  -->
    <SolidColorBrush x:Key="RowHoverBrush" Color="#EEF2F6" />
    <!--  خلفية عند تمرير الماوس (نفس Primary50 تقريباً)  -->

    <SolidColorBrush x:Key="Neutral50Brush" Color="{StaticResource Neutral50Color}" />

    <!--
        ═══════════════════════════════════════════════════════════
        4. GRADIENT BRUSHES — التدرجات الموحّدة
        ═══════════════════════════════════════════════════════════
    -->

    <!--  Gradient أساسي للهيدر والـ ColorZone (موجود مسبقاً)  -->
    <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="{StaticResource Primary800Color}" />
        <GradientStop Offset="1.0" Color="{StaticResource Primary500Color}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGreenGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="{StaticResource SuccessColor}" />
        <GradientStop Offset="1.0" Color="{StaticResource SuccessColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SeconderyGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="{StaticResource Secondary700Color}" />
        <GradientStop Offset="1.0" Color="{StaticResource Secondary500Color}" />
    </LinearGradientBrush>

    <!--  تدرج النجاح (الأخضر)  -->
    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="#43A047" />
        <GradientStop Offset="1.0" Color="#2E7D32" />
    </LinearGradientBrush>

    <!--  تدرج المعلومات/النشر (الأزرق)  -->
    <LinearGradientBrush x:Key="InfoGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="#42A5F5" />
        <GradientStop Offset="1.0" Color="#1976D2" />
    </LinearGradientBrush>

    <!--  ═════════════════════ DIALOG HEADER GRADIENTS ═════════════════════  -->

    <!--
        Dialog Header — الأساسي (Primary)
        الاستخدام: حوارات الإجراءات العامة (حفظ، تعديل، تأكيد)
        ملاحظة: أغمق من الهيدر الرئيسي ليعطي إحساس بالتركيز والأهمية
    -->
    <LinearGradientBrush x:Key="DialogHeaderPrimaryBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Offset="0.0" Color="{StaticResource Primary900Color}" />
        <GradientStop Offset="1.0" Color="{StaticResource Primary600Color}" />
    </LinearGradientBrush>

    <!--
        Dialog Header — المعلوماتي (Info Blend)
        الاستخدام: حوارات إظهار التفاصيل، المساعدة، أو الإشعارات
        ملاحظة: يدمج بين الـ Indigo والـ Light Blue لإعطاء شعور بالمعلوماتية والهدوء
    -->
    <LinearGradientBrush x:Key="DialogHeaderInfoBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Offset="0.0" Color="{StaticResource Primary700Color}" />
        <GradientStop Offset="1.0" Color="{StaticResource Secondary500Color}" />
    </LinearGradientBrush>

    <!--
        Dialog Header — الناعم (Subtle)
        الاستخدام: حوارات الإعدادات أو النوافذ المنبثقة الثانوية
        ملاحظة: تدرج أفقي خفيف جداً باستخدام درجات الـ Primary المتوسطة
    -->
    <LinearGradientBrush x:Key="DialogHeaderSubtleBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Offset="0.0" Color="{StaticResource Primary600Color}" />
        <GradientStop Offset="1.0" Color="{StaticResource Primary400Color}" />
    </LinearGradientBrush>

    <!--
        Dialog Header — التأكيد/الحذف (Danger)
        الاستخدام: حوارات حذف البيانات، أو التحذيرات المهمة
        ملاحظة: يعتمد على ألوان الـ Error المعرّفة لديك لتنبيه المستتبار للمخاطرة
    -->
    <LinearGradientBrush x:Key="DialogHeaderDangerBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Offset="0.0" Color="{StaticResource ErrorDarkColor}" />
        <GradientStop Offset="1.0" Color="{StaticResource ErrorColor}" />
    </LinearGradientBrush>

    <!--  ═════════════════════ END DIALOG GRADIENTS ═════════════════════  -->


    <!--  Gradient خفيف للبطاقات والخلفيات الفرعية (موجود مسبقاً)  -->
    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="{StaticResource Primary50Color}" />
        <GradientStop Offset="1.0" Color="{StaticResource Secondary50Color}" />
    </LinearGradientBrush>
    <!--
        ═══════════════════════════════════════════════════════════
        5. ELEVATION SHADOWS — ظلال الطبقات
        ═══════════════════════════════════════════════════════════
    -->

    <!--
        توجيه: استخدم materialDesign:ElevationAssist.Elevation من MDIX
        Dp0 → لا ظل     | Dp1 → بطاقة مسطحة
        Dp2 → بطاقة عادية | Dp3 → بطاقة رئيسية
        Dp4 → حوار / نافذة فرعية
    -->

    <!--
        ═══════════════════════════════════════════════════════════
        6. SPACING & RADIUS TOKENS — الأبعاد والزوايا
        ═══════════════════════════════════════════════════════════
    -->

    <CornerRadius x:Key="RadiusSmall">8</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">12</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">24</CornerRadius>
    <CornerRadius x:Key="RadiusFull">32</CornerRadius>

    <Thickness x:Key="SpacingXSmall">4</Thickness>
    <Thickness x:Key="SpacingSmall">8</Thickness>
    <Thickness x:Key="SpacingMedium">16</Thickness>
    <Thickness x:Key="SpacingLarge">24</Thickness>
    <Thickness x:Key="SpacingXLarge">32</Thickness>

    <!--  الخطوط والأحجام: Resources/AppFonts.xaml  -->

</ResourceDictionary>
