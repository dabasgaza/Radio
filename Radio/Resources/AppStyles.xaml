
<!--  AppStyles.xaml  -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">


    <!--  ═══════════ Global Font Settings — AppFonts.xaml ═══════════  -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
    </Style>
    <Style TargetType="{x:Type Control}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
    </Style>

    <!--  ═══════════ Typography ═══════════  -->
    <Style x:Key="HeadlineLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Headline}" />
        <Setter Property="FontWeight" Value="Regular" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
    </Style>
    <Style x:Key="TitleLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.TitleLarge}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
    </Style>
    <Style x:Key="BodyMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
    </Style>
    <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
    </Style>

    <!--  ═══════════ Buttons ═══════════  -->
    <Style
        x:Key="PrimaryActionButton"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
        <Setter Property="Height" Value="40" />
    </Style>

    <Style
        x:Key="DestructiveOutlinedButton"
        BasedOn="{StaticResource MaterialDesignOutlinedButton}"
        TargetType="Button">
        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
    </Style>

    <!--  ═══════════ ComboBoxes ═══════════  -->

    <Style
        x:Key="BroadcastComboBox"
        BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"
        TargetType="ComboBox">

        <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />

        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
        <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="12" />
        <Setter Property="materialDesign:TextFieldAssist.HasLeadingIcon" Value="True" />

        <Setter Property="VerticalContentAlignment" Value="Center" />

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  ═══════════ DatePicker ═══════════  -->

    <Style
        x:Key="BroadcastDatePicker"
        BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}"
        TargetType="DatePicker">

        <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />

        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
        <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="12" />
        <Setter Property="materialDesign:TextFieldAssist.HasLeadingIcon" Value="True" />
        <Setter Property="materialDesign:TextFieldAssist.LeadingIcon" Value="CalendarMonthOutline" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True" />

        <Setter Property="VerticalContentAlignment" Value="Center" />

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1" />
                <Setter Property="BorderThickness" Value="2" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  ═══════════ Cancel / Close Flat Button (تصميم هادئ) ═══════════  -->
    <Style
        x:Key="CancelFlatButton"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Label}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <!--  عند التمرير: خلفية رمادية شبحية جداً بدلاً من الأحمر  -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource MaterialDesignDivider}" />
            </Trigger>
            <!--  عند الضغط: رمادي أقلي قليلاً لإعطاء إحساس بالنقر  -->
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#E0E0E0" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--  ═══════════ TextBox ═══════════  -->
    <Style
        x:Key="BroadcastTextBox"
        BasedOn="{StaticResource MaterialDesignFilledTextBox}"
        TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
        <Setter Property="materialDesign:TextFieldAssist.HasOutlinedTextField" Value="True" />
        <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <!--  الحشوة الداخلية لجعل الحقل أوسع وأريح  -->
        <Setter Property="Padding" Value="12" />
        <!--  إزالة الحد السفلي المزدوج الافتراضي لجعله أنظف  -->
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True" />
    </Style>


    <!--  ═══════════ Card ═══════════  -->
    <Style x:Key="BroadcastCard" TargetType="materialDesign:Card">
        <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
        <Setter Property="materialDesign:ShadowAssist.Darken" Value="True" />
    </Style>


    <!--  ═══════════ On-Air Critical Button with Pulse ═══════════  -->
    <Style
        x:Key="BtnOnAir"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource OnAirBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!--  الحلقة المتحركة (Pulse Ring)  -->
                        <Ellipse
                            x:Name="PulseRing"
                            Width="140"
                            Height="68"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.6"
                            Stroke="{DynamicResource OnAirBrush}"
                            StrokeThickness="2">
                            <Ellipse.RenderTransform>
                                <ScaleTransform CenterX="70" CenterY="34" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <!--  زر البث الحقيقي  -->
                        <Border
                            x:Name="ButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  تشغيل الأنيميشن بمجرد تحميل الزر  -->
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        AutoReverse="True"
                                        Storyboard.TargetName="PulseRing"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                        From="1"
                                        To="1.3"
                                        Duration="0:0:1.5" />
                                    <DoubleAnimation
                                        AutoReverse="True"
                                        Storyboard.TargetName="PulseRing"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                        From="1"
                                        To="1.3"
                                        Duration="0:0:1.5" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="PulseRing"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0.6"
                                        To="0"
                                        Duration="0:0:1.5" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PulseRing" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>