
<!--
    AppStyles.xaml
    Consolidated — duplicate and misplaced styles have been removed.
    
    Removed (duplicates of named styles in other ResourceDictionary files):
    • HeadlineLarge       → use Type.Headline       (TextBlock.xaml)
    • TitleLarge          → use Type.TitleLarge      (TextBlock.xaml)
    • BodyMedium          → use Type.BodyMedium      (TextBlock.xaml)
    • DataGridTextStyle   → use Type.DataGrid.Cell   (TextBlock.xaml)
    • PrimaryActionButton → use Btn.Primary          (Buttons.xaml)
    • DestructiveOutlinedButton → use Btn.DangerOutlined (Buttons.xaml)
    • CancelFlatButton    → use Btn.Cancel           (Buttons.xaml)
    • BtnOnAir            → use Btn.OnAir            (Buttons.xaml)
    • BroadcastComboBox   → moved to ComboBox.xaml
    • BroadcastDatePicker → moved to DateTimePicker.xaml
    • BroadcastTextBox    → moved to TextBox.xaml
    • BroadcastCard       → moved to Cards.xaml
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">


    <!--  ═══════════ Global Font Settings — AppFonts.xaml ═══════════  -->
    <!--  أنماط ضمنية — تعيين الخط الافتراضي لجميع العناصر  -->
    <!--
        Foreground يُورث من UserControl/Window (TextPrimaryBrush) ولا نضبطه هنا
        حتى لا نغلب Foreground المخصص للأزرار والحقول
    -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
    </Style>
    <Style TargetType="{x:Type Control}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Input}" />
    </Style>

</ResourceDictionary>
