    <!--  ═══════════ Card ═══════════  -->
    <Style x:Key="BroadcastCard" TargetType="materialDesign:Card">
        <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="8"
                    Opacity="0.08"
                    ShadowDepth="2"
                    Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>


    <!--  ═══════════ On-Air Critical Button with Pulse ═══════════  -->
    <Style
        x:Key="BtnOnAir"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource OnAirBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!--  الحلقة المتحركة (Pulse Ring)  -->
                        <Ellipse
                            x:Name="PulseRing"
                            Width="140"
                            Height="68"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.6"
                            Stroke="{DynamicResource OnAirBrush}"
                            StrokeThickness="2">
                            <Ellipse.RenderTransform>
                                <ScaleTransform CenterX="70" CenterY="34" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <!--  زر البث الحقيقي  -->
                        <Border
                            x:Name="ButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  تشغيل الأنيميشن بمجرد تحميل الزر  -->
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        AutoReverse="True"
                                        Storyboard.TargetName="PulseRing"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                        From="1"
                                        To="1.3"
                                        Duration="0:0:1.5" />
                                    <DoubleAnimation
                                        AutoReverse="True"
                                        Storyboard.TargetName="PulseRing"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                        From="1"
                                        To="1.3"
                                        Duration="0:0:1.5" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="PulseRing"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0.6"
                                        To="0"
                                        Duration="0:0:1.5" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PulseRing" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>