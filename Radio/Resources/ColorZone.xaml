<!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║                         ColorZone.xaml                                  ║
    ║      مناطق الألوان وترويسات النوافذ — MaterialDesignInXAML              ║
    ║                                                                          ║
    ║  الأنواع:                                                                ║
    ║   • Zone.Header.Primary  — ترويسة أساسية (Indigo) لجميع Views          ║
    ║   • Zone.Header.Dark     — ترويسة داكنة (Indigo 800) للنوافذ الحوارية  ║
    ║   • Zone.Header.Neutral  — ترويسة محايدة (BlueGrey) للنوافذ الثانوية  ║
    ║   • Zone.Banner          — شريط إعلاني / تنبيه أعلى الصفحة            ║
    ║   • Header.App           — ترويسة التطبيق الرئيسية (MainWindow)        ║
    ║   • Header.TabBar        — شريط التبويبات                              ║
    ║   • Header.StatusBar     — شريط الحالة السفلي                          ║
    ║                                                                          ║
    ║  التبعيات: AppColors.xaml                                                ║
    ╚══════════════════════════════════════════════════════════════════════════╝
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        ═══════════════════════════════════════════════════════════
        Zone.Header.Primary — ترويسة أساسية موحّدة لجميع Views
        اللون: Indigo 800 → Indigo 500 (Gradient)
        الاستخدام: ProgramsView, GuestsView, UsersView...
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Zone.Header.Primary" TargetType="materialDesign:ColorZone">
        <Setter Property="Padding" Value="30,22" />
        <Setter Property="Mode" Value="Custom" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0.0" Color="{StaticResource Primary800Color}" />
                    <GradientStop Offset="1.0" Color="{StaticResource Primary500Color}" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ===========================================================
        Zone.Header.Primary — ترويسة أساسية موحّدة لجميع Views
        ===========================================================
    -->

    <Style x:Key="Zone.Header.Secondary" TargetType="materialDesign:ColorZone">
        <Setter Property="Padding" Value="30,22" />
        <Setter Property="Mode" Value="Custom" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0.0" Color="{StaticResource Secondary700Color}" />
                    <GradientStop Offset="1.0" Color="{StaticResource Secondary500Color}" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        Zone.Header.Dark — ترويسة داكنة للنوافذ الحوارية
        اللون: Indigo 900 → Indigo 700
        الاستخدام: DialogForm headers (ProgramFormDialog...)
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Zone.Header.Dark" TargetType="materialDesign:ColorZone">
        <Setter Property="Padding" Value="24,20" />
        <Setter Property="Mode" Value="Custom" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0.0" Color="{StaticResource Primary900Color}" />
                    <GradientStop Offset="1.0" Color="{StaticResource Primary700Color}" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        Zone.Header.Neutral — ترويسة محايدة
        اللون: BlueGrey (لا ينافس Indigo الأساسي)
        الاستخدام: نوافذ مساعدة كـ ExecutionLogDialog, ConcurrencyDialog
        ملاحظة: استخدم هذا بدلاً من #455A64 و #37474F المتناثرة
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Zone.Header.Neutral" TargetType="materialDesign:ColorZone">
        <Setter Property="Padding" Value="24,20" />
        <Setter Property="Mode" Value="Custom" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0.0" Color="#37474F" />
                    <GradientStop Offset="1.0" Color="#546E7A" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>


    <!--
        ================================================
        شريط أخضر متدرج
        ================================================
    -->

    <Style x:Key="Zone.Header.Green" TargetType="materialDesign:ColorZone">
        <Setter Property="Padding" Value="24,20" />
        <Setter Property="Mode" Value="Custom" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0.0" Color="{StaticResource SuccessDarkColor}" />
                    <GradientStop Offset="1.0" Color="{StaticResource SuccessColor}" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        Zone.Banner — شريط إعلاني ملوّن خفيف
        الاستخدام: تنبيهات، إشعارات، رسائل على مستوى الصفحة
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Zone.Banner.Info" TargetType="materialDesign:ColorZone">
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="Mode" Value="Custom" />
        <Setter Property="Foreground" Value="{StaticResource InfoBrush}" />
        <Setter Property="Background" Value="{StaticResource InfoLightBrush}" />
    </Style>

    <Style x:Key="Zone.Banner.Warning" TargetType="materialDesign:ColorZone">
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="Mode" Value="Custom" />
        <Setter Property="Foreground" Value="{StaticResource WarningDarkColor}" />
        <Setter Property="Background" Value="{StaticResource WarningLightBrush}" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        Header.App — ترويسة التطبيق الرئيسية
        الاستخدام: Border في قمة MainWindow
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Header.App" TargetType="Border">
        <Setter Property="Height" Value="56" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        Header.TabBar — شريط التبويبات الأفقية
        الاستخدام: Border تحت الترويسة مباشرةً
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Header.TabBar" TargetType="Border">
        <Setter Property="Height" Value="56" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="24,8" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        Header.StatusBar — الشريط السفلي (Bottom Bar)
        الاستخدام: Border في أسفل MainWindow (ON AIR + خروج)
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="Header.StatusBar" TargetType="Border">
        <Setter Property="Height" Value="64" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        AppLogo.Badge — شارة الشعار في الترويسة
        الاستخدام: المربع الأزرق مع أيقونة RadioTower
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="AppLogo.Badge" TargetType="Border">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource PrimaryMainBrush}" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        ClockDisplay — حاوية ساعة الوقت الحقيقي
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="ClockDisplay" TargetType="Border">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Background" Value="{StaticResource BackgroundColor}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════
        UserAvatar — دائرة صورة/أيقونة المستخدم
        ═══════════════════════════════════════════════════════════
    -->
    <Style x:Key="UserAvatar" TargetType="Border">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="{StaticResource PrimaryXLightBrush}" />
    </Style>

</ResourceDictionary>
