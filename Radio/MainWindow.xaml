<mah:MetroWindow
    x:Class="Radio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بث برو | نظام إدارة سير العمل"
    Width="1280"
    Height="800"
    Background="#0C0C0F"
    FlowDirection="RightToLeft"
    FontFamily="Hacen Tunisia"
    GlowBrush="#00D4FF"
    ShowTitleBar="False"
    TextElement.Foreground="#EAEAEA"
    TitleBarHeight="0"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <materialDesign:DialogHost DialogTheme="Inherit" Identifier="RootDialog">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <!--  Sidebar أوسع قليلاً للإحساس بالفخامة  -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  ====================== SIDEBAR ======================  -->
            <Border
                Grid.Column="0"
                Background="#121216"
                CornerRadius="0,12,12,0">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="30"
                        Direction="0"
                        Opacity="0.4"
                        ShadowDepth="5"
                        Color="#00D4FF" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  User Header - Glass + Gradient  -->
                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,20"
                        CornerRadius="0,0,16,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1F1F26" />
                                <GradientStop Offset="1" Color="#16161B" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel Margin="28,35,28,28" HorizontalAlignment="Center">
                            <Grid HorizontalAlignment="Center">
                                <Ellipse
                                    Width="88"
                                    Height="88"
                                    Fill="#1F1F26"
                                    Stroke="#00D4FF"
                                    StrokeThickness="2.5" />
                                <Ellipse
                                    Width="80"
                                    Height="80"
                                    Fill="#25252D" />
                                <materialDesign:PackIcon
                                    Width="46"
                                    Height="46"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#00D4FF"
                                    Kind="RadioTower" />
                            </Grid>

                            <TextBlock
                                x:Name="TxtUserFullName"
                                Margin="0,20,0,6"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#FFFFFF"
                                Text="اسم المستخدم"
                                TextAlignment="Center" />

                            <materialDesign:Chip
                                x:Name="ChipRole"
                                Padding="20,7"
                                Background="#2A2A32"
                                BorderBrush="#00D4FF"
                                BorderThickness="1"
                                Content="مدير النظام"
                                FontWeight="Medium"
                                Foreground="#00E0FF" />
                        </StackPanel>
                    </Border>

                    <!--  Menu  -->
                    <ScrollViewer
                        Grid.Row="1"
                        Margin="12,0,12,10"
                        VerticalScrollBarVisibility="Auto">
                        <ListBox
                            x:Name="MenuListBox"
                            FontSize="15.5"
                            SelectionChanged="MenuListBox_SelectionChanged"
                            Style="{StaticResource MaterialDesignNavigationListBox}">

                            <TextBlock
                                Margin="24,18,24,10"
                                FontSize="12.5"
                                FontWeight="DemiBold"
                                Foreground="#9999A8"
                                Text="البث والعمليات" />

                            <!--  Items مع ارتفاع أكبر ومسافات أفضل  -->
                            <ListBoxItem
                                x:Name="MenuHome"
                                Height="56"
                                IsSelected="True"
                                Tag="Home">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#00D4FF"
                                        Kind="ViewDashboard" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="لوحة التحكم" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuPrograms"
                                Height="56"
                                Tag="Programs">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#FF9E00"
                                        Kind="Television" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="إدارة البرامج" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuEpisodes"
                                Height="56"
                                Tag="Episodes">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#4FC3F7"
                                        Kind="MoviePlay" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="سجل الحلقات" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuGuests"
                                Height="56"
                                Tag="Guests">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#66DE93"
                                        Kind="AccountGroup" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="قاعدة الضيوف" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuCorrespondents"
                                Height="56"
                                Tag="Correspondents">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#FFEB3B"
                                        Kind="MapMarkerRadius" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="المراسلين والتغطيات" />
                                </StackPanel>
                            </ListBoxItem>

                            <Separator Margin="24,28,24,18" Opacity="0.18" />

                            <TextBlock
                                Margin="24,10,24,10"
                                FontSize="12.5"
                                FontWeight="DemiBold"
                                Foreground="#9999A8"
                                Text="إدارة النظام" />

                            <ListBoxItem
                                x:Name="MenuUsers"
                                Height="56"
                                Tag="Users">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#BA68C8"
                                        Kind="AccountMultiple" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="المستخدمين" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuPermissions"
                                Height="56"
                                Tag="Permissions">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#F06292"
                                        Kind="ShieldKey" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="مصفوفة الصلاحيات" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuReports"
                                Height="56"
                                Tag="Reports">
                                <StackPanel Margin="16,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="27"
                                        Height="27"
                                        Margin="8,0,22,0"
                                        Foreground="#FFD54F"
                                        Kind="ChartBar" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Medium"
                                        Text="التقارير والإحصائيات" />
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </ScrollViewer>

                    <!--  Logout  -->
                    <Button
                        Grid.Row="2"
                        Height="60"
                        Margin="24,12"
                        Background="Transparent"
                        BorderBrush="#FF5252"
                        BorderThickness="1.5"
                        Click="BtnLogout_Click"
                        Foreground="#FF6B6B"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="26"
                                Height="26"
                                Margin="0,0,14,0"
                                Kind="Logout" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="تسجيل الخروج" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  ====================== MAIN AREA ======================  -->
            <DockPanel Grid.Column="1">

                <!--  Header أكثر أناقة  -->
                <materialDesign:ColorZone
                    Padding="32,22"
                    Background="#16161B"
                    DockPanel.Dock="Top"
                    Mode="PrimaryMid">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="36"
                                Height="36"
                                Foreground="#00D4FF"
                                Kind="RadioTower" />
                            <TextBlock
                                Margin="20,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="23"
                                FontWeight="Black"
                                Foreground="#FFFFFF"
                                Text="بث برو" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="23"
                                FontWeight="Light"
                                Foreground="#888899"
                                Text="نظام إدارة البث" />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Border
                                Padding="18,9"
                                Background="#1F1F26"
                                CornerRadius="12">
                                <TextBlock
                                    x:Name="TxtClock"
                                    FontSize="17.5"
                                    FontWeight="Medium"
                                    Foreground="#B0B0C0"
                                    Text="00:00:00" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </materialDesign:ColorZone>

                <!--  Content  -->
                <Grid Background="#0C0C0F">
                    <ContentControl x:Name="MainContentArea" Margin="36" />

                    <materialDesign:Snackbar
                        x:Name="MainSnackbar"
                        Margin="0,0,0,40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        MessageQueue="{materialDesign:MessageQueue}" />
                </Grid>
            </DockPanel>
        </Grid>
    </materialDesign:DialogHost>
</mah:MetroWindow>