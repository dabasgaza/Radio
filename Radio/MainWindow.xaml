<mah:MetroWindow
    x:Class="Radio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بث برو | نظام إدارة سير العمل"
    Width="1280"
    Height="800"
    Background="#080810"
    FlowDirection="RightToLeft"
    FontFamily="Hacen Tunisia"
    GlowBrush="#7C3AED"
    ShowTitleBar="False"
    TextElement.Foreground="#EAEAEA"
    TitleBarHeight="0"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <mah:MetroWindow.Resources>

        <!--
            ═══════════════════════════════════════════════
            STYLES: Modern Sidebar Menu Item
            ═══════════════════════════════════════════════
        -->
        <Style x:Key="SideNavItem" TargetType="ListBoxItem">
            <Setter Property="Height" Value="58" />
            <Setter Property="Margin" Value="10,3,10,3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="Root"
                            Background="Transparent"
                            CornerRadius="14">
                            <Grid>
                                <ContentPresenter Margin="0" />
                                <!--  Accent left bar  -->
                                <Border
                                    x:Name="AccentBar"
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    CornerRadius="0,4,4,0"
                                    Opacity="0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A1A2A" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#1E1040" />
                                            <GradientStop Offset="1" Color="#0D0D1A" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1" />
                                <Setter TargetName="AccentBar" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#7C3AED" />
                                            <GradientStop Offset="1" Color="#00D4FF" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Section Label Style  -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="22,20,22,8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#4A4A6A" />

        </Style>

    </mah:MetroWindow.Resources>

    <materialDesign:DialogHost DialogTheme="Inherit" Identifier="RootDialog">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--
                ═══════════════════════════════════════════════
                SIDEBAR — Glassmorphism Dark
                ═══════════════════════════════════════════════
            -->
            <Border
                Grid.Column="0"
                ClipToBounds="True"
                CornerRadius="0,20,20,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#0E0E1C" />
                        <GradientStop Offset="0.5" Color="#0B0B17" />
                        <GradientStop Offset="1" Color="#0D0D1A" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="40"
                        Direction="0"
                        Opacity="0.5"
                        ShadowDepth="8"
                        Color="#7C3AED" />
                </Border.Effect>

                <!--  Decorative blurred orb top  -->
                <Grid>
                    <Ellipse
                        Width="260"
                        Height="260"
                        Margin="0,-100,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Opacity="0.07">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Offset="0" Color="#7C3AED" />
                                <GradientStop Offset="1" Color="Transparent" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  ── USER HEADER ──  -->
                        <Border
                            Grid.Row="0"
                            Margin="16,28,16,16"
                            CornerRadius="20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#1A1040" />
                                    <GradientStop Offset="1" Color="#12121E" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#7C3AED" />
                                    <GradientStop Offset="1" Color="#00D4FF" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>

                            <StackPanel Margin="20,24,20,24" HorizontalAlignment="Center">

                                <!--  Avatar Ring  -->
                                <Grid HorizontalAlignment="Center">
                                    <!--  Outer glow ring  -->
                                    <Ellipse Width="96" Height="96">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Offset="0.7" Color="Transparent" />
                                                <GradientStop Offset="1" Color="#7C3AED" />
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <!--  Gradient border ring  -->
                                    <Ellipse Width="90" Height="90">
                                        <Ellipse.Stroke>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#7C3AED" />
                                                <GradientStop Offset="1" Color="#00D4FF" />
                                            </LinearGradientBrush>
                                        </Ellipse.Stroke>
                                        <Ellipse.StrokeThickness>2.5</Ellipse.StrokeThickness>
                                        <Ellipse.Fill>Transparent</Ellipse.Fill>
                                    </Ellipse>
                                    <!--  Avatar fill  -->
                                    <Ellipse Width="82" Height="82">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#1E1040" />
                                                <GradientStop Offset="1" Color="#181828" />
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <materialDesign:PackIcon
                                        Width="46"
                                        Height="46"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Kind="RadioTower">
                                        <materialDesign:PackIcon.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#7C3AED" />
                                                <GradientStop Offset="1" Color="#00D4FF" />
                                            </LinearGradientBrush>
                                        </materialDesign:PackIcon.Foreground>
                                    </materialDesign:PackIcon>
                                    <!--  Online dot  -->
                                    <Ellipse
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,4,4"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Fill="#22C55E">
                                        <Ellipse.Effect>
                                            <DropShadowEffect
                                                BlurRadius="8"
                                                Opacity="0.9"
                                                ShadowDepth="0"
                                                Color="#22C55E" />
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>

                                <TextBlock
                                    x:Name="TxtUserFullName"
                                    Margin="0,18,0,4"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFFFF"
                                    Text="اسم المستخدم"
                                    TextAlignment="Center" />

                                <!--  Role Badge  -->
                                <Border
                                    Padding="18,6"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#3B1FA8" />
                                            <GradientStop Offset="1" Color="#0E7490" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <materialDesign:Chip
                                        x:Name="ChipRole"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Content="مدير النظام"
                                        FontSize="12.5"
                                        FontWeight="Bold"
                                        Foreground="#E0F2FE" />
                                </Border>

                            </StackPanel>
                        </Border>

                        <!--  ── NAVIGATION MENU ──  -->
                        <ScrollViewer
                            Grid.Row="1"
                            Margin="0,4,0,4"
                            VerticalScrollBarVisibility="Hidden">
                            <ListBox
                                x:Name="MenuListBox"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="15"
                                SelectionChanged="MenuListBox_SelectionChanged">

                                <!--  Group: البث  -->
                                <TextBlock Style="{StaticResource SectionLabel}" Text="● البث والعمليات" />

                                <ListBoxItem
                                    x:Name="MenuHome"
                                    IsSelected="True"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Home">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#1E1040" />
                                                    <GradientStop Offset="1" Color="#0A1628" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#7C3AED"
                                                Kind="ViewDashboard" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="لوحة التحكم" />
                                    </Grid>
                                </ListBoxItem>

                                <ListBoxItem
                                    x:Name="MenuPrograms"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Programs">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#291200" />
                                                    <GradientStop Offset="1" Color="#1A0A00" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#FF9E00"
                                                Kind="Television" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="إدارة البرامج" />
                                    </Grid>
                                </ListBoxItem>

                                <ListBoxItem
                                    x:Name="MenuEpisodes"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Episodes">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#0A1E2A" />
                                                    <GradientStop Offset="1" Color="#061218" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#4FC3F7"
                                                Kind="MoviePlay" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="سجل الحلقات" />
                                    </Grid>
                                </ListBoxItem>

                                <ListBoxItem
                                    x:Name="MenuGuests"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Guests">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#062A14" />
                                                    <GradientStop Offset="1" Color="#031A0C" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#66DE93"
                                                Kind="AccountGroup" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="قاعدة الضيوف" />
                                    </Grid>
                                </ListBoxItem>

                                <ListBoxItem
                                    x:Name="MenuCorrespondents"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Correspondents">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#2A2200" />
                                                    <GradientStop Offset="1" Color="#1A1500" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#FFEB3B"
                                                Kind="MapMarkerRadius" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="المراسلين" />
                                    </Grid>
                                </ListBoxItem>

                                <ListBoxItem
                                    x:Name="MenuCoverages"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="CoverageView">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--  أيقونة التغطيات بتصميم ذهبي متناسق  -->
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#2A2200" />
                                                    <GradientStop Offset="1" Color="#1A1500" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#FFEB3B"
                                                Kind="MapMarkerCheck" />
                                        </Border>

                                        <!--  نص العنصر  -->
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="سجل التغطيات الميدانية" />
                                    </Grid>
                                </ListBoxItem>
                                <!--  Divider  -->
                                <Separator
                                    Height="1"
                                    Margin="20,14,20,4"
                                    Background="#7C3AED"
                                    Opacity="0.08" />

                                <!--  Group: النظام  -->
                                <TextBlock Style="{StaticResource SectionLabel}" Text="● إدارة النظام" />

                                <ListBoxItem
                                    x:Name="MenuUsers"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Users">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#1E0A28" />
                                                    <GradientStop Offset="1" Color="#14061A" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#BA68C8"
                                                Kind="AccountMultiple" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="المستخدمين" />
                                    </Grid>
                                </ListBoxItem>

                                <ListBoxItem
                                    x:Name="MenuPermissions"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Permissions">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#2A0818" />
                                                    <GradientStop Offset="1" Color="#1A040E" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#F06292"
                                                Kind="ShieldKey" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="مصفوفة الصلاحيات" />
                                    </Grid>
                                </ListBoxItem>

                                <ListBoxItem
                                    x:Name="MenuReports"
                                    Style="{StaticResource SideNavItem}"
                                    Tag="Reports">
                                    <Grid Margin="18,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#2A2200" />
                                                    <GradientStop Offset="1" Color="#1A1500" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#FFD54F"
                                                Kind="ChartBar" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="Medium"
                                            Foreground="#D4D4E8"
                                            Text="التقارير والإحصائيات" />
                                    </Grid>
                                </ListBoxItem>

                            </ListBox>
                        </ScrollViewer>

                        <!--  ── LOGOUT BUTTON ──  -->
                        <Border
                            Grid.Row="2"
                            Margin="16,10,16,24"
                            CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#2A080E" />
                                    <GradientStop Offset="1" Color="#1A0408" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#FF4444" />
                                    <GradientStop Offset="1" Color="#FF8080" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Button
                                Height="52"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnLogout_Click"
                                Foreground="#FF6B6B"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <Button.Effect>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" />
                                </Button.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,12,0"
                                        Foreground="#FF6B6B"
                                        Kind="Logout" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="#FF6B6B"
                                        Text="تسجيل الخروج" />
                                </StackPanel>
                            </Button>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!--
                ═══════════════════════════════════════════════
                MAIN AREA
                ═══════════════════════════════════════════════
            -->
            <DockPanel Grid.Column="1">

                <!--  ── TOP HEADER ──  -->
                <Border Height="76" DockPanel.Dock="Top">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#0F0F1E" />
                            <GradientStop Offset="0.6" Color="#0C0C18" />
                            <GradientStop Offset="1" Color="#0A0A14" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <!--  Thin gradient bottom border  -->
                    <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#7C3AED" />
                            <GradientStop Offset="0.5" Color="#00D4FF" />
                            <GradientStop Offset="1" Color="#7C3AED" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>

                    <Grid Margin="32,0">

                        <!--  Left: Logo  -->
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <!--  Logo badge  -->
                            <Border
                                Width="44"
                                Height="44"
                                CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#7C3AED" />
                                        <GradientStop Offset="1" Color="#0EA5E9" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="16"
                                        Opacity="0.6"
                                        ShadowDepth="0"
                                        Color="#7C3AED" />
                                </Border.Effect>
                                <materialDesign:PackIcon
                                    Width="26"
                                    Height="26"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Kind="RadioTower" />
                            </Border>

                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="20"
                                    FontWeight="Black"
                                    Foreground="#FFFFFF"
                                    Text="بث برو" />
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Normal"
                                    Text="نظام إدارة البث المتكامل">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#7C3AED" />
                                            <GradientStop Offset="1" Color="#00D4FF" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!--  Right: Clock + Live Badge  -->
                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">


                            <!--  Clock  -->
                            <Border Padding="18,10" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#1A1040" />
                                        <GradientStop Offset="1" Color="#0E0E1C" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="#3B1FA8" />
                                        <GradientStop Offset="1" Color="#0E7490" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <TextBlock
                                    x:Name="TxtClock"
                                    FontSize="17"
                                    FontWeight="Medium"
                                    Text="00:00:00">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#A78BFA" />
                                            <GradientStop Offset="1" Color="#38BDF8" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ── CONTENT ──  -->
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#080810" />
                            <GradientStop Offset="1" Color="#0A0A14" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!--  Subtle corner orb decoration  -->
                    <Ellipse
                        Width="500"
                        Height="500"
                        Margin="0,0,-150,-150"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Opacity="0.04">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Offset="0" Color="#7C3AED" />
                                <GradientStop Offset="1" Color="Transparent" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <ContentControl x:Name="MainContentArea" Margin="36" />

                    <materialDesign:Snackbar
                        x:Name="MainSnackbar"
                        Margin="0,0,0,40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        MessageQueue="{materialDesign:MessageQueue}">
                        <materialDesign:Snackbar.Resources>
                            <!--  هذا الستايل يستهدف النص الداخلي للـ Snackbar  -->
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="TextAlignment" Value="Center" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="Padding" Value="5" />
                            </Style>
                        </materialDesign:Snackbar.Resources>

                    </materialDesign:Snackbar>
                </Grid>
            </DockPanel>
        </Grid>
    </materialDesign:DialogHost>
</mah:MetroWindow>
