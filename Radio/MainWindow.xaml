<mah:MetroWindow
    x:Class="Radio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بث برو | نظام إدارة سير العمل"
    Width="1280"
    Height="800"
    Background="#F5F5F5"
    FlowDirection="RightToLeft"
    ShowCloseButton="False"
    ShowMaxRestoreButton="False"
    ShowMinButton="False"
    ShowTitleBar="False"
    Style="{StaticResource Window.Main}"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <materialDesign:DialogHost Identifier="RootDialog">
        <DockPanel>

            <!--  ═══════════ الشريط السفلي (Bottom Dock) ═══════════  -->
            <Border
                Height="56"
                VerticalAlignment="Bottom"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
                <Grid Margin="24,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  1. زر ON AIR في المنتصف  -->
                    <Button
                        x:Name="BtnOnAir"
                        Grid.Column="1"
                        Width="140"
                        Height="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Content="ON AIR"
                        Style="{StaticResource Btn.OnAir}" />

                    <!--  2. زر إغلاق الجلسة  -->
                    <Button
                        Grid.Column="2"
                        Height="40"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="BtnLogout_Click"
                        Style="{StaticResource Btn.Icon.Close}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0"
                                Kind="Logout" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="14"
                                Text="خروج" />
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>

            <!--  ═══════════ شريط التنقل الجانبي (NavRail) ═══════════  -->
            <Border
                materialDesign:ElevationAssist.Elevation="Dp1"
                DockPanel.Dock="Left"
                Style="{StaticResource NavRail.Container}">
                <StackPanel VerticalAlignment="Top">
                    <!--  لوجو التطبيق المصغر  -->
                    <Border
                        Width="90"
                        Height="64"
                        Background="#303F9F">
                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="RadioTower" />
                    </Border>

                    <!--  عناصر التنقل  -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="NavRailPanel">

                            <!--  الرئيسية  -->
                            <RadioButton
                                x:Name="MenuHome"
                                Click="NavRailItem_Click"
                                Style="{StaticResource NavRail.Item}"
                                Tag="لوحة التحكم">
                                <materialDesign:PackIcon
                                    Width="22"
                                    Height="22"
                                    Kind="ViewDashboard" />
                            </RadioButton>

                            <!--  الحلقات  -->
                            <RadioButton
                                x:Name="MenuEpisodes"
                                Click="NavRailItem_Click"
                                Style="{StaticResource NavRail.Item}"
                                Tag="الحلقات">
                                <materialDesign:PackIcon
                                    Width="22"
                                    Height="22"
                                    Kind="MoviePlay" />
                            </RadioButton>

                            <!--  فاصل  -->
                            <Separator x:Name="Div1" Style="{StaticResource NavRail.Divider}" />

                            <!--  مجموعة: الجهات (قابلة للتوسيع)  -->
                            <RadioButton
                                x:Name="MenuContacts"
                                Click="GroupNav_Click"
                                Style="{StaticResource NavRail.GroupItem}"
                                Tag="الجهات">
                                <materialDesign:PackIcon
                                    Width="22"
                                    Height="22"
                                    Kind="AccountGroup" />
                            </RadioButton>
                            <StackPanel x:Name="ContactsSubMenu" Visibility="Collapsed">
                                <RadioButton
                                    x:Name="MenuGuests"
                                    Click="NavRailItem_Click"
                                    Content="الضيوف"
                                    Style="{StaticResource NavRail.SubItem}" />
                                <RadioButton
                                    x:Name="MenuCoverages"
                                    Click="NavRailItem_Click"
                                    Content="المراسلين"
                                    Style="{StaticResource NavRail.SubItem}" />
                                <RadioButton
                                    x:Name="MenuCorrespondents"
                                    Click="NavRailItem_Click"
                                    Content="التغطيات"
                                    Style="{StaticResource NavRail.SubItem}" />
                            </StackPanel>

                            <!--  فاصل  -->
                            <Separator x:Name="Div2" Style="{StaticResource NavRail.Divider}" />

                            <!--  مجموعة: التقارير (قابلة للتوسيع)  -->
                            <RadioButton
                                x:Name="MenuReportsGroup"
                                Click="GroupNav_Click"
                                Style="{StaticResource NavRail.GroupItem}"
                                Tag="التقارير">
                                <materialDesign:PackIcon
                                    Width="22"
                                    Height="22"
                                    Kind="ChartBar" />
                            </RadioButton>
                            <StackPanel x:Name="ReportsSubMenu" Visibility="Collapsed">
                                <RadioButton
                                    x:Name="MenuReports"
                                    Click="NavRailItem_Click"
                                    Content="التقارير"
                                    Style="{StaticResource NavRail.SubItem}" />
                                <RadioButton
                                    x:Name="MenuPublishingRecords"
                                    Click="NavRailItem_Click"
                                    Content="سجلات النشر"
                                    Style="{StaticResource NavRail.SubItem}" />
                            </StackPanel>

                            <!--  فاصل (الإدارة) ـ يختفي حسب الصلاحية  -->
                            <Separator
                                x:Name="Div3"
                                Style="{StaticResource NavRail.Divider}"
                                Visibility="Collapsed" />

                            <!--  مجموعة: الإدارة (قابلة للتوسيع)  -->
                            <RadioButton
                                x:Name="MenuAdminGroup"
                                Click="GroupNav_Click"
                                Style="{StaticResource NavRail.GroupItem}"
                                Tag="الإدارة">
                                <materialDesign:PackIcon
                                    Width="22"
                                    Height="22"
                                    Kind="Cog" />
                            </RadioButton>
                            <StackPanel x:Name="AdminSubMenu" Visibility="Collapsed">
                                <RadioButton
                                    x:Name="MenuUsers"
                                    Click="NavRailItem_Click"
                                    Content="المستخدمين"
                                    Style="{StaticResource NavRail.SubItem}" />
                                <RadioButton
                                    x:Name="MenuEmployees"
                                    Click="NavRailItem_Click"
                                    Content="طاقم العمل"
                                    Style="{StaticResource NavRail.SubItem}" />
                                <RadioButton
                                    x:Name="MenuStaffRoles"
                                    Click="NavRailItem_Click"
                                    Content="المسميات الوظيفية"
                                    Style="{StaticResource NavRail.SubItem}" />
                                <RadioButton
                                    x:Name="MenuSocialPlatforms"
                                    Click="NavRailItem_Click"
                                    Content="منصات التواصل"
                                    Style="{StaticResource NavRail.SubItem}" />
                                <RadioButton
                                    x:Name="MenuPermissions"
                                    Click="NavRailItem_Click"
                                    Content="الصلاحيات"
                                    Style="{StaticResource NavRail.SubItem}" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!--  ═══════════ الترويسة العلوية (Header) ═══════════  -->
            <Border
                materialDesign:ElevationAssist.Elevation="Dp2"
                DockPanel.Dock="Top"
                Style="{StaticResource Header.App}">
                <Grid Margin="24,0">

                    <!--  الجهة اليسرى: الشعار + العنوان  -->
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Border
                            Width="36"
                            Height="36"
                            Background="#303F9F"
                            CornerRadius="8">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="RadioTower" />
                        </Border>
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#212121"
                            Text="بث برو" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#757575"
                            Text="|  إذاعة صوت القدس" />
                    </StackPanel>

                    <!--  المنتصف: معلومات المستخدم (مصغرة)  -->
                    <Border
                        Padding="4,4,4,4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="20"
                        Style="{StaticResource Chip.Primary}"
                        ToolTipService.InitialShowDelay="300">
                        <Border.ToolTip>
                            <StackPanel>
                                <TextBlock
                                    x:Name="TxtUserFullName"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="اسم المستخدم" />
                                <TextBlock
                                    x:Name="ChipRole"
                                    Margin="0,2,0,0"
                                    FontSize="11"
                                    Foreground="#757575"
                                    Text="مدير النظام" />
                            </StackPanel>
                        </Border.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="32"
                                Height="32"
                                BorderThickness="0"
                                CornerRadius="16">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#303F9F"
                                    Kind="Account" />
                            </Border>
                            <Ellipse
                                Width="6"
                                Height="6"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Fill="#22C55E" />
                        </StackPanel>
                    </Border>

                    <!--  أزرار النافذة  -->
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="36"
                            Height="36"
                            Click="BtnMinimize_Click"
                            Foreground="#616161"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="تصغير">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="WindowMinimize" />
                        </Button>
                        <Button
                            Width="36"
                            Height="36"
                            Click="BtnMaximize_Click"
                            Foreground="#616161"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="تكبير">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="WindowMaximize" />
                        </Button>
                        <Button
                            Width="36"
                            Height="36"
                            Click="BtnClose_Click"
                            Foreground="#B00020"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="إغلاق">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="Close" />
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>

            <!--  ═══════════ منطقة العمل الأساسية ═══════════  -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  شريط المسار (Breadcrumb)  -->
                <TextBlock
                    x:Name="BreadcrumbBar"
                    Grid.Row="0"
                    Margin="24,12,24,0"
                    FontSize="12"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="لوحة التحكم"
                    Visibility="Collapsed" />

                <!--  محتوى الصفحة الرئيسي  -->
                <ContentControl x:Name="MainContentArea" Grid.Row="1" />

                <!--  حاوية الإشعارات (متراكبة فوق المحتوى)  -->
                <StackPanel
                    x:Name="NotificationHost"
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="999" />

            </Grid>

        </DockPanel>
    </materialDesign:DialogHost>
</mah:MetroWindow>
