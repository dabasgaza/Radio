<mah:MetroWindow
    x:Class="Radio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بث برو | نظام إدارة سير العمل"
    Width="1280"
    Height="800"
    Background="#0F0F0F"
    FlowDirection="RightToLeft"
    FontFamily="Segoe UI Semibold"
    GlowBrush="{DynamicResource PrimaryHueMidBrush}"
    ShowTitleBar="False"
    TextElement.Foreground="White"
    TitleBarHeight="0"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <materialDesign:DrawerHost
        x:Name="NavDrawer"
        Background="#0F0F0F"
        BorderThickness="0"
        OpenMode="Modal">
        <!--  القائمة الجانبية بتصميم Dark Glass  -->

        <!--  القائمة الجانبية (Navigation Drawer)  -->
        <materialDesign:DrawerHost.LeftDrawerContent>
            <Grid Width="280" Background="#161616">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  هيدر المستخدم  -->
                <Border
                    Grid.Row="0"
                    Padding="20,50,20,30"
                    Background="#1E1E1E"
                    CornerRadius="0,0,30,30">
                    <StackPanel>
                        <materialDesign:PackIcon
                            Width="70"
                            Height="70"
                            HorizontalAlignment="Center"
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            Kind="UserCircle" />
                        <TextBlock
                            x:Name="TxtUserFullName"
                            Margin="0,15,0,0"
                            HorizontalAlignment="Center"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="اسم المستخدم" />
                        <TextBlock
                            x:Name="TxtRoleNameSide"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="Gray"
                            Text="الصلاحية" />
                    </StackPanel>
                </Border>

                <!--  روابط التنقل - مع إضافة x:Name لكل عنصر  -->
                <ListBox
                    x:Name="MenuListBox"
                    Grid.Row="1"
                    Margin="10,20"
                    SelectionChanged="MenuListBox_SelectionChanged"
                    Style="{StaticResource MaterialDesignNavigationListBox}">

                    <ListBoxItem
                        x:Name="MenuHome"
                        Height="50"
                        Margin="0,2"
                        IsSelected="True"
                        Tag="Home">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="Cyan"
                                Kind="ViewDashboard" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="لوحة التحكم" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem
                        x:Name="MenuPrograms"
                        Height="50"
                        Margin="0,2"
                        Tag="Programs">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="Orange"
                                Kind="TelevisionPlay" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="إدارة البرامج" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem
                        x:Name="MenuEpisodes"
                        Height="50"
                        Margin="0,2"
                        Tag="Episodes">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="SkyBlue"
                                Kind="MoviePlayOutline" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="سجل الحلقات" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem
                        x:Name="MenuGuests"
                        Height="50"
                        Margin="0,2"
                        Tag="Guests">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="Lime"
                                Kind="AccountMultiple" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="قاعدة الضيوف" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem
                        x:Name="MenuCorrespondents"
                        Height="50"
                        Margin="0,2"
                        Tag="Correspondents">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="Yellow"
                                Kind="MapMarkerRadius" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="المراسلين الميدانيين" />
                        </StackPanel>
                    </ListBoxItem>

                    <Separator
                        Margin="20,10"
                        Opacity="0.1"
                        Style="{StaticResource MaterialDesignSeparator}" />

                    <ListBoxItem
                        x:Name="MenuUsers"
                        Height="50"
                        Margin="0,2"
                        Tag="Users">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="Violet"
                                Kind="AccountSettings" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="إدارة المستخدمين" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem
                        x:Name="MenuPermissions"
                        Height="50"
                        Margin="0,2"
                        Tag="Permissions">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="Cyan"
                                Kind="Security" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="مصفوفة الصلاحيات" />
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem
                        x:Name="MenuReports"
                        Height="50"
                        Margin="0,2"
                        Tag="Reports">
                        <StackPanel Margin="10,0" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Margin="0,0,15,0"
                                Foreground="Pink"
                                Kind="ChartBar" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="التقارير والإحصائيات" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!--  زر تسجيل الخروج  -->
                <Button
                    Grid.Row="2"
                    Height="50"
                    Margin="15"
                    Click="BtnLogout_Click"
                    Foreground="#FF5252"
                    Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="22"
                            Height="22"
                            Margin="0,0,10,0"
                            Kind="Logout" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="Bold"
                            Text="خروج آمن" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:DrawerHost.LeftDrawerContent>
        <!--  الواجهة الرئيسية  -->
        <DockPanel>
            <!--  Top Bar Modern Dark  -->
            <materialDesign:ColorZone
                Padding="15,10"
                materialDesign:ElevationAssist.Elevation="Dp0"
                Background="#161616"
                DockPanel.Dock="Top"
                Mode="Standard">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Button
                            x:Name="BtnToggleDrawer"
                            Click="BtnMenu_Click"
                            Foreground="White"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <materialDesign:PackIcon
                                Width="26"
                                Height="26"
                                Kind="Menu" />
                        </Button>
                        <TextBlock
                            Margin="20,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="22"
                            FontWeight="Black"
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            Text="BROADCAST" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="22"
                            FontWeight="Light"
                            Foreground="White"
                            Text="PRO" />
                    </StackPanel>

                    <!--  معلومات الجلسة  -->
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            x:Name="TxtClock"
                            Margin="0,0,25,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="Gray"
                            Text="12:00 PM" />

                        <materialDesign:Chip
                            x:Name="ChipRole"
                            Padding="10,0"
                            Background="#2D2D2D"
                            Content="مدير"
                            FontWeight="Bold"
                            Foreground="Cyan" />
                    </StackPanel>
                </Grid>
            </materialDesign:ColorZone>

            <!--  منطقة المحتوى السلسة  -->
            <Grid Background="#0F0F0F">
                <ContentControl x:Name="MainContentArea" Margin="25">
                    <!--  إضافة تأثير ظهور ناعم للنوافذ  -->
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0"
                                                To="1"
                                                Duration="0:0:0.5" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Grid>
        </DockPanel>
    </materialDesign:DrawerHost>
</mah:MetroWindow>