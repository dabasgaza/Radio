<mah:MetroWindow
    x:Class="Radio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بث برو | نظام إدارة سير العمل"
    Width="1280"
    Height="800"
    Background="#0F0F0F"
    FlowDirection="RightToLeft"
    FontFamily="Hacen Tunisia"
    GlowBrush="{DynamicResource PrimaryHueMidBrush}"
    ShowTitleBar="False"
    TextElement.Foreground="White"
    TitleBarHeight="0"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <!--  DialogHost يغلف النافذة بالكامل لضمان ظهور رسائل التأكيد فوق كل شيء  -->
    <!--  DialogHost يغلف النافذة بالكامل لضمان ظهور رسائل التأكيد فوق كل شيء  -->
    <materialDesign:DialogHost DialogTheme="Inherit" Identifier="RootDialog">

        <Grid>
            <Grid.ColumnDefinitions>
                <!--  العمود الأول: الشريط الجانبي (ثابت)  -->
                <ColumnDefinition Width="280" />
                <!--  العمود الثاني: المحتوى الرئيسي  -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  =============================================  -->
            <!--  الشريط الجانبي (Sidebar) - لون غامق متباين  -->
            <!--  =============================================  -->
            <Border
                Grid.Column="0"
                Background="#161616"
                BorderBrush="#252525"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  معلومات المستخدم  -->
                        <RowDefinition Height="*" />
                        <!--  القائمة الكاملة  -->
                        <RowDefinition Height="Auto" />
                        <!--  زر الخروج  -->
                    </Grid.RowDefinitions>

                    <!--  هيدر المستخدم  -->
                    <StackPanel Grid.Row="0" Background="#1A1A1A">
                        <Grid HorizontalAlignment="Center">
                            <Ellipse
                                Width="70"
                                Height="70"
                                Fill="#252525"
                                Stroke="{DynamicResource PrimaryHueMidBrush}"
                                StrokeThickness="2" />
                            <materialDesign:PackIcon
                                Width="40"
                                Height="40"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                Kind="Account" />
                        </Grid>
                        <TextBlock
                            x:Name="TxtUserFullName"
                            Margin="0,15,0,0"
                            HorizontalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="اسم المستخدم" />
                        <TextBlock
                            x:Name="TxtRoleDisplay"
                            Margin="0,5,0,0"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="Gray"
                            Text="مدير النظام" />
                    </StackPanel>

                    <!--  قائمة التنقل الكاملة  -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox
                            x:Name="MenuListBox"
                            Margin="10,10"
                            FontSize="16"
                            SelectionChanged="MenuListBox_SelectionChanged"
                            Style="{StaticResource MaterialDesignNavigationListBox}">

                            <!--  قسم العمليات اليومية  -->
                            <TextBlock
                                Margin="15,10,0,5"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="Gray"
                                Text="العمليات والبث" />

                            <ListBoxItem
                                x:Name="MenuHome"
                                Height="45"
                                IsSelected="True"
                                Tag="Home">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="Cyan"
                                        Kind="ViewDashboard" />
                                    <TextBlock VerticalAlignment="Center" Text="لوحة التحكم" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuPrograms"
                                Height="45"
                                Tag="Programs">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="Orange"
                                        Kind="Television" />
                                    <TextBlock VerticalAlignment="Center" Text="إدارة البرامج" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuEpisodes"
                                Height="45"
                                Tag="Episodes">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="SkyBlue"
                                        Kind="MoviePlay" />
                                    <TextBlock VerticalAlignment="Center" Text="سجل الحلقات" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuGuests"
                                Height="45"
                                Tag="Guests">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="Lime"
                                        Kind="AccountGroup" />
                                    <TextBlock VerticalAlignment="Center" Text="قاعدة الضيوف" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuCorrespondents"
                                Height="45"
                                Tag="Correspondents">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="Yellow"
                                        Kind="MapMarkerRadius" />
                                    <TextBlock VerticalAlignment="Center" Text="المراسلين والتغطيات" />
                                </StackPanel>
                            </ListBoxItem>

                            <!--  قسم الإدارة والنظام  -->
                            <Separator
                                Margin="15,10"
                                Opacity="0.1"
                                Style="{StaticResource MaterialDesignSeparator}" />
                            <TextBlock
                                Margin="15,0,0,5"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="Gray"
                                Text="إدارة النظام" />

                            <ListBoxItem
                                x:Name="MenuUsers"
                                Height="45"
                                Tag="Users">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="Violet"
                                        Kind="AccountSettings" />
                                    <TextBlock VerticalAlignment="Center" Text="المستخدمين" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuPermissions"
                                Height="45"
                                Tag="Permissions">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="LightPink"
                                        Kind="ShieldKey" />
                                    <TextBlock VerticalAlignment="Center" Text="مصفوفة الصلاحيات" />
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem
                                x:Name="MenuReports"
                                Height="45"
                                Tag="Reports">
                                <StackPanel Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,15,0"
                                        Foreground="Gold"
                                        Kind="ChartBar" />
                                    <TextBlock VerticalAlignment="Center" Text="التقارير والإحصائيات" />
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </ScrollViewer>

                    <!--  زر تسجيل الخروج  -->
                    <Button
                        Grid.Row="2"
                        Height="50"
                        Margin="15"
                        Click="BtnLogout_Click"
                        Foreground="#FF5252"
                        Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="22"
                                Height="22"
                                Margin="0,0,10,0"
                                Kind="Logout" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="تسجيل الخروج" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  =============================================  -->
            <!--  منطقة المحتوى الرئيسي (Main Content)  -->
            <!--  =============================================  -->
            <DockPanel Grid.Column="1">
                <!--  الشريط العلوي (Header) - لون Indigo لكسر الغامق  -->
                <materialDesign:ColorZone
                    Padding="20,15"
                    materialDesign:ElevationAssist.Elevation="Dp4"
                    DockPanel.Dock="Top"
                    Mode="PrimaryMid">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="Broadcast" />
                            <TextBlock
                                Margin="15,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="Black"
                                Foreground="White"
                                Text="BROADCAST PRO | نظام إدارة البث" />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <materialDesign:Chip
                                x:Name="ChipRole"
                                Margin="0,0,20,0"
                                Background="#33FFFFFF"
                                Content="مدير"
                                FontWeight="Bold"
                                Foreground="White" />
                            <TextBlock
                                x:Name="TxtClock"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Light"
                                Foreground="White"
                                Text="00:00:00" />
                        </StackPanel>
                    </Grid>
                </materialDesign:ColorZone>

                <!--  مساحة العرض المتغيرة  -->
                <Grid Background="#0F0F0F">
                    <ContentControl x:Name="MainContentArea" Margin="25" />

                    <!--  Snackbar للإشعارات  -->
                    <materialDesign:Snackbar
                        x:Name="MainSnackbar"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        MessageQueue="{materialDesign:MessageQueue}" />
                </Grid>
            </DockPanel>
        </Grid>
    </materialDesign:DialogHost>


</mah:MetroWindow>