<mah:MetroWindow
    x:Class="Radio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="بث برو | نظام إدارة سير العمل"
    Width="1280"
    Height="800"
    Background="#F5F5F5"
    FlowDirection="RightToLeft"
    ShowCloseButton="False"
    ShowMaxRestoreButton="False"
    ShowMinButton="False"
    ShowTitleBar="False"
    Style="{StaticResource Window.Main}"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <mah:MetroWindow.Resources>
        <!--  نمط التبويبات الأفقية  -->
        <Style x:Key="HubTabItem" TargetType="RadioButton">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#616161" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0E0E0" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#303F9F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <materialDesign:DialogHost
        DialogClosing="DialogHost_DialogClosing"
        DialogOpened="DialogHost_DialogOpened"
        Identifier="RootDialog">
        <DockPanel>
            <!--  ═══════════ الشريط السفلي (Bottom Dock) ═══════════  -->
            <Border
                Height="64"
                VerticalAlignment="Bottom"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
                <Grid Margin="24,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <!--  الأيقونات السريعة  -->
                        <ColumnDefinition Width="*" />
                        <!--  مساحة فارغة  -->
                        <ColumnDefinition Width="Auto" />
                        <!--  زر ON AIR  -->
                        <ColumnDefinition Width="*" />
                        <!--  مساحة فارغة  -->
                        <ColumnDefinition Width="Auto" />
                        <!--  زر الخروج  -->
                    </Grid.ColumnDefinitions>

                    <!--  1. أيقونات سريعة (يميناً في RTL)  -->
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="40"
                            Height="40"
                            Foreground="#616161"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="المراسلين">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="MapMarkerRadius" />
                        </Button>
                        <Button
                            Width="40"
                            Height="40"
                            Foreground="#616161"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="التغطيات">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="MapMarkerCheck" />
                        </Button>
                        <Button
                            Width="40"
                            Height="40"
                            Foreground="#616161"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="الصلاحيات">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="ShieldKey" />
                        </Button>
                    </StackPanel>

                    <!--  2. زر ON AIR في المنتصف تماماً  -->
                    <Button
                        x:Name="BtnOnAir"
                        Grid.Column="2"
                        Width="140"
                        Height="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Content="ON AIR"
                        Style="{StaticResource Btn.OnAir}" />

                    <!--  3. زر إغلاق الجلسة (يساراً في RTL)  -->
                    <Button
                        Grid.Column="4"
                        Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="BtnLogout_Click"
                        Style="{StaticResource Btn.Icon.Close}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0"
                                Kind="Logout" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="14"
                                Text="خروج" />
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>

            <!--  ═══════════ الترويسة العلوية (Header) ═══════════  -->
            <!--  ── TOP HEADER (Adaptive) ──  -->
            <Border
                materialDesign:ElevationAssist.Elevation="Dp2"
                DockPanel.Dock="Top"
                Style="{StaticResource Header.App}">
                <Grid Margin="24,0">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                        <Border
                            Width="40"
                            Height="40"
                            Background="#303F9F"
                            CornerRadius="8">
                            <materialDesign:PackIcon
                                Width="22"
                                Height="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="RadioTower" />
                        </Border>

                        <TextBlock
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#212121"
                            Text="بث برو" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#757575"
                            Text="|  إذاعة صوت القدس" />

                    </StackPanel>

                    <!--  Center: User Info  -->
                    <Border
                        Padding="4,4,14,4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="14"
                        Style="{StaticResource Chip.Primary}">
                        <StackPanel Orientation="Horizontal">

                            <!--  Avatar  -->
                            <Border
                                Width="34"
                                Height="34"
                                BorderBrush="Black"
                                BorderThickness="0"
                                CornerRadius="0">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#303F9F"
                                    Kind="Account" />
                            </Border>

                            <!--  Divider  -->
                            <Rectangle
                                Width="1"
                                Margin="10,8"
                                Fill="{StaticResource PrimaryDarkBrush}"
                                Opacity="0.4" />

                            <!--  Info  -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    x:Name="TxtUserFullName"
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{DynamicResource MaterialDesignBody}"
                                    Text="اسم المستخدم"
                                    TextTrimming="CharacterEllipsis" />
                                <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                    <TextBlock
                                        x:Name="ChipRole"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                                        Text="مدير النظام" />
                                    <Ellipse
                                        Width="5"
                                        Height="5"
                                        Margin="7,0,0,0"
                                        VerticalAlignment="Center"
                                        Fill="#22C55E" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="9.5"
                                        Foreground="#22C55E"
                                        Text="متصل" />
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Button
                            Width="36"
                            Height="36"
                            Click="BtnMinimize_Click"
                            Foreground="#616161"
                            Style="{StaticResource MaterialDesignIconButton}">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="WindowMinimize" />
                        </Button>
                        <Button
                            Width="36"
                            Height="36"
                            Click="BtnMaximize_Click"
                            Foreground="#616161"
                            Style="{StaticResource MaterialDesignIconButton}">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="WindowMaximize" />
                        </Button>
                        <Button
                            Width="36"
                            Height="36"
                            Click="BtnClose_Click"
                            Foreground="#B00020"
                            Style="{StaticResource MaterialDesignIconButton}">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="Close" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  ═══════════ شريط التبويبات الأفقية (Tabs) ═══════════  -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Header.TabBar}">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <RadioButton
                        x:Name="MenuHome"
                        Click="Tab_Click"
                        Content="لوحة التحكم"
                        IsChecked="True"
                        Style="{StaticResource HubTabItem}"
                        Tag="Home" />
                    <RadioButton
                        x:Name="MenuPrograms"
                        Click="Tab_Click"
                        Content="إدارة البرامج"
                        Style="{StaticResource HubTabItem}"
                        Tag="Programs" />
                    <RadioButton
                        x:Name="MenuEpisodes"
                        Click="Tab_Click"
                        Content="سجل الحلقات"
                        Style="{StaticResource HubTabItem}"
                        Tag="Episodes" />
                    <RadioButton
                        x:Name="MenuGuests"
                        Click="Tab_Click"
                        Content="الضيوف"
                        Style="{StaticResource HubTabItem}"
                        Tag="Guests" />
                    <RadioButton
                        x:Name="MenuCoverages"
                        Click="Tab_Click"
                        Content="المراسلين"
                        Style="{StaticResource HubTabItem}"
                        Tag="Correspondents" />
                    <RadioButton
                        x:Name="MenuCorrespondents"
                        Click="Tab_Click"
                        Content="التغطيات"
                        Style="{StaticResource HubTabItem}"
                        Tag="Coverage" />
                    <RadioButton
                        x:Name="MenuReports"
                        Click="Tab_Click"
                        Content="التقارير"
                        Style="{StaticResource HubTabItem}"
                        Tag="Reports" />
                    <RadioButton
                        x:Name="MenuUsers"
                        Click="Tab_Click"
                        Content="المستخدمين"
                        Style="{StaticResource HubTabItem}"
                        Tag="Users" />
                    <RadioButton
                        x:Name="MenuEmployees"
                        Click="Tab_Click"
                        Content="طاقم العمل"
                        Style="{StaticResource HubTabItem}"
                        Tag="Employees" />
                    <RadioButton
                        x:Name="MenuStaffRoles"
                        Click="Tab_Click"
                        Content="المسميات الوظيفية"
                        Style="{StaticResource HubTabItem}"
                        Tag="StaffRoles" />

                    <RadioButton
                        x:Name="MenuSocialPlatforms"
                        Click="Tab_Click"
                        Content="منصات التواصل"
                        Style="{StaticResource HubTabItem}"
                        Tag="SocialPlatforms" />

                    <RadioButton
                        x:Name="MenuPermissions"
                        Click="Tab_Click"
                        Content="الصلاحيات"
                        Style="{StaticResource HubTabItem}"
                        Tag="Permissions" />
                </StackPanel>
            </Border>

            <!--  ═══════════ منطقة العمل الخالية ═══════════  -->

            <Grid>
                <ContentControl x:Name="MainContentArea" />



                <!--  نظام الإشعارات (مثبت في الأسفل فوق الشريط السفلي)  -->
                <StackPanel
                    x:Name="NotificationHost"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="999" />
            </Grid>



        </DockPanel>

    </materialDesign:DialogHost>
    <!--  الهيكل الأساسي: ترويسة، تبويبات، محتوى، شريط سفلي  -->
</mah:MetroWindow>